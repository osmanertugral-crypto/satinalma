    "definition":  "CREATE PROCEDURE LG_DTHANDLENUMBERS_099_01\n       @par_Coef           SMALLINT,\n       @par_ItemRef        INT,\n       @par_VariantRef     INT,\n       @par_OrdLineRef     INT,\n       @par_DOrdDate       DATETIME,\n       @par_ShipAmount     FLOAT,\n       @par_RemAmount      FLOAT,\n       @par_UomRef         INT,\n       @par_SourceIndex    SMALLINT,\n       @par_DOrdStatus     INT,\n       @par_DOrdGoDate     DATETIME,\n       @par_DOrdRetDate    DATETIME,\n       @par_uinfo1         FLOAT,\n       @par_uinfo2         FLOAT\nAS\nIF (@par_OrdLineRef \u003c\u003e 0) AND\n   (EXISTS(SELECT LOGICALREF FROM LG_099_01_ORFLINE WHERE LOGICALREF = @par_OrdLineRef))\n BEGIN\n      IF (@par_DOrdStatus = 0)\n       UPDATE LG_099_01_ORFLINE\n           SET DISTRESERVED = DISTRESERVED + @par_Coef * @par_ShipAmount\n           WHERE (LOGICALREF = @par_OrdLineRef)\n      IF (@par_DOrdStatus = 1) OR (@par_DOrdStatus = 2)\n       UPDATE LG_099_01_ORFLINE\n           SET ONVEHICLE = ONVEHICLE + @par_Coef * @par_ShipAmount\n           WHERE (LOGICALREF = @par_OrdLineRef)\n      IF (@par_DOrdStatus = 2) AND (@par_RemAmount \u003e 0)\n       UPDATE LG_099_01_ORFLINE\n           SET ONVEHICLE = ONVEHICLE - @par_Coef * @par_RemAmount\n           WHERE (LOGICALREF = @par_OrdLineRef)\n END\n"
}
