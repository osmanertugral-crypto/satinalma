    "definition":  "\n   CREATE PROCEDURE LG_CONVFACT\n          @UINF1   FLOAT,\n          @UINF2   FLOAT,\n          @RETFACT FLOAT OUTPUT AS\n   IF (@UINF1 = 0) OR (@UINF2 = 0) OR ((@UINF2/@UINF1) = 0)\n    SELECT @RETFACT = 1\n   ELSE SELECT @RETFACT = @UINF2 / @UINF1\n   "
