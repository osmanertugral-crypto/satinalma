    "definition":  "CREATE PROCEDURE LG_UPDATE_EMTRANS_223_01\n       @DT     DATETIME,\n       @SIGN  SMALLINT,\n       @ACCOUNTREF INT,\n       @CENTERREF       INT,\n       @TRCODE  SMALLINT,\n       @ACCOUNTCODE     VARCHAR(100),\n       @LNDEBIT  FLOAT,\n       @LNCREDIT FLOAT,\n       @LNEMUDEBIT   FLOAT,\n       @LNEMUCREDIT FLOAT,\n       @CANCELLED SMALLINT,\n       @REPORTNET FLOAT,\n       @AMNT  FLOAT,\n       @COEF  SMALLINT,\n       @INFIDX          FLOAT,\n       @NOTINFLATED     INT,\n       @NOTCALCULATED   INT,\n       @LNBRANCH SMALLINT,\n       @LNDEPARTMENT SMALLINT,\n       @STATUS          SMALLINT,\n       @FROMDEMTYPE     SMALLINT,\n       @BDGTLNTYPE      SMALLINT,\n       @EMDEMLNREF      INT,\n       @MONTH          SMALLINT,\n       @YEAR          SMALLINT,\n       @TRNET           FLOAT,\n       @TRCURR          SMALLINT\n       AS\nDECLARE @VALID  SMALLINT\nDECLARE @EPSILON FLOAT\nDECLARE @DEMPAYTOTINC   FLOAT\nDECLARE @DEMLNCLOSE     SMALLINT\nDECLARE @DEMLNDEBIT     FLOAT\nDECLARE @DEMLNCREDIT    FLOAT\nDECLARE @DEMPAYEDTOTAL  FLOAT\nSELECT  @EPSILON     = 0.0000001\nSELECT @VALID = 0\nIF (((@ACCOUNTREF \u003c\u003e 0) OR (@CENTERREF\u003c\u003e0) ) AND ((ABS(@LNDEBIT) \u003e @EPSILON) OR (ABS(@LNCREDIT) \u003e @EPSILON) OR (ABS(@LNEMUDEBIT) \u003e @EPSILON) OR (ABS(@LNEMUCREDIT) \u003e @EPSILON)) AND\n    (@CANCELLED = 0) AND (@TRCODE \u003c\u003e 5) AND (@TRCODE \u003c\u003e 8) AND (@TRCODE \u003c\u003e 9) AND (@TRCODE \u003c\u003e 10) AND ((@STATUS = 0) OR (@STATUS IS NULL)) AND (@LNDEPARTMENT IS NOT NULL))\n  SELECT @VALID = 1\nIF (@VALID = 1)\n  BEGIN\n       IF  (@ACCOUNTREF \u003c\u003e 0) AND (@FROMDEMTYPE = 1) AND (@EMDEMLNREF \u003c\u003e 0)\n        BEGIN SELECT @DEMLNDEBIT = DEBIT,\n                     @DEMLNCREDIT = CREDIT,\n                     @DEMPAYEDTOTAL = PAIDTOTAL\n              FROM LG_223_01_EMDEMFLINE\n              WHERE ((BDGTLINETYPE = @bdgtLnType) AND (LOGICALREF = @emDemLnRef)) OR\n                    ((BDGTLINETYPE = @bdgtLnType) AND (PARENTLNREF = @emDemLnRef))\n              SELECT @DEMPAYTOTINC = ((@LNDEBIT + @LNCREDIT) * @COEF)\n              IF @DEMPAYTOTINC + @DEMPAYEDTOTAL \u003e= @DEMLNDEBIT + @DEMLNCREDIT\n                SELECT @DEMLNCLOSE = 1\n               ELSE SELECT @DEMLNCLOSE = 0\n              UPDATE LG_223_01_EMDEMFLINE\n              SET PAIDTOTAL = PAIDTOTAL + @DEMPAYTOTINC,\n                  CLOSED = @DEMLNCLOSE\n              WHERE ((BDGTLINETYPE = @bdgtLnType) AND (LOGICALREF = @emDemLnRef)) OR\n                    ((BDGTLINETYPE = @bdgtLnType) AND (PARENTLNREF = @emDemLnRef))\n        END\n  END"
}
