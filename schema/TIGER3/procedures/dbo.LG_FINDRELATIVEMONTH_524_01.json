    "definition":  "CREATE PROCEDURE LG_FINDRELATIVEMONTH_524_01\n       @TRDATE DATETIME,\n       @RETMON  SMALLINT OUTPUT,\n       @RETYEAR SMALLINT OUTPUT\n       AS\nSELECT @RETYEAR = DATEPART(YEAR, @TRDATE)\nSELECT @RETMON  = DATEPART(MONTH, @TRDATE)"
