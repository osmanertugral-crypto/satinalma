{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_SIPARIS_SATINALMA_RAPORU",
    "full_name":  "dbo.AA_SIPARIS_SATINALMA_RAPORU",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_SIPARIS_SATINALMA_RAPORU] AS\r\n\r\n\r\n\r\nSELECT \r\nyear(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY \r\n,F.DATE_ TARIH\r\n,F.FICHENO FISNO\r\n,C.CODE CARI_KODU\r\n,C.DEFINITION_ CARI_UNVANI\r\n,S.CODE STOK_KODU\r\n,s.NAME STOK_ADI\r\n,L.AMOUNT  MIKTAR\r\n,U.CODE BIRIM\r\n--,L.SHIPPEDAMOUNT TESLIM_ALINAN\r\n,SAT.AMOUNT TESLIM_ALINAN\r\n,L.AMOUNT-L.SHIPPEDAMOUNT BEKLEYEN\r\n,ISNULL((SELECT sum(AMOUNT) FROM lg_001_01_STLINE WITH (NOLOCK) WHERE TRCODE=6 AND CLIENTREF=L.CLIENTREF AND STOCKREF=L.STOCKREF),0) AS IADE_MIKTAR\r\n,L.PRICE FIYAT\r\n,L.TOTAL TUTAR\r\n\r\n,CASE WHEN L.REPORTRATE=0 THEN (SELECT TOP 1 RATES2 FROM L_DAILYEXCHANGES WHERE CRTYPE=20 AND EDATE\u003e=L.DATE_ ORDER BY EDATE ASC) ELSE L.REPORTRATE END AS KUR\r\n\r\n,CAST((NULLIF(L.LINENET,0)/NULLIF(L.AMOUNT,0))/CASE WHEN L.REPORTRATE=0 THEN (SELECT TOP 1 RATES2 FROM L_DAILYEXCHANGES WHERE \r\nCRTYPE=20 AND EDATE\u003e=L.DATE_ ORDER BY EDATE ASC) ELSE L.REPORTRATE END AS DECIMAL (18,2)) AS EUR_TUTAR\r\n,SAT.REPORTRATE FATURA_KUR\r\n,SAT.DATE_ FATURA_TARIHI\r\n,SAT.LINENET FATURA_TUTAR\r\n\r\n,CAST(ISNULL(( (NULLIF(SAT.LINENET,0)/NULLIF(SAT.REPORTRATE,0)) ),0) AS decimal(18,4)) FATURA_EUR\r\n,cast(ISNULL(( ((NULLIF(SAT.LINENET,0)/NULLIF(SAT.REPORTRATE,0))/NULLIF(SAT.AMOUNT,0)) ),0) as decimal(18,4)) EUR_BIRIM_FIYAT\r\n,L.TRRATE KESILEN_KUR\r\n,CASE WHEN L.TRCURR =0 THEN \u0027TL\u0027 WHEN L.TRCURR =160 THEN \u0027TL\u0027 WHEN L.TRCURR =20 THEN \u0027EUR\u0027 WHEN L.TRCURR =1 THEN \u0027USD\u0027 ELSE \u0027NFD\u0027 END AS DOVIZ\r\n,CASE WHEN SAT.TRCURR IN (0,160) THEN (NULLIF(L.LINENET,0)/NULLIF(L.AMOUNT,0)) ELSE\r\ncast(ISNULL(( ((NULLIF(SAT.LINENET,0)/NULLIF(SAT.TRRATE,0))/NULLIF(SAT.AMOUNT,0)) ),0) as decimal(18,4)) END KESILEN_BIRIM_FIYAT\r\n,\r\nCASE WHEN SAT.TRCURR IN (0,160) THEN L.LINENET ELSE\r\nCAST(ISNULL(ROUND(NULLIF(L.LINENET,0)/NULLIF(L.TRRATE,0),2),0) AS DECIMAL (18,2)) END KESILEN_TUTAR\r\n\r\n\r\n\r\n\r\n\r\nFROM LG_001_01_ORFLINE AS L WITH (NOLOCK)\r\nINNER JOIN LG_001_01_ORFICHE AS F WITH (NOLOCK) ON F.LOGICALREF=L.ORDFICHEREF\r\nINNER JOIN LG_001_ITEMS AS S WITH (NOLOCK) ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_001_CLCARD AS C WITH (NOLOCK) ON C.LOGICALREF=F.CLIENTREF\r\nINNER JOIN LG_001_UNITSETL AS U WITH (NOLOCK) ON U.LOGICALREF=L.UOMREF\r\nLEFT OUTER JOIN  LG_001_01_STLINE AS SAT  WITH (NOLOCK) ON SAT.ORDTRANSREF=L.LOGICALREF AND SAT.TRCODE=1\r\n\r\n\r\nWHERE L.TRCODE=2\r\n\r\n--and F.FICHENO=\u0027001840\u0027\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
