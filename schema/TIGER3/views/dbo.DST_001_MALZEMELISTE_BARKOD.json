{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DST_001_MALZEMELISTE_BARKOD",
    "full_name":  "dbo.DST_001_MALZEMELISTE_BARKOD",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[DST_001_MALZEMELISTE_BARKOD]\r\nAS\r\n\r\nSELECT \r\n--ITM.LOGICALREF [ITEMREF]\r\nCASE  ITM.CARDTYPE WHEN 1 THEN \u0027Ticari Mal\u0027when 10 then \u0027Hammadde\u0027when 11 then \u0027Yarı mamul\u0027when 12 then \u0027Mamül\u0027when 4 then \u0027Sabit kıymet\u0027else \u0027diğer\u0027end \u0027Kart tipi\u0027\r\n,ITM.CODE [MALZEME KODU]\r\n,ITM.NAME [MALZEME AÇIKLAMASI]\r\n,ITM.SPECODE [ÖZEL KOD]\r\n,ITM.SPECODE2 [ÖZEL KOD2]\r\n,ITM.SPECODE3 [ÖZEL KOD3]\r\n,ITM.SPECODE4 [ÖZEL KOD4]\r\n,ITM.SPECODE5 [ÖZEL KOD5]\r\n,ITM.CYPHCODE [YETKİ KODU]\r\n,ITM.STGRPCODE [MALZEME GRUP KODU]\r\n,ITM.PRODUCERCODE  [ÜRETİCİ KODU]\r\n,ITM.GTIPCODE      [GTIP KODU]\r\n--,ITM.PRODCOUNTRY   [ÜRETİM YERİ KODU]\r\n\r\n--,CNT.CODE  [MENŞEİ KOD]\r\n\r\n--,CNT.NAME  [MENŞEİ ADI]\r\n--------------------------1.BİRİM------------------------------------------------\r\n,(SELECT UNL.CODE FROM  LG_001_UNITSETL UNL  WHERE  UNL.LOGICALREF IN (SELECT UNITLINEREF  FROM LG_001_ITMUNITA WHERE UNITLINEREF=UNL.LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=1)) AS [1.BİRİM SETİ]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=1 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=1 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=1))) AS [1.BİRİM BARKOD (1.SATIR BARKOD)]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=2 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=1 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=1))) AS [1.BİRİM BARKOD (2.SATIR BARKOD)]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=3 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=1 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=1))) AS [1.BİRİM BARKOD (3.SATIR BARKOD)]\r\n,(SELECT CONVFACT2  FROM LG_001_ITMUNITA WHERE LINENR=1 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=1)) AS [ÇEVRİM KATSAYI 1]\r\n----------------------------------------------------------------2.BİRİM---------------------------\r\n,(SELECT UNL.CODE FROM  LG_001_UNITSETL UNL  WHERE  UNL.LOGICALREF IN (SELECT UNITLINEREF  FROM LG_001_ITMUNITA WHERE UNITLINEREF=UNL.LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=2)) AS [2.BİRİM SETİ]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=1 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=2 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=2))) AS [2.BİRİM BARKOD (1.SATIR BARKOD)]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=2 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=2 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=2))) AS [2.BİRİM BARKOD (2.SATIR BARKOD)]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=3 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=2 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=2))) AS [2.BİRİM BARKOD (3.SATIR BARKOD)]\r\n,(SELECT CONVFACT2  FROM LG_001_ITMUNITA WHERE LINENR=2 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=2)) AS [ÇEVRİM KATSAYI 2]\r\n---------------------------------------------------------3.BİRİM------------\r\n\r\n,(SELECT UNL.CODE FROM  LG_001_UNITSETL UNL  WHERE  UNL.LOGICALREF IN (SELECT UNITLINEREF  FROM LG_001_ITMUNITA WHERE UNITLINEREF=UNL.LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=3)) AS [3.BİRİM SETİ]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=1 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=3 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=3))) AS [3.BİRİM BARKOD (1.SATIR BARKOD)]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=2 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=3 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=3))) AS [3.BİRİM BARKOD (2.SATIR BARKOD)]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=3 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=3 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=3))) AS [3.BİRİM BARKOD (3.SATIR BARKOD)]\r\n,(SELECT CONVFACT2  FROM LG_001_ITMUNITA WHERE LINENR=3 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=3)) AS [ÇEVRİM KATSAYI 3]\r\n---------------------------------------------------------------------------------------\r\n\r\n---------------------------------------------------------4.BİRİM------------\r\n\r\n,(SELECT UNL.CODE FROM  LG_001_UNITSETL UNL  WHERE  UNL.LOGICALREF IN (SELECT UNITLINEREF  FROM LG_001_ITMUNITA WHERE UNITLINEREF=UNL.LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=4)) AS [4.BİRİM SETİ]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=1 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=4 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=4))) AS [4.BİRİM BARKOD (1.SATIR BARKOD)]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=2 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=4 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=4))) AS [4.BİRİM BARKOD (2.SATIR BARKOD)]\r\n,(SELECT BRC.BARCODE FROM  LG_001_UNITBARCODE BRC  WHERE BRC.LINENR=3 AND  BRC.ITMUNITAREF  IN \r\n(SELECT LOGICALREF  FROM LG_001_ITMUNITA WHERE LINENR=4 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=4))) AS [4.BİRİM BARKOD (3.SATIR BARKOD)]\r\n,(SELECT CONVFACT2  FROM LG_001_ITMUNITA WHERE LINENR=4 AND UNITLINEREF IN (SELECT LOGICALREF FROM LG_001_UNITSETL WHERE UNITLINEREF=LOGICALREF  AND ITEMREF=ITM.LOGICALREF AND LINENR=4)) AS [ÇEVRİM KATSAYI 4]\r\n---------------------------------------------------------------------------------------\r\n\r\n\r\n\r\n\r\n\r\n\r\n--,ISNULL (ITM.SHELFLIFE,0) [RAF ÖMRÜ]\r\n--,CASE ITM.SHELFDATE WHEN 0 THEN \u0027GÜN\u0027 WHEN 1 THEN \u0027HAFTA\u0027WHEN 2 THEN \u0027AY\u0027WHEN 3 THEN \u0027YIL\u0027ELSE\u0027Boş\u0027END AS[SÜRE]\r\nFROM LG_001_ITEMS ITM\r\n--LEFT JOIN LG_001_MARK MRK ON MRK.LOGICALREF=ITM.MARKREF\r\nLEFT JOIN L_COUNTRY CNT ON CNT.COUNTRYNR=ITM.PUBLICCOUNTRYREF\r\n\r\n\r\nWHERE ITM.ACTIVE=0 --and ITM.CODE=\u00271.41\u0027\r\nAND ITM.CARDTYPE IN (1,10,11,12) --AND ITM.CODE LIKE \u0027MBAP%\u0027\r\n---SELECT * FROM LG_001_UNITBARCODE\r\n--SELECT * FROM LG_001_UNITSETL WHERE LINENR  IN (1,2) AND LOGICALREF IN (23,26)\r\n--SELECT CONVFACT2,* FROM LG_001_ITMUNITA WHERE ITEMREF=14  23,26\r\n\r\n---SELECT SHELFLIFE,SHELFDATE,* FROM LG_001_ITEMS WHERE CODE=\u0027TURGAY SON\u0027\r\n",
