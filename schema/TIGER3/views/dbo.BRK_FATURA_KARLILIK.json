{
    "type":  "view",
    "schema":  "dbo",
    "name":  "BRK_FATURA_KARLILIK",
    "full_name":  "dbo.BRK_FATURA_KARLILIK",
    "definition":  "\r\n\r\nCREATE VIEW\t[dbo].[BRK_FATURA_KARLILIK] AS\r\n\r\nSELECT \r\n    INVOICE.FICHENO AS FATURA_NO,\r\n    INVOICE.DOCODE AS BELGE_NO,\r\n    CLCARD.SPECODE2 AS CARİ_OZELKOD2,\r\n    CLCARD.DEFINITION_ AS CARİ_ADI,\r\n    INVOICE.SPECODE AS CARİ_ÖZELKOD1,\r\n    LG_SLSMAN.CODE AS SATIŞ_ELEMAN_KODU,\r\n    STLINE.AMOUNT * STLINE.PRICE AS TL_TOPLAM_TUTAR,\r\n    STLINE.AMOUNT * STLINE.OUTCOST AS TL_MALİYET,\r\n    STLINE.AMOUNT * STLINE.PRICE - STLINE.AMOUNT * STLINE.OUTCOST AS TL_KAR,\r\n    CASE \r\n        WHEN STLINE.REPORTRATE = 0 THEN 0 \r\n        ELSE STLINE.TOTAL / STLINE.REPORTRATE * \r\n             CASE WHEN STLINE.TRCODE IN (6) THEN -1 ELSE 1 END * \r\n             CASE WHEN STLINE.LINETYPE = 1 THEN 0 ELSE 1 END\r\n    END AS RD_TUTARI,\r\n    STLINE.AMOUNT * STLINE.OUTCOSTCURR AS RD_ÇıkışMaliyeti,\r\n    CASE \r\n        WHEN STLINE.REPORTRATE = 0 THEN 0 \r\n        ELSE STLINE.TOTAL / STLINE.REPORTRATE * \r\n             CASE WHEN STLINE.TRCODE IN (6) THEN -1 ELSE 1 END * \r\n             CASE WHEN STLINE.LINETYPE = 1 THEN 0 ELSE 1 END\r\n    END - STLINE.AMOUNT * STLINE.OUTCOSTCURR AS RD_KAR\r\nFROM\r\n    LG_123_01_STLINE STLINE\r\n    LEFT JOIN LG_123_01_STFICHE STFICHE WITH (NOLOCK) ON STLINE.STFICHEREF = STFICHE.LOGICALREF\r\n    LEFT JOIN LG_123_01_INVOICE INVOICE WITH (NOLOCK) ON INVOICE.LOGICALREF = STFICHE.INVOICEREF\r\n    LEFT JOIN LG_123_CLCARD CLCARD WITH (NOLOCK) ON CLCARD.LOGICALREF = STFICHE.CLIENTREF\r\n    LEFT JOIN LG_SLSMAN WITH (NOLOCK) ON STFICHE.SALESMANREF = LG_SLSMAN.LOGICALREF AND LG_SLSMAN.FIRMNR = \u0027123\u0027\r\nWHERE\r\n    INVOICE.CANCELLED = 0\r\n    AND STLINE.LINETYPE IN (0, 2, 4, 8)\r\n    AND INVOICE.TRCODE = 8\r\n    AND (STFICHE.BILLED = 1 OR STFICHE.BILLED IS NULL)",
