    "full_name":  "dbo.AARP_TEDARIKCI_ODEME_RAPORU_ICMAL_123",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[AARP_TEDARIKCI_ODEME_RAPORU_ICMAL_123] AS \r\nSELECT DISTINCT \u0027EUR\u0027 DOVIZ,\r\nCONVERT(VARCHAR ,GETDATE() ,104) TARIH,CARI, SUM(TUTAR_ALACAK) AS BAKIYE,\r\n(SELECT SUM(TUTAR_ALACAK) from AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 ARATBL\r\nWHERE ARATBL.CARI=EURTBL.CARI AND GUN\u003c=0 AND ARATBL.DOVIZ=\u0027EUR\u0027) AS VADESI_GELEN\r\n,(SELECT SUM(TUTAR_ALACAK) from AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 ARATBL\r\nWHERE ARATBL.CARI=EURTBL.CARI AND GUN\u003e0 AND ARATBL.DOVIZ=\u0027EUR\u0027) AS VADESI_GELMEYEN\r\n\r\n\r\nFROM AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 EURTBL WHERE DOVIZ=\u0027EUR\u0027  \r\nGROUP BY CARI\r\n\r\nUNION ALL\r\n\r\nSELECT DISTINCT \u0027USD\u0027 DOVIZ,\r\nCONVERT(VARCHAR ,GETDATE() ,104) TARIH,CARI, SUM(TUTAR_ALACAK) AS BAKIYE,\r\n(SELECT SUM(TUTAR_ALACAK) from AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 ARATBL\r\nWHERE ARATBL.CARI=EURTBL.CARI AND GUN\u003c=0 AND ARATBL.DOVIZ=\u0027USD\u0027) AS VADESI_GELEN\r\n,(SELECT SUM(TUTAR_ALACAK) from AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 ARATBL\r\nWHERE ARATBL.CARI=EURTBL.CARI AND GUN\u003e0 AND ARATBL.DOVIZ=\u0027USD\u0027) AS VADESI_GELMEYEN\r\n\r\n\r\nFROM AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 EURTBL WHERE DOVIZ=\u0027USD\u0027  \r\nGROUP BY CARI\r\n\r\n\r\nUNION ALL\r\n\r\nSELECT DISTINCT \u0027TL\u0027 DOVIZ,\r\nCONVERT(VARCHAR ,GETDATE() ,104) TARIH,CARI, SUM(TUTAR_ALACAK) AS BAKIYE,\r\n(SELECT SUM(TUTAR_ALACAK) from AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 ARATBL\r\nWHERE ARATBL.CARI=EURTBL.CARI AND GUN\u003c=0 AND ARATBL.DOVIZ=\u0027TL\u0027) AS VADESI_GELEN\r\n,(SELECT SUM(TUTAR_ALACAK) from AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 ARATBL\r\nWHERE ARATBL.CARI=EURTBL.CARI AND GUN\u003e0 AND ARATBL.DOVIZ=\u0027TL\u0027) AS VADESI_GELMEYEN\r\n\r\n\r\nFROM AARP_TEDARIKCI_ODEME_RAPORU_DATA_123 EURTBL WHERE DOVIZ=\u0027TL\u0027  \r\nGROUP BY CARI\r\n",
