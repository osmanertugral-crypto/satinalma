{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_PROJE_MALZEME_DAGILIMI",
    "full_name":  "dbo.AA_PROJE_MALZEME_DAGILIMI",
    "definition":  "CREATE VIEW AA_PROJE_MALZEME_DAGILIMI AS\r\n\r\nSELECT \r\nS.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,L.DATE_ TARIH\r\n,L.AMOUNT MIKTAR\r\n,(SELECT CODE FROM LG_001_PROJECT WHERE LOGICALREF=L.PROJECTREF) PROJE_KODU \r\n,(SELECT NAME FROM LG_001_PROJECT WHERE LOGICALREF=L.PROJECTREF) PROJE_ADI\r\n\r\n\r\n\r\n\r\nFROM LG_001_01_STLINE AS L\r\nINNER JOIN LG_001_ITEMS AS S ON S.LOGICALREF=L.STOCKREF\r\n\r\nWHERE L.TRCODE=12\r\nAND LINETYPE=0\r\nAND (SELECT CODE FROM LG_001_PROJECT WHERE LOGICALREF=L.PROJECTREF) IN (SELECT PROJE_KODU FROM AA_SATIS_SIPARIS_OZET  WHERE GERCEKLESEN_URETIM_TARIHI IS NULL)\r\n\r\n--AND S.CODE=\u00272021X23\u0027",
