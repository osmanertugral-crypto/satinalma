{
    "type":  "view",
    "schema":  "dbo",
    "name":  "LV_123_01_EMUHTOTV3",
    "full_name":  "dbo.LV_123_01_EMUHTOTV3",
    "definition":  "CREATE VIEW [DBO].[LV_123_01_EMUHTOTV3] WITH SCHEMABINDING AS\n  SELECT CENTERREF AS ACCOUNTREF,\n         (CASE TRCODE WHEN 1 THEN -1 WHEN 7 THEN -2 ELSE MONTH_ END) AS MONTH_,\n         YEAR_,\n         SUM(ISNULL((CREDEBNET * (1 - TSIGN)), 0)) AS DEBIT,\n         SUM(ISNULL((CREDEBNET * TSIGN), 0)) AS CREDIT,\n         SUM(ISNULL((REPORTNET * (1 - TSIGN)), 0)) AS DEBIT_RC,\n         SUM(ISNULL((REPORTNET * TSIGN), 0)) AS CREDIT_RC,\n         SUM(0) AS DEBIT_LC,\n         SUM(0) AS CREDIT_LC,\n         SUM(0) AS DEBIT_AMNT,\n         SUM(0) AS CREDIT_AMNT,\n         SUM(0) AS DEBIT_EMU,\n         SUM(0) AS CREDIT_EMU,\n         BRANCH AS BRANCH,\n         DEPARTMENT AS DEPARTMENT,\n         TRCURR AS TRCURR,\n         SUM(0) AS DEBITRESRV,\n         SUM(0) AS CREDITRESRV,\n         SUM(0) AS DEBITRESRV_RC,\n         COUNT_BIG(*) AS CNT\n    FROM [dbo].LG_123_01_ACCDISTDETLN\n   WHERE STATUS = 0 AND CANCELLED = 0 AND TRCODE NOT IN (5, 10)\nGROUP BY CENTERREF,\n         (CASE TRCODE WHEN 1 THEN -1 WHEN 7 THEN -2 ELSE MONTH_ END),\n         YEAR_,\n         BRANCH,\n         DEPARTMENT,\n         TRCURR\n",
