    "name":  "AA_ALIŞ-SATIS_323",
    "full_name":  "dbo.AA_ALIŞ-SATIS_323",
    "definition":  "CREATE VIEW [dbo].[AA_ALIŞ-SATIS_323] AS\r\n\r\nWITH BaseQuery AS (\r\n    SELECT \r\n        YEAR(F.DATE_) AS YIL,\r\n        MONTH(F.DATE_) AS AY,\r\n        F.DATE_ AS TARIH,\r\n        F.FICHENO AS FATURA_NO,\r\n        C.CODE AS CARI_KODU,\r\n        C.DEFINITION_ AS CARI_ADI,\r\n        \u0027\u0027 AS STOK_KODU,\r\n        \u0027\u0027 AS STOK_ADI,\r\n        1 AS MIKTAR,\r\n        (L.DEBIT - L.CREDIT) AS FIYAT,\r\n        0 AS KDV,\r\n        (L.DEBIT - L.CREDIT) AS TUTAR,\r\n        D_EXC.RATES1 AS USD_KUR,\r\n        CASE WHEN ISNULL(D_EXC.RATES1, 0) = 0 THEN 0 ELSE ((L.DEBIT - L.CREDIT) / D_EXC.RATES1) END AS FIYAT_USD,\r\n        0 AS KDV_USD,\r\n        CASE WHEN ISNULL(D_EXC.RATES1, 0) = 0 THEN 0 ELSE ((L.DEBIT - L.CREDIT) / D_EXC.RATES1) END AS TUTAR_USD,\r\n        L.TRRATE AS EUR_KUR,\r\n        CASE WHEN SIGN = 0 THEN L.TRNET ELSE L.TRNET * -1 END AS FIYAT_EUR,\r\n        0 AS KDV_EUR,\r\n        CASE WHEN SIGN = 0 THEN L.TRNET ELSE L.TRNET * -1 END AS TUTAR_EUR,\r\n        \u0027\u0027 AS [S INDIRIM ORANI],\r\n        \u0027\u0027 AS [G INDIRIM ORANI],\r\n        \u0027\u0027 AS [MASRAF TUTARI],\r\n        \u0027\u0027 AS TUR,\r\n        \u0027TLP\u0027 AS FIS_TURU,\r\n        (SELECT CODE FROM LG_323_PROJECT WITH (NOLOCK) WHERE LOGICALREF = L.PROJECTREF) AS IS_EMRI_N0,\r\n        (SELECT NAME FROM LG_323_PROJECT WITH (NOLOCK) WHERE LOGICALREF = L.PROJECTREF) AS IS_EMRI_ADI,\r\n        F.FICHENO AS [MUH FİŞ NO],\r\n        C.CODE AS [MUHASEBE FİŞİ MUHASEBE KODU]\r\n    FROM \r\n        LG_323_01_EMFLINE AS L WITH (NOLOCK)\r\n    INNER JOIN \r\n        LG_323_EMUHACC AS C WITH (NOLOCK) ON C.LOGICALREF = L.ACCOUNTREF\r\n    INNER JOIN \r\n        LG_323_01_EMFICHE AS F WITH (NOLOCK) ON F.LOGICALREF = L.ACCFICHEREF\r\n    LEFT OUTER JOIN \r\n        LG_EXCHANGE_323 D_EXC WITH (NOLOCK) ON D_EXC.CRTYPE = 1 AND D_EXC.EDATE = F.DATE_\r\n    LEFT OUTER JOIN \r\n        LG_EXCHANGE_323 D_EXC_EUR WITH (NOLOCK) ON D_EXC_EUR.CRTYPE = 20 AND D_EXC_EUR.EDATE = F.DATE_\r\n    WHERE \r\n        YEAR(F.DATE_) \u003e 2021\r\n        AND L.KEBIRCODE IN (\u0027153\u0027, \u0027600\u0027)\r\n        AND ISNULL(L.PROJECTREF, 0) \u003c\u003e 0\r\n),\r\nSalesPurchases AS (\r\n    SELECT \r\n        L.DATE_ AS SP_DATE,\r\n        (SELECT CODE FROM LG_323_PROJECT WHERE LOGICALREF = L.PROJECTREF) AS SP_IS_EMRI_NO,\r\n        C.CODE AS SP_CARI_KODU,\r\n        C.DEFINITION_ AS SP_CARI_ADI\r\n    FROM \r\n        LG_323_01_EMFLINE AS L WITH (NOLOCK)\r\n    INNER JOIN \r\n        LG_323_EMUHACC AS C WITH (NOLOCK) ON C.LOGICALREF = L.ACCOUNTREF\r\n    WHERE \r\n        L.KEBIRCODE IN (\u0027120\u0027, \u0027320\u0027)\r\n)\r\nSELECT \r\n    BQ.YIL,\r\n    BQ.AY,\r\n    BQ.TARIH,\r\n    BQ.FATURA_NO,\r\n    BQ.CARI_KODU,\r\n    BQ.CARI_ADI,\r\n    BQ.STOK_KODU,\r\n    BQ.STOK_ADI,\r\n    BQ.MIKTAR,\r\n    BQ.FIYAT,\r\n    BQ.KDV,\r\n    BQ.TUTAR,\r\n    BQ.USD_KUR,\r\n    BQ.FIYAT_USD,\r\n    BQ.KDV_USD,\r\n    BQ.TUTAR_USD,\r\n    BQ.EUR_KUR,\r\n    BQ.FIYAT_EUR,\r\n    BQ.KDV_EUR,\r\n    BQ.TUTAR_EUR,\r\n    BQ.[S INDIRIM ORANI],\r\n    BQ.[G INDIRIM ORANI],\r\n    BQ.[MASRAF TUTARI],\r\n    BQ.TUR,\r\n    BQ.FIS_TURU,\r\n    BQ.IS_EMRI_N0,\r\n    BQ.IS_EMRI_ADI,\r\n    BQ.[MUH FİŞ NO],\r\n    BQ.[MUHASEBE FİŞİ MUHASEBE KODU],\r\n    SP.SP_CARI_KODU AS SALE_PURCHASE_CARI_KODU,\r\n    SP.SP_CARI_ADI AS SALE_PURCHASE_CARI_ADI\r\nFROM \r\n    BaseQuery BQ\r\nLEFT JOIN \r\n    SalesPurchases SP ON BQ.IS_EMRI_N0 = SP.SP_IS_EMRI_NO AND BQ.TARIH = SP.SP_DATE;\r\n\r\n",
