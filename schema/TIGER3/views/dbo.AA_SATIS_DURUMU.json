    "name":  "AA_SATIS_DURUMU",
    "full_name":  "dbo.AA_SATIS_DURUMU",
    "definition":  "\r\nCREATE VIEW [dbo].[AA_SATIS_DURUMU] AS\r\n\r\n\r\nSELECT\r\nP.CODE \u0027PROJE KODU\u0027\r\n,P.NAME \u0027FATURA ISMI\u0027\r\n,ISNULL((SELEct SUM(TUTAR) FROM [AA_SARF_PROJE] WHERE IS_EMRI_N0=P.CODE AND RECETE_TURU=\u0027STANDART\u0027),0) \u0027STANDART MALIYETI\u0027\r\n,ISNULL((SELEct SUM(TUTAR) FROM [AA_SARF_PROJE] WHERE IS_EMRI_N0=P.CODE AND RECETE_TURU=\u0027OPSIYONEL\u0027),0) \u0027OPSIYON MALIYETI\u0027\r\n,ISNULL((SELEct SUM(TUTAR) FROM [AA_SARF_PROJE] WHERE IS_EMRI_N0=P.CODE AND RECETE_TURU=\u0027ARABA\u0027),0) \u0027ARAÇ MALIYETI\u0027\r\n,ISNULL((SELEct SUM(TUTAR) FROM [AA_SARF_PROJE] WHERE IS_EMRI_N0=P.CODE AND RECETE_TURU=\u0027OTV\u0027),0) \u0027VERGI MALIYETI\u0027\r\n,ISNULL((SELEct SUM(TUTAR) FROM [AA_SARF_PROJE] WHERE IS_EMRI_N0=P.CODE),0) \u0027TOPLAM MALIYET\u0027\r\n,ISNULL((select sum(LINENET) from LG_001_01_ORFLINE WHERE TRCODE=1 AND LINENO_=1 AND PROJECTREF=P.LOGICALREF),0) \u0027STANDART SATIŞ\u0027 \r\n,ISNULL((select sum(LINENET) from LG_001_01_ORFLINE WHERE TRCODE=1 AND  LINENO_\u003c\u003e1 AND PROJECTREF=P.LOGICALREF),0)-(SELECT SUM(TOTAL) FROM LG_001_01_ORFLINE WHERE PROJECTREF=P.LOGICALREF AND STOCKREF IN (SELECT LOGICALREF FROM LG_001_ITEMS WHERE STGRPCODE=\u0027ARABA\u0027)) \u0027OPSIYON SATIŞ\u0027 \r\n,(SELECT SUM(TOTAL) FROM LG_001_01_ORFLINE WHERE PROJECTREF=P.LOGICALREF AND STOCKREF IN (SELECT LOGICALREF FROM LG_001_ITEMS WHERE STGRPCODE=\u0027ARABA\u0027)) ARAC_SATIS\r\n,ISNULL((select sum(LINENET) from LG_001_01_ORFLINE WHERE TRCODE=1 AND  PROJECTREF=P.LOGICALREF),0) \u0027TOPLAM GELIR\u0027  \r\n,ISNULL((select sum(LINENET) from LG_001_01_ORFLINE WHERE TRCODE=1 AND  PROJECTREF=P.LOGICALREF),0)-\r\nISNULL((SELEct SUM(TUTAR) FROM [AA_SARF_PROJE] WHERE IS_EMRI_N0=P.CODE),0)  KAZANC\r\n\r\n--,P.LOGICALREF\r\nFROM LG_001_PROJECT AS P\r\nWHERE \r\nP.LOGICALREF IN (SELECT PROJECTREF FROM LG_001_01_INVOICE WHERE TRCODE IN (7,8,9))\r\n--AND P.CODE=\u0027RXL011\u0027\r\n\r\n\r\n--SELECT * FROM LG_001_01_ORFICHE WHERE FICHENO=\u0027000054\u0027\r\n",
