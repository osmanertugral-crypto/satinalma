    "definition":  "\r\n\r\n--USE [TIGER3]\r\n--GO\r\n\r\n--/****** Object:  View [dbo].[DST_123_01_FATURAKONTROL]    Script Date: 15.02.2023 18:26:23 ******/\r\n--SET ANSI_NULLS ON\r\n--GO\r\n\r\n--SET QUOTED_IDENTIFIER ON\r\n--GO\r\n\r\n\r\n\r\n----USE [TIGER3]\r\n----GO\r\n\r\n----/****** Object:  View [dbo].[DST_123_01_KONTROLRAPORU]    Script Date: 19.11.2022 12:39:09 ******/\r\n----SET ANSI_NULLS ON\r\n----GO\r\n\r\n----SET QUOTED_IDENTIFIER ON\r\n----GO\r\n\r\n----ALTER VIEW [dbo].[DST_123_01_KONTROLRAPORU]\r\n\r\n----AS\r\n\r\nCREATE VIEW [dbo].[DST_123_01_FATURAKONTROL] AS\r\n\r\nSELECT DOCNR,DOCDATE\r\n\r\nFROM LG_123_01_APPROVAL\r\nWHERE RECTYPE=111 AND DOCDATE between \u002720230101\u0027 and  \u002720251231\u0027\r\n\r\nEXCEPT\r\n\r\nSELECT \r\nINV.DOCODE,DATE_\r\n\r\n\r\nFROM LG_123_01_INVOICE INV\r\n--LEFT JOIN LG_123_CLCARD CLC ON CLC.LOGICALREF=INV.CLIENTREF\r\n\r\nWHERE TRCODE IN (1,4) and DATE_ between \u002720230101\u0027 and  \u002720251231\u0027\r\n\r\n\r\n--------------------------------------------------\r\n--SELECT * FROM LG_123_01_APPROVAL WHERE DOCNR=\u00270012022182519229\u0027\r\n\r\n\r\n",
