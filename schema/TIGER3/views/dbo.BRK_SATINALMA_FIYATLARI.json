{
    "type":  "view",
    "schema":  "dbo",
    "name":  "BRK_SATINALMA_FIYATLARI",
    "full_name":  "dbo.BRK_SATINALMA_FIYATLARI",
    "definition":  "\r\nCREATE VIEW [dbo].[BRK_SATINALMA_FIYATLARI] AS\r\n\r\nWITH LastThreePurchases AS (\r\n    SELECT\r\n        MLZ.LOGICALREF,\r\n        MLZ.CODE AS KOD,\r\n        MLZ.NAME AS TANIM,\r\n        ISNULL(MLZ.STGRPCODE, \u0027\u0027) AS GRUP_KOD,\r\n        CASE MLZ.CARDTYPE \r\n            WHEN 1 THEN \u0027Ticari Mal\u0027 \r\n            WHEN 10 THEN \u0027Ham Madde\u0027\r\n            WHEN 11 THEN \u0027Yarı Mamül\u0027 \r\n            WHEN 12 THEN \u0027Mamül\u0027\r\n            WHEN 4 THEN \u0027Sabit Kıymet\u0027 \r\n            ELSE \u0027Diğer\u0027\r\n        END AS KART_TIPI,\r\n        STLINE.DATE_ + dbo.LG_INTTOTIME(STLINE.FTIME) AS PURCHASE_DATETIME,\r\n        (STLINE.LINENET + STLINE.DIFFPRICE) / NULLIF(STLINE.AMOUNT, 0) AS PURCHASE_PRICE,\r\n        STLINE.AMOUNT AS PURCHASE_AMOUNT,\r\n        CLCARD.CODE AS CARI_KODU,\r\n        CLCARD.DEFINITION_ AS CARI_ADI,\r\n        ROW_NUMBER() OVER (\r\n            PARTITION BY MLZ.LOGICALREF \r\n            ORDER BY STLINE.DATE_ + dbo.LG_INTTOTIME(STLINE.FTIME) DESC\r\n        ) AS RN\r\n    FROM LG_123_ITEMS MLZ\r\n    INNER JOIN LG_123_01_STLINE STLINE WITH (NOLOCK)\r\n        ON STLINE.STOCKREF = MLZ.LOGICALREF\r\n    INNER JOIN LG_123_01_INVOICE INVOICE WITH (NOLOCK)\r\n        ON INVOICE.LOGICALREF = STLINE.INVOICEREF\r\n    INNER JOIN LG_123_CLCARD CLCARD WITH (NOLOCK)\r\n        ON CLCARD.LOGICALREF = INVOICE.CLIENTREF\r\n    WHERE\r\n        MLZ.ACTIVE = 0\r\n        AND STLINE.PRICE \u003e 0\r\n        AND STLINE.TRCODE IN (1, 14)\r\n)\r\n\r\nSELECT\r\n    KOD,\r\n    TANIM,\r\n    GRUP_KOD,\r\n    KART_TIPI,\r\n    -- Last purchase\r\n    CONVERT(VARCHAR(10), MAX(CASE WHEN RN = 1 THEN PURCHASE_DATETIME END), 104) AS LAST_PURCHASE_DATE,\r\n    MAX(CASE WHEN RN = 1 THEN CARI_KODU END) AS SON_ALIM_CARI_KODU,\r\n    MAX(CASE WHEN RN = 1 THEN CARI_ADI END) AS SON_ALIM_CARI_ADI,\r\n    DATEDIFF(DAY, MAX(CASE WHEN RN = 1 THEN PURCHASE_DATETIME END), GETDATE()) AS DAYS_SINCE_LAST_PURCHASE,\r\n    FORMAT(MAX(CASE WHEN RN = 1 THEN PURCHASE_PRICE END), \u0027N2\u0027, \u0027tr-TR\u0027) AS LAST_PURCHASE_PRICE,\r\n    MAX(CASE WHEN RN = 1 THEN PURCHASE_AMOUNT END) AS LAST_PURCHASE_AMOUNT,\r\n    -- Second last purchase\r\n    CONVERT(VARCHAR(10), MAX(CASE WHEN RN = 2 THEN PURCHASE_DATETIME END), 104) AS [2ND_LAST_PURCHASE_DATE],\r\n    MAX(CASE WHEN RN = 2 THEN CARI_KODU END) AS SONDAN_IKINCI_ALIM_CARI_KODU,\r\n    MAX(CASE WHEN RN = 2 THEN CARI_ADI END) AS SONDAN_IKINCI_ALIM_CARI_ADI,\r\n    DATEDIFF(DAY, MAX(CASE WHEN RN = 2 THEN PURCHASE_DATETIME END), MAX(CASE WHEN RN = 1 THEN PURCHASE_DATETIME END)) AS [DAYS_BETWEEN_PURCHASES],\r\n    FORMAT(MAX(CASE WHEN RN = 2 THEN PURCHASE_PRICE END), \u0027N2\u0027, \u0027tr-TR\u0027) AS [2ND_LAST_PURCHASE_PRICE],\r\n    MAX(CASE WHEN RN = 2 THEN PURCHASE_AMOUNT END) AS [2ND_LAST_PURCHASE_AMOUNT],\r\n    -- Third last purchase\r\n    CONVERT(VARCHAR(10), MAX(CASE WHEN RN = 3 THEN PURCHASE_DATETIME END), 104) AS [3RD_LAST_PURCHASE_DATE],\r\n    MAX(CASE WHEN RN = 3 THEN CARI_KODU END) AS SONDAN_UCUNCU_ALIM_CARI_KODU,\r\n    MAX(CASE WHEN RN = 3 THEN CARI_ADI END) AS SONDAN_UCUNCU_ALIM_CARI_ADI,\r\n    DATEDIFF(DAY, MAX(CASE WHEN RN = 3 THEN PURCHASE_DATETIME END), MAX(CASE WHEN RN = 2 THEN PURCHASE_DATETIME END)) AS [DAYS_BETWEEN_2ND_AND_3RD_PURCHASES],\r\n    FORMAT(MAX(CASE WHEN RN = 3 THEN PURCHASE_PRICE END), \u0027N2\u0027, \u0027tr-TR\u0027) AS [3RD_LAST_PURCHASE_PRICE],\r\n    MAX(CASE WHEN RN = 3 THEN PURCHASE_AMOUNT END) AS [3RD_LAST_PURCHASE_AMOUNT]\r\nFROM LastThreePurchases\r\nGROUP BY\r\n    KOD,\r\n    TANIM,\r\n    GRUP_KOD,\r\n    KART_TIPI;\r\n\r\n\r\n--WITH LastThreePurchases AS (\r\n--    SELECT\r\n--        MLZ.LOGICALREF,\r\n--        MLZ.CODE AS KOD,\r\n--        MLZ.NAME AS TANIM,\r\n--        ISNULL(MLZ.STGRPCODE, \u0027\u0027) AS GRUP_KOD,\r\n--        CASE MLZ.CARDTYPE \r\n--            WHEN 1 THEN \u0027Ticari Mal\u0027 \r\n--            WHEN 10 THEN \u0027Ham Madde\u0027\r\n--            WHEN 11 THEN \u0027Yarı Mamül\u0027 \r\n--            WHEN 12 THEN \u0027Mamül\u0027\r\n--            WHEN 4 THEN \u0027Sabit Kıymet\u0027 \r\n--            ELSE \u0027Diğer\u0027\r\n--        END AS KART_TIPI,\r\n--        STLINE.DATE_ + dbo.LG_INTTOTIME(STLINE.FTIME) AS PURCHASE_DATETIME,\r\n--        (STLINE.LINENET + STLINE.DIFFPRICE) / NULLIF(STLINE.AMOUNT, 0) AS PURCHASE_PRICE,\r\n--        STLINE.AMOUNT AS PURCHASE_AMOUNT,\r\n--        ROW_NUMBER() OVER (\r\n--            PARTITION BY MLZ.LOGICALREF \r\n--            ORDER BY STLINE.DATE_ + dbo.LG_INTTOTIME(STLINE.FTIME) DESC\r\n--        ) AS RN\r\n--    FROM LG_123_ITEMS MLZ\r\n--    INNER JOIN LG_123_01_STLINE STLINE WITH (NOLOCK)\r\n--        ON STLINE.STOCKREF = MLZ.LOGICALREF\r\n--    WHERE\r\n--        MLZ.ACTIVE = 0\r\n--        AND STLINE.PRICE \u003e 0\r\n--        AND STLINE.TRCODE IN (1, 14)\r\n--)\r\n--SELECT\r\n--    KOD,\r\n--    TANIM,\r\n--    GRUP_KOD,\r\n--    KART_TIPI,\r\n--    -- Last purchase\r\n--    CONVERT(VARCHAR(10), MAX(CASE WHEN RN = 1 THEN PURCHASE_DATETIME END), 104) AS LAST_PURCHASE_DATE,\r\n--    DATEDIFF(DAY, MAX(CASE WHEN RN = 1 THEN PURCHASE_DATETIME END), GETDATE()) AS DAYS_SINCE_LAST_PURCHASE,\r\n--    FORMAT(MAX(CASE WHEN RN = 1 THEN PURCHASE_PRICE END), \u0027N2\u0027, \u0027tr-TR\u0027) AS LAST_PURCHASE_PRICE,\r\n--    MAX(CASE WHEN RN = 1 THEN PURCHASE_AMOUNT END) AS LAST_PURCHASE_AMOUNT,\r\n--    -- Second last purchase\r\n--    CONVERT(VARCHAR(10), MAX(CASE WHEN RN = 2 THEN PURCHASE_DATETIME END), 104) AS [2ND_LAST_PURCHASE_DATE],\r\n--    DATEDIFF(DAY, MAX(CASE WHEN RN = 2 THEN PURCHASE_DATETIME END), MAX(CASE WHEN RN = 1 THEN PURCHASE_DATETIME END)) AS [DAYS_BETWEEN_PURCHASES],\r\n--    FORMAT(MAX(CASE WHEN RN = 2 THEN PURCHASE_PRICE END), \u0027N2\u0027, \u0027tr-TR\u0027) AS [2ND_LAST_PURCHASE_PRICE],\r\n--    MAX(CASE WHEN RN = 2 THEN PURCHASE_AMOUNT END) AS [2ND_LAST_PURCHASE_AMOUNT],\r\n--    -- Third last purchase\r\n--    CONVERT(VARCHAR(10), MAX(CASE WHEN RN = 3 THEN PURCHASE_DATETIME END), 104) AS [3RD_LAST_PURCHASE_DATE],\r\n--    DATEDIFF(DAY, MAX(CASE WHEN RN = 3 THEN PURCHASE_DATETIME END), MAX(CASE WHEN RN = 2 THEN PURCHASE_DATETIME END)) AS [DAYS_BETWEEN_2ND_AND_3RD_PURCHASES],\r\n--    FORMAT(MAX(CASE WHEN RN = 3 THEN PURCHASE_PRICE END), \u0027N2\u0027, \u0027tr-TR\u0027) AS [3RD_LAST_PURCHASE_PRICE],\r\n--    MAX(CASE WHEN RN = 3 THEN PURCHASE_AMOUNT END) AS [3RD_LAST_PURCHASE_AMOUNT]\r\n--FROM LastThreePurchases\r\n--GROUP BY\r\n--    KOD,\r\n--    TANIM,\r\n--    GRUP_KOD,\r\n--    KART_TIPI;\r\n\r\n",
