    "full_name":  "dbo.LV_123_01_EXIMDISTPEG",
    "definition":  "CREATE VIEW [dbo].[LV_123_01_EXIMDISTPEG] AS\nSELECT LGMAIN.ITEMREF, LGMAIN.STTRANSREF, SUM(LGMAIN.ADDEXPENSE) AS ADDEXPENSE, SUM(LGMAIN.TOTALAMNT) AS TOTALAMNT\n FROM LG_123_01_EXIMDISTPEG LGMAIN\n WHERE (LGMAIN.ISDISTRIBUTED = 1) AND (LGMAIN.TOTALAMNT \u003e 0)\n GROUP BY LGMAIN.ITEMREF, LGMAIN.STTRANSREF\n",
