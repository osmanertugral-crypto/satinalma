    "name":  "AA_GIDER_RAPORU",
    "full_name":  "dbo.AA_GIDER_RAPORU",
    "definition":  "CREATE VIEW AA_GIDER_RAPORU AS \r\nselect \r\nH.CODE\r\n,H.DEFINITION_\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =1),0) \u002701_OCAK\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =2),0) \u002702_SUBAT\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =3),0) \u002703_MART\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =4),0) \u002704_NISAN\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =5),0) \u002705_MAYIS\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =6),0) \u002706_HAZIRAN\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =7),0) \u002707_TEMMUZ\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =8),0) \u002708_AGUSTOS\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =9),0) \u002709_EYLUL\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =10),0) \u002710_EKIM\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =11),0) \u002711_KASIM\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =12),0) \u002712_ARALIK\u0027\r\n\r\nfrom LG_001_EMUHACC  AS H\r\n\r\n\r\nWHERE H.CODE LIKE\u00277%\u0027\r\n--AND LEN(H.CODE)=3\r\nAND H.CODE IN (SELECT ACCOUNTCODE FROM LG_001_01_EMFLINE)\r\n",
