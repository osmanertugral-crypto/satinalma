    "name":  "AA_PROJELERDEKI_MALZEMELER_123",
    "full_name":  "dbo.AA_PROJELERDEKI_MALZEMELER_123",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[AA_PROJELERDEKI_MALZEMELER_123] AS \r\n SELECT \u0027Sarf Fişi\u0027 as FIS_TURU,\r\n FIS.DATE_ AS TARIH,\r\n FIS.FICHENO AS FIS_NO,\r\n (sELECT CODE FROM LG_123_PROJECT WHERE LOGICALREF=SAT.PROJECTREF) AS PROJE_KODU,\r\n MLZ.CODE AS MALZEME_KODU,\r\n MLZ.NAME AS MALZEME_ADI,\r\n SAT.AMOUNT AS MIKTAR\r\n  \r\n  FROM LG_123_01_STLINE SAT\r\n INNER JOIN LG_123_ITEMS MLZ ON MLZ.LOGICALREF=SAT.STOCKREF\r\n INNER JOIN LG_123_01_STFICHE FIS ON FIS.LOGICALREF=SAT.STFICHEREF\r\n\r\n --WHERE FIS.PROJECTREF IN (sELECT PROJECTREF FROM LG_123_01_ORFICHE WHERE TRCODE=1 AND CYPHCODE\u003c\u003e\u0027KAPALI\u0027) AND SAT.TRCODE=12\r\n",
