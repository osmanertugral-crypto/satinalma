{
    "type":  "view",
    "schema":  "dbo",
    "name":  "ENVANTER_ANALIZ_BURAK_2024",
    "full_name":  "dbo.ENVANTER_ANALIZ_BURAK_2024",
    "definition":  "CREATE view ENVANTER_ANALIZ_BURAK_2024 AS\r\n\r\nselect ITEMS.LOGICALREF,\r\nITEMS.code [Malzeme Kodu],ITEMS.name [Malzeme Adı],ITEMS.STGRPCODE [Malzeme Grup Kodu],\r\nDATEDIFF(DAY,\u00272024-01-01 00:00:00.000\u0027 , getdate()) AS [Raporlanan Aralık Gün Sayısı],\r\nSUM(case SOURCEINDEX when 2 then CASE STLINE.TRCODE WHEN \u002701\u0027 THEN STLINE.AMOUNT/UINFO2*UINFO1 WHEN \u002706\u0027 THEN -1*STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END else 0 end) [2\u0027 Nolu AmbarToplan Satınalam - İade],\r\nSUM(case  when SOURCEINDEX\u003c\u003e2 then CASE STLINE.TRCODE WHEN \u002701\u0027 THEN STLINE.AMOUNT/UINFO2*UINFO1 WHEN \u002706\u0027 THEN -1*STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END else 0 end) [Diğerleri Toplan Satınalam - İade]\r\n,SUM(\r\ncase IOCODE\r\nwhen 1 then CASE SOURCEINDEX WHEN 2 THEN STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END\r\nwhen 2 then CASE SOURCEINDEX WHEN 2 THEN STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END\r\nwhen 3 then CASE SOURCEINDEX WHEN 2 THEN -1*STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END\r\nwhen 4 then CASE SOURCEINDEX WHEN 2 THEN -1*STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END\r\nELSE 0 END) [2\u0027NOLU AMBAR TOPLAM ÇIKIŞLAR],\r\nSUM(case IOCODE when 4 then STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END)/DATEDIFF(DAY,\u00272024-01-01 00:00:00.000\u0027 ,getdate()) [Günlük Ortalama Harcama],\r\n(select SUM(ONHAND) from LV_123_01_STINVTOT TOT WHERE TOT.STOCKREF=ITEMS.LOGICALREF AND INVENNO=2 ) [Anlık 2\u0027nolu Ambar Stok],\r\n(select SUM(ONHAND) from LV_123_01_STINVTOT TOT WHERE TOT.STOCKREF=ITEMS.LOGICALREF AND INVENNO=2 )*SUM(case IOCODE when 4 then STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END)/DATEDIFF(DAY,\u00272024-01-01 00:00:00.000\u0027 , getdate()) [Ortalama Bitiş Süresi],\r\n(select TOP 1 PRICE from LG_123_01_ORFLINE orf where orf.STOCKREF=ITEMS.LOGICALREF ORDER BY ORF.LOGICALREF DESC  ) [Birim Fiyat],\r\nISNULL((select TOP 1 PRICE from LG_123_01_ORFLINE orf where orf.STOCKREF=ITEMS.LOGICALREF ORDER BY ORF.LOGICALREF DESC  ),0)*ISNULL((select SUM(ONHAND) from LV_123_01_STINVTOT TOT WHERE TOT.STOCKREF=ITEMS.LOGICALREF AND INVENNO=2 ),0)*SUM(case IOCODE when 4 then STLINE.AMOUNT/UINFO2*UINFO1 ELSE 0 END)/DATEDIFF(DAY,\u00272024-01-01 00:00:00.000\u0027 ,getdate())  [Toplam Tutar],\r\nITEMS.CAPIBLOCK_CREADEDDATE [Malzeme Kartı Oluşturma Tarihi]\r\nfrom lg_123_Items ITEMS\r\nleft JOIN LG_123_01_STLINE STLINE ON STLINE.STOCKREF=ITEMS.LOGICALREF  AND LINETYPE=0 AND LPRODSTAT=0\r\nWHERE  STLINE.DATE_ BETWEEN \u00272024-01-01 00:00:00.000\u0027 AND getdate()\r\nGROUP BY ITEMS.LOGICALREF,ITEMS.code,ITEMS.name ,ITEMS.STGRPCODE ,ITEMS.LOGICALREF,ITEMS.CAPIBLOCK_CREADEDDATE\r\n",
