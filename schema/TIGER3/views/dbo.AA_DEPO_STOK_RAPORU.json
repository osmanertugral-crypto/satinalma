{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_DEPO_STOK_RAPORU",
    "full_name":  "dbo.AA_DEPO_STOK_RAPORU",
    "definition":  "CREATE VIEW AA_DEPO_STOK_RAPORU AS\r\nSELECT       ITM.LOGICALREF AS MLZ_ID, ITM.CODE, ITM.NAME, SUM(ISNULL(STN.ONHAND, 0)) - SUM(ISNULL(STN.ONVEHICLE, 0)) AS MIKTAR, STN.INVENNO AS DEPO,\r\n                             (SELECT        NAME\r\n                               FROM            dbo.L_CAPIWHOUSE\r\n                               WHERE        (STN.INVENNO = NR) AND (FIRMNR = 1)) AS DEPO_ADI\r\nFROM            dbo.LV_001_01_STINVTOT AS STN WITH (nolock) LEFT OUTER JOIN\r\n                         dbo.LG_001_ITEMS AS ITM WITH (nolock) ON STN.STOCKREF = ITM.LOGICALREF\r\nWHERE        (STN.INVENNO \u003c\u003e - 1) AND (STN.DATE_ \u003c= GETDATE())\r\nGROUP BY STN.INVENNO, STN.STOCKREF, ITM.CODE, ITM.NAME, ITM.LOGICALREF\r\nHAVING        (SUM(STN.ONHAND) \u003e= - 99999999) AND (SUM(STN.ONHAND) \u003c= 99999999)\r\n",
    "columns":  [
                    {
                        "COLUMN_NAME":  "MLZ_ID",
                        "ORDINAL_POSITION":  1,
                        "DATA_TYPE":  "int",
                        "CHARACTER_MAXIMUM_LENGTH":  "",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "CODE",
                        "ORDINAL_POSITION":  2,
                        "DATA_TYPE":  "varchar",
