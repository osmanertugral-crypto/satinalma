    "full_name":  "dbo.LV_223_01_CLCARD",
    "definition":  "CREATE VIEW [dbo].[LV_223_01_CLCARD] AS\nSELECT\n      LGMAIN.LOGICALREF, LGMAIN.CODE, LGMAIN.DEFINITION_, LGMAIN.CITY, LGMAIN.COUNTRY, LGMAIN.ACTIVE, LGMAIN.CARDTYPE, LGMAIN.SPECODE, LGMAIN.TRADINGGRP,\n   LGMAIN.CYPHCODE, LGMAIN.INCHARGE, LGMAIN.SPECODE2, LGMAIN.SPECODE3, LGMAIN.SPECODE4, LGMAIN.SPECODE5, LGMAIN.TAXOFFICE, LGMAIN.TAXNR, LGMAIN.TCKNO,\n   LGMAIN.EMAILADDR, LGMAIN.TELNRS1, LGMAIN.TELNRS2, LGMAIN.ORGLOGICREF, LGMAIN.WFLOWCRDREF,LGMAIN.PURCHBRWS, LGMAIN.SALESBRWS, LGMAIN.FINBRWS, LGMAIN.WFLOWCRD,\n      (SELECT SUM(B.DEBIT) FROM LV_223_01_GNTOTCL B WHERE B.TOTTYP=1 AND B.CARDREF=LGMAIN.LOGICALREF) AS DEBIT,\n      (SELECT SUM(B.CREDIT) FROM LV_223_01_GNTOTCL B WHERE B.TOTTYP=1 AND B.CARDREF=LGMAIN.LOGICALREF) AS CREDIT,\n      (SELECT SUM(B.DEBIT) FROM LV_223_01_GNTOTCL B WHERE B.TOTTYP=2 AND B.CARDREF=LGMAIN.LOGICALREF) AS DEBIT_RD,\n      (SELECT SUM(B.CREDIT) FROM LV_223_01_GNTOTCL B WHERE B.TOTTYP=2 AND B.CARDREF=LGMAIN.LOGICALREF) AS CREDIT_RD\nFROM\n     LV_223_CLCARD LGMAIN\nWHERE\n     LGMAIN.CARDTYPE NOT IN (4,22) AND LGMAIN.LOWLEVELCODES1 \u003c\u003e \u00270\u0027\nUNION ALL\nSELECT\n      LGMAIN.LOGICALREF, LGMAIN.CODE, LGMAIN.DEFINITION_, LGMAIN.CITY, LGMAIN.COUNTRY, LGMAIN.ACTIVE, LGMAIN.CARDTYPE, LGMAIN.SPECODE, LGMAIN.TRADINGGRP,\n   LGMAIN.CYPHCODE, LGMAIN.INCHARGE, LGMAIN.SPECODE2, LGMAIN.SPECODE3, LGMAIN.SPECODE4, LGMAIN.SPECODE5, LGMAIN.TAXOFFICE, LGMAIN.TAXNR, LGMAIN.TCKNO,\n   LGMAIN.EMAILADDR, LGMAIN.TELNRS1, LGMAIN.TELNRS2, LGMAIN.ORGLOGICREF, LGMAIN.WFLOWCRDREF,LGMAIN.PURCHBRWS, LGMAIN.SALESBRWS, LGMAIN.FINBRWS, LGMAIN.WFLOWCRD,\n      (SELECT SUM(B.DEBIT) FROM LV_223_01_GNTOTCL B WHERE B.TOTTYP=1 AND B.CARDREF=LGMAIN.LOGICALREF) AS DEBIT,\n      (SELECT SUM(B.CREDIT) FROM LV_223_01_GNTOTCL B WHERE B.TOTTYP=1 AND B.CARDREF=LGMAIN.LOGICALREF) AS CREDIT,\n      (SELECT SUM(B.DEBIT) FROM LV_223_01_GNTOTCL B WHERE B.TOTTYP=2 AND B.CARDREF=LGMAIN.LOGICALREF) AS DEBIT_RD,\n      (SELECT SUM(B.CREDIT) FROM LV_223_01_GNTOTCL B WHERE B.TOTTYP=2 AND B.CARDREF=LGMAIN.LOGICALREF) AS CREDIT_RD\nFROM\n     LV_223_CLCARD LGMAIN\nWHERE\n     LGMAIN.CARDTYPE NOT IN (4,22) AND LGMAIN.LOWLEVELCODES1=0",
