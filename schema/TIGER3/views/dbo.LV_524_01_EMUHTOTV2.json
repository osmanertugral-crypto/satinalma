    "name":  "LV_524_01_EMUHTOTV2",
    "full_name":  "dbo.LV_524_01_EMUHTOTV2",
    "definition":  "CREATE VIEW [DBO].[LV_524_01_EMUHTOTV2] WITH SCHEMABINDING AS\n  SELECT ACCOUNTREF AS ACCOUNTREF,\n         (CASE TRCODE WHEN 1 THEN -1 WHEN 7 THEN -2 ELSE MONTH (DATE_) END) AS MONTH_,\n         YEAR(DATE_) AS YEAR_,\n         SUM(0) AS DEBIT,\n         SUM(0) AS CREDIT,\n         SUM(0) AS DEBIT_RC,\n         SUM(0) AS CREDIT_RC,\n         SUM(0) AS DEBIT_LC,\n         SUM(0) AS CREDIT_LC,\n         SUM(ISNULL((AMNT * (1 - SIGN)), 0)) AS DEBIT_AMNT,\n         SUM(ISNULL((AMNT * SIGN), 0)) AS CREDIT_AMNT,\n         SUM(0) AS DEBIT_EMU,\n         SUM(0) AS CREDIT_EMU,\n         BRANCH AS BRANCH,\n         DEPARTMENT AS DEPARTMENT,\n         TRCURR AS TRCURR,\n         SUM(ISNULL((CASE WHEN SIGN = 1 THEN CREDIT ELSE DEBIT END), 0))\n            AS DEBITRESRV,\n         SUM(ISNULL((CASE WHEN SIGN = 1 THEN PAIDTOTAL ELSE PAIDTOTAL END), 0))\n            AS CREDITRESRV,\n         SUM(ISNULL(REPORTNET, 0)) AS DEBITRESRV_RC,\n         COUNT_BIG(*) AS CNT\n    FROM [dbo].LG_524_01_EMDEMFLINE\n   WHERE     BDGTLINETYPE = 3\n         AND STATUS = 0\n         AND CANCELLED = 0\n         AND TRCODE NOT IN (5, 10)\nGROUP BY ACCOUNTREF,\n         (CASE TRCODE WHEN 1 THEN -1 WHEN 7 THEN -2 ELSE MONTH (DATE_) END),\n         YEAR(DATE_),\n         BRANCH,\n         DEPARTMENT,\n         TRCURR\n",
