    "name":  "AA_SARF_PROJE_123_TOPLAM_BURAK",
    "full_name":  "dbo.AA_SARF_PROJE_123_TOPLAM_BURAK",
    "definition":  "CREATE VIEW [dbo].[AA_SARF_PROJE_123_TOPLAM_BURAK] AS\r\nSELECT STFICHE.FICHENO FIS_NO, STFICHE.DATE_ FIS_TARIHI, ITEMS.CODE URUN_KODU, ITEMS.NAME URUN_ADI, PROJECT.CODE PROJE_KODU , PROJECT.NAME PROJE_ADI,STLINE.AMOUNT ADET,  STLINE.OUTCOST BIRIM_FIYAT, STLINE.AMOUNT * STLINE.OUTCOST TOPLAM\r\n\r\nFROM LG_123_01_STLINE STLINE WITH(NOLOCK)\r\n\r\nINNER JOIN LG_123_01_STFICHE STFICHE WITH(NOLOCK) ON STLINE.STFICHEREF = STFICHE.LOGICALREF\r\nINNER JOIN LG_123_ITEMS ITEMS WITH(NOLOCK) ON STLINE.STOCKREF = ITEMS.LOGICALREF\r\nINNER JOIN LG_123_PROJECT PROJECT WITH(NOLOCK) ON STFICHE.PROJECTREF = PROJECT.LOGICALREF\r\n\r\n\r\nWHERE STLINE.TRCODE = 12 \r\nAND STLINE.CANCELLED = 0\r\n\r\n",
