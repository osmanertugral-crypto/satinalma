{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DST_123_01_HİZMET FATURALARI",
    "full_name":  "dbo.DST_123_01_HİZMET FATURALARI",
    "definition":  "\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[DST_123_01_HİZMET FATURALARI]\r\nAS\r\n\r\n\r\nSELECT   \r\n\r\n\u0027RESTAR 123\u0027 FİRMA,\r\nMONTH(INVOICE.DATE_ )AS AY,\r\nYEAR(INVOICE.DATE_ )AS YIL,\r\nINVOICE.DATE_ AS [FATURA TARİHİ], \r\nINVOICE.FICHENO AS FATURA_NO,\r\nINVOICE.DOCODE AS BELGE_NO,\r\nCLCARD.CODE \u0027CARİ KODU\u0027,\r\nCLCARD.DEFINITION_ AS [CARİ ÜNVANI], \r\nCLCARD.TAXNR \u0027VERGİ KİMLİK NO\u0027,\r\n       CASE STLINE.LINETYPE WHEN 0 THEN \u0027Stok\u0027 WHEN 4 THEN \u0027Hizmet\u0027 ELSE \u0027DİGER\u0027 END \u0027TİPİ\u0027, CASE WHEN STLINE.TRCODE IN (1, 3) \r\n                      THEN CASE WHEN STLINE.LINETYPE IN (0) \r\n                      THEN ITEMS.CODE ELSE SRVCARD.CODE END ELSE CASE WHEN STLINE.LINETYPE = 4 THEN SRVCARD.CODE ELSE ITEMS.CODE END END \u0027HİZMET  KODU\u0027, \r\n                      CASE WHEN STLINE.TRCODE IN (1, 3) THEN CASE WHEN STLINE.LINETYPE IN (0) \r\n                      THEN ITEMS.NAME ELSE SRVCARD.DEFINITION_ END ELSE CASE WHEN STLINE.LINETYPE = 4 THEN SRVCARD.DEFINITION_ ELSE ITEMS.NAME END END \u0027HİZMET AÇIKLAMASI\u0027,\r\n\r\n\r\n\r\n\r\n\r\n--STFICHE.FICHENO AS [İRSALİYE NO],\r\n\r\n\r\n\r\n                       \r\n       --               STLINE.DATE_ AS [İŞLEM TARİHİ], \r\n                                   --YEAR(STLINE.DATE_) [YIL],\r\n                                   --MONTH(STLINE.DATE_) [AY],\r\n                                   --CASE DATEPART(MONTH, STLINE.DATE_) \r\n       --               WHEN 1 THEN \u0027OCAK\u0027 WHEN 2 THEN \u0027ŞUBAT\u0027 WHEN 3 THEN \u0027MART\u0027 WHEN 4 THEN \u0027NİSAN\u0027 WHEN 5 THEN \u0027MAYIS\u0027 WHEN 6 THEN \u0027HAZİRAN\u0027 WHEN 7 THEN \u0027TEMMUZ\u0027\r\n       --                WHEN 8 THEN \u0027AĞUSTOS\u0027 WHEN 9 THEN \u0027EYLÜL\u0027 WHEN 10 THEN \u0027EKİM\u0027 WHEN 11 THEN \u0027KASIM\u0027 WHEN 12 THEN \u0027ARALIK\u0027 END AS [İŞLEM AYI], \r\n                                    CASE STLINE.TRCODE WHEN 1 THEN \u0027Alım Faturası\u0027WHEN 3 THEN \u0027Satış iade İrsaliyesi\u0027WHEN 4 THEN \u0027Alınan Hizmet\u0027 WHEN 13 THEN \u0027Üretimden Giriş Fişi\u0027 WHEN 50 THEN \u0027Sayım Fazlası Fişi\u0027WHEN 25 THEN \u0027Ambar Fişi\u0027WHEN 14 THEN \u0027Devir Fişi\u0027WHEN 9 THEN \u0027Verilen Hizmet\u0027ELSE \u0027DİĞER\u0027END AS TÜR,\r\n                       STLINE.AMOUNT AS [MİKTAR],\r\n                                   \r\n                                    (SELECT CODE FROM LG_123_UNITSETL WHERE LOGICALREF=STLINE.UOMREF) BIRIM,\r\n                                   --STLINE.PRICE AS [BİRİM FİYAT],\r\n                                 \r\n                                   CASE STLINE.TRCODE WHEN 1 THEN VATMATRAH WHEN 4 THEN VATMATRAH ELSE VATMATRAH *  1 END +STLINE.DISTEXP AS KDVMATRAHI,\r\n                                   STLINE.VATAMNT AS [KDVTUTARI],\r\n                                   --CASE STLINE.TRCODE WHEN 1 THEN VATMATRAH WHEN 4 THEN VATMATRAH ELSE VATMATRAH *  1 END+STLINE.VATAMNT+STLINE.DISTEXP AS [NET TUTAR],\r\n                                   --STLINE.TOTAL AS İNDİRİMSİZTUTAR,CASE WHEN STLINE.TRCODE IN (2, 3) THEN STLINE.DISTDISC * - 1 ELSE STLINE.DISTDISC END AS İSKONTO,\r\n                                 STLINE.VAT ,\r\n                                   \r\n                      --CASE STLINE.TRCURR WHEN 0 THEN \u0027TL\u0027WHEN 1 THEN \u0027USD\u0027WHEN 20 THEN \u0027EURO\u0027 ELSE \u0027\u0027 END AS İDTÜRÜ, \r\n                      --CASE STLINE.TRRATE WHEN 0 THEN 0 ELSE STLINE.PRICE / STLINE.TRRATE END AS İDBİRİMFİYATI, \r\n                      --CASE STLINE.TRRATE WHEN 0 THEN 0 ELSE STLINE.VAT / STLINE.TRRATE END AS İDKDV, \r\n                      --CASE STLINE.TRRATE WHEN 0 THEN 0 ELSE STLINE.TOTAL / STLINE.TRRATE END AS İDTUTAR,\r\n                      -- PYP.DEFINITION_ AS VADE,\r\n                                    CASE STLINE.BILLED WHEN 1 THEN \u0027FATURALANDI\u0027 WHEN 0 THEN \u0027İRSALİYE\u0027 ELSE \u0027DİĞER\u0027 END [FATURALANMA DURUMU]\r\n                                    --,STLINE.SOURCEINDEX [AMBAR NO]\r\n                                   --,CASE STLINE.SOURCEINDEX WHEN 0 THEN \u0027MERKEZ\u0027 WHEN 2 THEN \u0027IGA\u0027  WHEN 4 THEN \u0027ORHANLI\u0027 WHEN 6 THEN \u0027ESKİŞEHİR\u0027 WHEN 8 THEN \u0027MANİSA\u0027 \r\n                                   --WHEN 10 THEN \u0027GÖLCÜK\u0027 WHEN 1 THEN \u0027MERKEZ SERVİS\u0027 WHEN 3 THEN \u0027IGA SERVİS\u0027WHEN 5 THEN \u0027ORHANLI SERVİS\u0027WHEN 7 THEN \u0027ESKİŞEHİR SERVİS\u0027\r\n                                   --WHEN 9 THEN \u0027MANİSA SERVİS\u0027WHEN 5 THEN \u0027ORHANLI SERVİS\u0027\r\n                                   -- ELSE \u0027BOS\u0027END[AMBAR]\r\n                                    \r\n                                    --,EMC.CODE [MM KODU],\r\n                                 --EMC.DEFINITION_ [MM ADI],EMC.SPECODE [ÖZEL KOD],EMC.CYPHCODE [MODEL],EMC.SPECODE2 [MODEL YILI],EMC.SPECODE3 [PARK ALANI],\r\n                                   --PROJ.NAME [PROJE KODU],\r\n                                        ,  (SELECT        FICHENO\r\n                               FROM            LG_123_01_EMFICHE\r\n                               WHERE        LOGICALREF IN\r\n                                                             (SELECT        ACCFICHEREF\r\n                                                               FROM            LG_123_01_INVOICE\r\n                                                               WHERE        LOGICALREF = INVOICE.LOGICALREF)) [MUH FİŞ NO],\r\n\r\n----------------------------------------------\r\n\r\n\r\n                                                ISNULL(  (SELECT       TOP 1 ACCOUNTCODE \r\n\r\n                               FROM            LG_123_01_EMFLINE\r\n                               WHERE        ACCFICHEREF IN\r\n                                                             (SELECT        ACCFICHEREF\r\n                                                               FROM            LG_123_01_INVOICE\r\n                                                               WHERE        LOGICALREF = INVOICE.LOGICALREF)AND ACCOUNTCODE LIKE \u002719%\u0027),\u0027\u0027) [MUHASEBE FİŞİ MUHASEBE KODU],\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t   -------------\r\n(SELECT DEFINITION_ FROM LG_123_EMUHACC WHERE LOGICALREF IN (\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t   \r\n                                                ISNULL(  (SELECT       TOP 1 ACCOUNTREF\r\n\r\n                               FROM            LG_123_01_EMFLINE\r\n                               WHERE        ACCFICHEREF IN\r\n                                                             (SELECT        ACCFICHEREF\r\n                                                               FROM            LG_123_01_INVOICE\r\n                                                               WHERE        LOGICALREF = INVOICE.LOGICALREF)AND ACCOUNTCODE LIKE \u002719%\u0027),\u0027\u0027))) [MUHASEBE FİŞİ KDV ADI],\r\n\r\n\r\n\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t   -------------------\r\n\r\nISNULL(  (SELECT       SUM( DEBIT )\r\n\r\n                               FROM            LG_123_01_EMFLINE\r\n                               WHERE        ACCFICHEREF IN\r\n                                                             (SELECT        ACCFICHEREF\r\n                                                               FROM            LG_123_01_INVOICE\r\n                                                               WHERE        LOGICALREF = INVOICE.LOGICALREF)AND ACCOUNTCODE LIKE \u0027191.00.0000%\u0027),\u0027\u0027) [MUHASEBE FİŞİ KDV TOPLAMI],\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t   \r\nISNULL(  (SELECT       SUM( DEBIT )\r\n\r\n                               FROM            LG_123_01_EMFLINE\r\n                               WHERE        ACCFICHEREF IN\r\n                                                             (SELECT        ACCFICHEREF\r\n                                                               FROM            LG_123_01_INVOICE\r\n                                                               WHERE        LOGICALREF = INVOICE.LOGICALREF)AND ACCOUNTCODE LIKE \u002719%\u0027),\u0027\u0027) [MUHASEBE FİŞİ KDV TOPLAMI_ESKI]\r\n\r\n\r\n\r\n\r\n                                                                                                      --SUBSTRING(EMU.CODE, 1, 15) [Fatura muhasebe Kodu]\r\n                                 \r\n                                   \r\nFROM         dbo.LG_123_01_STLINE AS STLINE LEFT OUTER JOIN\r\n                      dbo.LG_123_ITEMS AS ITEMS ON STLINE.STOCKREF = ITEMS.LOGICALREF LEFT OUTER JOIN\r\n                      dbo.LG_123_SRVCARD AS SRVCARD ON STLINE.STOCKREF = SRVCARD.LOGICALREF LEFT OUTER JOIN\r\n                      dbo.LG_123_CLCARD AS CLCARD ON STLINE.CLIENTREF = CLCARD.LOGICALREF LEFT OUTER JOIN\r\n                      dbo.LG_123_01_INVOICE AS INVOICE ON INVOICE.LOGICALREF = STLINE.INVOICEREF LEFT OUTER JOIN\r\n                      dbo.LG_123_PAYPLANS AS PYP ON PYP.LOGICALREF = CLCARD.PAYMENTREF LEFT JOIN\r\n                                   ---dbo.LG_123_EMCENTER AS EMC ON EMC.LOGICALREF=STLINE.CENTERREF LEFT JOIN\r\n                                   --dbo.lg_123_PROJECT AS PROJ ON PROJ.LOGICALREF=STLINE.PROJECTREF LEFT JOIN\r\n                                    LG_123_UNITSETF AS UNT ON UNT.LOGICALREF=ITEMS.UNITSETREF LEFT JOIN \r\n                                   --dbo.LG_123_01_STFICHE AS STFICHE ON STFICHE.LOGICALREF = STLINE.STFICHEREF LEFT JOIN\r\n                                   TIGER3.DBO.L_CAPIWHOUSE CAPI ON CAPI.NR=STLINE.SOURCEINDEX AND CAPI.FIRMNR=123 \r\n                                   LEFT JOIN LG_123_EMUHACC EMU ON EMU.LOGICALREF = STLINE.ACCOUNTREF\r\nWHERE     (STLINE.TRCODE IN (4,1,9))  AND (STLINE.CANCELLED = 0) AND (STLINE.LINETYPE IN (4)) ---and STLINE.BILLED=1\r\n--AND DOCODE=\u0027TEF2023000000023\u0027\r\n---(STLINE.DATE_ BETWEEN \u002720200101\u0027 AND \u002721001231\u0027)\r\n--OR (ITEMS.CODE  NOT LIKE \u0027260%\u0027AND ITEMS.CODE  NOT LIKE \u0027252%\u0027AND ITEMS.CODE  NOT LIKE \u0027254%\u0027AND ITEMS.CODE  NOT LIKE \u0027255%\u0027AND ITEMS.CODE  NOT LIKE \u0027264%\u0027)\r\n\r\n",
