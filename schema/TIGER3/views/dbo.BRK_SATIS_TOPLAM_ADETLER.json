    "name":  "BRK_SATIS_TOPLAM_ADETLER",
    "full_name":  "dbo.BRK_SATIS_TOPLAM_ADETLER",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[BRK_SATIS_TOPLAM_ADETLER] AS\r\n\r\nSELECT\r\n    I.CARDTYPE AS MalzemeTuru,\r\n    I.CODE AS MalzemeKodu,\r\n    I.NAME AS MalzemeAdi,\r\n    I.SPECODE AS MalzemeOzelKodu,\r\n    I.CYPHCODE AS MalzemeYetkiKodu,\r\n    U.CODE AS BirimSeti,\r\n    T.CODE AS BirimKodu,\r\n    SUM(CASE WHEN L.IOCODE \u003e 1 THEN L.AMOUNT ELSE 0 END) AS SatisMiktari,\r\n    SUM(CASE WHEN L.IOCODE \u003c 4 THEN L.AMOUNT ELSE 0 END) AS IadeMiktari,\r\n    SUM(CASE WHEN L.IOCODE \u003e 1 THEN L.TOTAL ELSE 0 END) AS SatisTutari\r\nFROM\r\n    LG_123_01_STLINE L\r\n    LEFT OUTER JOIN LG_123_01_STFICHE F ON L.STFICHEREF = F.LOGICALREF\r\n    LEFT OUTER JOIN LG_123_ITEMS I ON L.STOCKREF = I.LOGICALREF AND L.LINETYPE NOT IN (1,2,3,4)\r\n    LEFT OUTER JOIN LG_123_UNITSETF U ON I.UNITSETREF = U.LOGICALREF\r\n    LEFT OUTER JOIN LG_123_UNITSETL T ON U.LOGICALREF = T.UNITSETREF\r\nWHERE\r\n    I.LOGICALREF IS NOT NULL\r\n    AND F.GRPCODE = 2\r\n    AND T.LINENR = 1\r\nGROUP BY\r\n    I.CARDTYPE,\r\n    I.CODE,\r\n    I.NAME,\r\n    U.CODE,\r\n    T.CODE,\r\n    I.SPECODE,\r\n    I.CYPHCODE",
