{
    "type":  "view",
    "schema":  "dbo",
    "name":  "ONR_CARI_HESAP_EKSTRESI_ALACAKLAR_223",
    "full_name":  "dbo.ONR_CARI_HESAP_EKSTRESI_ALACAKLAR_223",
    "definition":  "\r\n\r\nCREATE     VIEW [dbo].[ONR_CARI_HESAP_EKSTRESI_ALACAKLAR_223] AS\r\n\r\nSELECT        LOGICALREF, CODE, DEFINITION_, TRADINGGRP, SIGN, BORC, ALACAK, INDATE, DUEDATE, DATEDIFF(DAY, INDATE, DUEDATE) AS VADESURESI, NOWDATE, SONODEMETARIHI, DATEDIFF(DAY, GETDATE(), SONODEMETARIHI) \r\n                         AS [ÖDEME YAPILMAMIŞ GÜN SAYISI], SONODEMETUTARI, ENUZAKTARIH, DATEDIFF(DAY, GETDATE(), ENUZAKTARIH) AS [EN UZAK GÜN], ENYAKINTARIH, DATEDIFF(DAY, GETDATE(), ENYAKINTARIH) AS [EN YAKIN GÜN], \r\n                         ORTALAMATARIH, TYP, MODULENR, TRCODE, SOURCEFREF, ISLEM_DOVIZI, ISLEM_DOVIZ_TUTARI, FIS_NO, BELGE_NO, SATIR_ACIKLAMASI\r\nFROM            (SELECT        L.LOGICALREF, C.CODE, C.DEFINITION_, CASE L.TRADINGGRP WHEN \u0027\u0027 THEN \u0027BOS\u0027 ELSE L.TRADINGGRP END AS TRADINGGRP, L.SIGN, CASE SIGN WHEN 0 THEN AMOUNT ELSE 0 END AS BORC, \r\n                                                    CASE SIGN WHEN 1 THEN AMOUNT * - 1 ELSE 0 END AS ALACAK, L.DATE_ AS INDATE, CASE MODULENR WHEN 4 THEN\r\n                                                        (SELECT        MAX(DATE_)\r\n                                                          FROM            LG_223_01_PAYTRANS\r\n                                                          WHERE        MODULENR = 4 AND FICHEREF = L.SOURCEFREF) WHEN 10 THEN\r\n                                                        (SELECT        MAX(DATE_)\r\n                                                          FROM            LG_223_01_PAYTRANS\r\n                                                          WHERE        MODULENR = 10 AND FICHEREF = L.SOURCEFREF) WHEN 5 THEN\r\n                                                        (SELECT        MAX(DATE_)\r\n                                                          FROM            LG_223_01_PAYTRANS\r\n                                                          WHERE        MODULENR = 5 AND FICHEREF = L.LOGICALREF) WHEN 7 THEN\r\n                                                        (SELECT        MAX(DATE_)\r\n                                                          FROM            LG_223_01_PAYTRANS\r\n                                                          WHERE        MODULENR = 7 AND FICHEREF = L.SOURCEFREF) WHEN 6 THEN\r\n                                                        (SELECT        MAX(DATE_)\r\n                                                          FROM            LG_223_01_PAYTRANS\r\n                                                          WHERE        MODULENR = 6 AND FICHEREF = L.SOURCEFREF) WHEN 61 THEN L.DATE_ ELSE NULL END AS DUEDATE, CONVERT(NVARCHAR, GETDATE(), 104) AS NOWDATE,\r\n                                                        (SELECT        TOP (1) DATE_\r\n                                                          FROM            dbo.LG_223_01_CLFLINE\r\n                                                          WHERE        (CLIENTREF = C.LOGICALREF) AND (TRCODE IN (2, 3, 5, 21, 63, 64, 72)) AND (CANCELLED = 0)\r\n                                                          ORDER BY DATE_ DESC) AS SONODEMETARIHI,\r\n                                                        (SELECT        TOP (1) TRNET\r\n                                                          FROM            dbo.LG_223_01_CLFLINE\r\n                                                          WHERE        (CLIENTREF = C.LOGICALREF) AND (TRCODE IN (2, 3, 5, 21, 63, 64, 72))\r\n                                                          ORDER BY DATE_ DESC) AS SONODEMETUTARI,\r\n                                                        (SELECT        TOP (1) PROCDATE\r\n                                                          FROM            dbo.LG_223_01_PAYTRANS\r\n                                                          WHERE        (MODULENR = 4) AND (PAID \u003c TOTAL) AND (CARDREF = C.LOGICALREF)\r\n                                                          ORDER BY PROCDATE) AS ENUZAKTARIH,\r\n                                                        (SELECT        TOP (1) PROCDATE\r\n                                                          FROM            dbo.LG_223_01_PAYTRANS\r\n                                                          WHERE        (MODULENR = 4) AND (PAID \u003c TOTAL) AND (CARDREF = C.LOGICALREF)\r\n                                                          ORDER BY PROCDATE DESC) AS ENYAKINTARIH,\r\n                                                        (SELECT        SUM(DATEDIFF(DAY, GETDATE(), PROCDATE)) / COUNT(*) AS Expr1\r\n                                                          FROM            dbo.LG_223_01_PAYTRANS\r\n                                                          WHERE        (MODULENR = 4) AND (PAID \u003c TOTAL) AND (CARDREF = C.LOGICALREF)) AS ORTALAMATARIH, \r\n                                                    CASE L.TRCODE WHEN 1 THEN \u0027Nakit Tahsilat\u0027 WHEN 2 THEN \u0027Nakit Ödeme\u0027 WHEN 3 THEN \u0027Borç Dekontu\u0027 WHEN 4 THEN \u0027Alacak Dekontu\u0027 WHEN 5 THEN \u0027Virman İşlemi\u0027 WHEN 6 THEN \u0027Kur Farkı İşlemi\u0027 WHEN 12\r\n                                                     THEN \u0027Özel İşlem\u0027 WHEN 14 THEN \u0027Açılış Fişi\u0027 WHEN 20 THEN \u0027Gelen Havaleler\u0027 WHEN 21 THEN \u0027Gönderilen Havaleler\u0027 WHEN 24 THEN \u0027Döviz Alış Belgesi\u0027 WHEN 25 THEN \u0027Döviz Satış Belgesi\u0027 WHEN 28 THEN \u0027Banka Alınan Hizmet Faturası\u0027\r\n                                                     WHEN 31 THEN \u0027Satınalma Faturası\u0027 WHEN 32 THEN \u0027Perakende Satış İade Faturası\u0027 WHEN 33 THEN \u0027Toptan Satış İade Faturası\u0027 WHEN 34 THEN \u0027Alınan Hizmet Faturası\u0027 WHEN 35 THEN \u0027Alınan Proforma Faturası\u0027\r\n                                                     WHEN 36 THEN \u0027Satınalma İade Faturası\u0027 WHEN 37 THEN \u0027Perakende Satış Faturası\u0027 WHEN 38 THEN \u0027Toptan Satış Faturası\u0027 WHEN 39 THEN \u0027Verilen Hizmet Faturası\u0027 WHEN 40 THEN \u0027Verilen Proforma Faturası\u0027 WHEN\r\n                                                     41 THEN \u0027Verilen Vade Farkı Faturası\u0027 WHEN 42 THEN \u0027Alınan Vade Farkı Faturası\u0027 WHEN 43 THEN \u0027Alınan Fiyat Farkı Faturası\u0027 WHEN 44 THEN \u0027Verilen Fiyat Farkı Faturası\u0027 WHEN 46 THEN \u0027Alınan Ser. Mes. Makbuzu\u0027\r\n                                                     WHEN 56 THEN \u0027Müstahsil Makbuzu\u0027 WHEN 61 THEN \u0027Çek Girişi\u0027 WHEN 62 THEN \u0027Senet Girişi\u0027 WHEN 63 THEN \u0027Çek Çıkış Cari Hesaba\u0027 WHEN 64 THEN \u0027Senet Çıkış Cari Hesaba\u0027 WHEN 70 THEN \u0027Kredi Kartı Fişi\u0027 WHEN\r\n                                                     71 THEN \u0027Kredi Kartı İade Fişi\u0027 WHEN 72 THEN \u0027Firma Kredi Kartı Fişi\u0027 WHEN 73 THEN \u0027Firma Kredi Kartı İade Fişi\u0027 WHEN 81 THEN \u0027Ödemeli Satış Siparişi\u0027 WHEN 82 THEN \u0027Ödemeli Satınalma Siparişi\u0027 ELSE \u0027\u0027 END\r\n                                                     AS TYP, L.MODULENR, L.TRCODE, L.SOURCEFREF, CASE L.TRCURR WHEN 0 THEN \u0027TL\u0027 WHEN 160 THEN \u0027TL\u0027 WHEN 1 THEN \u0027USD\u0027 WHEN 17 THEN \u0027GBP\u0027 WHEN 20 THEN \u0027EUR\u0027 ELSE \u0027Diğer\u0027 END AS ISLEM_DOVIZI,\r\n                                                     CASE L.SIGN WHEN 0 THEN ROUND(L.TRNET, 2) ELSE ROUND(- 1 * L.TRNET, 2) END AS ISLEM_DOVIZ_TUTARI, L.TRANNO AS FIS_NO, L.DOCODE AS BELGE_NO, L.LINEEXP AS SATIR_ACIKLAMASI\r\n                          FROM            dbo.LG_223_01_CLFLINE AS L INNER JOIN\r\n                                                    dbo.LG_223_CLCARD AS C ON C.LOGICALREF = L.CLIENTREF\r\n                          WHERE      PAIDINCASH=0 AND  (C.CODE LIKE \u0027120%\u0027) AND (L.CANCELLED = 0)) AS RAPOR\r\n",
    "columns":  [
