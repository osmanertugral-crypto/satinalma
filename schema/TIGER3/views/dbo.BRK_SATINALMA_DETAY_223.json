    "name":  "BRK_SATINALMA_DETAY_223",
    "full_name":  "dbo.BRK_SATINALMA_DETAY_223",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[BRK_SATINALMA_DETAY_223] AS\r\n\r\n\r\nSELECT\r\n    CONVERT(nvarchar(20), INVOICE.DATE_, 104) as Tarih,\r\n    CLCARD.CODE as [Cari Kod],\r\n    CLCARD.DEFINITION_ as [Cari Ad],\r\n    INVOICE.SERIALCODE as [Seri No],\r\n    INVOICE.FICHENO as [Fiş No],\r\n    (\r\n        COALESCE(\r\n            CASE STLINE.UINFO1\r\n                WHEN 0 THEN STLINE.AMOUNT\r\n                ELSE STLINE.AMOUNT * STLINE.UINFO2 / STLINE.UINFO1\r\n            END, \r\n            STLINE.AMOUNT / 1000\r\n        ) * (CASE WHEN INVOICE.TRCODE = 6 THEN -1 ELSE 1 END)\r\n    ) as [Miktar],\r\n    UNT.CODE as [Birim],\r\n    CASE WHEN STLINE.LINETYPE = 4 THEN SRV.CODE ELSE INV.CODE END AS [Malzeme Kod],\r\n    CASE WHEN STLINE.LINETYPE = 4 THEN SRV.DEFINITION_ ELSE INV.NAME END AS [Malzeme Ad],\r\n    CASE WHEN STLINE.LINETYPE = 4 THEN \u0027\u0027 ELSE INV.STGRPCODE END AS [Malzeme Grup],\r\n    CASE WHEN STLINE.LINETYPE = 4 THEN SRV.SPECODE ELSE INV.SPECODE END AS [Malzeme Özel Kod],\r\n    STLINE.PRICE * (CASE WHEN INVOICE.TRCODE = 6 THEN -1 ELSE 1 END) as [Birim Fiyat],\r\n    STLINE.VATMATRAH * (CASE WHEN INVOICE.TRCODE = 6 THEN -1 ELSE 1 END) as [KDV Matrah],\r\n    STLINE.VATAMNT * (CASE WHEN INVOICE.TRCODE = 6 THEN -1 ELSE 1 END) as [KDV Tutar],\r\n    STLINE.VAT as [KDV %],\r\n    CASE \r\n        WHEN INVOICE.TRCODE = 1 THEN \u0027Satınalma Faturası\u0027\r\n        WHEN INVOICE.TRCODE = 4 THEN \u0027Alınan Hizmet Faturası\u0027\r\n        WHEN INVOICE.TRCODE = 5 THEN \u0027Alınan Proforma Fatura\u0027\r\n        WHEN INVOICE.TRCODE = 6 THEN \u0027Satınalma İade Faturası\u0027\r\n        WHEN INVOICE.TRCODE = 12 THEN \u0027Alınan Vade Farkı Faturası\u0027\r\n        WHEN INVOICE.TRCODE = 13 THEN \u0027Satınalma Fiyat Farkı Faturası\u0027\r\n        WHEN INVOICE.TRCODE = 26 THEN \u0027Müstahsil Makbuzu\u0027\r\n    END as [Fatura Tipi],\r\n    CASE WHEN CLCARD.ISPERSCOMP = 1 THEN CLCARD.TCKNO ELSE CLCARD.TAXNR END AS [Cari VNO],\r\n    CLCARD.TAXOFFICE as [Cari VDaire],\r\n    EMUH.CODE as [Muhasebe Hesap Planı Kod],\r\n    EMUH.DEFINITION_ as [Muhasebe Hesap Planı Ad],\r\n    RTRIM(INVOICE.GENEXP1 + \u0027 \u0027 + INVOICE.GENEXP2 + \u0027 \u0027 + INVOICE.GENEXP3 + \u0027 \u0027 + INVOICE.GENEXP4) AS [Açıklama]\r\nFROM LG_223_01_INVOICE AS INVOICE WITH (NOLOCK)\r\nINNER JOIN LG_223_01_STLINE AS STLINE ON INVOICE.LOGICALREF = STLINE.INVOICEREF\r\nLEFT JOIN LG_223_ITEMS INV ON INV.LOGICALREF = STLINE.STOCKREF\r\nLEFT JOIN LG_223_SRVCARD SRV ON SRV.LOGICALREF = STLINE.STOCKREF\r\nINNER JOIN LG_223_CLCARD CLCARD ON CLCARD.LOGICALREF = INVOICE.CLIENTREF\r\nLEFT JOIN LG_223_EMUHACC EMUH ON EMUH.LOGICALREF = STLINE.ACCOUNTREF\r\nINNER JOIN LG_223_UNITSETL UNT ON UNT.UNITSETREF = INV.UNITSETREF AND UNT.LINENR = 1\r\nWHERE INVOICE.TRCODE IN (1, 4, 5, 6, 12, 13, 26)\r\n\r\n\r\n\r\n\r\n--SELECT\r\n--    CONVERT(nvarchar(20), INVOICE.DATE_, 104) as Tarih,\r\n--    CLCARD.CODE as [Cari Kod],\r\n--    CLCARD.DEFINITION_ as [Cari Ad],\r\n--    INVOICE.SERIALCODE as [Seri No],\r\n--    INVOICE.FICHENO as [Fiş No],\r\n--    COALESCE(\r\n--        CASE STLINE.UINFO1\r\n--            WHEN 0 THEN STLINE.AMOUNT\r\n--            ELSE STLINE.AMOUNT * STLINE.UINFO2 / STLINE.UINFO1\r\n--        END, \r\n--        STLINE.AMOUNT / 1000\r\n--    ) as [Miktar],\r\n--    UNT.CODE as [Birim],\r\n--    CASE WHEN STLINE.LINETYPE = 4 THEN SRV.CODE ELSE INV.CODE END AS [Malzeme Kod],\r\n--    CASE WHEN STLINE.LINETYPE = 4 THEN SRV.DEFINITION_ ELSE INV.NAME END AS [Malzeme Ad],\r\n--    CASE WHEN STLINE.LINETYPE = 4 THEN \u0027\u0027 ELSE INV.STGRPCODE END AS [Malzeme Grup],\r\n--    CASE WHEN STLINE.LINETYPE = 4 THEN SRV.SPECODE ELSE INV.SPECODE END AS [Malzeme Özel Kod],\r\n--    STLINE.PRICE * (CASE WHEN INVOICE.TRCODE = 6 THEN -1 ELSE 1 END) as [Birim Fiyat],\r\n--    STLINE.VATMATRAH * (CASE WHEN INVOICE.TRCODE = 6 THEN -1 ELSE 1 END) as [KDV Matrah],\r\n--    STLINE.VATAMNT * (CASE WHEN INVOICE.TRCODE = 6 THEN -1 ELSE 1 END) as [KDV Tutar],\r\n--    STLINE.VAT as [KDV %],\r\n--    CASE \r\n--        WHEN INVOICE.TRCODE = 1 THEN \u0027Satınalma Faturası\u0027\r\n--        WHEN INVOICE.TRCODE = 4 THEN \u0027Alınan Hizmet Faturası\u0027\r\n--        WHEN INVOICE.TRCODE = 5 THEN \u0027Alınan Proforma Fatura\u0027\r\n--        WHEN INVOICE.TRCODE = 6 THEN \u0027Satınalma İade Faturası\u0027\r\n--        WHEN INVOICE.TRCODE = 12 THEN \u0027Alınan Vade Farkı Faturası\u0027\r\n--        WHEN INVOICE.TRCODE = 13 THEN \u0027Satınalma Fiyat Farkı Faturası\u0027\r\n--        WHEN INVOICE.TRCODE = 26 THEN \u0027Müstahsil Makbuzu\u0027\r\n--    END as [Fatura Tipi],\r\n--    CASE WHEN CLCARD.ISPERSCOMP = 1 THEN CLCARD.TCKNO ELSE CLCARD.TAXNR END AS [Cari VNO],\r\n--    CLCARD.TAXOFFICE as [Cari VDaire],\r\n--    EMUH.CODE as [Muhasebe Hesap Planı Kod],\r\n--    EMUH.DEFINITION_ as [Muhasebe Hesap Planı Ad],\r\n--    RTRIM(INVOICE.GENEXP1 + \u0027 \u0027 + INVOICE.GENEXP2 + \u0027 \u0027 + INVOICE.GENEXP3 + \u0027 \u0027 + INVOICE.GENEXP4) AS [Açıklama]\r\n--FROM LG_223_01_INVOICE AS INVOICE WITH (NOLOCK)\r\n--INNER JOIN LG_223_01_STLINE AS STLINE ON INVOICE.LOGICALREF = STLINE.INVOICEREF\r\n--LEFT JOIN LG_223_ITEMS INV ON INV.LOGICALREF = STLINE.STOCKREF\r\n--LEFT JOIN LG_223_SRVCARD SRV ON SRV.LOGICALREF = STLINE.STOCKREF\r\n--INNER JOIN LG_223_CLCARD CLCARD ON CLCARD.LOGICALREF = INVOICE.CLIENTREF\r\n--LEFT JOIN LG_223_EMUHACC EMUH ON EMUH.LOGICALREF = STLINE.ACCOUNTREF\r\n--INNER JOIN LG_223_UNITSETL UNT ON UNT.UNITSETREF = INV.UNITSETREF AND UNT.LINENR = 1\r\n--WHERE INVOICE.TRCODE IN (1, 4, 5, 6, 12, 13, 26)\r\n\r\n",
