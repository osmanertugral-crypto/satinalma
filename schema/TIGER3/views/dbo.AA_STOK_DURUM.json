    "name":  "AA_STOK_DURUM",
    "full_name":  "dbo.AA_STOK_DURUM",
    "definition":  "/****** Script for SelectTopNRows command from SSMS  ******/\r\n\r\nCREATE VIEW AA_STOK_DURUM AS\r\n\r\nSELECT \r\n[MLZ_ID] REF\r\n,S.[CODE] STOK_KODU\r\n,S.[NAME] STOK_ADI\r\n,[MIKTAR] MIKTAR\r\n,(SELECT CODE FROM LG_001_UNITSETF WHERE LOGICALREF = S.UNITSETREF ) BIRIM\r\n,ISNULL((SELECT TOP 1 LINENET/AMOUNT FROM LG_001_01_STLINE WHERE STOCKREF=S.LOGICALREF AND LINETYPE=0 AND CANCELLED=0 AND TRCODE IN (1,50) AND TOTAL\u003c\u003e0 ORDER BY DATE_ DESC),0) ORT_FIYAT\r\n,[MIKTAR]*ISNULL((SELECT TOP 1 LINENET/AMOUNT FROM LG_001_01_STLINE WHERE STOCKREF=S.LOGICALREF AND LINETYPE=0 AND CANCELLED=0 AND TRCODE IN (1,50) AND TOTAL\u003c\u003e0 ORDER BY DATE_ DESC),0) TUTAR\r\n,[DEPO] DEPO_NO\r\n,[DEPO_ADI] DEPO_ADI\r\n,ISNULL((SELECT SUM(AMOUNT) FROM LG_001_01_STLINE AS LL\r\nWHERE TRCODE=12 \r\nAND CANCELLED=0 \r\nAND LINETYPE=0 \r\nAND STOCKREF=L.MLZ_ID \r\nAND (SELECT CODE FROM LG_001_PROJECT WHERE LOGICALREF=LL.PROJECTREF) IN (SELECT PROJE_KODU FROM AA_SATIS_SIPARIS_OZET  WHERE GERCEKLESEN_URETIM_TARIHI IS NULL)),0) PROJEYE_CIKILAN\r\n   \r\nFROM [TIGER3].[dbo].[AA_DEPO_STOK_RAPORU] AS L\r\nINNER JOIN LG_001_ITEMS AS S ON S.LOGICALREF=MLZ_ID\r\n   \r\n\r\n\r\n\r\n\r\n\r\n  --SELECT PROJECTREF FROM LG_001_01_INVOICE WHERE TRCODE IN (7,8,9)",
