{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_STOK_VE_ACIK_SIPARISLER_TOPLAMI",
    "full_name":  "dbo.AA_STOK_VE_ACIK_SIPARISLER_TOPLAMI",
    "definition":  "\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_STOK_VE_ACIK_SIPARISLER_TOPLAMI] AS \r\n\r\n SELECT * , (FIZIKI_TOPLAM_STOK+MONTAJ_HATTI_STOK ) AS FABRIKA_STOK,ABS(FIZIKI_TOPLAM_STOK*BR_FIYAT) STOK_TUTARI\r\n \r\n FROM (\r\n SELECT LOGICALREF,\r\n CODE, NAME ,SPECODE AS OZEL_KODU,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=0),0) AS DEPO_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=1),0) AS SHOWROOM_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=2),0) AS GEBZE_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=3),0) AS SERVIS_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=4),0) AS MOBILYA_ON_IMALAT,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=5),0) AS MONTAJ_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=6),0) AS POLYESTER_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=7),0) AS ELEKTRIK_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=8),0) AS DOSEME_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=9),0) AS TESISAT_STOK,\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF AND DEPO=10),0) AS ENKA_STOK,\r\n\r\n ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=MLZ.LOGICALREF ),0) AS FIZIKI_TOPLAM_STOK,\r\n\r\n ISNULL((SELECT SUM(AMOUNT) FROM LG_001_01_STLINE WHERE TRCODE=12 AND STOCKREF=MLZ.LOGICALREF AND \r\n PROJECTREF IN (sELECT PROJECTREF FROM LG_001_01_ORFICHE WHERE TRCODE=1 AND CYPHCODE\u003c\u003e\u0027KAPALI\u0027)),0) AS MONTAJ_HATTI_STOK\r\n ,cast(CASE WHEN (sELECT TOP 1 PRICE FROM LG_001_01_STLINE WHERE STOCKREF=MLZ.LOGICALREF AND  PRICE\u003e0 AND TRCODE=1 ORDER BY DATE_ DESC) IS NULL THEN \r\n\t(SELECT TOP 1 PRICE FROM LG_001_PRCLIST WHERE CARDREF=MLZ.LOGICALREF ORDER BY BEGDATE DESC) ELSE \r\n\t(sELECT TOP 1 PRICE FROM LG_001_01_STLINE WHERE STOCKREF=MLZ.LOGICALREF AND  PRICE\u003e0 AND TRCODE=1 ORDER BY DATE_ DESC) END as decimal(18,2)) AS BR_FIYAT\r\n FROM LG_001_ITEMS AS  MLZ WHERE MLZ.ACTIVE=0\r\n ) AS RAPOR\r\n\r\n\r\n",
