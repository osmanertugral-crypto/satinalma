    "name":  "LV_523_01_BNFLINE",
    "full_name":  "dbo.LV_523_01_BNFLINE",
    "definition":  "CREATE VIEW [dbo].[LV_523_01_BNFLINE] AS\nSELECT\n        LGMAIN.LOGICALREF, LGMAIN.CLIENTREF, LGMAIN.MODULENR, LGMAIN.TRCODE, LGMAIN.BANKPROCTYPE, LGMAIN.LINENR, BANKACC.CODE, BANKACC.DEFINITION_ DEFINITION_, LGMAIN.LINEEXP, LGMAIN.DATE_,\n  CASE WHEN LGMAIN.SIGN=0 THEN LGMAIN.AMOUNT ELSE 0 END AS DEBIT,\n  CASE WHEN LGMAIN.SIGN=1 THEN LGMAIN.AMOUNT ELSE 0 END AS CREDIT,\n  CASE WHEN LGMAIN.MODULENR=7 AND LGMAIN.TRCODE IN (16, 17) THEN 4 ELSE 0 END AS LINETYPE\nFROM\n     LG_523_01_BNFLINE LGMAIN\n  LEFT OUTER JOIN LG_523_BNCARD BANK WITH(NOLOCK) ON LGMAIN.BANKREF = BANK.LOGICALREF\n  LEFT OUTER JOIN LG_523_BANKACC BANKACC WITH(NOLOCK) ON LGMAIN.BNACCREF = BANKACC.LOGICALREF",
