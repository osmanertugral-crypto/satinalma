    "full_name":  "dbo.LV_223_01_CLTOTFIL",
    "definition":  "CREATE VIEW [DBO].[LV_223_01_CLTOTFIL]\nAS\nSELECT 1 AS LOGICALREF\n ,CARDREF AS CARDREF\n ,1 AS TOTTYP\n ,MONTH_ AS MONTH_\n ,DEBIT AS DEBIT\n ,CREDIT AS CREDIT\n  ,YEAR_ AS YEAR_\n ,BRANCH AS BRANCH\n ,DEPARTMENT AS DEPARTMENT\nFROM LV_223_01_CLTOTFILV1 WITH(NOEXPAND,NOLOCK)\nUNION ALL\nSELECT 1 AS LOGICALREF\n ,CARDREF AS CARDREF\n ,2 AS TOTTYP\n ,MONTH_ AS MONTH_\n ,DEBIT_RC AS DEBIT\n ,CREDIT_RC AS CREDIT\n  ,YEAR_ AS YEAR_\n ,BRANCH AS BRANCH\n ,DEPARTMENT AS DEPARTMENT\nFROM LV_223_01_CLTOTFILV1 WITH(NOEXPAND,NOLOCK)\nWHERE DEBIT_RC \u003c\u003e0 OR  CREDIT_RC\u003c\u003e0",
