    "name":  "LV_001_01_STINVTOT_V3",
    "full_name":  "dbo.LV_001_01_STINVTOT_V3",
    "definition":  "\nCREATE VIEW [DBO].LV_001_01_STINVTOT_V3 WITH SCHEMABINDING\nAS\n  SELECT STOCKREF AS STOCKREF,\n         SOURCEINDEX AS INVENNO,\n         DATE_ AS DATE_,\n         SUM(ISNULL(DBO.LG_001_01_GETORDTRANSCOEF(TRCODE,\n                                        DORESERVE,\n                                        CLOSED,\n                                        AMOUNT,\n                                        RESERVEAMOUNT,\n                                        SHIPPEDAMOUNT,\n                                        DATE_,\n                                        RESERVEDATE,\n                                        1)\n                    * (DBO.LG_001_01_GETUNITCOEF(UINFO1, UINFO2)),\n                    0))\n            AS RESERVED,\n         SUM(ISNULL(DBO.LG_001_01_GETORDTRANSCOEF(TRCODE,\n                                        DORESERVE,\n                                        CLOSED,\n                                        AMOUNT,\n                                        RESERVEAMOUNT,\n                                        SHIPPEDAMOUNT,\n                                        DATE_,\n                                        RESERVEDATE,\n                                        2)\n                    * (DBO.LG_001_01_GETUNITCOEF(UINFO1, UINFO2)),\n                    0))\n            AS ACTPORDER,\n         SUM(ISNULL(DBO.LG_001_01_GETORDTRANSCOEF(TRCODE,\n                                        DORESERVE,\n                                        CLOSED,\n                                        AMOUNT,\n                                        RESERVEAMOUNT,\n                                        SHIPPEDAMOUNT,\n                                        DATE_,\n                                        RESERVEDATE,\n                                        3)\n                    * (DBO.LG_001_01_GETUNITCOEF(UINFO1, UINFO2)),\n                    0))\n            AS ACTSORDER,\n         VARIANTREF AS VARIANTREF,\n   STATUS AS STATUS,\n         (CASE WHEN LINETYPE IN (4,11) THEN 1 ELSE 0 END) AS TYP,\n         COUNT_BIG(*) AS CNT\n    FROM [DBO].LG_001_01_ORFLINE\n   WHERE (STOCKREF \u003c\u003e 0) AND (LINETYPE NOT IN (2, 3, 7))\n   AND NOT (STATUS IN (1,2) AND DORESERVE=0)\nGROUP BY STOCKREF,\n         DATE_,\n         SOURCEINDEX,\n         VARIANTREF,\n   STATUS,\n         (CASE WHEN LINETYPE IN (4,11) THEN 1 ELSE 0 END)\n",
