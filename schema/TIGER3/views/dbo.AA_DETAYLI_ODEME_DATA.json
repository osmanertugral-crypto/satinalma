{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_DETAYLI_ODEME_DATA",
    "full_name":  "dbo.AA_DETAYLI_ODEME_DATA",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[AA_DETAYLI_ODEME_DATA] AS \r\nselect *,\r\nCASE WHEN GUN\u003e=0 THEN ID_TUTAR ELSE 0 END AS VADESI_GELMEYEN,\r\nCASE WHEN GUN\u003c0 THEN ID_TUTAR ELSE 0 END AS VADESI_GELEN\r\nfrom (\r\n\r\nselect FAT.LOGICALREF FAT_ID, CAR.LOGICALREF AS CAR_ID,\r\nCAR.CODE + \u0027 / \u0027 +CAR.DEFINITION_ AS UNVAN,\r\nisnull(DATEADD(DAY, (\r\nSELECT CASE WHEN CODE=\u0027\u0027 THEN 0\r\nWHEN LEFT(CODE,4)=\u0027PESI\u0027  THEN 0\r\nWHEN CODE IS NULL THEN 0\r\nWHEN CODE=\u00270\u0027 THEN 0\r\nWHEN LEFT(CODE,4)=\u00271030\u0027  THEN 0\r\n  WHEN LEFT(CODE,4)=\u00277419\u0027  THEN 0\r\n   ELSE cast(CODE as int) END AS VADE\r\nFROM LG_001_PAYPLANS  WITH (NOLOCK) WHERE LOGICALREF=FAT.PAYDEFREF),FAT.DATE_),FAT.DATE_) \u0027Ödeme_Vade\u0027,\r\nFAT.DATE_ AS ISLEM_TARIHI,\r\nFAT.FICHENO AS BELGE_NO,\r\n\r\nCASE WHEN FAT.TRCODE=1 THEN \u0027Satınalma Faturası\u0027\r\nelse \u0027Alınan Hizmet Faturası\u0027 end as ISLEM_TURU,\r\nDATEDIFF(DAY,(isnull(DATEADD(DAY, (\r\nSELECT CASE WHEN CODE=\u0027\u0027 THEN 0\r\nWHEN LEFT(CODE,4)=\u0027PESI\u0027  THEN 0\r\nWHEN CODE IS NULL THEN 0\r\nWHEN CODE=\u00270\u0027 THEN 0\r\nWHEN LEFT(CODE,4)=\u00271030\u0027  THEN 0\r\n  WHEN LEFT(CODE,4)=\u00277419\u0027  THEN 0\r\n   ELSE cast(CODE as int) END AS VADE\r\nFROM LG_001_PAYPLANS  WITH (NOLOCK) WHERE LOGICALREF=FAT.PAYDEFREF),FAT.DATE_),FAT.DATE_)),GETDATE()) AS GUN\r\n\r\n\r\n\r\n, FAT.NETTOTAL AS TL_TUTAR\r\n,ISNULL((select TOP 1 CURCODE from L_CURRENCYLIST where CURTYPE=FAT.TRCURR),\u0027TL\u0027) as ISLEM_DOVIZ\r\n,FAT.TRRATE AS ID_KUR\r\n,FAT.TRNET AS ID_TUTAR\r\n\r\n--CASE WHEN ODM.TRCURR=0 THEN TOTAL ELSE ISNULL((NULLIF(ODM.TOTAL,0)/NULLIF(ODM.TRRATE,0)),0) END AS KAPATMA\r\n\r\n--, REPORTRATE AS RD_KUR_USD\r\n--, REPORTNET AS RD_TUTAR_USD\r\n from LG_001_01_INVOICE FAT WITH (NOLOCK)\r\nINNER JOIN LG_001_CLCARD CAR WITH (NOLOCK) ON FAT.CLIENTREF=CAR.LOGICALREF \r\n\r\nWHERE FAT.TRCODE IN (1,4)  AND STATUS\u003c\u003e1 AND YEAR(FAT.DATE_)\u003e2021 AND CAR.CODE LIKE \u0027320.01.%\u0027\r\n\r\n) AS RAPOR\r\n",
