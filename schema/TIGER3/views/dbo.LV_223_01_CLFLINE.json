    "full_name":  "dbo.LV_223_01_CLFLINE",
    "definition":  "CREATE VIEW [dbo].[LV_223_01_CLFLINE] AS\nSELECT\n      LGMAIN.LOGICALREF, LGMAIN.CLIENTREF, LGMAIN.LINENR, CLIENT.CODE, CLIENT.DEFINITION_ LINEEXP, LGMAIN.SOURCEFREF, LGMAIN.DATE_, LGMAIN.TRANNO, LGMAIN.TRCODE, LGMAIN.MODULENR, LGMAIN.FTIME,\n      CASE WHEN  LGMAIN.SIGN=0 THEN LGMAIN.AMOUNT ELSE 0 END DEBIT,\n      CASE WHEN  LGMAIN.SIGN=1 THEN LGMAIN.AMOUNT ELSE 0 END CREDIT\nFROM\n     LG_223_01_CLFLINE LGMAIN WITH(NOLOCK)\n  LEFT OUTER JOIN LG_223_CLCARD CLIENT WITH(NOLOCK) ON LGMAIN.CLIENTREF = CLIENT.LOGICALREF",
