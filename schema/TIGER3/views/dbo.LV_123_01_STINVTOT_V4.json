    "name":  "LV_123_01_STINVTOT_V4",
    "full_name":  "dbo.LV_123_01_STINVTOT_V4",
    "definition":  "\nCREATE VIEW [DBO].LV_123_01_STINVTOT_V4 WITH SCHEMABINDING\nAS\n  SELECT ITEMREF AS STOCKREF,\n         SOURCEINDEX AS INVENNO,\n         DATE_ AS DATE_,\n         DORDGODATE AS DORDGODATE,\n         DORDRETURNDATE AS DORDRETURNDATE,\n         SUM(ISNULL(SHIPAMOUNT * (DBO.LG_123_01_GETUNITCOEF(UINFO1, UINFO2)), 0))\n            AS DISTRESERVED1,\n         SUM(0)  AS ONVEHICLE1,\n         SUM(ISNULL(-SHIPAMOUNT * (DBO.LG_123_01_GETUNITCOEF(UINFO1, UINFO2)), 0))\n            AS DISTRESERVED2,\n         SUM(ISNULL(SHIPAMOUNT * (DBO.LG_123_01_GETUNITCOEF(UINFO1, UINFO2)), 0))\n            AS ONVEHICLE2,\n         SUM(0) AS DISTRESERVED3,\n         SUM(ISNULL(-REMAMOUNT * (DBO.LG_123_01_GETUNITCOEF(UINFO1, UINFO2)), 0))\n            AS ONVEHICLE3,\n         VARIANTREF AS VARIANTREF,\n         (CASE WHEN LINETYPE IN (4,11) THEN 1 ELSE 0 END) AS TYP,\n         COUNT_BIG(*) AS CNT\n    FROM [DBO].LG_123_01_DISTORDLINE\n   WHERE ITEMREF \u003c\u003e 0 AND LINETYPE NOT IN (2, 3, 7)\nGROUP BY ITEMREF,\n         DATE_,\n         DORDGODATE,\n         DORDRETURNDATE,\n         SOURCEINDEX,\n         VARIANTREF,\n         (CASE WHEN LINETYPE IN (4,11) THEN 1 ELSE 0 END)\n",
