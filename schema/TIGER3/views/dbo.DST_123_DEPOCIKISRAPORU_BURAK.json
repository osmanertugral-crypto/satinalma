{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DST_123_DEPOCIKISRAPORU_BURAK",
    "full_name":  "dbo.DST_123_DEPOCIKISRAPORU_BURAK",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[DST_123_DEPOCIKISRAPORU_BURAK] AS\r\n\r\n\r\n\r\nSELECT\r\n\r\nITM.CODE [MALZ. KODU]\r\n,ITM.NAME [MALZ. ADI]\r\n,STL.AMOUNT [MIKTAR]\r\n,UNL.NAME [BIRIM],\r\nGNT.ONHAND [ELDE KALAN 2 NOLU AMBAR],\r\nGNT1.ONHAND [ELDE KALAN 5 NOLU AMBAR],\r\nGNT2.ONHAND [ELDE KALAN 11 NOLU AMBAR],\r\n\r\nCASE WHEN STL.IOCODE IN (1,2) THEN \u0027GIRIS\u0027 WHEN STL.IOCODE IN (3,4) THEN \u0027CIKIS\u0027 ELSE \u0027DIGER\u0027 END [HAREKET TURU]\r\n,CASE STL.TRCODE \r\nWHEN 1 THEN \u0027SATIN ALMA IRS\u0027\r\nWHEN 2 THEN\u0027PAR. SATIS IADE IRS\u0027\r\nWHEN 3 THEN\u0027TOPTAN SATIS IADE IRS\u0027\r\nWHEN 4 THEN\u0027KONS. CIKIS IADE \u0027\r\nWHEN 5 THEN\u0027KONS. GIRIS\u0027\r\nWHEN 6 THEN\u0027SATIN ALMA IADE IRS\u0027\r\nWHEN 7 THEN\u0027PAR. SATIS IRS\u0027\r\nWHEN 8 THEN\u0027TOPTAN SATIS IRS\u0027\r\nWHEN 9 THEN\u0027KONS CIKIS IRS\u0027\r\nWHEN 10 THEN\u0027KONS. GIRIS IADE\u0027\r\nWHEN 11 THEN\u0027FIRE FISI\u0027\r\nWHEN 12 THEN\u0027SARF FISI\u0027\r\nWHEN 13 THEN\u0027URT. GIRIS FISI\u0027\r\nWHEN 14 THEN\u0027DEVIR FISI\u0027\r\nWHEN 25 THEN\u0027AMBAR FISI\u0027\r\nWHEN 50 THEN\u0027SAYIM FAZ. FISI\u0027\r\nWHEN 51 THEN\u0027SAYIM EKS. FISI\u0027\r\nEND [FIS TURU] \r\n\r\n--EMC.CODE MM_KODU,\r\n--EMC.SPECODE MARKA,\r\n--EMC.CYPHCODE MODEL,\r\n--EMC.DEFINITION_ MM_ADI\r\n,STF.FICHENO [FIS NO]\r\n,month(STF.DATE_) [AY]\r\n--,(select max(S1.DATE_) from LG_123_01_STLINE S1 where s1.LOGICALREF=STL.LOGICALREF ) XX\r\n,STF.DATE_ [TARIH]\r\n\r\n\r\n--,ROUND(STL.PRICE,3) [BIRIM FIYAT]\r\n--,ROUND(STL.TOTAL,3) [TUTAR]\r\n---,CASE STL.AMOUNT WHEN 0 THEN 0 ELSE STL.AMOUNT * (STL.UINFO2/STL.UINFO1) END [MIKTAR ANA BIRIM]\r\n---,[KALAN ANA BIRIM] = (SELECT ROUND(SUM(CASE STL1.AMOUNT WHEN 0 THEN 0 ELSE CASE WHEN STL1.IOCODE IN (1,2) THEN STL1.AMOUNT * (STL1.UINFO2/STL1.UINFO1) WHEN  STL1.IOCODE IN (3,4) THEN (STL1.AMOUNT * (STL1.UINFO2/STL1.UINFO1)) * -1 END END),3) FROM LG_123_01_STLINE STL1 WHERE STL1.LINETYPE = 0 AND STL1.CANCELLED = 0 AND ((STL1.DATE_ \u003c STL.DATE_) OR (STL1.DATE_ = STL.DATE_ AND STL1.FTIME \u003c STL.FTIME) OR (STL1.DATE_ = STL.DATE_ AND STL1.FTIME = STL.FTIME AND STL1.LOGICALREF \u003c= STL.LOGICALREF)) AND STL1.STOCKREF = STL.STOCKREF)\r\nFROM LG_123_01_STLINE STL \r\n\r\nLEFT JOIN LG_123_ITEMS ITM ON ITM.LOGICALREF = STL.STOCKREF\r\nLEFT JOIN LG_123_01_STFICHE STF ON STF.LOGICALREF = STL.STFICHEREF\r\n--LEFT JOIN LV_123_01_STINVTOT INVTOT ON INVTOT.STOCKREF=ITM.LOGICALREF AND INVTOT.INVENNO=2\r\nLEFT JOIN LV_123_01_GNTOTST GNT ON GNT.STOCKREF=ITM.LOGICALREF AND GNT.INVENNO=2\r\nLEFT JOIN LV_123_01_GNTOTST GNT1 ON GNT1.STOCKREF=ITM.LOGICALREF AND GNT1.INVENNO=5\r\nLEFT JOIN LV_123_01_GNTOTST GNT2 ON GNT2.STOCKREF=ITM.LOGICALREF AND GNT2.INVENNO=11\r\n\r\nLEFT JOIN LG_123_UNITSETL UNL ON UNL.LOGICALREF = STL.UOMREF\r\n--LEFT JOIN LG_123_EMUHACC EMU ON EMU.LOGICALREF=STL.ACCOUNTREF\r\n--LEFT JOIN LG_123_EMCENTER EMC ON EMC.LOGICALREF=STL.CENTERREF\r\nWHERE STL.LINETYPE = 0 AND STL.CANCELLED = 0 \r\nAND  STL.DESTINDEX IN (5,11) AND STL.SOURCEINDEX IN(2) AND STL.IOCODE IN (3,4)\r\n---AND ITM.CODE=\u0027HRXX0099H421\u0027\r\n--SELECT * FROM LG_123_ITEMS WHERE CODE=\u0027ELSF0099H083\u0027--AND ITM.CODE=\u0027ELSF0099H083\u0027 \r\n\r\n--AND STL.TRCODE\u003c\u003e25---AND ITM.CODE=\u00272021X326\u0027\r\n--ORDER BY STF.DATE_ ASC\r\n",
