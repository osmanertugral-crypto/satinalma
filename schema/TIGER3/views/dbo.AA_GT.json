    "name":  "AA_GT",
    "full_name":  "dbo.AA_GT",
    "definition":  "CREATE VIEW AA_GT AS\r\n\r\nselect \r\nH.CODE\r\n,H.DEFINITION_\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =1),0) \u002701_OCAK\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =2),0) \u002702_SUBAT\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =3),0) \u002703_MART\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =4),0) \u002704_NISAN\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =5),0) \u002705_MAYIS\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =6),0) \u002706_HAZIRAN\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =7),0) \u002707_TEMMUZ\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =8),0) \u002708_AGUSTOS\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =9),0) \u002709_EYLUL\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =10),0) \u002710_EKIM\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =11),0) \u002711_KASIM\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE KEBIRCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =12),0) \u002712_ARALIK\u0027\r\n\r\nfrom LG_001_EMUHACC  AS H\r\n\r\n\r\nWHERE (H.CODE LIKE\u00276%\u0027 OR H.CODE LIKE\u00277%\u0027)\r\nAND LEN(H.CODE)=3\r\nAND H.CODE IN (SELECT KEBIRCODE FROM LG_001_01_EMFLINE)",
