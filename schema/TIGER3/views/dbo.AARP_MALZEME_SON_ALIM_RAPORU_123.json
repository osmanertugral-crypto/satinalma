{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AARP_MALZEME_SON_ALIM_RAPORU_123",
    "full_name":  "dbo.AARP_MALZEME_SON_ALIM_RAPORU_123",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[AARP_MALZEME_SON_ALIM_RAPORU_123] AS \r\nSELECT LOGICALREF\r\n, CODE AS KOD\r\n, NAME AS TANIM\r\n,ISNULL(STGRPCODE,\u0027\u0027) AS GRUP_KOD\r\n,(SELECT NAME  FROM LG_123_UNITSETF WHERE LOGICALREF IN (SELECT UNITSETREF FROM LG_123_UNITSETL WHERE LOGICALREF IN (select UNITLINEREF from LG_123_ITMUNITA WHERE ITEMREF=MLZ.LOGICALREF AND LINENR=1))) \u0027ANA BİRİMİ\u0027\r\n\r\n, ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU_123_GEBZE WHERE MLZ_ID=LOGICALREF),0) AS GEBZE_STOK\r\n, ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU_123_ETICARET WHERE MLZ_ID=LOGICALREF),0) AS ETICARET_STOK\r\n\r\n,ISNULL((SELECT CASE  WHEN (SUM(AMOUNT - SHIPPEDAMOUNT)\u003c0) THEN 0 ELSE SUM(AMOUNT - SHIPPEDAMOUNT) END FROM LG_123_01_ORFLINE WHERE TRCODE = 2 AND STOCKREF IN (MLZ.LOGICALREF) GROUP BY STOCKREF),0)\u0027AÇIK SATINALMA SİPARİŞİ\u0027\r\n\r\n, ISNULL(CAST(ISNULL((SELECT TOP 1 (NULLIF((STLINE.LINENET+STLINE.DIFFPRICE),0)/NULLIF(STLINE.AMOUNT,0))  \r\nFROM LG_123_01_STLINE STLINE WHERE STLINE.TRCODE IN (1,14) AND STLINE.STOCKREF= MLZ.LOGICALREF ORDER BY STLINE.DATE_ + dbo.LG_INTTOTIME(STLINE.FTIME)  DESC),\r\n(SELECT TOP 1 ORFLINE.PRICE  \r\nFROM LG_123_01_ORFLINE ORFLINE WHERE ORFLINE.TRCODE=2 AND ORFLINE.STOCKREF= MLZ.LOGICALREF ORDER BY ORFLINE.DATE_ + dbo.LG_INTTOTIME(ORFLINE.TIME_)  DESC)\r\n\r\n)AS DECIMAL(18,2)),0) SON_ALIM_TL\r\n\r\n, (SELECT TOP 1 STLINE.DATE_  FROM LG_123_01_STLINE STLINE WITH (NOLOCK) WHERE STLINE.TRCODE IN (1,14) AND STLINE.STOCKREF= MLZ.LOGICALREF ORDER BY STLINE.DATE_ DESC) SON_ALIM_TARIHI\r\n\r\n,MLZ.CYPHCODE \u0027YETKİ KODU\u0027\r\n,CASE WHEN MLZ.CARDTYPE = 1 THEN \u0027Ticari Mal\u0027 WHEN MLZ.CARDTYPE = 10 THEN \u0027Hammadde\u0027 WHEN MLZ.CARDTYPE = 11 THEN \u0027Yarı Mamül\u0027 WHEN MLZ.CARDTYPE = 12 THEN \u0027Mamül\u0027 ELSE \u0027Malzeme\u0027 END AS TURU\r\n,MLZ.CAPIBLOCK_CREADEDDATE \u0027MALZEME_KARTI_ACILIS_TARIHI\u0027\r\n\r\n,CASE WHEN MLZ.CARDTYPE = 12 THEN dbo.KS_RecipeCostFunc ( MLZ.CODE ) \r\n\t  WHEN MLZ.CARDTYPE = 11 THEN dbo.KS_RecipeCostSubFunc ( MLZ.LOGICALREF, 1) \r\n\t  ELSE\r\n(CAST(CAST(\r\n\t\tISNULL\r\n\t\t(CASE \r\n\t\t\tWHEN (SELECT TOP 1 (LINENET+DIFFPRICE)/NULLIF(AMOUNT,0) FROM LG_123_01_STLINE WITH (NOLOCK) WHERE STOCKREF=MLZ.LOGICALREF AND  PRICE\u003e0 AND TRCODE IN (1,14) ORDER BY DATE_ + dbo.LG_INTTOTIME(FTIME)  DESC) IS NULL \r\n\t\t\t\tTHEN (SELECT TOP 1 PRICE FROM LG_123_PRCLIST WITH (NOLOCK) WHERE CARDREF=MLZ.LOGICALREF ORDER BY BEGDATE DESC )\t\r\n\t\t\tELSE (SELECT TOP 1 (LINENET+DIFFPRICE)/NULLIF(AMOUNT,0) FROM LG_123_01_STLINE WITH (NOLOCK) WHERE STOCKREF=MLZ.LOGICALREF AND  PRICE\u003e0 AND TRCODE IN  (1,14) ORDER BY DATE_ + dbo.LG_INTTOTIME(FTIME)  DESC) \t\r\n\t\tEND ,0) AS  DECIMAL(18,2)) AS float)) END BIRIM_FIYAT\r\n\r\nFROM LG_123_ITEMS MLZ WITH (NOLOCK) WHERE ACTIVE=0 \r\n\r\n---ORDER BY CODE\r\n",
