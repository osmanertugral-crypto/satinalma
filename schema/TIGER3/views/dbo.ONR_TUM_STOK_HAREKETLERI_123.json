{
    "type":  "view",
    "schema":  "dbo",
    "name":  "ONR_TUM_STOK_HAREKETLERI_123",
    "full_name":  "dbo.ONR_TUM_STOK_HAREKETLERI_123",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n--4706\r\nCREATE       VIEW [dbo].[ONR_TUM_STOK_HAREKETLERI_123] AS \r\nSELECT \r\nISNULL((SELECT P.PROJE_KODU FROM EVIRA..PROJE P WHERE P.PROJE_REF=SF.PROJE_REF),\u0027PROJESIZ\u0027) PROJE_KODU,\r\nISNULL((SELECT P.PROJE_ADI FROM EVIRA..PROJE P WHERE P.PROJE_REF=SF.PROJE_REF),\u0027PROJESIZ\u0027) PROJE_ADI,\r\n\tSF.TARIH,\r\n\tSF.FIS_NO ,\r\n\tSF.BELGE_NO,\r\n\tAMBAR_KODU=(SELECT AMBAR_KODU+\u0027,\u0027+AMBAR_ADI FROM EVIRA..AMBAR WHERE AMBAR_KODU=SH.AMBAR_KODU),\r\n\tHEDEF_AMBAR=(SELECT AMBAR_KODU+\u0027,\u0027+AMBAR_ADI FROM EVIRA..AMBAR WHERE AMBAR_KODU=SH.HEDEF_AMBAR),\r\n\tFIS_TURU =(SELECT FIS_ADI FROM EVIRA..FISTURLERI WHERE FIS_TURU=SF.FIS_TURU),\r\n\tISLEMTIPI= CASE SF.FIS_GCD WHEN \u00270\u0027 THEN \u0027GIRIS\u0027 WHEN \u00271\u0027 THEN \u0027TUKETIM\u0027 WHEN \u00272\u0027 THEN \u0027TRANSFER\u0027 ELSE \u0027YOK\u0027 END,\r\n\t FIRMA=\r\n\t\r\n\tCASE WHEN (SELECT FIRMA_UNVANI FROM EVIRA..FIRMAKARTI WHERE FIRMA_REF=SH.FIRMA_REF) IS NULL\r\n\tTHEN\r\n\t(SELECT FIRMA_UNVANI FROM EVIRA..SIPARISFISLERI SF , EVIRA..FIRMAKARTI FK WHERE SF.FIRMA_REF=FK.FIRMA_REF AND SF.SB_REF=SH.SB_REF)\r\n\tELSE\r\n\t(SELECT FIRMA_UNVANI FROM EVIRA..FIRMAKARTI WHERE FIRMA_REF=SH.FIRMA_REF)\r\n\tEND,\r\n\tSK.STOK_KODU,\r\n\tSK.STOK_ADI,\r\n\tSK.STOK_TIPI,\r\nSUM(MIKTAR) MIKTAR,\r\n\tBIRIM=(SELECT BIRIM FROM EVIRA..STOKBIRIM WHERE BIRIM_REF=ANABIRIM_REF)\t,\r\n\tKULLANICI=(SELECT KULLANICI_ADI +\u0027 - \u0027 + ADI_SOYADI FROM EVIRA..KULLANICI WHERE KULLANICI_REF=SF.KULLANICI_REF)\r\n\t\r\n\r\n\t----------------------------------\r\n\r\n\r\n\r\n\r\nFROM \r\n\tEVIRA..STOKKARTI SK ,\r\n\tEVIRA..STOKFISLERI SF,\r\n\tEVIRA..STOKHAREKETLERI SH\r\nWHERE \r\n\tSK.STOK_REF=SH.STOK_REF\r\n\tAND SH.FB_REF=SF.FB_REF\r\n\tAND SH.FIS_TURU IN (25,01,12,13,300,302,303,304,305,306,307,308,309,900,903,904)\r\n\t--AND SH.FIS_TURU NOT IN (100,51,50)\r\n\t--AND SF.TARIH\u003e=@P_TARIH1 AND SF.TARIH\u003c=@P_TARIH2\r\n\t--AND SF.FIS_GCD=2 AND SK.STOK_ADI=\u0027POLYESTER\u0027\r\n\t\r\nGROUP BY \r\n\tSK.STOK_KODU,STOK_ADI,TARIH,FIS_NO,SH.AMBAR_KODU,SH.HEDEF_AMBAR,SH.FIS_TURU,SF.FIS_GCD,SH.FIRMA_REF,SH.ANABIRIM_REF,SF.KULLANICI_REF,SH.TAKIP_NO\r\n\t,SH.STOK_REF,SH.PAKET,SH.HEDEF_PAKET,SF.SAAT,SF.SB_REF,SF.FIS_TURU,SH.SB_REF\r\n\t,SF.PROJE_REF,SF.BELGE_NO,SK.STOK_REF,SK.STOK_TIPI\r\n\r\n",
