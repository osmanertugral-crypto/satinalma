    "name":  "LV_099_01_GNTOTVRNT",
    "full_name":  "dbo.LV_099_01_GNTOTVRNT",
    "definition":  "CREATE VIEW [dbo].[LV_099_01_GNTOTVRNT] AS\nSELECT\n      0 AS LOGICALREF, GNTOTVRNT.STOCKREF, GNTOTVRNT.INVENNO, SUM(GNTOTVRNT.PLNPRODIN) AS PLNPRODIN,\n      SUM(GNTOTVRNT.PLNPRODOUT) AS PLNPRODOUT, SUM(GNTOTVRNT.PLNOTHERIN) AS PLNOTHERIN, SUM(GNTOTVRNT.PLNOTHEROUT) AS PLNOTHEROUT,\n      SUM(GNTOTVRNT.PLNWHOUSEIN) AS PLNWHOUSEIN, SUM(GNTOTVRNT.PLNWHOUSEOUT) AS PLNWHOUSEOUT, SUM(GNTOTVRNT.TEMPIN) AS TEMPIN,\n      SUM(GNTOTVRNT.TEMPOUT) AS TEMPOUT, SUM(GNTOTVRNT.RESERVED) AS RESERVED, SUM(GNTOTVRNT.ACTPORDER) AS ACTPORDER,\n      SUM(GNTOTVRNT.RECEIVED) AS RECEIVED, SUM(GNTOTVRNT.ACTPRODIN) AS ACTPRODIN, SUM(GNTOTVRNT.ACTOTHERIN) AS ACTOTHERIN, SUM(GNTOTVRNT.ACTSORDER) AS ACTSORDER,\n      SUM(GNTOTVRNT.SHIPPED) AS SHIPPED, SUM(GNTOTVRNT.ACTWASTE) AS ACTWASTE, SUM(GNTOTVRNT.ACTOTHEROUT) AS ACTOTHEROUT, SUM(GNTOTVRNT.TRANSFERRED) AS TRANSFERRED,\n      SUM((GNTOTVRNT.TRANSFERRED+GNTOTVRNT.PURAMNT)*GNTOTVRNT.AVGVALUE)/\n      CASE WHEN SUM(GNTOTVRNT.TRANSFERRED+GNTOTVRNT.PURAMNT) \u003e0 THEN SUM(GNTOTVRNT.TRANSFERRED+GNTOTVRNT.PURAMNT) ELSE 1 END AS AVGVALUE,\n      SUM((GNTOTVRNT.TRANSFERRED+GNTOTVRNT.PURAMNT)*GNTOTVRNT.AVGCURRVAL)/\n      CASE WHEN SUM(GNTOTVRNT.TRANSFERRED+GNTOTVRNT.PURAMNT) \u003e0 THEN SUM(GNTOTVRNT.TRANSFERRED+GNTOTVRNT.PURAMNT) ELSE 1 END AS AVGCURRVAL,\n      SUM(GNTOTVRNT.PURAMNT) AS PURAMNT, SUM(GNTOTVRNT.PURCASH) AS PURCASH,\n      SUM(GNTOTVRNT.PURCURR) AS PURCURR, SUM(GNTOTVRNT.SALAMNT) AS SALAMNT, SUM(GNTOTVRNT.SALCASH) AS SALCASH, SUM(GNTOTVRNT.SALCURR) AS SALCURR,\n      MAX(GNTOTVRNT.LASTTRDATE) AS LASTTRDATE, SUM(GNTOTVRNT.ONHAND) AS ONHAND, SUM(GNTOTVRNT.ACTWHOUSEIN) AS ACTWHOUSEIN, SUM(GNTOTVRNT.ACTWHOUSEOUT) AS ACTWHOUSEOUT,\n      SUM(GNTOTVRNT.COUNTADD) AS COUNTADD, SUM(GNTOTVRNT.COUNTDEC) AS COUNTDEC, SUM(GNTOTVRNT.DISTRESERVED) AS DISTRESERVED, SUM(GNTOTVRNT.ONVEHICLE) AS ONVEHICLE,\n      GNTOTVRNT.VARIANTREF,\n      SUM(GNTOTVRNT.PLNRSRVPRODIN) AS PLNRSRVPRODIN, SUM(GNTOTVRNT.PLNRSRVPRODOUT) AS PLNRSRVPRODOUT,\n      SUM(GNTOTVRNT.PLNRSRVWHOUSEIN) AS PLNRSRVWHOUSEIN, SUM(GNTOTVRNT.PLNRSRVWHOUSEOUT) AS PLNRSRVWHOUSEOUT,\n      ISNULL(WHOUSE.VIRTUALINVEN,0) VIRTUALINVEN\n FROM\n      LV_099_01_VRNTINVTOT GNTOTVRNT\n      LEFT OUTER JOIN \"TIGER3\"..L_CAPIWHOUSE WHOUSE WITH(NOLOCK)  ON GNTOTVRNT.INVENNO=WHOUSE.NR AND WHOUSE.FIRMNR=099\nGROUP BY\n      GNTOTVRNT.STOCKREF, GNTOTVRNT.VARIANTREF, GNTOTVRNT.INVENNO, ISNULL(WHOUSE.VIRTUALINVEN,0)",
