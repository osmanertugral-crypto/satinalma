{
    "type":  "view",
    "schema":  "dbo",
    "name":  "KS_NAKIT_AKIS_GERCEKLESEN",
    "full_name":  "dbo.KS_NAKIT_AKIS_GERCEKLESEN",
    "definition":  "\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[KS_NAKIT_AKIS_GERCEKLESEN] AS \r\n  \r\nSELECT  \r\nCLCARD.CODE , \r\nCLCARD.DEFINITION_,\r\nBNFICHE.FICHENO FICHENO,\r\nBNFICHE.DATE_ DATE_,\r\nBNFLINE.LINEEXP,\r\nEMFICHE.FICHENO MUH_FICHENO,\r\nEMFICHE.DATE_ MUH_DATE_,\r\n\r\nCASE WHEN CLCARD.CODE LIKE \u0027120.07%\u0027 THEN \u0027Mağaza Para\u0027 \r\n WHEN CLCARD.CODE LIKE \u0027335.01%\u0027 THEN \u0027Personel\u0027  \r\n WHEN CLCARD.CODE LIKE \u0027336.%\u0027 THEN \u0027Personel\u0027  \r\n WHEN CLCARD.CODE LIKE \u0027195.%\u0027 THEN \u0027Personel\u0027  \r\n WHEN CLCARD.CODE LIKE \u0027196.%\u0027 THEN \u0027Personel\u0027  \r\n WHEN CLCARD.CODE LIKE \u0027108.01%\u0027 THEN \u0027KKartı\u0027    \r\n WHEN CLCARD.CODE LIKE \u0027329.%\u0027 THEN \u0027Şirket KKartı\u0027    \r\n WHEN CLCARD.CODE LIKE \u0027108.02%\u0027 THEN \u0027HGS\u0027 ELSE  \r\n \r\n(\r\nCASE BNFLINE.TRCODE WHEN 1 THEN \u0027Banka İşlem\u0027 \r\n\t\t\t\t\tWHEN 3 THEN \u0027Cari\u0027 \r\n\t\t\t\t\tWHEN 4 THEN \u0027Cari\u0027 \r\n\t\t\t\t\tWHEN 6 THEN \u0027Kur Farkı\u0027 \r\n \r\n\r\nELSE\r\n(CASE BNFLINE.MODULENR WHEN 7 THEN \u0027Virman\u0027  \r\n\r\nWHEN 6 THEN \u0027Çek/Senet\u0027 \r\nWHEN 61 THEN \u0027Çek/Senet\u0027 \r\nWHEN 62 THEN \u0027Çek/Senet\u0027 \r\nWHEN 63 THEN \u0027Çek/Senet\u0027 \r\nWHEN 64 THEN \u0027Çek/Senet\u0027 \r\nWHEN 65 THEN \u0027Çek/Senet\u0027 \r\n\r\nEND) \r\nEND\r\n)\r\n\r\nEND TYPE,\r\n\r\nCASE BNFLINE.SIGN WHEN 1 THEN \u0027Ödemeler\u0027 WHEN 0 THEN \u0027Tahsilat\u0027 END AS SIGN,\r\nBNFLINE.TRCODE ,\r\n(CASE BNFLINE.SIGN WHEN 1 THEN BNFLINE.AMOUNT * (-1) WHEN 0 THEN BNFLINE.AMOUNT END) AS TOTAL ,\r\nDATEPART( wk, BNFLINE.DATE_) HAFTA  , (BNFLINE.DATE_) BAS_TAR , (BNFLINE.DATE_) BIT_TAR\r\n\r\n\r\nFROM dbo.LG_123_01_BNFLINE AS BNFLINE WITH (NOLOCK) LEFT OUTER JOIN--ON TKVM.HAFTA = DATEPART( wk, BNFLINE.DATE_) AND YEAR(BNFLINE.DATE_) = 2023 LEFT OUTER JOIN\r\n  dbo.LG_123_01_BNFICHE AS BNFICHE WITH (NOLOCK) ON BNFLINE.SOURCEFREF = BNFICHE.LOGICALREF AND BNFLINE.MODULENR = BNFICHE.MODULENR LEFT OUTER JOIN \r\n  dbo.LG_123_CLCARD AS CLCARD WITH (NOLOCK) ON BNFLINE.CLIENTREF = CLCARD.LOGICALREF LEFT OUTER JOIN\r\n  dbo.LG_123_01_EMFICHE AS EMFICHE WITH (NOLOCK) ON BNFLINE.ACCFICHEREF = EMFICHE.LOGICALREF LEFT OUTER JOIN\r\n  dbo.L_CURRENCYLIST AS L_CURRENCYLIST WITH (NOLOCK) ON L_CURRENCYLIST.CURTYPE = BNFLINE.TRCURR AND L_CURRENCYLIST.FIRMNR = \u0027123\u0027\r\n\r\nWHERE BNFLINE.TRCODE NOT IN (2) --OR (BNFLINE.MODULENR LIKE \u00276%\u0027)) AND BNFLINE.CANCELLED = 0\r\n--Bozarsan bunu geri koy (YEAR(BNFLINE.DATE_) = 2024 ) AND\r\n--GROUP BY CLCARD.CODE , CLCARD.DEFINITION_ , DATEPART( wk, BNFLINE.DATE_) , BNFLINE.MODULENR , BNFLINE.SIGN , BNFLINE.TRCODE , BNFICHE.FICHENO , BNFICHE.DATE_ , EMFICHE.FICHENO , EMFICHE.DATE_ \r\n\r\nUNION ALL\r\n \r\n\r\nSELECT \r\nBANKACC.CODE , \r\nBANKACC.DEFINITION_,\r\n      \r\n\u0027\u0027 FICHENO,\r\nCONVERT(DATE,GETDATE()) DATE_,\r\nBNFLINE.LINEEXP,\r\n\t \r\n\u0027\u0027 MUH_FICHENO,\r\nCONVERT(DATE,GETDATE()) MUH_DATE_,\r\n\r\n\u0027Banka\u0027 TYPE,\r\n\u0027Açılış Bakiye\u0027 AS SIGN,\r\n7 TRCODE ,\r\n\r\n (SUM((CASE BNFLINE.SIGN WHEN 1 THEN ROUND((CASE BNFLINE.TRCURR WHEN 0 THEN BNFLINE.AMOUNT ELSE BNFLINE.TRNET END),2)\r\n                      * - 1 ELSE ROUND((CASE BNFLINE.TRCURR WHEN 0 THEN BNFLINE.AMOUNT ELSE BNFLINE.TRNET END),2) END)))\r\n* MAX(ISNULL(EXCHANGE.RATES1,1))   \t\t\t\t\t  \r\n\t\t\t\t\t  AS TOTAL ,\r\nDATEPART( wk, GETDATE()) HAFTA , MIN(GETDATE()) BAS_TAR , MAX(GETDATE()) BIT_TAR\r\n\r\n\r\nFROM         dbo.LG_123_01_BNFLINE AS BNFLINE WITH (NOLOCK) LEFT OUTER JOIN\r\n                      dbo.LG_123_BNCARD AS BNCARD WITH (NOLOCK) ON BNFLINE.BANKREF = BNCARD.LOGICALREF LEFT OUTER JOIN\r\n                      dbo.LG_123_BANKACC AS BANKACC WITH (NOLOCK) ON BNFLINE.BNACCREF = BANKACC.LOGICALREF LEFT OUTER JOIN\r\n                      dbo.LG_123_01_BNFICHE AS BNFICHE WITH (NOLOCK) ON BNFLINE.SOURCEFREF = BNFICHE.LOGICALREF LEFT OUTER JOIN\r\n                      dbo.LG_123_BANKACC AS BANKACC1 WITH (NOLOCK) ON BNFICHE.BNACCOUNTREF = BANKACC1.LOGICALREF LEFT OUTER JOIN\r\n                      dbo.L_CURRENCYLIST AS L_CURRENCYLIST WITH (NOLOCK) ON L_CURRENCYLIST.CURTYPE = BNFLINE.TRCURR AND L_CURRENCYLIST.FIRMNR = \u0027123\u0027 LEFT OUTER JOIN\r\n\t\t\t\t\t  dbo.LG_EXCHANGE_123 AS EXCHANGE WITH(NOLOCK) ON EXCHANGE.CRTYPE = L_CURRENCYLIST.CURTYPE AND EXCHANGE.EDATE = CONVERT(DATE,GETDATE())\r\nWHERE BNFLINE.CANCELLED = 0 \r\nAND BANKACC.CARDTYPE IN (1,3)\r\nGROUP BY  BANKACC.CODE , BNFLINE.LINEEXP, BANKACC.DEFINITION_ ,  BANKACC.LOGICALREF  , BNCARD.LOGICALREF , BNFLINE.TRCURR , L_CURRENCYLIST.CURCODE \r\n\r\n\r\n",
