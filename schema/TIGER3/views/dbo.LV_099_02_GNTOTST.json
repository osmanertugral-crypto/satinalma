{
    "type":  "view",
    "schema":  "dbo",
    "name":  "LV_099_02_GNTOTST",
    "full_name":  "dbo.LV_099_02_GNTOTST",
    "definition":  "CREATE VIEW [dbo].[LV_099_02_GNTOTST] AS\nSELECT\n      0 AS LOGICALREF, GNTOTST.STOCKREF, GNTOTST.INVENNO, SUM(GNTOTST.PLNPRODIN) AS PLNPRODIN,\n      SUM(GNTOTST.PLNPRODOUT) AS PLNPRODOUT, SUM(GNTOTST.PLNOTHERIN) AS PLNOTHERIN, SUM(GNTOTST.PLNOTHEROUT) AS PLNOTHEROUT,\n      SUM(GNTOTST.PLNWHOUSEIN) AS PLNWHOUSEIN, SUM(GNTOTST.PLNWHOUSEOUT) AS PLNWHOUSEOUT, SUM(GNTOTST.TEMPIN) AS TEMPIN,\n      SUM(GNTOTST.TEMPOUT) AS TEMPOUT, SUM(GNTOTST.RESERVED) AS RESERVED, SUM(GNTOTST.ACTPORDER) AS ACTPORDER,\n      SUM(GNTOTST.RECEIVED) AS RECEIVED, SUM(GNTOTST.ACTPRODIN) AS ACTPRODIN, SUM(GNTOTST.ACTOTHERIN) AS ACTOTHERIN, SUM(GNTOTST.ACTSORDER) AS ACTSORDER,\n      SUM(GNTOTST.SHIPPED) AS SHIPPED, SUM(GNTOTST.ACTWASTE) AS ACTWASTE, SUM(GNTOTST.ACTOTHEROUT) AS ACTOTHEROUT, SUM(GNTOTST.TRANSFERRED) AS TRANSFERRED,\n      SUM(CASE WHEN GNTOTST.TRANSFERRED\u003e0 THEN GNTOTST.TRANSFERRED*GNTOTST.AVGVALUE\n            WHEN GNTOTST.ACTPRODIN\u003e0 THEN GNTOTST.ACTPRODIN*GNTOTST.AVGVALUE\n            ELSE GNTOTST.PURCASH END)/\n          CASE WHEN SUM(GNTOTST.TRANSFERRED+GNTOTST.PURAMNT+GNTOTST.ACTPRODIN) \u003e0 THEN SUM(GNTOTST.TRANSFERRED+GNTOTST.PURAMNT+GNTOTST.ACTPRODIN)\n             ELSE 1 END AS AVGVALUE,\n      SUM(CASE WHEN GNTOTST.TRANSFERRED\u003e0 THEN GNTOTST.TRANSFERRED*GNTOTST.AVGCURRVAL\n             WHEN GNTOTST.ACTPRODIN\u003e0 THEN GNTOTST.ACTPRODIN*GNTOTST.AVGCURRVAL\n             ELSE GNTOTST.PURCURR END)/\n          CASE WHEN SUM(GNTOTST.TRANSFERRED+GNTOTST.PURAMNT+GNTOTST.ACTPRODIN) \u003e0 THEN SUM(GNTOTST.TRANSFERRED+GNTOTST.PURAMNT+GNTOTST.ACTPRODIN)\n             ELSE 1 END AS AVGCURRVAL,\n      SUM(GNTOTST.PURAMNT) AS PURAMNT, SUM(GNTOTST.PURCASH) AS PURCASH,\n      SUM(GNTOTST.PURCURR) AS PURCURR, SUM(GNTOTST.SALAMNT) AS SALAMNT, SUM(GNTOTST.SALCASH) AS SALCASH, SUM(GNTOTST.SALCURR) AS SALCURR,\n      MAX(GNTOTST.LASTTRDATE) AS LASTTRDATE, SUM(GNTOTST.ONHAND) AS ONHAND, SUM(GNTOTST.ACTWHOUSEIN) AS ACTWHOUSEIN, SUM(GNTOTST.ACTWHOUSEOUT) AS ACTWHOUSEOUT,\n      SUM(GNTOTST.COUNTADD) AS COUNTADD, SUM(GNTOTST.COUNTDEC) AS COUNTDEC, SUM(GNTOTST.DISTRESERVED) AS DISTRESERVED, SUM(GNTOTST.ONVEHICLE) AS ONVEHICLE,\n      0 AS VARIANTREF,\n      SUM(GNTOTST.PLNRSRVPRODIN) AS PLNRSRVPRODIN, SUM(GNTOTST.PLNRSRVPRODOUT) AS PLNRSRVPRODOUT,\n      SUM(GNTOTST.PLNRSRVWHOUSEIN) AS PLNRSRVWHOUSEIN, SUM(GNTOTST.PLNRSRVWHOUSEOUT) AS PLNRSRVWHOUSEOUT,\n      ISNULL(WHOUSE.VIRTUALINVEN,0) VIRTUALINVEN\n FROM\n      LV_099_02_STINVTOT GNTOTST\n      LEFT OUTER JOIN \"TIGER3\"..L_CAPIWHOUSE WHOUSE WITH(NOLOCK)  ON GNTOTST.INVENNO=WHOUSE.NR AND WHOUSE.FIRMNR=099\nGROUP BY\n      GNTOTST.STOCKREF, GNTOTST.INVENNO, ISNULL(WHOUSE.VIRTUALINVEN,0)",
