{
    "type":  "view",
    "schema":  "dbo",
    "name":  "KREKPOT_BIRIM_FIYAT_LISTESI",
    "full_name":  "dbo.KREKPOT_BIRIM_FIYAT_LISTESI",
    "definition":  "\r\n\r\nCREATE view [dbo].[KREKPOT_BIRIM_FIYAT_LISTESI] as\r\nSELECT MLZ.CODE AS KOD,\r\n       MLZ.NAME AS TANIM,\r\n       (CAST(ISNULL(\r\n               CASE WHEN (SELECT TOP 1 (LINENET+DIFFPRICE)/NULLIF(AMOUNT,0) FROM LG_123_01_STLINE WITH (NOLOCK) WHERE STOCKREF=MLZ.LOGICALREF AND  PRICE\u003e0 AND TRCODE IN (1,14) ORDER BY DATE_ + dbo.LG_INTTOTIME(FTIME)  DESC) IS NULL THEN\r\n                        (SELECT TOP 1 PRICE FROM LG_123_PRCLIST WITH (NOLOCK) WHERE CARDREF=MLZ.LOGICALREF ORDER BY BEGDATE DESC) ELSE\r\n                        (SELECT TOP 1 (LINENET+DIFFPRICE)/NULLIF(AMOUNT,0) FROM LG_123_01_STLINE WITH (NOLOCK) WHERE STOCKREF=MLZ.LOGICALREF AND  PRICE\u003e0 AND TRCODE IN (1,14) ORDER BY DATE_ + dbo.LG_INTTOTIME(FTIME)  DESC) END\r\n\r\n           ,0) AS DECIMAL(18,2))*1) AS BR_FIYAT,\r\n\t\t   ISNULL(\r\n               CASE WHEN (SELECT TOP 1 DATE_ FROM LG_123_01_STLINE WITH (NOLOCK) WHERE STOCKREF=MLZ.LOGICALREF AND  PRICE\u003e0 AND TRCODE IN (1,14) ORDER BY DATE_ + dbo.LG_INTTOTIME(FTIME)  DESC) IS NULL THEN\r\n                        (SELECT TOP 1 BEGDATE FROM LG_123_PRCLIST WITH (NOLOCK) WHERE CARDREF=MLZ.LOGICALREF ORDER BY BEGDATE DESC) ELSE\r\n                        (SELECT TOP 1 DATE_ FROM LG_123_01_STLINE WITH (NOLOCK) WHERE STOCKREF=MLZ.LOGICALREF AND  PRICE\u003e0 AND TRCODE IN (1,14) ORDER BY DATE_ + dbo.LG_INTTOTIME(FTIME)  DESC) END\r\n\r\n           ,0) AS TARIH \r\n\r\nFROM LG_123_ITEMS MLZ WHERE ACTIVE=0\r\n",
    "columns":  [
                    {
                        "COLUMN_NAME":  "KOD",
                        "ORDINAL_POSITION":  1,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "25",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "TANIM",
                        "ORDINAL_POSITION":  2,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "51",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "BR_FIYAT",
                        "ORDINAL_POSITION":  3,
                        "DATA_TYPE":  "decimal",
                        "CHARACTER_MAXIMUM_LENGTH":  "",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "TARIH",
                        "ORDINAL_POSITION":  4,
                        "DATA_TYPE":  "datetime",
                        "CHARACTER_MAXIMUM_LENGTH":  "",
                        "IS_NULLABLE":  "NO"
                    }
                ],
