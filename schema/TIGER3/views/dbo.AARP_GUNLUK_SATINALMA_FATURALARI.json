    "definition":  "\r\n\r\n\r\nCREATE VIEW [dbo].[AARP_GUNLUK_SATINALMA_FATURALARI] AS\r\n--select \r\n--FAT.DATE_ TARIH,\r\n--FAT.FICHENO FIS_NO,\r\n--CAR.DEFINITION_ CARI_ADI,\r\n--FAT.NETTOTAL TUTAR,\r\n--(SELECT NAME FROM L_CAPIUSER KUL WHERE KUL.NR=FAT.CAPIBLOCK_CREATEDBY) GIREN_KULLANICI\r\n-- from LG_001_01_INVOICE FAT\r\n--INNER JOIN LG_001_CLCARD CAR ON FAT.CLIENTREF=CAR.LOGICALREF\r\n--WHERE TRCODE=01 AND year(date_)=2022 and \r\n--convert(varchar,FAT.DATE_,104)\r\n--\u003e=\r\n--convert(varchar,GETDATE()-1,104)\r\n\r\n\r\nSELECT \r\n\r\ndate_ AS  TARIH,\r\nDOCNR AS FIS_NO,\r\nLGMAIN.SENDERTITLE AS CARI_ADI,\r\nLGMAIN.DOCTOTAL AS TUTAR,\r\nLGMAIN.SENDER AS GIREN_KULLANICI\r\n\r\n\r\n FROM \r\nLG_001_01_APPROVAL LGMAIN WITH(NOLOCK) \r\n --WHERE \r\n --LGMAIN.DATE_ = CONVERT(dateTime, convert(varchar,format(getdate(),\u0027MM-dd-yyyy\u0027),105), 101)\r\n--(STATUS IN (0,1)) AND (OPTYPE=1) AND (RECTYPE IN (111,113,115,119)) AND \r\n--((LGMAIN.DATE_ \u003e= CONVERT(dateTime, convert(varchar,format(getdate(),\u0027MM-dd-yyyy\u0027),105), 101))\r\n--AND (LGMAIN.DATE_ \u003c= CONVERT(dateTime, convert(varchar,format(getdate(),\u0027MM-dd-yyyy\u0027),105), 101)))\r\n\r\n\r\n\r\n",
