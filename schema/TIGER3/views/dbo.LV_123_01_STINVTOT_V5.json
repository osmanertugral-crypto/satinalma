{
    "type":  "view",
    "schema":  "dbo",
    "name":  "LV_123_01_STINVTOT_V5",
    "full_name":  "dbo.LV_123_01_STINVTOT_V5",
    "definition":  "\nCREATE VIEW [DBO].LV_123_01_STINVTOT_V5 WITH SCHEMABINDING\nAS\n  SELECT STOCKREF AS STOCKREF,\n         SOURCEINDEX AS INVENNO,\n         RESERVEDATE AS DATE_,\n         SUM(ISNULL(DBO.LG_123_01_GETORDTRANSCOEF(TRCODE,\n                                        DORESERVE,\n                                        CLOSED,\n                                        AMOUNT,\n                                        RESERVEAMOUNT,\n                                        SHIPPEDAMOUNT,\n                                        DATE_,\n                                        RESERVEDATE,\n                                        4)\n                    * (DBO.LG_123_01_GETUNITCOEF(UINFO1, UINFO2)),\n                    0))\n                AS RESERVED,\n         SUM(0) AS ACTPORDER,\n         SUM(0) AS ACTSORDER,\n         VARIANTREF AS VARIANTREF,\n       STATUS AS STATUS,\n         (CASE WHEN LINETYPE IN (4,11) THEN 1 ELSE 0 END) AS TYP,\n         COUNT_BIG(*) AS CNT\n    FROM [DBO].LG_123_01_ORFLINE\n   WHERE (STOCKREF \u003c\u003e 0) AND (LINETYPE NOT IN (2, 3, 7))\n   AND NOT (STATUS IN (1,2) AND DORESERVE=0)\n   AND (RESERVEDATE IS NOT NULL) AND (RESERVEDATE \u003c\u003e DATE_)\nGROUP BY STOCKREF,\n         RESERVEDATE,\n         SOURCEINDEX,\n         VARIANTREF,\n   STATUS,\n         (CASE WHEN LINETYPE IN (4,11) THEN 1 ELSE 0 END)\n",
