    "full_name":  "dbo.LV_323_01_MULTIADDTAXLN",
    "definition":  "CREATE VIEW [dbo].[LV_323_01_MULTIADDTAXLN] AS\nSELECT S.INVOICEREF AS FICHEREF, S.LOGICALREF AS LINEREF, I.ADDTAXREF, ISNULL(S.ADDTAXAMOUNT, 0) AS ADDTAXAMOUNT, ISNULL(E.ADDTAXAMOUNTX, 0) AS ADDTAXAMOUNTX\nFROM LG_323_01_STLINE S\n     LEFT OUTER JOIN LG_323_ITEMS I ON S.STOCKREF = I.LOGICALREF\n     LEFT OUTER JOIN LG_323_01_STLINEEXCH E ON S.LOGICALREF = E.TRANSREF\nWHERE ISNULL(I.MULTIADDTAX, 0) = 0\nAND ISNULL(S.ADDTAXAMOUNT, 0) \u003e 0\nAND ISNULL(I.ADDTAXREF, 0) \u003e 0\nUNION ALL\nSELECT FICHEREF, LINEREF, ADDTAXREF, ADDTAXAMOUNT, ADDTAXAMOUNTX\nFROM LG_323_01_MULTIADDTAXLN",
