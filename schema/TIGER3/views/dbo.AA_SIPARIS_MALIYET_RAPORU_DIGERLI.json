{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_SIPARIS_MALIYET_RAPORU_DIGERLI",
    "full_name":  "dbo.AA_SIPARIS_MALIYET_RAPORU_DIGERLI",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[AA_SIPARIS_MALIYET_RAPORU_DIGERLI] AS\r\n\r\n\r\n\r\nSELECT MONTH((sELECT ENDDATE FROM LG_123_PROJECT WHERE CODE=PROJE )) DONEM,* FROM AA_SIPARIS_MALIYET_RAPORU \r\nUNION ALL\r\nSELECT MONTH((sELECT ENDDATE FROM LG_123_PROJECT WHERE CODE=IS_EMRI_N0 )) DONEM,IS_EMRI_N0 AS PROJE, \u0027DİĞER\u0027AS OZEL_KOD, 0 AS SIPARIS_TUTARI , SUM(TUTAR)-\r\n(SELECT SUM(MALIYET_TUTARI) FROM AA_SIPARIS_MALIYET_RAPORU WHERE PROJE=AA.IS_EMRI_N0)\r\n\r\n AS TUTAR FROM AA_SARF_PROJE_123 AA  GROUP BY  AA.IS_EMRI_N0\r\n\r\n",
