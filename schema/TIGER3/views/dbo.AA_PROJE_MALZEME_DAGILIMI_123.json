    "name":  "AA_PROJE_MALZEME_DAGILIMI_123",
    "full_name":  "dbo.AA_PROJE_MALZEME_DAGILIMI_123",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[AA_PROJE_MALZEME_DAGILIMI_123] AS\r\n\r\nSELECT \r\nS.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,L.DATE_ TARIH\r\n,L.AMOUNT MIKTAR\r\n,(SELECT CODE FROM LG_123_PROJECT WHERE LOGICALREF=L.PROJECTREF) PROJE_KODU \r\n,(SELECT NAME FROM LG_123_PROJECT WHERE LOGICALREF=L.PROJECTREF) PROJE_ADI\r\n\r\n\r\n\r\n\r\nFROM LG_123_01_STLINE AS L\r\nINNER JOIN LG_123_ITEMS AS S ON S.LOGICALREF=L.STOCKREF\r\n\r\nWHERE L.TRCODE=12\r\nAND LINETYPE=0\r\n--AND (SELECT CODE FROM LG_123_PROJECT WHERE LOGICALREF=L.PROJECTREF) IN (SELECT PROJE_KODU FROM AA_SATIS_SIPARIS_OZET_123  WHERE GERCEKLESEN_URETIM_TARIHI IS NULL)\r\n\r\n--AND S.CODE=\u00272021X23\u0027\r\n",
