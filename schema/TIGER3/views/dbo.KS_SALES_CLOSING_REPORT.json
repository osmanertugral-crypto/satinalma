{
    "type":  "view",
    "schema":  "dbo",
    "name":  "KS_SALES_CLOSING_REPORT",
    "full_name":  "dbo.KS_SALES_CLOSING_REPORT",
    "definition":  "\r\nCREATE VIEW [dbo].[KS_SALES_CLOSING_REPORT] AS\r\n\r\n\r\nSELECT \r\nYEAR(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY\r\n,S.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,S.STGRPCODE \r\n,CASE F.trcode WHEN 3 THEN L.AMOUNT*-1 ELSE L.AMOUNT END MIKTAR\r\n---,L.AMOUNT MIKTAR\r\n---,L.PRICE FIYAT\r\n,CASE F.trcode WHEN 3 THEN L.PRICE*-1 ELSE L.PRICE END FIYAT\r\n,CASE F.trcode WHEN 3 THEN CASE WHEN L.TRCODE=7 THEN L.TOTAL-L.VATAMNT ELSE L.TOTAL END *-1\r\nELSE CASE WHEN L.TRCODE=7 THEN L.TOTAL-L.VATAMNT ELSE L.TOTAL END END TUTAR\r\n,ISNULL ((SELECT S.DISCPER FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=2 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0 AND S.PARENTLNREF=L.LOGICALREF),0) \u0027S INDIRIM ORANI\u0027\r\n,ISNULL ((SELECT S.DISCPER FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=2 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0 AND S.PARENTLNREF=0),0) \u0027G INDIRIM ORANI\u0027\r\n,ISNULL ((SELECT S.TOTAL/(INVOICELNNO-1) FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=3 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0),0) \u0027MASRAF TUTARI\u0027\r\n\r\n,(SELECT DEFINITION_ FROM LG_123_SPECODES WITH (NOLOCK) WHERE SPECODETYPE=25 AND SPECODE=L.SPECODE) TUR\r\n\r\nFROM LG_123_01_STLINE AS L WITH (NOLOCK)\r\nINNER JOIN LG_123_ITEMS AS S WITH (NOLOCK) ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_123_01_INVOICE AS F WITH (NOLOCK) ON F.LOGICALREF=L.INVOICEREF\r\nINNER JOIN LG_123_CLCARD AS C WITH (NOLOCK) ON C.LOGICALREF=F.CLIENTREF\r\nLEFT JOIN LG_123_EMUHACC EMU WITH (NOLOCK) ON EMU.LOGICALREF = L.ACCOUNTREF\r\nWHERE LINETYPE=0 AND F.TRCODE IN (8,9,7,3,6,14)----8,9,7,\r\nAND F.CANCELLED=0\r\nAND YEAR(F.DATE_)\u003e2021\r\n--AND F.FICHENO=\u0027RST2023000000096\u0027\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nYEAR(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY\r\n,S.CODE STOK_KODU\r\n,S.DEFINITION_ STOK_ADI\r\n,\u0027\u0027 STGRPCODE \r\n,CASE F.trcode WHEN 3 THEN L.AMOUNT*-1 ELSE L.AMOUNT END MIKTAR\r\n--,L.AMOUNT MIKTAR\r\n,CASE F.trcode WHEN 3 THEN L.PRICE*-1 ELSE L.PRICE END FIYAT\r\n--,L.PRICE FIYAT\r\n\r\n--,CASE WHEN L.TRCODE=7 THEN L.TOTAL-L.VATAMNT ELSE L.TOTAL END TUTARESKI\r\n----\r\n,CASE F.trcode WHEN 3 THEN CASE WHEN L.TRCODE=7 THEN L.TOTAL-L.VATAMNT ELSE L.TOTAL END *-1\r\n\r\n\r\nELSE CASE WHEN L.TRCODE=7 THEN L.TOTAL-L.VATAMNT ELSE L.TOTAL END END TUTAR\r\n\r\n,ISNULL ((SELECT S.DISCPER FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=2 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0 AND S.PARENTLNREF=L.LOGICALREF),0) \u0027S INDIRIM ORANI\u0027\r\n,ISNULL ((SELECT S.DISCPER FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=2 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0 AND S.PARENTLNREF=0),0) \u0027G INDIRIM ORANI\u0027\r\n,ISNULL ((SELECT S.TOTAL/(INVOICELNNO-1) FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=3 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0),0) \u0027MASRAF TUTARI\u0027\r\n\r\n-----\r\n\r\n,(SELECT DEFINITION_ FROM LG_123_SPECODES WITH (NOLOCK) WHERE SPECODETYPE=25 AND SPECODE=L.SPECODE) TUR\r\n\r\n\t\t\t\t\t\r\nFROM LG_123_01_STLINE AS L WITH (NOLOCK)\r\nINNER JOIN LG_123_SRVCARD AS S WITH (NOLOCK) ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_123_01_INVOICE AS F WITH (NOLOCK) ON F.LOGICALREF=L.INVOICEREF\r\nINNER JOIN LG_123_CLCARD AS C WITH (NOLOCK) ON C.LOGICALREF=F.CLIENTREF\r\nLEFT JOIN LG_123_EMUHACC EMU WITH (NOLOCK) ON EMU.LOGICALREF = L.ACCOUNTREF\r\nWHERE LINETYPE=4 AND F.TRCODE IN (9,8,7,3,6,14)--9,8,7,\r\nAND F.CANCELLED=0\r\nAND YEAR(F.DATE_)\u003e2021\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nYEAR(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY\r\n,S.CODE STOK_KODU\r\n,S.DEFINITION_ STOK_ADI\r\n,\u0027\u0027 STGRPCODE \r\n,L.AMOUNT MIKTAR\r\n,L.PRICE FIYAT\r\n,L.PRICE TUTAR\r\n,\u0027\u0027 \u0027S INDIRIM ORANI\u0027\r\n,\u0027\u0027 \u0027G INDIRIM ORANI\u0027\r\n,\u0027\u0027 \u0027MASRAF TUTARI\u0027\r\n,S.DEFINITION2 TUR\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t--   \u0027\u0027 [Fatura muhasebe Kodu]\r\n\r\nFROM LG_123_01_DEMANDLINE AS L WITH (NOLOCK)\r\nINNER JOIN LG_123_SRVCARD AS S  WITH (NOLOCK) ON S.LOGICALREF=L.ITEMREF\r\nINNER JOIN LG_123_CLCARD AS C  WITH (NOLOCK) ON C.LOGICALREF=L.CLIENTREF\r\nINNER JOIN LG_123_01_DEMANDFICHE AS F WITH (NOLOCK) ON F.LOGICALREF=L.DEMANDFICHEREF\r\n\r\nWHERE S.CODE LIKE\u0027X 6%\u0027\r\nAND YEAR(F.DATE_)\u003e2021\r\n\r\n",
