{
    "type":  "view",
    "schema":  "dbo",
    "name":  "BRK_PROJELERDEKI_MALZEMELER",
    "full_name":  "dbo.BRK_PROJELERDEKI_MALZEMELER",
    "definition":  "CREATE VIEW [dbo].[BRK_PROJELERDEKI_MALZEMELER] AS\r\n\r\nSELECT\r\n    ITEMS.CODE AS ITEMS_CODE,\r\n    ITEMS.NAME AS ITEMS_NAME,\r\n    ITEMS.STGRPCODE AS ITEMS_STGRPCODE,\r\n    SUM(SH.MIKTAR * (SH.CARPAN2 / NULLIF(SH.CARPAN1, 0))) AS MIKTAR,\r\n    UNITSETF.CODE AS UNITSETF_CODE,\r\n    SH.HEDEF_ADRES AS ADRES,\r\n    CASE WHEN SH.IZLEME_TURU IN (0, 3, 4) THEN \u0027\u0027 ELSE SH.TAKIP_NO END AS TAKIP_NO,\r\n    SH.HEDEF_DURUM AS DURUM_KODU\r\nFROM\r\n    EVIRA.dbo.STOKHAREKETLERI SH WITH (NOLOCK)\r\n    LEFT JOIN TIGER3.dbo.LG_123_ITEMS ITEMS ON SH.STOK_REF = ITEMS.LOGICALREF\r\n    LEFT JOIN TIGER3.dbo.LG_123_UNITSETF UNITSETF ON ITEMS.UNITSETREF = UNITSETF.LOGICALREF\r\nWHERE\r\n    SH.FIS_GCD = \u00272\u0027\r\n    AND SH.HEDEF_AMBAR = 5\r\nGROUP BY\r\n    ITEMS.CODE,\r\n    ITEMS.NAME,\r\n    ITEMS.STGRPCODE,\r\n    UNITSETF.CODE,\r\n    SH.HEDEF_ADRES,\r\n    CASE WHEN SH.IZLEME_TURU IN (0, 3, 4) THEN \u0027\u0027 ELSE SH.TAKIP_NO END,\r\n    SH.HEDEF_DURUM;\r\n",
    "columns":  [
                    {
                        "COLUMN_NAME":  "ITEMS_CODE",
                        "ORDINAL_POSITION":  1,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "25",
