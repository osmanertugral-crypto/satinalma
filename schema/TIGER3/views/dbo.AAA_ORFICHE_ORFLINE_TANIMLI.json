    "name":  "AAA_ORFICHE_ORFLINE_TANIMLI",
    "full_name":  "dbo.AAA_ORFICHE_ORFLINE_TANIMLI",
    "definition":  "CREATE VIEW AAA_ORFICHE_ORFLINE_TANIMLI AS\n\n\nSELECT \nORFICHE.LOGICALREF AS ORFICHE_LOGICALREF,\nORFLINE.LOGICALREF AS  ORFLINE_LOGICALREF,\nORFICHE.PROJECTREF AS ORFICHE_PROJECTREF,\nORFLINE.PROJECTREF AS ORFLINE_PROJECTREF,\nORFLINE.STOCKREF AS ORFLINE_STOCKREF\n,CONVERT(NVARCHAR,(SELECT DBO.LG_INTTODATE(NUMFLDS18) FROM  LG_001_01_DEFNFLDSTRANV WHERE NUMFLDS18\u003c\u003e0 AND MODULENR=8 AND PARENTREF=ORFICHE.LOGICALREF),104) PLANLANAN_URETIM_TARIHI\n,CONVERT(NVARCHAR,(SELECT DBO.LG_INTTODATE(NUMFLDS19) FROM  LG_001_01_DEFNFLDSTRANV WHERE NUMFLDS19\u003c\u003e0 AND MODULENR=8 AND PARENTREF=ORFICHE.LOGICALREF),104) GERCEKLESEN_URETIM_TARIHI\n,CONVERT(NVARCHAR,(SELECT DBO.LG_INTTODATE(NUMFLDS20) FROM  LG_001_01_DEFNFLDSTRANV WHERE NUMFLDS20\u003c\u003e0 AND MODULENR=8 AND PARENTREF=ORFICHE.LOGICALREF),104) PLANLANAN_TESLIM_TARIHI\n,(SELECT NUMFLDS21 FROM  LG_001_01_DEFNFLDSTRANV WHERE MODULENR=8 AND PARENTREF=ORFICHE.LOGICALREF) GERCEKLESEN_TESLIM_TARIHI\n,ORFLINE.LINENO_ AS LINENO_\nFROM LG_001_01_ORFICHE AS ORFICHE \nINNER JOIN LG_001_01_ORFLINE AS ORFLINE ON ORFICHE.LOGICALREF=ORFLINE.ORDFICHEREF \n\nWHERE ORFICHE.TRCODE=1",
