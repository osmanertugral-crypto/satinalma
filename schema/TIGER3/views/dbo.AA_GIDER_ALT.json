    "name":  "AA_GIDER_ALT",
    "full_name":  "dbo.AA_GIDER_ALT",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_GIDER_ALT] AS\r\n\r\n\r\n\r\nSELECT \r\nYEAR(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY\r\n,L.KEBIRCODE GRUP\r\n,F.SPECODE OZEL_KOD\r\n,H.CODE HESAP_KODU\r\n,H.DEFINITION_ HESAP_ADI\r\n,L.DEBIT TUTAR\r\n,L.LINEEXP ACIKLAMA\r\n,H.CLDEF TYP\r\nFROM LG_001_EMUHACC AS H\r\nINNER JOIN LG_001_01_EMFLINE AS L ON L.ACCOUNTREF=H.LOGICALREF\r\nINNER JOIN LG_001_01_EMFICHE AS F ON F.LOGICALREF=L.ACCFICHEREF\r\nWHERE H.CODE LIKE\u00277%\u0027\r\nAND L.CANCELLED=0\r\nAND YEAR(F.DATE_)\u003e2021\r\nAND H.CLDEF IN (\u0027CAPEX\u0027,\u0027\u0027)\r\n\r\n--UNION ALL\r\n\r\n--SELECT\r\n--YEAR(L.PROCUREDATE) YIL\r\n--,MONTH(L.PROCUREDATE) AY\r\n--,\u0027TLP\u0027 GRUP\r\n--,\u0027\u0027 OZEL_KOD\r\n--,S.CODE \u0027HESAP_KODU\u0027\r\n--,S.DEFINITION_ \u0027HESAP_ADI\u0027\r\n--,L.PRICE TUTAR\r\n--,L.LINEEXP ACIKLAMA\r\n--,S.DEFINITION2 TYP\r\n\r\n\r\n\r\n--FROM LG_001_01_DEMANDLINE AS L\r\n--INNER JOIN LG_001_SRVCARD AS S ON S.LOGICALREF=L.ITEMREF\r\n\r\n--WHERE S.CODE LIKE\u0027X 7%\u0027\r\n--AND YEAR(l.PROCUREDATE)\u003e2021\r\n--AND S.DEFINITION2  IN (\u0027CAPEX\u0027,\u0027ARGE GİDERLERİ\u0027)\r\n\r\n--SELECT * FROM LG_001_01_DEMANDLINE\r\nUNION ALL\r\n\r\nSELECT \r\nYEAR(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY\r\n,L.KEBIRCODE GRUP\r\n,F.SPECODE OZEL_KOD\r\n,H.CODE HESAP_KODU\r\n,H.DEFINITION_ HESAP_ADI\r\n,L.DEBIT TUTAR\r\n,L.LINEEXP ACIKLAMA\r\n,CASE SUBSTRING(H.CODE,1,2) WHEN  \u002715\u0027 THEN \u0027HAMMADDE ALISI\u0027 WHEN  \u002725\u0027 THEN \u0027SABIT KIYMET ALISI\u0027 END  TYP\r\nFROM LG_001_EMUHACC AS H\r\nINNER JOIN LG_001_01_EMFLINE AS L ON L.ACCOUNTREF=H.LOGICALREF\r\nINNER JOIN LG_001_01_EMFICHE AS F ON F.LOGICALREF=L.ACCFICHEREF\r\nWHERE SUBSTRING(H.CODE,1,2) IN (\u002715\u0027,\u002725\u0027)\r\nAND L.CANCELLED=0\r\nAND YEAR(F.DATE_)\u003e2021\r\nAND H.CODE NOT LIKE\u0027255.03%\u0027\r\nUNION ALL\r\n\r\nSELECT \r\nYEAR(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY\r\n,L.KEBIRCODE GRUP\r\n,L.SPECODE OZEL_KOD\r\n,H.CODE HESAP_KODU\r\n,H.DEFINITION_ HESAP_ADI\r\n,CASE SIGN WHEN 0 THEN L.DEBIT ELSE L.CREDIT*-1 END  TUTAR\r\n,L.LINEEXP ACIKLAMA\r\n,\u0027GOSB FABRIKA\u0027  TYP\r\n\r\n\r\nFROM LG_001_01_EMFLINE AS L\r\nINNER JOIN LG_001_EMUHACC AS H ON H.LOGICALREF=L.ACCOUNTREF\r\n\r\nWHERE H.CLDEF LIKE\u0027%GOSB%\u0027\r\nAND YEAR(L.DATE_)\u003e2021\r\n\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nYEAR(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY\r\n,L.KEBIRCODE GRUP\r\n,L.SPECODE OZEL_KOD\r\n,H.CODE HESAP_KODU\r\n,H.DEFINITION_ HESAP_ADI\r\n,CASE SIGN WHEN 0 THEN L.DEBIT ELSE L.CREDIT*-1 END  TUTAR\r\n,L.LINEEXP ACIKLAMA\r\n,\u0027KDV DURUMU\u0027  TYP\r\n\r\n\r\nFROM LG_001_01_EMFLINE AS L\r\nINNER JOIN LG_001_EMUHACC AS H ON H.LOGICALREF=L.ACCOUNTREF\r\n\r\nWHERE KEBIRCODE IN (190,191,391)\r\nAND YEAR(L.DATE_)\u003e2021\r\n\r\n\r\nUNION ALL\r\n\r\nSELECT\r\nYEAR(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY\r\n,\u0027TLP\u0027 GRUP\r\n,\u0027\u0027 OZEL_KOD\r\n,S.CODE \u0027HESAP_KODU\u0027\r\n,S.DEFINITION_ \u0027HESAP_ADI\u0027\r\n,L.PRICE TUTAR\r\n,L.LINEEXP ACIKLAMA\r\n,S.DEFINITION2 TYP\r\n\r\n\r\n\r\nFROM LG_001_01_DEMANDLINE AS L\r\nINNER JOIN LG_001_SRVCARD AS S ON S.LOGICALREF=L.ITEMREF\r\nINNER JOIN LG_001_01_DEMANDFICHE AS F ON F.LOGICALREF=L.DEMANDFICHEREF\r\n\r\nWHERE S.CODE LIKE\u0027X GOSB%\u0027\r\nAND YEAR(l.PROCUREDATE)\u003e2021\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
