    "name":  "AAA_RAPOR_001",
    "full_name":  "dbo.AAA_RAPOR_001",
    "definition":  "CREATE VIEW AAA_RAPOR_001 AS\r\nSELECT\r\n\u0027S\u0027 DURUM_RECETE, \r\nMAINCREF AS ANA_MALZEME_REF_ORFICHE_LOG,\r\nSTCREF AS ALT_MALZEME_REF_ORFLINE_LOG,\r\n(SELECT CODE FROM LG_001_ITEMS WHERE LOGICALREF=ST.STCREF) AS ALT_MALZEME_KODU_RECETE,\r\n(SELECT NAME FROM LG_001_ITEMS WHERE LOGICALREF=ST.STCREF) AS ALT_MALZEME_AÇIKLAMASI_RECETE,\r\n(SELECT CODE FROM LG_001_ITEMS WHERE LOGICALREF=ST.MAINCREF) AS ANA_MALZEME_KODU_ORFLINE_RECETE,\r\n(SELECT NAME FROM LG_001_ITEMS WHERE LOGICALREF=ST.MAINCREF) AS ANA_MALZEME_AÇIKLAMASI_RECETE\r\n,ST.LINENO_ AS LINENO_RECETE\r\n,AMNT AS AMOUNT_RECETE\r\n,ORFICHE_LOGICALREF\r\n,ORFLINE_LOGICALREF\r\n,ORFICHE_PROJECTREF\r\n,ORFLINE_PROJECTREF\r\n,ORFLINE_STOCKREF\r\n,B_SATIR_TUTAR\r\n,LINENET\r\n,FICHENO\r\n,AAA.LINENO_\r\n\r\nFROM LG_001_STCOMPLN AS ST FULL JOIN AAA_ORFLINE_ORFICHE_RAPOR AS AAA ON ST.MAINCREF=AAA.ORFLINE_STOCKREF",
