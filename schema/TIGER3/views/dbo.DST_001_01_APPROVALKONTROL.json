    "name":  "DST_001_01_APPROVALKONTROL",
    "full_name":  "dbo.DST_001_01_APPROVALKONTROL",
    "definition":  "CREATE VIEW DST_001_01_APPROVALKONTROL AS\r\n\r\nSELECT       \r\nAPPROVAL.SENDERTITLE AS GFirma, \r\n--CL.DEFINITION_ AS Müşteri, \r\nAPPROVAL.DOCNR AS [Connect E-Fat No], \r\nAPPROVAL.DOCDATE AS [C.E-Fat Tarh], \r\nAPPROVAL.DOCTOTAL AS [C.E-Fat Tutarı] ,\r\n--INVOICE.FICHENO AS [Logo Fatura No],\r\n--INVOICE.DATE_ AS [Logo Fatura Tarihi],\r\n--INVOICE.DOCODE AS [Logo Fatura Belge No],\r\n--INVOICE.NETTOTAL AS [Logo Fatura Tutarı], \r\nCASE APPROVAL.STATUS WHEN \u00270\u0027 THEN \u0027blob\u0027\u0027ta\u0027 WHEN \u00271\u0027 THEN \u0027Onay satirlari olusturulmus\u0027 WHEN \u00272\u0027 THEN \u0027Onay bekliyor\u0027 WHEN \u00273\u0027 THEN \u0027Onaylandi\u0027 WHEN \u00274\u0027 THEN \u0027Paketlendi/Kaydedildi\u0027 WHEN \u00275\u0027 THEN \u0027Onay satirlari olusturulmus\u0027\r\nWHEN \u00276\u0027 THEN \u0027Bankaya iletildi\u0027 WHEN \u00277\u0027 THEN \u0027LDX\u0027\u0027e iletildi\u0027 WHEN \u00278\u0027 THEN \u0027Arsive gönderildi.\u0027 WHEN \u00279\u0027 THEN \u0027Onay Reddi\u0027 WHEN \u002710\u0027 THEN \u0027Doküman Reddi\u0027 END AS STATUS, \r\nCASE APPROVAL.TRCODE WHEN \u00271\u0027 THEN \u0027Satinalma Faturasi\u0027 WHEN \u00273\u0027 THEN \u0027Toptan Satis iade Faturasi\u0027 WHEN \u00274\u0027 THEN \u0027Alinan Hizmet Faturasi\u0027 WHEN \u002713\u0027 THEN \u0027Satinalma Fiyat Farki Faturasi\u0027 WHEN \u002714\u0027 THEN \u0027Satis Fiyat Farki Faturasi\u0027\r\nWHEN \u00278\u0027 THEN \u0027Toptan Satış Faturası\u0027 WHEN \u00279\u0027 THEN \u0027Verilen Hizmet Faturası\u0027 END AS TRCODE, \r\nCASE APPROVAL.PROFILEID WHEN \u00270\u0027 THEN \u0027Temel Fatura\u0027 WHEN \u00271\u0027 THEN \u0027Ticari Fatura\u0027 END AS PROFILEID\r\nFROM          LG_001_01_APPROVAL AS APPROVAL WITH (NOLOCK) \r\n--LEFT OUTER JOIN\r\n                        -- dbo.LG_001_01_INVOICE AS INVOICE WITH (NOLOCK) ON INVOICE.FICHENO = APPROVAL.DOCNR AND INVOICE.TRCODE IN (1, 4, 8, 3, 9, 13, 14) LEFT OUTER JOIN\r\n                         --dbo.LG_001_CLCARD AS CL ON INVOICE.CLIENTREF = CL.LOGICALREF\r\nWHERE        (APPROVAL.TRCODE IN (1, 4, 8, 3, 9, 13, 14)) AND (APPROVAL.DOCDATE BETWEEN \u002720220101\u0027 AND \u002720221231\u0027) AND APPROVAL.RECTYPE=111\r\n\r\n",
