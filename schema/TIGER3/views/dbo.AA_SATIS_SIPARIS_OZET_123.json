{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_SATIS_SIPARIS_OZET_123",
    "full_name":  "dbo.AA_SATIS_SIPARIS_OZET_123",
    "definition":  "\r\n\r\n\r\nCREATE VIEW [dbo].[AA_SATIS_SIPARIS_OZET_123] AS\r\nselect \r\nF.FICHENO SIPARIS_NO\r\n,CONVERT(NVARCHAR,F.DATE_,104) SIPARIS_TARIHI\r\n,ISNULL(CONVERT(VARCHAR,(SELECT  TOP 1 DATE_ FROM LG_001_01_INVOICE WHERE PROJECTREF=F.PROJECTREF),104),0) AS FATURA_TARİHİ\r\n,ISNULL((SELECT  TOP 1 FICHENO FROM LG_001_01_INVOICE WHERE PROJECTREF=F.PROJECTREF),\u0027\u0027) AS FATURA_NO\r\n,ISNULL((SELECT TOP 1 MONTH(DATE_) FROM LG_001_01_INVOICE WHERE PROJECTREF=F.PROJECTREF),0) AS FATURA_AY\r\n,ISNULL((SELECT TOP 1 YEAR(DATE_) FROM LG_001_01_INVOICE WHERE PROJECTREF=F.PROJECTREF),0) AS FATURA_YIL\r\n--,CONVERT(VARCHAR, ISNULL((SELECT DATE_ FROM LG_001_01_INVOICE WHERE LOGICALREF=( SELECT TOP 1 INVOICEREF FROM LG_001_01_STLINE WHERE ORDFICHEREF=F.LOGICALREF)),0),104) AS FATURA_TARİHİ\r\n--,ISNULL((SELECT MONTH(DATE_) FROM LG_001_01_INVOICE WHERE LOGICALREF=( SELECT TOP 1 INVOICEREF FROM LG_001_01_STLINE WHERE ORDFICHEREF=F.LOGICALREF)),0) AS FATURA_TARİHİ_AY\r\n--,ISNULL((SELECT YEAR(DATE_) FROM LG_001_01_INVOICE WHERE LOGICALREF=( SELECT TOP 1 INVOICEREF FROM LG_001_01_STLINE WHERE ORDFICHEREF=F.LOGICALREF)),0) AS FATURA_TARİHİ_YIL\r\n--,ISNULL((SELECT FICHENO FROM LG_001_01_INVOICE WHERE LOGICALREF=( SELECT TOP 1 INVOICEREF FROM LG_001_01_STLINE WHERE ORDFICHEREF=F.LOGICALREF)),\u0027\u0027) AS FATURA_NUMARASI\r\n,CASE WHEN C.TAXNR=\u00272222222222\u0027 THEN \u0027YURT DISI\u0027 ELSE \u0027YURT ICI\u0027 END TIP\r\n,C.CODE CARI_KODU\r\n,C.DEFINITION_ CARI_UNVANI\r\n,C.COUNTRY CARI_ULKE\r\n,(SELECT STOK_KODU FROM AA_SATIS_SIPARIS_123 WHERE SIPARIS_NO=F.FICHENO AND SIRA=1) STOK_KODU\r\n,(SELECT STOK_ADI FROM AA_SATIS_SIPARIS_123 WHERE SIPARIS_NO=F.FICHENO AND SIRA=1) STOK_ADI\r\n,(SELECT STOK_KODU FROM AA_SATIS_SIPARIS_123 WHERE SIPARIS_NO=F.FICHENO AND STOK_KODU LIKE\u0027ARABA%\u0027) ARABA_KODU\r\n,(SELECT STOK_ADI FROM AA_SATIS_SIPARIS_123 WHERE SIPARIS_NO=F.FICHENO AND STOK_KODU LIKE\u0027ARABA%\u0027) ARABA_ADI\r\n,(select CODE from LG_001_PROJECT WHERE LOGICALREF=F.PROJECTREF) PROJE_KODU\r\n,(select DEFINITION_ from LG_001_PROJECT WHERE LOGICALREF=F.PROJECTREF) PROJE_ADI\r\n,(SELECT NUMFLDS15 FROM  LG_001_01_DEFNFLDSTRANV WHERE MODULENR=8 AND PARENTREF=F.LOGICALREF) FATURA_TUTARI\r\n,(SELECT CASE NUMFLDS17 WHEN 1 THEN \u0027EUR\u0027 WHEN 2 THEN  \u0027USD\u0027 WHEN 4 THEN \u0027GBP\u0027 ELSE \u0027TL\u0027 END  FROM  LG_001_01_DEFNFLDSTRANV WHERE  MODULENR=8 AND PARENTREF=F.LOGICALREF) FATURA_DOVIZ_TURU\r\n,(SELECT NUMFLDS16 FROM  LG_001_01_DEFNFLDSTRANV WHERE  MODULENR=8 AND PARENTREF=F.LOGICALREF) FATURA_KDV_ORANI\r\n,(SELECT SUM(AMOUNT) FROM LG_001_01_BNFLINE WHERE PROJECTREF=F.PROJECTREF AND CLIENTREF IN (SELECT LOGICALREF FROM LG_001_CLCARD WHERE CODE LIKE\u0027340%\u0027) ) AVANS_TUTARI\r\n,(SELECT SUM(NETTOTAL) FROM LG_001_01_INVOICE WHERE TRCODE IN (7,9,8) and  PROJECTREF=F.PROJECTREF AND CLIENTREF=C.LOGICALREF) KESILEN_FATURA_TUTARI\r\n,CASE WHEN TRCURR=0 THEN (SELECT SUM(CASE WHEN SIGN=0 THEN AMOUNT WHEN SIGN=1 THEN AMOUNT*-1 END) FROM LG_001_01_CLFLINE WHERE CANCELLED=0 AND CLPRJREF=F.PROJECTREF and TRCODE NOT IN (31)) ELSE 0 END AS TL_BAKİYE\r\n,CASE WHEN TRCURR\u003c\u003e0 THEN (SELECT SUM(CASE WHEN SIGN=0 THEN AMOUNT2 ELSE AMOUNT2*-1 END) FROM  AA_CLFLINE_001 AS L WHERE  CLPRJREF=F.PROJECTREF and TRCODE NOT IN (31)) ELSE 0 END AS EURO_BAKİYE\r\n,CONVERT(NVARCHAR,(SELECT DBO.LG_INTTODATE(NUMFLDS18) FROM  LG_001_01_DEFNFLDSTRANV WHERE NUMFLDS18\u003c\u003e0 AND MODULENR=8 AND PARENTREF=F.LOGICALREF),104) PLANLANAN_URETIM_TARIHI\r\n,CONVERT(NVARCHAR,(SELECT DBO.LG_INTTODATE(NUMFLDS19) FROM  LG_001_01_DEFNFLDSTRANV WHERE NUMFLDS19\u003c\u003e0 AND MODULENR=8 AND PARENTREF=F.LOGICALREF),104) GERCEKLESEN_URETIM_TARIHI\r\n,CONVERT(NVARCHAR,(SELECT DBO.LG_INTTODATE(NUMFLDS20) FROM  LG_001_01_DEFNFLDSTRANV WHERE NUMFLDS20\u003c\u003e0 AND MODULENR=8 AND PARENTREF=F.LOGICALREF),104) PLANLANAN_TESLIM_TARIHI\r\n,CONVERT(NVARCHAR,(SELECT DBO.LG_INTTODATE(NUMFLDS21) FROM  LG_001_01_DEFNFLDSTRANV WHERE NUMFLDS21\u003c\u003e0 AND MODULENR=8 AND PARENTREF=F.LOGICALREF),104) GERCEKLESEN_TESLIM_TARIHI\r\n,F.TRADINGGRP AS TİCARİ_İŞLEM_GRUBU\r\n,ISNULL((SELECT NUMFLDS36 FROM LG_001_01_DEFNFLDSTRANV WHERE PARENTREF=F.LOGICALREF AND MODULENR=8 AND LEVEL_=0),0) AS GROSS_KG\r\n,ISNULL((SELECT NUMFLDS37 FROM LG_001_01_DEFNFLDSTRANV WHERE PARENTREF=F.LOGICALREF AND MODULENR=8 AND LEVEL_=0),0) AS NET_KG\r\nfrom  LG_001_01_ORFICHE AS F \r\nINNER JOIN LG_001_CLCARD AS C ON C.LOGICALREF=F.CLIENTREF\r\nAND F.TRCODE=1\r\n",
