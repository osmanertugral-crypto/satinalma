    "name":  "AA_GIDER",
    "full_name":  "dbo.AA_GIDER",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_GIDER] AS\r\n\r\n\r\n\r\nSELECT \r\nYEAR(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY\r\n,L.KEBIRCODE GRUP\r\n,F.SPECODE OZEL_KOD\r\n,H.CODE HESAP_KODU\r\n,H.DEFINITION_ HESAP_ADI\r\n,L.DEBIT TUTAR\r\n,L.LINEEXP ACIKLAMA\r\n,H.CLDEF TYP\r\nFROM LG_001_EMUHACC AS H\r\nINNER JOIN LG_001_01_EMFLINE AS L ON L.ACCOUNTREF=H.LOGICALREF\r\nINNER JOIN LG_001_01_EMFICHE AS F ON F.LOGICALREF=L.ACCFICHEREF\r\nWHERE H.CODE LIKE\u00277%\u0027\r\nAND L.CANCELLED=0\r\nAND YEAR(F.DATE_)\u003e2021\r\nAND H.CLDEF NOT IN (\u0027CAPEX\u0027,\u0027ARGE GİDERLERİ\u0027)\r\nUNION ALL\r\n\r\nSELECT \r\nYEAR(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY\r\n,L.KEBIRCODE GRUP\r\n,F.SPECODE OZEL_KOD\r\n,H.CODE HESAP_KODU\r\n,H.DEFINITION_ HESAP_ADI\r\n,L.DEBIT TUTAR\r\n,L.LINEEXP ACIKLAMA\r\n,H.CLDEF TYP\r\nFROM LG_001_EMUHACC AS H\r\nINNER JOIN LG_001_01_EMFLINE AS L ON L.ACCOUNTREF=H.LOGICALREF\r\nINNER JOIN LG_001_01_EMFICHE AS F ON F.LOGICALREF=L.ACCFICHEREF\r\nWHERE H.CODE LIKE\u00277%\u0027\r\nAND L.CANCELLED=0\r\nAND YEAR(F.DATE_)\u003e2021\r\nAND H.CLDEF IN (\u0027ARGE GİDERLERİ\u0027)\r\n\r\n\r\n\r\nUNION ALL\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\nSELECT \r\nYEAR(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY\r\n,\u0027710\u0027 GRUP\r\n,\u0027R\u0027 OZEL_KOD\r\n,\u0027710\u0027 HESAP_KODU\r\n,\u0027Üretimden giriş\u0027 HESAP_ADI\r\n,l.TOTAL TUTAR\r\n,(SELECT CODE FROM LG_001_PROJECT WHERE LOGICALREF=L.PROJECTREF) IS_EMRI_N0\r\n,\u0027MAL MALİYETİ Üretim Giriş\u0027 TYP\r\nFROM LG_001_01_STFICHE AS F\r\nINNER JOIN LG_001_01_STLINE AS L ON L.STFICHEREF=F.LOGICALREF\r\nINNER JOIN LG_001_ITEMS AS S ON S.LOGICALREF=L.STOCKREF\r\nwhere YEAR(F.DATE_)\u003e2021\r\nAND F.TRCODE=13\r\n\r\nUNION ALL\r\n\r\n\r\nSELECT\r\nYEAR(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY\r\n,\u0027TLP\u0027 GRUP\r\n,\u0027\u0027 OZEL_KOD\r\n,S.CODE \u0027HESAP_KODU\u0027\r\n,S.DEFINITION_ \u0027HESAP_ADI\u0027\r\n,L.PRICE TUTAR\r\n,L.LINEEXP ACIKLAMA\r\n,S.DEFINITION2 TYP\r\n\r\n\r\n\r\nFROM LG_001_01_DEMANDLINE AS L\r\nINNER JOIN LG_001_SRVCARD AS S ON S.LOGICALREF=L.ITEMREF\r\nINNER JOIN LG_001_01_DEMANDFICHE AS F ON F.LOGICALREF=L.DEMANDFICHEREF\r\n\r\nWHERE S.CODE LIKE\u0027X 7%\u0027\r\nAND YEAR(l.PROCUREDATE)\u003e2021\r\nAND S.DEFINITION2 NOT IN (\u0027CAPEX\u0027,\u0027ARGE GİDERLERİ\u0027)\r\n\r\n--SELECT * FROM LG_001_01_DEMANDLINE\r\n\r\n--UNION ALL\r\n\r\n--SELECT\r\n--YEAR(F.DATE_) YIL\r\n--,MONTH(F.DATE_) AY\r\n--,\u0027TLP\u0027 GRUP\r\n--,\u0027\u0027 OZEL_KOD\r\n--,S.CODE \u0027HESAP_KODU\u0027\r\n--,S.DEFINITION_ \u0027HESAP_ADI\u0027\r\n--,L.PRICE TUTAR\r\n--,L.LINEEXP ACIKLAMA\r\n--,S.DEFINITION2 TYP\r\n\r\n\r\n\r\n--FROM LG_001_01_DEMANDLINE AS L\r\n--INNER JOIN LG_001_SRVCARD AS S ON S.LOGICALREF=L.ITEMREF\r\n--INNER JOIN LG_001_01_DEMANDFICHE AS F ON F.LOGICALREF=L.DEMANDFICHEREF\r\n\r\n--WHERE S.CODE LIKE\u0027X 7%\u0027\r\n--AND YEAR(l.PROCUREDATE)\u003e2021\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
