{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_PEOJE_BAKIYE_123",
    "full_name":  "dbo.AA_PEOJE_BAKIYE_123",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[AA_PEOJE_BAKIYE_123] AS\r\n\r\nselect \r\np.code PROJE_KODU\r\n,P.NAME PROJE_ADI\r\n,P.SPECODE OZELKOD\r\n,(SELECT SUM(NETTOTAL) FROM LG_123_01_ORFICHE WHERE PROJECTREF=P.LOGICALREF) SIPARIS_TUTARI_TL\r\n,(SELECT SUM(TRNET) FROM LG_123_01_ORFICHE WHERE PROJECTREF=P.LOGICALREF) SIPARIS_TUTARI_DOVIZ\r\n,(SELECT MAX(CASE TRCURR WHEN 1 THEN \u0027USD\u0027  WHEN 20 THEN \u0027EUR\u0027 ELSE \u0027TL\u0027  END) FROM LG_123_01_ORFICHE WHERE PROJECTREF=P.LOGICALREF) PARA_BRIMI\r\n,ISNULL((SELECT SUM(TRNET) FROM LG_123_01_CLFLINE WHERE CLPRJREF=P.LOGICALREF AND SIGN=1),0) GELEN_ODEME\r\n,ISNULL((SELECT SUM(TRNET) FROM LG_123_01_CLFLINE WHERE CLPRJREF=P.LOGICALREF AND SIGN=0),0) KESILEN_FAT\r\n,ISNULL((SELECT SUM(TRNET) FROM LG_123_01_CLFLINE WHERE CLPRJREF=P.LOGICALREF AND SIGN=0),0) \r\n-ISNULL((SELECT SUM(TRNET) FROM LG_123_01_CLFLINE WHERE CLPRJREF=P.LOGICALREF AND SIGN=1),0) KALAN\r\n--,P.LOGICALREF\r\nfrom LG_123_PROJECT as p\r\nwhere P.ACTIVE=0\r\n--WHERE P.CODE=\u0027G0135\u0027\r\n",
    "columns":  [
                    {
