{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DST_123_01_URETIM_FARK_TL",
    "full_name":  "dbo.DST_123_01_URETIM_FARK_TL",
    "definition":  "CREATE VIEW [dbo].[DST_123_01_URETIM_FARK_TL] AS\r\n\r\nSELECT\r\n\r\nTA.*\r\n\r\nFROM\r\n\r\n(SELECT\r\n\r\n LEFT(STF.FICHENO,12) [SARF FIS NO]\r\n,STF.DATE_ [TARIH]\r\n,ROUND(SUM(VATMATRAH),2) [SARF TOPLAM]\r\n\r\n,[UG TOPLAM] = (SELECT ROUND(SUM(VATMATRAH),2) FROM LG_123_01_STLINE STLU WHERE STLU.QPRODFCREF = STLS.QPRODFCREF AND STLU.TRCODE = 13 AND STLU.CANCELLED = 0 )\r\n,[UG FİŞNO] = (SELECT STF1.FICHENO FROM LG_123_01_STFICHE STF1 ,LG_123_01_STLINE STLU WHERE STF1.LOGICALREF =STLU.STFICHEREF AND STLU.QPRODFCREF = STLS.QPRODFCREF AND STLU.TRCODE = 13 AND STLU.CANCELLED = 0 )\r\n,QPR.FICHENO URETIM_NO\r\nFROM LG_123_01_STLINE STLS\r\nLEFT JOIN LG_123_01_STFICHE STF ON STF.LOGICALREF = STLS.STFICHEREF\r\nLEFT JOIN LG_123_01_QPRODUCT QPR ON QPR.LOGICALREF=STF.QPRODFCREF\r\n\r\nWHERE STLS.TRCODE = 12 AND STLS.CANCELLED = 0 AND STLS.QPRODFCREF \u003e 0\r\n\r\nGROUP BY STF.FICHENO , STF.DATE_ , STLS.QPRODFCREF ,QPR.FICHENO\r\n\r\n) TA\r\n\r\nWHERE TA.[SARF TOPLAM] \u003c\u003e TA.[UG TOPLAM]\r\n\r\n\r\n\r\n-------------------------------------\r\n\r\n\r\n\r\n",
