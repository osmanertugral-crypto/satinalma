    "name":  "LV_002_01_TRDGRP",
    "full_name":  "dbo.LV_002_01_TRDGRP",
    "definition":  "CREATE VIEW [dbo].[LV_002_01_TRDGRP] AS\nSELECT\n CLCARD.LOGICALREF AS CARI_REF,\n CLCARD.ACTIVE AS KULLANIM, CLCARD.CODE AS CARI_KODU, CLCARD.DEFINITION_ AS CARI_UNVANI, CLCARD.SPECODE AS OZEL_KOD,\n  CLCARD.SPECODE2 AS OZEL_KOD2, CLCARD.SPECODE3 AS OZEL_KOD3, CLCARD.SPECODE4 AS OZEL_KOD4, CLCARD.SPECODE5 AS OZEL_KOD5,\n  CLCARD.CYPHCODE AS YETKI_KODU, CLCARD.TELNRS1 AS TEL_NO1, CLCARD.TELNRS2 TEL_NO2 ,\n  CLCARD.CELLPHONE AS CEP_TELEFONU , CLCARD.COUNTRY AS ULKE ,CLCARD.CITY AS SEHIR , CLCARD.TOWN AS ILCE,\n  (CASE WHEN TRDGRP = \u0027\u0027 THEN NULL ELSE TRDGRP END) AS TIG_KODU,\n  GDEF TIG_ACIKLAMA,\n  SUM(DEBIT) AS BORC,\n  SUM(CREDIT) AS ALACAK,\n  CONVERT(SMALLDATETIME,\u002701.01.2006\u0027,103) AS \"TARIH\",\n  CASE WHEN TRDGRP=\u0027\u0027 THEN 0 ELSE 1 END AS TIG_SAYI, DATE_, BRANCH,\n  SUM(DEBIT)-SUM(CREDIT) AS BAKIYE\nFROM\n    (\n    (SELECT CTRNS.TRADINGGRP AS TRDGRP,\n            ROUND(ISNULL(SUM((1-CTRNS.SIGN)*CTRNS.AMOUNT),0),2) AS DEBIT,\n            ROUND(ISNULL(SUM(CTRNS.SIGN*CTRNS.AMOUNT),0),2) AS CREDIT ,\n            CTRNS.CLIENTREF , TGRP.GDEF,CTRNS.DATE_,CTRNS.BRANCH\n    FROM (LG_002_01_CLFLINE CTRNS WITH(NOLOCK)\n    LEFT OUTER JOIN \"TIGER3\"..L_TRADGRP TGRP WITH(NOLOCK) ON TGRP.GCODE = CTRNS.TRADINGGRP)\n    WHERE (CTRNS.TRCODE IN (31, 32, 33, 34, 36, 37, 38, 39, 43, 44, 56, 1, 2, 3, 4, 5, 6, 12, 14, 41, 42, 70, 71, 20, 21, 61, 62, 63, 64, 81, 82))\n            AND\n           (CTRNS.CANCELLED = 0)\n            AND\n           (CTRNS.MODULENR \u003c\u003e 4)\n           AND\n           (TGRP.GATTRIB \u003e= 512)\n    GROUP BY CTRNS.CLIENTREF , CTRNS.TRADINGGRP , TGRP.GDEF,CTRNS.DATE_,CTRNS.BRANCH)\n    UNION ALL\n    (SELECT CTRNS.TRADINGGRP AS TRDGRP, ROUND(ISNULL(SUM(((1-CTRNS.SIGN)+(CTRNS.SIGN*INVFC.FROMKASA))*CTRNS.AMOUNT),0),2) AS DEBIT,\n            ROUND(ISNULL(SUM((CTRNS.SIGN+((1-CTRNS.SIGN)*INVFC.FROMKASA))*CTRNS.AMOUNT),0),2) AS CREDIT , CTRNS.CLIENTREF , TGRP.GDEF,\n   CTRNS.DATE_,CTRNS.BRANCH\n    FROM LG_002_01_CLFLINE CTRNS WITH(NOLOCK) LEFT OUTER JOIN \"TIGER3\"..L_TRADGRP TGRP WITH(NOLOCK) ON TGRP.GCODE = CTRNS.TRADINGGRP\n            LEFT OUTER JOIN LG_002_01_INVOICE INVFC WITH(NOLOCK) ON (CTRNS.SOURCEFREF = INVFC.LOGICALREF)\n    WHERE (CTRNS.TRCODE IN (31, 32, 33, 34, 36, 37, 38, 39, 43, 44, 56, 1, 2, 3, 4, 5, 6, 12, 14, 41, 42, 70, 71, 20, 21, 61, 62, 63, 64))\n            AND (CTRNS.CANCELLED = 0)\n            AND (CTRNS.MODULENR=4)\n            AND (TGRP.GATTRIB \u003e= 512)\n    GROUP BY CTRNS.CLIENTREF , CTRNS.TRADINGGRP , TGRP.GDEF,CTRNS.DATE_,CTRNS.BRANCH)\n ) AS TMP_TABLE\n      LEFT OUTER JOIN LG_002_CLCARD CLCARD WITH(NOLOCK) ON TMP_TABLE.CLIENTREF = CLCARD.LOGICALREF\nGROUP BY CLCARD.LOGICALREF, CLCARD.ACTIVE, CLCARD.CODE, CLCARD.DEFINITION_, CLCARD.SPECODE, CLCARD.SPECODE2, CLCARD.SPECODE3,\n      CLCARD.SPECODE4, CLCARD.SPECODE5, CLCARD.CYPHCODE , CLCARD.TELNRS1, CLCARD.TELNRS2,\n      CLCARD.CELLPHONE, CLCARD.COUNTRY ,CLCARD.CITY, CLCARD.TOWN, TRDGRP , GDEF,DATE_, BRANCH",
