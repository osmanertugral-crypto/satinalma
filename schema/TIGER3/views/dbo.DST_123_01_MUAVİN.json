    "name":  "DST_123_01_MUAVİN",
    "full_name":  "dbo.DST_123_01_MUAVİN",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[DST_123_01_MUAVİN] AS\r\nSELECT     \r\nEMF.FICHENO AS [Fiş No], \r\nCASE \r\nWHEN EMF.TRCODE=1 THEN \u0027Açılış\u0027\r\nWHEN EMF.TRCODE=2 THEN \u0027Tahsil\u0027\r\nWHEN EMF.TRCODE=3 THEN \u0027Tediye\u0027\r\nWHEN EMF.TRCODE=4 THEN \u0027Mahsup\u0027\r\nWHEN EMF.TRCODE=5 THEN \u0027Özel Fiş\u0027\r\nWHEN EMF.TRCODE=6 THEN \u0027Kur Farkı Fişi\u0027\r\nWHEN EMF.TRCODE=7 THEN \u0027Kapanış\u0027\r\nWHEN EMF.TRCODE=8 THEN \u0027Enflasyon Muhasebesi Fişi\u0027\r\nWHEN EMF.TRCODE=9 THEN \u0027Konsolidasyon Düzeltme Fişi\u0027\r\nWHEN EMF.TRCODE=9 THEN \u0027TFRS Düzeltme Fişi\u0027\r\nELSE \u0027\u0027 end [Fiş Türü],\r\nEML.KEBIRCODE [Kebir],\r\nCASE EMF.MODULENR \r\nWHEN 1 THEN \u0027Malzeme Fişi\u0027 WHEN 2 THEN \u0027Satınalma Ft\u0027 WHEN 3 THEN \u0027Satış Ft\u0027 WHEN 4 THEN \u0027Cari Hesap Fişi\u0027 \r\nWHEN 5 THEN \u0027Çek-Senet Bordro\u0027 WHEN 6 THEN \u0027Banka Fişi\u0027 WHEN 7 THEN \u0027Kasa İşlemi\u0027 WHEN 20 THEN \u0027Dağıtım Fişi\u0027 \r\nWHEN 25 THEN \u0027Sabit Kıymet\u0027 WHEN 0 THEN \u0027Kaynak Fiş Yok\u0027 ELSE \u0027\u0027 END AS [Kaynak Fiş Türü], \r\nMONTH(EMF.DATE_) AY ,\r\nEMF.DATE_ AS [Fiş Tarihi], \r\nEMF.JOURNALNO AS [Yevmiye No], \r\nEMU.CODE AS [Hesap Kodu],\r\nEMU.DEFINITION_ AS [Hesap Adı],\r\n \r\nEML.DEBIT AS Borç, EML.CREDIT AS Alacak,\r\nCASE WHEN EML.TRCURR = 0 THEN \u0027TL\u0027 WHEN EML.TRCURR = 1 THEN \u0027USD\u0027 WHEN EML.TRCURR = 20 THEN \u0027EUR\u0027 ELSE \u0027\u0027 END AS Döviz,\r\nCASE WHEN EML.SIGN = 0 THEN EML.TRNET ELSE 0 END AS [Borç İD], CASE WHEN EML.SIGN = 1 THEN EML.TRNET ELSE 0 END AS [Alacak İD],\r\nEML.LINEEXP AS Açıklama\r\n\r\n,EMF.CAPIBLOCK_CREADEDDATE [Eklenme Tarihi]\r\n,CPU.NAME [Ekleyen]\r\n\r\n,ISNULL(EMU2.CODE,\u0027\u0027)[Karşı Hesap Kodu],\r\nISNULL(EMU2.DEFINITION_,\u0027\u0027) [Karşı Hesap Adı],\r\n\r\nCASE EMF.MODULENR WHEN 2 THEN ISNULL(INV.FICHENO,\u0027\u0027) WHEN 7 THEN ISNULL(KSL.FICHENO ,\u0027\u0027)WHEN 3 THEN ISNULL(INV.FICHENO,\u0027\u0027)\r\nWHEN 6 THEN ISNULL(BNF.FICHENO ,\u0027\u0027)WHEN 4 THEN ISNULL(CLF.FICHENO ,\u0027\u0027) WHEN 5 THEN ISNULL(CSR.ROLLNO ,\u0027\u0027)WHEN 0 THEN \u0027Kaynak Fiş türü yok\u0027\r\nELSE \u0027\u0027 END[Kaynak Fiş Numarası]\r\n\r\n\r\n\r\nFROM dbo.LG_123_01_EMFLINE AS EML WITH (NOLOCK) \r\n       LEFT OUTER JOIN dbo.LG_123_EMUHACC AS EMU WITH (NOLOCK)  ON EML.ACCOUNTREF = EMU.LOGICALREF \r\n       LEFT OUTER JOIN dbo.LG_123_01_EMFICHE AS EMF WITH (NOLOCK)  ON EMF.LOGICALREF = EML.ACCFICHEREF\r\n\t     LEFT OUTER JOIN LG_123_EMUHACC  AS EMU2 ON EMU2.CODE=EML.CROSSCODE\r\n\r\n\t\t LEFT JOIN LG_123_01_INVOICE INV ON INV.LOGICALREF=EML.SOURCEFREF \r\n\r\nLEFT JOIN LG_123_01_BNFICHE BNF ON BNF.LOGICALREF=EML.SOURCEFREF\r\nLEFT JOIN LG_123_01_CLFICHE CLF ON CLF.LOGICALREF=EML.SOURCEFREF  \r\nLEFT JOIN LG_123_01_KSLINES KSL ON KSL.LOGICALREF=EML.SOURCEFREF \r\nLEFT JOIN LG_123_01_CSROLL CSR ON CSR.LOGICALREF=EML.SOURCEFREF\r\n\r\n       LEFT OUTER JOIN L_CAPIUSER AS CPU  WITH (NOLOCK) ON CPU.NR=EMF.CAPIBLOCK_CREATEDBY\r\n\r\n\r\nWHERE EML.CANCELLED=0-- AND EMF.DATE_ BETWEEN \u002720210101\u0027 AND \u002720210131\u0027\r\n",
