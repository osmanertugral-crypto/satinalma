{
    "type":  "view",
    "schema":  "dbo",
    "name":  "KS_SATIS_123_MALIYET_ARABA_RAPORU",
    "full_name":  "dbo.KS_SATIS_123_MALIYET_ARABA_RAPORU",
    "definition":  "\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[KS_SATIS_123_MALIYET_ARABA_RAPORU] AS\r\n\r\nWITH ARABA_TABLE as (\r\nSELECT PROJECT.CODE PRJ_CODE, ITEMS.CODE ARABA_TABLE_CODE, ITEMS.NAME ARABA_TABLE_NAME, ITEMS.NAME3 ARABA_TABLE_NAME3,STLINE_SATINALMA.PRICE ARABA_TABLE_PRICE, STLINE_SATINALMA.ADDTAXAMOUNT  ARABA_TABLE_ADDTAXAMOUNT\r\nFROM LG_123_01_STLINE STLINE WITH(NOLOCK) \r\nINNER JOIN LG_123_01_STFICHE STFICHE WITH(NOLOCK) ON STLINE.STFICHEREF =  STFICHE.LOGICALREF\r\nLEFT OUTER JOIN LG_123_ITEMS ITEMS WITH(NOLOCK) ON ITEMS.LOGICALREF = STLINE.STOCKREF\r\nLEFT OUTER JOIN LG_123_PROJECT PROJECT WITH(NOLOCK) ON STFICHE.PROJECTREF =  PROJECT.LOGICALREF\r\nLEFT OUTER JOIN LG_123_01_STLINE STLINE_SATINALMA WITH(NOLOCK) ON STLINE_SATINALMA.STOCKREF =  STLINE.STOCKREF AND ((STLINE_SATINALMA.TRCODE =14 and STLINE_SATINALMA.STFICHEREF \u003e 0) OR (STLINE_SATINALMA.TRCODE IN (1,50,51)))\r\nWHERE STFICHE.TRCODE = 12 \r\nAND STFICHE.CANCELLED = 0\r\nAND (ITEMS.CODE LIKE \u0027%ARABA%\u0027 OR ITEMS.STGRPCODE LIKE \u0027%ARABA%\u0027 )\r\n) \r\n\r\nSELECT \r\nYEAR(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY\r\n,F.DATE_ TARIH\r\n,F.FICHENO FATURA_NO\r\n,C.CODE CARI_KODU\r\n,C.DEFINITION_ CARI_ADI\r\n,REPLACE(S.CODE,\u0027-01\u0027,\u0027\u0027) STOK_KODU--S.CODE\r\n,S.NAME STOK_ADI\r\n\r\n,CASE F.TRCODE WHEN 3 THEN L.AMOUNT*-1 ELSE L.AMOUNT END MIKTAR\r\n\r\n,CASE F.TRCODE WHEN 3 THEN (L.PRICE) *-1 ELSE (L.PRICE) END FIYAT\r\n,CASE L.DISTCOST WHEN 0 THEN (CASE F.TRCODE WHEN 3 THEN L.VATAMNT*-1 ELSE L.VATAMNT END) ELSE 0 END KDV\r\n,CASE F.TRCODE WHEN 3 THEN CASE WHEN L.TRCODE=7 THEN (L.TOTAL-L.VATAMNT) - (L.DISTCOST) ELSE (L.TOTAL) - (L.DISTCOST) END *-1\r\n\r\nELSE CASE WHEN L.TRCODE=7 THEN (L.TOTAL-L.VATAMNT) - (L.DISTCOST) ELSE (L.TOTAL) - (L.DISTCOST) END END TUTAR\r\n\r\n,D_EXC.RATES1 USD_KUR\r\n,CASE WHEN ISNULL(D_EXC.RATES1,0) = 0 THEN 0 ELSE ((CASE F.TRCODE WHEN 3 THEN L.PRICE*-1 ELSE L.PRICE END) / D_EXC.RATES1) END FIYAT_USD\r\n\r\n,CASE WHEN ISNULL(D_EXC.RATES1,0) = 0 THEN 0 ELSE ((CASE L.DISTCOST WHEN 0 THEN (CASE F.TRCODE WHEN 3 THEN L.VATAMNT*-1 ELSE L.VATAMNT END) ELSE 0 END) / D_EXC.RATES1) END KDV_USD\r\n\r\n,CASE WHEN ISNULL(D_EXC.RATES1,0) = 0 THEN 0\r\nELSE \r\n((\r\nCASE F.TRCODE WHEN 3 THEN CASE WHEN L.TRCODE=7 THEN (L.TOTAL-L.VATAMNT) - (L.DISTCOST) ELSE (L.TOTAL) - (L.DISTCOST) END *-1\r\n\r\n\r\nELSE CASE WHEN L.TRCODE=7 THEN (L.TOTAL-L.VATAMNT) - (L.DISTCOST) ELSE (L.TOTAL) - (L.DISTCOST) END END)\r\n\r\n/ D_EXC.RATES1)\r\nEND TUTAR_USD\r\n\r\n,D_EXC_EUR.RATES1 EUR_KUR\r\n,CASE WHEN ISNULL(D_EXC_EUR.RATES1,0) = 0 THEN 0 ELSE ((CASE F.TRCODE WHEN 3 THEN L.PRICE*-1 ELSE L.PRICE END) / D_EXC_EUR.RATES1) END  FIYAT_EUR\r\n\r\n,CASE WHEN ISNULL(D_EXC_EUR.RATES1,0) = 0 THEN 0 ELSE ((CASE L.DISTCOST WHEN 0 THEN (CASE F.TRCODE WHEN 3 THEN L.VATAMNT*-1 ELSE L.VATAMNT END) ELSE 0 END) / D_EXC_EUR.RATES1) END KDV_EUR\r\n\r\n\r\n,CASE WHEN ISNULL(D_EXC_EUR.RATES1,0) = 0 THEN 0\r\nELSE \r\n((\r\nCASE F.TRCODE WHEN 3 THEN CASE WHEN L.TRCODE=7 THEN (L.TOTAL-L.VATAMNT) - (L.DISTCOST) ELSE (L.TOTAL) - (L.DISTCOST) END *-1\r\n\r\n\r\nELSE CASE WHEN L.TRCODE=7 THEN (L.TOTAL-L.VATAMNT) - (L.DISTCOST) ELSE (L.TOTAL) - (L.DISTCOST) END END)\r\n\r\n/ D_EXC_EUR.RATES1)\r\nEND TUTAR_EUR\r\n\r\n--,ISNULL ((SELECT S.DISCPER FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=2 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0 AND S.PARENTLNREF=L.LOGICALREF),0) \u0027S INDIRIM ORANI\u0027\r\n--,ISNULL ((SELECT S.DISCPER FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=2 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0 AND S.PARENTLNREF=0),0) \u0027G INDIRIM ORANI\u0027\r\n--,ISNULL ((SELECT S.TOTAL/(INVOICELNNO-1) FROM LG_123_01_STLINE S WITH (NOLOCK) WHERE LINETYPE=3 AND INVOICEREF=F.LOGICALREF AND S.DISCPER\u003e0),0) \u0027MASRAF TUTARI\u0027\r\n\r\n,(SELECT DEFINITION_ FROM LG_123_SPECODES WITH (NOLOCK) WHERE SPECODETYPE=25 AND SPECODE=L.SPECODE) TUR\r\n,CASE WHEN L.TRCODE=3 THEN \u0027IADE\u0027 \r\n\t\tWHEN L.TRCODE=14 THEN \u0027FİYAT FARKI\u0027\r\n\t\tWHEN L.TRCODE=6 THEN \u0027SATINALMA IADE\u0027 ELSE \u0027SATIS\u0027 END FIS_TURU\r\n,[dbo].[FN_TRCODE](\u0027Stline\u0027,L.TRCODE,L.STFICHEREF,0) FIS_TURU_2\r\n,(SELECT CODE FROM LG_123_PROJECT WITH (NOLOCK) WHERE LOGICALREF=L.PROJECTREF) IS_EMRI_N0\r\n,(SELECT NAME FROM LG_123_PROJECT WITH (NOLOCK) WHERE LOGICALREF=L.PROJECTREF) IS_EMRI_ADI\r\n,S.SPECODE2 \u0027KARAVAN_TUR\u0027\r\n,CASE WHEN C.SPECODE5 = \u0027GST\u0027 THEN \u0027YURTDIŞI\u0027 ELSE \u0027YURTİÇİ\u0027 END \u0027SATIS_BOLGE\u0027\r\n\r\n\r\n,dbo.KS_RecipeCostFunc(REPLACE(S.CODE,\u0027-01\u0027,\u0027\u0027)) SON_SATINALMA\r\n,dbo.KS_RecipeCostFuncByDate(REPLACE(S.CODE,\u0027-01\u0027,\u0027\u0027),L.DATE_) SON_SATINALMA_FATURA_TARIHINE_GORE\r\n,dbo.KS_RecipeCostModPriceFuncByDate(REPLACE(S.CODE,\u0027-01\u0027,\u0027\u0027),L.DATE_) ORTALAMA_FIYAT_FATURA_TARIHINE_GORE\r\n, ((\r\n\r\nSELECT SUM(STLINE.LINENET+STLINE.DIFFPRICE)\r\nFROM LG_123_01_STLINE STLINE WITH(NOLOCK) \r\nINNER JOIN LG_123_01_STFICHE STFICHE WITH(NOLOCK) ON STLINE.STFICHEREF =  STFICHE.LOGICALREF\r\nLEFT OUTER JOIN LG_123_ITEMS ITEMS WITH(NOLOCK) ON ITEMS.LOGICALREF = STLINE.STOCKREF\r\nLEFT OUTER JOIN LG_123_PROJECT PROJECT WITH(NOLOCK) ON STFICHE.PROJECTREF =  PROJECT.LOGICALREF\r\nWHERE STFICHE.TRCODE = 12 \r\nAND STFICHE.CANCELLED = 0\r\nAND PROJECT.CODE = REPLACE(S.CODE,\u0027-01\u0027,\u0027\u0027)\r\n)) SARF_MALIYET\r\n\r\n,ARABA.ARABA_TABLE_CODE ARABA_KODU\r\n,ARABA.ARABA_TABLE_NAME ARABA_ADI\r\n,ARABA.ARABA_TABLE_PRICE ARABA_SATINALMA\r\n,ARABA.ARABA_TABLE_ADDTAXAMOUNT OTV_GIDERI_4 \r\n\r\n\r\nFROM LG_123_01_STLINE AS L WITH (NOLOCK)\r\nINNER JOIN LG_123_ITEMS AS S WITH (NOLOCK) ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_123_01_INVOICE AS F WITH (NOLOCK) ON F.LOGICALREF=L.INVOICEREF\r\nINNER JOIN LG_123_CLCARD AS C WITH (NOLOCK) ON C.LOGICALREF=F.CLIENTREF\r\nLEFT JOIN LG_123_EMUHACC EMU WITH (NOLOCK) ON EMU.LOGICALREF = L.ACCOUNTREF\r\nLEFT OUTER JOIN LG_EXCHANGE_123 D_EXC WITH (NOLOCK) ON D_EXC.CRTYPE = 1  AND D_EXC.EDATE = L.DATE_\r\nLEFT OUTER JOIN LG_EXCHANGE_123 D_EXC_EUR WITH (NOLOCK) ON D_EXC_EUR.CRTYPE = 20  AND D_EXC_EUR.EDATE = L.DATE_\r\nLEFT OUTER JOIN ARABA_TABLE ARABA ON ARABA.PRJ_CODE =REPLACE(S.CODE,\u0027-01\u0027,\u0027\u0027)\r\nWHERE LINETYPE=0 \r\nAND F.CANCELLED=0\r\nAND YEAR(F.DATE_)\u003e2023\r\nAND S.CYPHCODE = \u0027KARAVAN\u0027\r\n",
