    "definition":  "CREATE VIEW AA_RECETE_LISTESI AS\r\n\r\n\r\nselect \r\nSM.CODE MAMUL_KODU\r\n,SM.NAME MAMUL_ADI\r\n,S.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,R.AMNT MIKTAR\r\n,U.CODE BIRIM\r\n\r\n\r\n\r\n\r\nfrom LG_001_STCOMPLN AS R\r\nINNER JOIN LG_001_ITEMS AS S ON S.LOGICALREF=R.STCREF\r\nINNER JOIN LG_001_ITEMS AS SM ON SM.LOGICALREF=R.MAINCREF\r\nINNER JOIN LG_001_UNITSETL AS U ON U.LOGICALREF=R.UOMREF\r\n\r\n\r\n\r\n\r\n\r\n--WHERE MAINCREF=4869\r\n\r\n",
