{
    "type":  "view",
    "schema":  "dbo",
    "name":  "KREKPOT_RECETE_LISTESI_MALIYETLI_123",
    "full_name":  "dbo.KREKPOT_RECETE_LISTESI_MALIYETLI_123",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\nCREATE     VIEW [dbo].[KREKPOT_RECETE_LISTESI_MALIYETLI_123] AS\r\n\r\n-- Eğer bunu bir view olarak kaydedecekseniz başına CREATE VIEW [dbo].[VIEW_ADI] AS ekleyebilirsiniz.\r\n\r\nSELECT \r\n    SM.CODE AS MAMUL_KODU,\r\n    SM.CAPIBLOCK_CREADEDDATE AS TARIH,\r\n    SM.NAME AS MAMUL_ADI,\r\n    S.CODE AS STOK_KODU,\r\n    S.NAME AS STOK_ADI,\r\n    R.AMNT AS MIKTAR,\r\n    U.CODE AS BIRIM,\r\n    \r\n    -- 1. YENİ EKLENTİ: Mamülün oluşturulma tarihindeki alt malzeme birim alış maliyeti\r\n    CAST(ISNULL(SON_ALIS.BR_FIYAT, ISNULL(FIYAT_KARTI.PRICE, 0)) AS DECIMAL(18,2)) AS GUNCEL_ALIS_FIYATI,\r\n    \r\n    -- 2. YENİ EKLENTİ: Reçetedeki miktar ile birim fiyatın çarpımı (Toplam Satır Maliyeti)\r\n    CAST(R.AMNT * ISNULL(SON_ALIS.BR_FIYAT, ISNULL(FIYAT_KARTI.PRICE, 0)) AS DECIMAL(18,2)) AS TOPLAM_TUTAR\r\n\r\nFROM LG_123_STCOMPLN AS R WITH (NOLOCK)\r\nINNER JOIN LG_123_ITEMS AS S WITH (NOLOCK) ON S.LOGICALREF = R.STCREF\r\nINNER JOIN LG_123_ITEMS AS SM WITH (NOLOCK) ON SM.LOGICALREF = R.MAINCREF\r\nINNER JOIN LG_123_UNITSETL AS U WITH (NOLOCK) ON U.LOGICALREF = R.UOMREF\r\n\r\n-- MALİYET BULUCU 1: Alt malzeme için ilgili tarihten önceki en son Alış/Devir fişi\r\nOUTER APPLY (\r\n    SELECT TOP 1 (STL.LINENET + STL.DIFFPRICE) / NULLIF(STL.AMOUNT, 0) AS BR_FIYAT\r\n    FROM LG_123_01_STLINE STL WITH (NOLOCK)\r\n    WHERE STL.STOCKREF = S.LOGICALREF -- Aramayı alt malzeme (S) için yapıyoruz\r\n      AND STL.PRICE \u003e 0\r\n      AND STL.TRCODE IN (1, 14) \r\n      AND STL.DATE_ \u003c= SM.CAPIBLOCK_CREADEDDATE -- Hedef tarih: Mamül kartının (SM) oluşturulma tarihi\r\n    ORDER BY STL.DATE_ + dbo.LG_INTTOTIME(STL.FTIME) DESC\r\n) SON_ALIS\r\n\r\n-- MALİYET BULUCU 2: Eğer fişlerde hareket yoksa Fiyat Kartlarına (PRCLIST) bak\r\nOUTER APPLY (\r\n    SELECT TOP 1 PRC.PRICE\r\n    FROM LG_123_PRCLIST PRC WITH (NOLOCK)\r\n    WHERE PRC.CARDREF = S.LOGICALREF\r\n      AND PRC.BEGDATE \u003c= SM.CAPIBLOCK_CREADEDDATE\r\n    ORDER BY PRC.BEGDATE DESC\r\n) FIYAT_KARTI\r\n\r\nWHERE SM.CARDTYPE = 12 \r\n  AND SM.CYPHCODE = \u0027KARAVAN\u0027\r\n\r\n",
