    "name":  "AA_SATIS_SIPARIS_123",
    "full_name":  "dbo.AA_SATIS_SIPARIS_123",
    "definition":  "\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_SATIS_SIPARIS_123] AS\r\n\r\nselect \r\nF.FICHENO SIPARIS_NO\r\n,F.DATE_ SIPARIS_TARIHI\r\n,C.CODE CARI_KODU\r\n,C.DEFINITION_ CARI_UNVANI\r\n,S.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,L.AMOUNT MIKTAR\r\n,L.PRICE FIYAT\r\n,L.TOTAL TUTAR\r\n,CASE L.TRCURR WHEN 1 THEN \u0027USD\u0027 WHEN 20  THEN \u0027EUR\u0027 WHEN 17 THEN \u0027GBP\u0027 ELSE \u0027TL\u0027 END DOVIZ_TURU\r\n,L.TRRATE DOVIZ_KURU\r\n,L.PRICE/CASE WHEN L.TRRATE=0 THEN 1 ELSE L.TRRATE END  DOVIZ_FIYAT\r\n,L.TOTAL/CASE WHEN L.TRRATE=0 THEN 1 ELSE L.TRRATE END DOVIZ_TUTAR\r\n,(SELECT NUMFLDS15 FROM  LG_123_01_DEFNFLDSTRANV WHERE MODULENR=8 AND PARENTREF=F.LOGICALREF) FATURA_TUTARI\r\n,(SELECT CASE NUMFLDS17 WHEN 1 THEN \u0027EUR\u0027 WHEN 2 THEN  \u0027USD\u0027 WHEN 4 THEN \u0027GBP\u0027 ELSE \u0027TL\u0027 END  FROM  LG_123_01_DEFNFLDSTRANV WHERE MODULENR=8 AND PARENTREF=F.LOGICALREF) FATURA_DOVIZ_TURU\r\n,(SELECT NUMFLDS16 FROM  LG_123_01_DEFNFLDSTRANV WHERE MODULENR=8 AND PARENTREF=F.LOGICALREF) FATURA_KDV_ORANI\r\n\r\n,(SELECT DBO.LG_INTTODATE(NUMFLDS18) FROM  LG_123_01_DEFNFLDSTRANV WHERE NUMFLDS18\u003c\u003e0 AND MODULENR=8 AND PARENTREF=F.LOGICALREF) PLANLANAN_URETIM_TARIHI\r\n,(SELECT DBO.LG_INTTODATE(NUMFLDS19) FROM  LG_123_01_DEFNFLDSTRANV WHERE NUMFLDS19\u003c\u003e0 AND MODULENR=8 AND PARENTREF=F.LOGICALREF) GERCEKLESEN_URETIM_TARIHI\r\n,(SELECT DBO.LG_INTTODATE(NUMFLDS20) FROM  LG_123_01_DEFNFLDSTRANV WHERE NUMFLDS20\u003c\u003e0 AND MODULENR=8 AND PARENTREF=F.LOGICALREF) PLANLANAN_TESLIM_TARIHI\r\n,(SELECT DBO.LG_INTTODATE(NUMFLDS21) FROM  LG_123_01_DEFNFLDSTRANV WHERE NUMFLDS21\u003c\u003e0 AND MODULENR=8 AND PARENTREF=F.LOGICALREF) GERCEKLESEN_TESLIM_TARIHI\r\n,L.LINENO_ SIRA\r\n\r\nfrom lg_123_01_ORFLINE AS L\r\nINNER JOIN LG_123_01_ORFICHE AS F ON F.LOGICALREF=L.ORDFICHEREF\r\nINNER JOIN LG_123_CLCARD AS C ON C.LOGICALREF=F.CLIENTREF\r\nINNER JOIN LG_123_ITEMS AS S ON S.LOGICALREF=L.STOCKREF\r\n\r\n\r\nAND F.TRCODE=1\r\n\r\n\r\n\r\n\r\n--SELECT * FROM LG_123_01_DEFNFLDSTRANV \r\n",
