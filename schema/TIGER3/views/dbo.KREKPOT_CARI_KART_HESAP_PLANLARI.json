{
    "type":  "view",
    "schema":  "dbo",
    "name":  "KREKPOT_CARI_KART_HESAP_PLANLARI",
    "full_name":  "dbo.KREKPOT_CARI_KART_HESAP_PLANLARI",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\nCREATE     view [dbo].[KREKPOT_CARI_KART_HESAP_PLANLARI] as\r\n\r\nSELECT     CLCARD.CODE, CLCARD.DEFINITION_, EMUH.MUHCODE, EMUH.MUHDEFINITION_,PYP.CODE AS ODEME_PLANI,PYP.DEFINITION_ AS ODEME_PLANI_ACIKLAMA\r\nFROM            LG_123_CLCARD AS CLCARD LEFT OUTER JOIN\r\n                             (SELECT        CRDACREF.CARDREF, EMUHACC.CODE AS MUHCODE, EMUHACC.DEFINITION_ AS MUHDEFINITION_\r\n                               FROM            lg_123_CRDACREF AS CRDACREF FULL OUTER JOIN\r\n                                                         lg_123_EMUHACC AS EMUHACC ON CRDACREF.ACCOUNTREF = EMUHACC.LOGICALREF\r\n                               WHERE        (CRDACREF.TRCODE = 5)) AS EMUH ON CLCARD.LOGICALREF = EMUH.CARDREF\r\n\t\t\t\t\t\t\t   LEFT OUTER JOIN LG_123_PAYPLANS AS PYP ON CLCARD.PAYMENTREF = PYP.LOGICALREF\r\n\r\n\r\n",
    "columns":  [
