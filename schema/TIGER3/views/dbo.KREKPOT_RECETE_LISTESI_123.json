    "full_name":  "dbo.KREKPOT_RECETE_LISTESI_123",
    "definition":  "\r\n\r\n\r\n\r\n\r\nCREATE   VIEW [dbo].[KREKPOT_RECETE_LISTESI_123] AS\r\n\r\nselect \r\nSM.CODE MAMUL_KODU\r\n,SM.CAPIBLOCK_CREADEDDATE TARIH\r\n,SM.NAME MAMUL_ADI\r\n,S.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,R.AMNT MIKTAR\r\n,U.CODE BIRIM\r\n\r\n\r\n\r\n\r\nfrom LG_123_STCOMPLN AS R\r\nINNER JOIN LG_123_ITEMS AS S ON S.LOGICALREF=R.STCREF\r\nINNER JOIN LG_123_ITEMS AS SM ON SM.LOGICALREF=R.MAINCREF\r\nINNER JOIN LG_123_UNITSETL AS U ON U.LOGICALREF=R.UOMREF\r\n\r\nwhere SM.CARDTYPE=12 AND SM.CYPHCODE=\u0027KARAVAN\u0027\r\n\r\n",
