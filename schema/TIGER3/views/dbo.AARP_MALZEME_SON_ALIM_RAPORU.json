{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AARP_MALZEME_SON_ALIM_RAPORU",
    "full_name":  "dbo.AARP_MALZEME_SON_ALIM_RAPORU",
    "definition":  "\r\n\r\n\r\nCREATE VIEW [dbo].[AARP_MALZEME_SON_ALIM_RAPORU] AS \r\nselect \r\n  CODE AS KOD\r\n, NAME AS TANIM\r\n, ISNULL((SELECT SUM(MIKTAR) FROM AA_DEPO_STOK_RAPORU WHERE MLZ_ID=LOGICALREF),0) AS TOPLAM_STOK\r\n\r\n, ISNULL(CAST(ISNULL((SELECT TOP 1 (NULLIF(LINENET,0)/NULLIF(AMOUNT,0))  \r\nFROM LG_001_01_STLINE WHERE TRCODE=1 AND STOCKREF= MLZ.LOGICALREF ORDER BY DATE_ DESC),\r\n(SELECT TOP 1 PRICE  \r\nFROM LG_001_01_ORFLINE WHERE TRCODE=2 AND STOCKREF= MLZ.LOGICALREF ORDER BY DATE_ DESC)\r\n\r\n)AS DECIMAL(18,2)),0) SON_ALIM_TL\r\n\r\n, (SELECT TOP 1 DATE_  FROM LG_001_01_STLINE WHERE TRCODE=1 AND STOCKREF= MLZ.LOGICALREF ORDER BY DATE_ DESC) SON_ALIM_TARIHI\r\n\r\nfrom LG_001_ITEMS MLZ WHERE ACTIVE=0\r\n\r\n",
    "columns":  [
                    {
                        "COLUMN_NAME":  "KOD",
                        "ORDINAL_POSITION":  1,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "25",
