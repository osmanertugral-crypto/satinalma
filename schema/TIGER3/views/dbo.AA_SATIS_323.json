    "name":  "AA_SATIS_323",
    "full_name":  "dbo.AA_SATIS_323",
    "definition":  "\r\nCREATE VIEW AA_SATIS_323 AS\r\n\r\nSELECT        YEAR(F.DATE_) AS YIL, MONTH(F.DATE_) AS AY, F.DATE_ AS TARIH, F.FICHENO AS FATURA_NO, C.CODE AS CARI_KODU, C.DEFINITION_ AS CARI_ADI, \u0027\u0027 AS STOK_KODU, \u0027\u0027 AS STOK_ADI, 1 AS MIKTAR, \r\n                         L.DEBIT - L.CREDIT AS FIYAT, 0 AS KDV, L.DEBIT - L.CREDIT AS TUTAR, D_EXC.RATES1 AS USD_KUR, CASE WHEN ISNULL(D_EXC.RATES1, 0) = 0 THEN 0 ELSE ((L.DEBIT) - (L.CREDIT) / D_EXC.RATES1) END AS FIYAT_USD, \r\n                         0 AS KDV_USD, CASE WHEN ISNULL(D_EXC.RATES1, 0) = 0 THEN 0 ELSE ((L.DEBIT) - (L.CREDIT) / D_EXC.RATES1) END AS TUTAR_USD, L.TRRATE AS EUR_KUR, \r\n                         \r\n\t\t\t\t\t\t \r\n\t\t\t\t\t\t CASE WHEN SIGN = 0 THEN L.TRNET ELSE L.TRNET * - 1 END AS FIYAT_EUR, 0 AS KDV_EUR, CASE WHEN SIGN = 0 THEN L.TRNET ELSE L.TRNET * - 1 END AS TUTAR_EUR, \u0027\u0027 AS [S INDIRIM ORANI], \u0027\u0027 AS [G INDIRIM ORANI], \r\n                         \u0027\u0027 AS [MASRAF TUTARI], \u0027\u0027 AS TUR, \r\n\t\t\t\t\t\t CASE WHEN KEBIRCODE=\u0027610\u0027 THEN \u0027IADE\u0027 ELSE \r\n\t\t\t\t\t\t CASE WHEN (L.DEBIT - L.CREDIT) \u003e 0 THEN \u0027SATIŞ\u0027 ELSE \u0027ALIM\u0027 END END AS \u0027FIS_TURU\u0027,\r\n                         \r\n\t\t\t\t\t\t \r\n\t\t\t\t\t\t (SELECT        CODE\r\n                               FROM            dbo.LG_323_PROJECT WITH (NOLOCK)\r\n                               WHERE        (LOGICALREF = L.PROJECTREF)) AS IS_EMRI_N0,\r\n                             (SELECT        NAME\r\n                               FROM            dbo.LG_323_PROJECT WITH (NOLOCK)\r\n                               WHERE        (LOGICALREF = L.PROJECTREF)) AS IS_EMRI_ADI, F.FICHENO AS [MUH FİŞ NO], C.CODE AS [MUHASEBE FİŞİ MUHASEBE KODU]\r\nFROM            dbo.LG_323_01_EMFLINE AS L WITH (NOLOCK) INNER JOIN\r\n                         dbo.LG_323_EMUHACC AS C WITH (NOLOCK) ON C.LOGICALREF = L.ACCOUNTREF INNER JOIN\r\n                         dbo.LG_323_01_EMFICHE AS F WITH (NOLOCK) ON F.LOGICALREF = L.ACCFICHEREF LEFT OUTER JOIN\r\n                         dbo.LG_EXCHANGE_323 AS D_EXC WITH (NOLOCK) ON D_EXC.CRTYPE = 1 AND D_EXC.EDATE = F.DATE_ LEFT OUTER JOIN\r\n                         dbo.LG_EXCHANGE_323 AS D_EXC_EUR WITH (NOLOCK) ON D_EXC_EUR.CRTYPE = 20 AND D_EXC_EUR.EDATE = F.DATE_\r\nWHERE        (YEAR(F.DATE_) \u003e 2021) AND (L.KEBIRCODE IN (\u0027120\u0027, \u0027320\u0027, \u0027610\u0027)) AND (ISNULL(L.PROJECTREF, 0) \u003c\u003e 0)",
