{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DST_123_STOK_GIRIS_CIKIS",
    "full_name":  "dbo.DST_123_STOK_GIRIS_CIKIS",
    "definition":  "\r\n\r\n\r\nCREATE VIEW [dbo].[DST_123_STOK_GIRIS_CIKIS] AS\r\n\r\n\r\n\r\nSELECT\r\nCASE WHEN STL.IOCODE IN (1,2) THEN \u0027GIRIS\u0027 WHEN STL.IOCODE IN (3,4) THEN \u0027CIKIS\u0027 ELSE \u0027DIGER\u0027 END [HARELET TURU]\r\n,CASE STL.TRCODE \r\nWHEN 1 THEN \u0027SATIN ALMA IRS\u0027\r\nWHEN 2 THEN\u0027PAR. SATIS IADE IRS\u0027\r\nWHEN 3 THEN\u0027TOPTAN SATIS IADE IRS\u0027\r\nWHEN 4 THEN\u0027KONS. CIKIS IADE \u0027\r\nWHEN 5 THEN\u0027KONS. GIRIS\u0027\r\nWHEN 6 THEN\u0027SATIN ALMA IADE IRS\u0027\r\nWHEN 7 THEN\u0027PAR. SATIS IRS\u0027\r\nWHEN 8 THEN\u0027TOPTAN SATIS IRS\u0027\r\nWHEN 9 THEN\u0027KONS CIKIS IRS\u0027\r\nWHEN 10 THEN\u0027KONS. GIRIS IADE\u0027\r\nWHEN 11 THEN\u0027FIRE FISI\u0027\r\nWHEN 12 THEN\u0027SARF FISI\u0027\r\nWHEN 13 THEN\u0027URT. GIRIS FISI\u0027\r\nWHEN 14 THEN\u0027DEVIR FISI\u0027\r\nWHEN 25 THEN\u0027AMBAR FISI\u0027\r\nWHEN 50 THEN\u0027SAYIM FAZ. FISI\u0027\r\nWHEN 51 THEN\u0027SAYIM EKS. FISI\u0027\r\nEND [FIS TURU] \r\n,ITM.CODE [MALZ. KODU]\r\n,ITM.NAME [MALZ. ADI]\r\n--EMC.CODE MM_KODU,\r\n--EMC.SPECODE MARKA,\r\n--EMC.CYPHCODE MODEL,\r\n--EMC.DEFINITION_ MM_ADI\r\n,STF.FICHENO [FIS NO]\r\n\r\n--,(select max(S1.DATE_) from LG_123_01_STLINE S1 where s1.LOGICALREF=STL.LOGICALREF ) XX\r\n,STF.DATE_ [TARIH]\r\n,STL.AMOUNT [MIKTAR]\r\n,UNL.NAME [BIRIM]\r\n,ROUND(STL.PRICE,3) [BIRIM FIYAT]\r\n,ROUND(STL.TOTAL,3) [TUTAR]\r\n,CASE STL.AMOUNT WHEN 0 THEN 0 ELSE STL.AMOUNT * (STL.UINFO2/STL.UINFO1) END [MIKTAR ANA BIRIM]\r\n,[KALAN ANA BIRIM] = (SELECT ROUND(SUM(CASE STL1.AMOUNT WHEN 0 THEN 0 ELSE CASE WHEN STL1.IOCODE IN (1,2) THEN STL1.AMOUNT * (STL1.UINFO2/STL1.UINFO1) WHEN  STL1.IOCODE IN (3,4) THEN (STL1.AMOUNT * (STL1.UINFO2/STL1.UINFO1)) * -1 END END),3) FROM LG_123_01_STLINE STL1 WHERE STL1.LINETYPE = 0 AND STL1.CANCELLED = 0 AND ((STL1.DATE_ \u003c STL.DATE_) OR (STL1.DATE_ = STL.DATE_ AND STL1.FTIME \u003c STL.FTIME) OR (STL1.DATE_ = STL.DATE_ AND STL1.FTIME = STL.FTIME AND STL1.LOGICALREF \u003c= STL.LOGICALREF)) AND STL1.STOCKREF = STL.STOCKREF)\r\nFROM LG_123_01_STLINE STL \r\nLEFT JOIN LG_123_ITEMS ITM ON ITM.LOGICALREF = STL.STOCKREF\r\nLEFT JOIN LG_123_01_STFICHE STF ON STF.LOGICALREF = STL.STFICHEREF\r\n\r\nLEFT JOIN LG_123_UNITSETL UNL ON UNL.LOGICALREF = STL.UOMREF\r\nLEFT JOIN LG_123_EMUHACC EMU ON EMU.LOGICALREF=STL.ACCOUNTREF\r\nLEFT JOIN LG_123_EMCENTER EMC ON EMC.LOGICALREF=STL.CENTERREF\r\nWHERE STL.LINETYPE = 0 AND STL.CANCELLED = 0 ---AND ITM.CODE=\u00272021X326\u0027\r\n--ORDER BY STF.DATE_ ASC\r\n",
