{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DST_001_01_KONTROLRAPORU",
    "full_name":  "dbo.DST_001_01_KONTROLRAPORU",
    "definition":  "\r\nCREATE VIEW [dbo].[DST_001_01_KONTROLRAPORU]\r\n\r\nAS\r\n\r\nSELECT DOCNR,DOCDATE\r\n\r\nFROM LG_001_01_APPROVAL\r\nWHERE RECTYPE=111 AND DOCDATE between \u002720221001\u0027 and  \u002720221231\u0027\r\n\r\nEXCEPT\r\n\r\nSELECT \r\nINV.FICHENO,DATE_\r\n\r\n\r\nFROM LG_001_01_INVOICE INV\r\n--LEFT JOIN LG_001_CLCARD CLC ON CLC.LOGICALREF=INV.CLIENTREF\r\n\r\nWHERE TRCODE IN (1,4) and DATE_ between \u002720221001\u0027 and  \u002720221231\u0027\r\n\r\n\r\n--------------------------------------------------\r\n\r\n",
    "columns":  [
                    {
                        "COLUMN_NAME":  "DOCNR",
                        "ORDINAL_POSITION":  1,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "25",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "DOCDATE",
                        "ORDINAL_POSITION":  2,
