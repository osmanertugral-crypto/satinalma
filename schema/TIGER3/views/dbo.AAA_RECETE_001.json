    "definition":  "CREATE VIEW AAA_RECETE_001 AS\r\nSELECT \r\nMAINCREF AS ANA_MALZEME_REF,\r\nSTCREF AS ALT_MALZEME_REF,\r\n(SELECT CODE FROM LG_001_ITEMS WHERE LOGICALREF=ST.STCREF) AS ALT_MALZEME_KODU,\r\n(SELECT NAME FROM LG_001_ITEMS WHERE LOGICALREF=ST.STCREF) AS ALT_MALZEME_AÇIKLAMASI,\r\n(SELECT CODE FROM LG_001_ITEMS WHERE LOGICALREF=ST.MAINCREF) AS ANA_MALZEME_KODU,\r\n(SELECT NAME FROM LG_001_ITEMS WHERE LOGICALREF=ST.MAINCREF) AS ANA_MALZEME_AÇIKLAMASI\r\n,*\r\nFROM LG_001_STCOMPLN AS ST ",
