    "name":  "BRK_PROJELERDE_KULLANILAN_ARAÇLAR",
    "full_name":  "dbo.BRK_PROJELERDE_KULLANILAN_ARAÇLAR",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[BRK_PROJELERDE_KULLANILAN_ARAÇLAR] AS\r\n\r\n\r\nSELECT PROJECT.CODE PRJ_CODE, ITEMS.CODE ARABA_TABLE_CODE, ITEMS.NAME ARABA_TABLE_NAME, ITEMS.NAME3 ARABA_TABLE_NAME3,STLINE_SATINALMA.PRICE ARABA_TABLE_PRICE, STLINE_SATINALMA.ADDTAXAMOUNT  ARABA_TABLE_ADDTAXAMOUNT\r\nFROM LG_123_01_STLINE STLINE WITH(NOLOCK) \r\nINNER JOIN LG_123_01_STFICHE STFICHE WITH(NOLOCK) ON STLINE.STFICHEREF =  STFICHE.LOGICALREF\r\nLEFT OUTER JOIN LG_123_ITEMS ITEMS WITH(NOLOCK) ON ITEMS.LOGICALREF = STLINE.STOCKREF\r\nLEFT OUTER JOIN LG_123_PROJECT PROJECT WITH(NOLOCK) ON STFICHE.PROJECTREF =  PROJECT.LOGICALREF\r\nLEFT OUTER JOIN LG_123_01_STLINE STLINE_SATINALMA WITH(NOLOCK) ON STLINE_SATINALMA.STOCKREF =  STLINE.STOCKREF AND ((STLINE_SATINALMA.TRCODE =14 and STLINE_SATINALMA.STFICHEREF \u003e 0) OR (STLINE_SATINALMA.TRCODE IN (1,50,51)))\r\nWHERE STFICHE.TRCODE = 12 \r\nAND STFICHE.CANCELLED = 0\r\nAND (ITEMS.CODE LIKE \u0027%ARABA%\u0027 OR ITEMS.STGRPCODE LIKE \u0027%ARABA%\u0027)\r\n\r\n",
    "columns":  [
                    {
