    "full_name":  "dbo.AA_SIPARIS_SATINALMA_RAPORU_YENI_123",
    "definition":  "--USE [TIGER3]\r\n--GO\r\n\r\n--/****** Object:  View [dbo].[AA_SIPARIS_SATINALMA_RAPORU_YENI_123]    Script Date: 22.11.2023 15:59:14 ******/\r\n--SET ANSI_NULLS ON\r\n--GO\r\n\r\n--SET QUOTED_IDENTIFIER ON\r\n--GO\r\n\r\n\r\nCREATE VIEW [dbo].[AA_SIPARIS_SATINALMA_RAPORU_YENI_123] AS\r\nSELECT\r\nTA1.YIL YIL,\r\nTA1.AY AY,\r\nTA1.TARIH\r\n,TA1.FISNO\r\n,TA1.CARI_KODU\r\n,TA1.CARI_UNVANI\r\n,TA1.STOK_KODU\r\n,TA1.STOK_ADI,\r\nTA1.STOK_GRUP,\r\nTA1.MIKTAR,\r\nTA1.BIRIM BIRIM,\r\nSUM(TA1.TALINAN) TALINAN,\r\nTA1.BEKLEYEN,\r\nTA1.IADE_MIKTAR,\r\nTA1.FIYAT,\r\nTA1.TUTAR,\r\n\r\n\r\nTA1.RD_KUR,\r\nTA1.RD_EUR_TUTAR_SIPARIS\r\n----,TA1.FATURA_RDKUR\r\n----,TA1.FATURA_TARIHI\r\n,SUM(TA1.FATURA_TUTAR)FATURA_TUTAR\r\n,SUM(TA1.[TOPLAM FATURA TUTAR])[TOPLAM FATURALANAN TUTAR]\r\n\r\n--,SUM(TA1.FATURA_TUTAR_YENI) FATURA_TUTAR_YENI\r\n\r\n\r\n,SUM(TA1. RD_FATURA_EUR)RD_FATURA_EUR\r\n-----,TA1.RD_EUR_BIRIM_FIYAT_FATURA\r\n,TA1.[KESILEN_KUR (SİPARİŞ İ.D. KURU)]\r\n,TA1. SIPARIS_DOVIZ_TIPI\r\n----,TA1.ID_KESILEN_BIRIM_FIYAT\r\n,TA1.FATURA_KESİLEN_TUTAR FATURA_KESİLEN_TUTAR\r\n,TA1.KAPALI\r\n\r\n\r\n\r\n\r\nFROM\r\n\r\n\r\n(\r\n\r\n\r\n\r\n\r\n\r\n\r\nSELECT\r\nTA.YIL YIL,\r\nTA.AY AY,\r\nTA.TARIH\r\n,TA.FISNO\r\n,TA.CARI_KODU\r\n,TA.CARI_UNVANI\r\n,TA.STOK_KODU\r\n,TA.STOK_ADI,\r\nTA.STOK_GRUP,\r\nTA.MIKTAR,\r\nTA.BIRIM BIRIM,\r\nSUM(TA.TESLIM_ALINAN) TALINAN,\r\nTA.BEKLEYEN,\r\nTA.IADE_MIKTAR,\r\nTA.FIYAT,\r\nTA.TUTAR,\r\nTA.RD_KUR,\r\nTA.RD_EUR_TUTAR_SIPARIS\r\n,TA.FATURA_RDKUR\r\n,TA.FATURA_TARIHI\r\n,SUM(TA.FATURA_TUTAR)FATURA_TUTAR\r\n,SUM(TA.[TOPLAM FATURA TUTAR])[TOPLAM FATURA TUTAR]\r\n--,SUM(TA.FATURA_TUTAR_YENI) FATURA_TUTAR_YENI\r\n\r\n\r\n,SUM(TA.RD_FATURA_EUR) RD_FATURA_EUR\r\n,TA.RD_EUR_BIRIM_FIYAT_FATURA\r\n,TA.[KESILEN_KUR (SİPARİŞ İ.D. KURU)]\r\n,TA.SIPARIS_DOVIZ SIPARIS_DOVIZ_TIPI\r\n,TA.ID_KESILEN_BIRIM_FIYAT\r\n,TA.KESILEN_TUTAR FATURA_KESİLEN_TUTAR\r\n,TA.KAPALI\r\n\r\nFROM\r\n\r\n(\r\nSELECT \r\n CASE WHEN ((L.AMOUNT - L.SHIPPEDAMOUNT)\u003c=0) OR (L.CLOSED=1) THEN 1 ELSE 0 END AS KAPALI,\r\nyear(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY \r\n,F.DATE_ TARIH\r\n,F.FICHENO FISNO\r\n,C.CODE CARI_KODU\r\n,C.DEFINITION_ CARI_UNVANI\r\n,S.CODE STOK_KODU\r\n,s.NAME STOK_ADI\r\n,S.STGRPCODE STOK_GRUP\r\n,SUM(L.AMOUNT)  MIKTAR\r\n,U.CODE BIRIM\r\n--,L.SHIPPEDAMOUNT TESLIM_ALINAN\r\n,L.AMOUNT AS[SIPARIS_MIKTAR]\r\n------------------------------------------------\r\n--,ISNULL(sum(SAT.AMOUNT),0) TESLIM_ALINAN\r\n,(select SUM(ALT.TALINAN) from AA_SIPARIS_SATINALMA_RAPORU_YENI_YEDEK_ESKIHALI_123 ALT WHERE  S.CODE=ALT.STOK_KODU AND ALT.CARI_KODU=C.CODE AND ALT.FISNO=F.FICHENO)TESLIM_ALINAN---////////////////////////////\r\n\r\n\r\n\r\n---------------------\r\n--,L.AMOUNT-L.SHIPPEDAMOUNT BEKLEYEN\r\n,CASE WHEN L.AMOUNT-L.SHIPPEDAMOUNT\u003c0 THEN 0 ELSE L.AMOUNT-L.SHIPPEDAMOUNT END AS BEKLEYEN\r\n---,ISNULL((SELECT sum(AMOUNT) FROM lg_123_01_STLINE WITH (NOLOCK) WHERE TRCODE=6 AND CLIENTREF=L.CLIENTREF AND STOCKREF=L.STOCKREF),0) AS IADE_MIKTAR\r\n--,ISNULL((SELECT sum(RETAMOUNT) FROM lg_123_01_STLINE WITH (NOLOCK) WHERE TRCODE=1 AND CLIENTREF=L.CLIENTREF AND STOCKREF=L.STOCKREF AND ORDFICHEREF=F.LOGICALREF AND L.LOGICALREF=ORDTRANSREF),0) AS IADE_MIKTAR\r\n---\r\n\r\n,(select SUM(ALT.IADE_MIKTAR) from AA_SIPARIS_SATINALMA_RAPORU_YENI_YEDEK_ESKIHALI_123 ALT WHERE  S.CODE=ALT.STOK_KODU AND ALT.CARI_KODU=C.CODE AND ALT.FISNO=F.FICHENO)IADE_MIKTAR--/////////////////////\r\n----\r\n,ROUND((L.LINENET/L.AMOUNT),2) FIYAT\r\n,SUM(L.TOTAL) TUTAR\r\n\r\n,CASE WHEN L.REPORTRATE=0 THEN (SELECT TOP 1 RATES2 FROM L_DAILYEXCHANGES WHERE CRTYPE=20 AND EDATE\u003e=L.DATE_ ORDER BY EDATE ASC) ELSE L.REPORTRATE END AS RD_KUR\r\n\r\n,CAST((NULLIF(L.LINENET,0)/NULLIF(L.AMOUNT,0))/CASE WHEN L.REPORTRATE=0 THEN (SELECT TOP 1 RATES2 FROM L_DAILYEXCHANGES WHERE \r\nCRTYPE=20 AND EDATE\u003e=L.DATE_ ORDER BY EDATE ASC) ELSE L.REPORTRATE END AS DECIMAL (18,2)) AS RD_EUR_TUTAR_SIPARIS\r\n,SAT.REPORTRATE FATURA_RDKUR\r\n,SAT.DATE_ FATURA_TARIHI\r\n,SUM(SAT.LINENET) FATURA_TUTAR\r\n---------------\r\n,(select SUM(ALT.FATURA_TUTAR_YENI) from AA_SIPARIS_SATINALMA_RAPORU_YENI_YEDEK_ESKIHALI_123 ALT WHERE  S.CODE=ALT.STOK_KODU AND ALT.CARI_KODU=C.CODE AND ALT.FISNO=F.FICHENO)[TOPLAM FATURA TUTAR]\r\n\r\n------------\r\n--,(SELECT SUM(S2.LINENET) FROM  LG_123_01_STLINE S2 WHERE S2.LOGICALREF= (select max(S3.LOGICALREF) from LG_123_01_STLINE S3 )  )FATURA_TUTAR_YENI\r\n--,(select ALT.FATURA_TUTAR from AA_SIPARIS_SATINALMA_RAPORU_YENI_YEDEK_ESKIHALI_123 ALT WHERE ALT.IRSALIYENO=SAT.STFICHEREF AND S.CODE=ALT.STOK_KODU) FATURA_TUTAR_YENI\r\n--,(SELECT S.LINENET FROM  LG_123_01_STLINE S WHERE S.LOGICALREF= (select max(S1.LOGICALREF) from LG_123_01_STLINE S1 WHERE S1.LOGICALREF=S.LOGICALREF) AND S.LOGICALREF=SAT.LOGICALREF  )FATURA_TUTAR_YENI\r\n--,(SELECT S1.LINENET FROM  LG_123_01_STLINE S1 WHERE S1.LOGICALREF= (select max(S1.LOGICALREF) from LG_123_01_STLINE S1 ) AND S1.LOGICALREF=SAT.LOGICALREF AND S1.STOCKREF=S.LOGICALREF )FATURA_TUTAR_YENI\r\n\r\n,SUM(CAST(ISNULL(( (NULLIF(SAT.LINENET,0)/NULLIF(SAT.REPORTRATE,0)) ),0) AS decimal(18,4)))RD_FATURA_EUR\r\n,cast(ISNULL(( ((NULLIF(SAT.LINENET,0)/NULLIF(SAT.REPORTRATE,0))/NULLIF(SAT.AMOUNT,0)) ),0) as decimal(18,4)) RD_EUR_BIRIM_FIYAT_FATURA\r\n,L.TRRATE [KESILEN_KUR (SİPARİŞ İ.D. KURU)]\r\n,CASE WHEN L.TRCURR =0 THEN \u0027TL\u0027 WHEN L.TRCURR =160 THEN \u0027TL\u0027 WHEN L.TRCURR =20 THEN \u0027EUR\u0027 WHEN L.TRCURR =1 THEN \u0027USD\u0027 ELSE \u0027XXX\u0027 END AS SIPARIS_DOVIZ\r\n,CASE WHEN SAT.TRCURR IN (0,160) THEN (NULLIF(L.LINENET,0)/NULLIF(L.AMOUNT,0)) ELSE\r\ncast(ISNULL(( ((NULLIF(SAT.LINENET,0)/NULLIF(SAT.TRRATE,0))/NULLIF(SAT.AMOUNT,0)) ),0) as decimal(18,4)) END ID_KESILEN_BIRIM_FIYAT\r\n,\r\nSUM(CASE WHEN SAT.TRCURR IN (0,160) THEN SAT.LINENET ELSE\r\nCAST(ISNULL(ROUND(NULLIF(SAT.LINENET,0)/NULLIF(SAT.TRRATE,0),2),0) AS DECIMAL (18,2)) END) KESILEN_TUTAR\r\n\r\n\r\n\r\n\r\n\r\nFROM LG_123_01_ORFLINE AS L WITH (NOLOCK)\r\nINNER JOIN LG_123_01_ORFICHE AS F WITH (NOLOCK) ON F.LOGICALREF=L.ORDFICHEREF\r\nINNER JOIN LG_123_ITEMS AS S WITH (NOLOCK) ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_123_CLCARD AS C WITH (NOLOCK) ON C.LOGICALREF=F.CLIENTREF\r\nINNER JOIN LG_123_UNITSETL AS U WITH (NOLOCK) ON U.LOGICALREF=L.UOMREF\r\nLEFT OUTER JOIN  LG_123_01_STLINE AS SAT  WITH (NOLOCK) ON SAT.ORDTRANSREF=L.LOGICALREF AND SAT.TRCODE IN (1) \r\nand Sat.LOGICALREF= (select max(S1.LOGICALREF) from LG_123_01_STLINE S1 where s1.ordtransref=L.LOGICALREF )\r\n--LEFT  JOIN  LG_123_01_STLINE AS SAT3  WITH (NOLOCK) ON SAT3.ORDTRANSREF=L.LOGICALREF AND SAT3.TRCODE IN (1) \r\nWHERE L.TRCODE=2\r\n--AND F.FICHENO=\u0027TEF2022000001285\u0027\r\n\r\n--and F.FICHENO=\u0027001336\u0027\r\n--AND F.FICHENO=\u0027001195\u0027\r\n--AND S.CODE=\u0027A2021X163\u0027\r\n\r\ngroup by l.date_,F.DATE_,F.FICHENO,C.CODE,S.STGRPCODE ,C.DEFINITION_,S.CODE,s.NAME,L.AMOUNT,U.CODE,L.SHIPPEDAMOUNT,L.CLIENTREF,L.STOCKREF,L.PRICE,L.TOTAL,\r\nL.REPORTRATE,L.LINENET,SAT.REPORTRATE,SAT.DATE_,SAT.LINENET,SAT.AMOUNT,L.TRRATE,L.TRCURR,SAT.TRCURR,SAT.TRRATE,F.LOGICALREF,L.LOGICALREF,SAT.LOGICALREF,S.LOGICALREF,SAT.STFICHEREF,L.CLOSED) TA\r\n--WHERE TA.FISNO=\u0027001825\u0027\r\n--WHERE TA.FISNO=\u0027001336\u0027\r\n--WHERE TA.STOK_KODU=\u0027KMPY0099H008\u0027\r\nGROUP BY \r\n\r\nTA.YIL,TA.MIKTAR,TA.AY,\r\nTA.TARIH\r\n,TA.FISNO\r\n,TA.CARI_KODU\r\n,TA.CARI_UNVANI\r\n,TA.STOK_KODU\r\n,TA.STOK_ADI\r\n,TA.STOK_GRUP\r\n,TA.BIRIM \r\n,TA.BEKLEYEN\r\n,TA.FIYAT\r\n,TA.TUTAR\r\n,TA.RD_KUR\r\n,TA.RD_EUR_TUTAR_SIPARIS\r\n,TA.FATURA_RDKUR\r\n,TA.FATURA_TARIHI\r\n--,TA.FATURA_TUTAR\r\n--,TA.FATURA_TUTAR_YENI\r\n,TA.RD_EUR_BIRIM_FIYAT_FATURA\r\n,TA.[KESILEN_KUR (SİPARİŞ İ.D. KURU)]\r\n,TA.SIPARIS_DOVIZ \r\n,TA.ID_KESILEN_BIRIM_FIYAT\r\n,TA.KESILEN_TUTAR\r\n,TA.IADE_MIKTAR,TA.KAPALI )TA1\r\n\r\n--WHERE TA1.STOK_KODU=\u0027A2021X163\u0027\r\nGROUP BY\r\n\r\nTA1.YIL,\r\nTA1.AY,\r\nTA1.TARIH,\r\nTA1.FISNO\r\n,TA1.CARI_KODU\r\n,TA1.CARI_UNVANI\r\n,TA1.STOK_KODU\r\n,TA1.STOK_ADI\r\n,TA1.STOK_GRUP\r\n,TA1.MIKTAR\r\n,TA1.BIRIM\r\n--,TA1.TALINAN\r\n,TA1.BEKLEYEN\r\n,TA1.IADE_MIKTAR\r\n,TA1.FIYAT\r\n,TA1.TUTAR\r\n,TA1.RD_KUR\r\n,TA1.RD_EUR_TUTAR_SIPARIS\r\n--,TA1.FATURA_RDKUR\r\n--,TA1.FATURA_TARIHI\r\n----,TA1.FATURA_TUTAR\r\n--,TA1.FATURA_TUTAR_YENI\r\n--,TA1. RD_FATURA_EUR\r\n--,TA1.RD_EUR_BIRIM_FIYAT_FATURA\r\n,TA1.[KESILEN_KUR (SİPARİŞ İ.D. KURU)]\r\n,TA1. SIPARIS_DOVIZ_TIPI\r\n--,TA1.ID_KESILEN_BIRIM_FIYAT\r\n,TA1.FATURA_KESİLEN_TUTAR,TA1.KAPALI\r\n\r\n\r\n",
