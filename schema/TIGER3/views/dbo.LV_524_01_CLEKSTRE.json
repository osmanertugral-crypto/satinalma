    "definition":  "CREATE VIEW [dbo].[LV_524_01_CLEKSTRE] AS\nSELECT\n  LGMAIN.LOGICALREF, LGMAIN.CLIENTREF, LGMAIN.SOURCEFREF, LGMAIN.DATE_, LGMAIN.TRANNO, LGMAIN.TRCODE, LGMAIN.LINEEXP, LGMAIN.MODULENR, LGMAIN.FTIME, LGMAIN.AMOUNT, LGMAIN.CYPHCODE,\n  CASE WHEN  LGMAIN.SIGN=0 THEN LGMAIN.AMOUNT ELSE 0 END DEBIT,\n  CASE WHEN  LGMAIN.SIGN=1 THEN LGMAIN.AMOUNT ELSE 0 END CREDIT,\n    LGMAIN.TRCURR,LGMAIN.TRNET,LGMAIN.DOCODE,LGMAIN.CANCELLED,LGMAIN.PAIDINCASH\nFROM\n     LG_524_01_CLFLINE LGMAIN WITH(NOLOCK)",
