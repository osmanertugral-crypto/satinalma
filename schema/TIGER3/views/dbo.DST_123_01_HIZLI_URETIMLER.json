    "name":  "DST_123_01_HIZLI_URETIMLER",
    "full_name":  "dbo.DST_123_01_HIZLI_URETIMLER",
    "definition":  "\r\nCREATE VIEW [dbo].[DST_123_01_HIZLI_URETIMLER] AS\r\n\r\nSELECT \r\n\r\nCASE WHEN STL.TRCODE=12 THEN \u0027SARF\u0027 WHEN STL.TRCODE=13 THEN \u0027ÜRETİM\u0027 ELSE \u0027DİĞER\u0027 END HAREKET,\r\nMONTH(STL.DATE_) AY,\r\nSTL.DATE_ TARIH,\r\nSTF.FICHENO FIS_NO,\r\nITM.CARDTYPE AS KART_TURU,\r\nITM.CODE STOK_KODU,\r\nITM.NAME STOK_ADI,\r\nITM.SPECODE2 MAMUL_TİPİ,\r\nITM.SPECODE5 ANA_MAMUL_TİPİ,\r\nCASE WHEN STL.UINFO1 = 0 THEN 0 ELSE CASE WHEN STL.TRCODE=13 THEN STL.AMOUNT*(STL.UINFO2/STL.UINFO1) ELSE STL.AMOUNT*(STL.UINFO2/STL.UINFO1)*-1 END END MIKTAR,\r\nCASE WHEN STL.TRCODE=13 THEN STL.PRICE ELSE STL.PRICE*-1 END AS FİŞ_BİRİM_FİYAT,\r\n--STL.PRICE AS BİRİM_FİYAT,\r\nCASE WHEN STL.TRCODE=13 THEN STL.TOTAL ELSE STL.TOTAL*-1 END AS FİŞ_TUTAR,\r\n--STL.TOTAL AS TUTAR,\r\nQPR.FICHENO URETIM_NO,\r\n\r\nSTL.OUTCOST *(CASE WHEN STL.UINFO1 = 0 THEN 0 ELSE CASE WHEN STL.TRCODE=13 THEN STL.AMOUNT*(STL.UINFO2/STL.UINFO1) ELSE STL.AMOUNT*(STL.UINFO2/STL.UINFO1)*-1 END END )[MALIYET],\r\nCAST(CWH.NR AS VARCHAR) + \u0027 - \u0027 + CWH.NAME AS AMBAR\r\n\r\n\r\nFROM LG_123_01_STLINE STL\r\n\t\tLEFT JOIN LG_123_ITEMS ITM ON ITM.LOGICALREF=STL.STOCKREF\r\n\t\tLEFT JOIN LG_123_01_STFICHE STF ON STF.LOGICALREF=STL.STFICHEREF\r\n\t\tLEFT JOIN LG_123_01_QPRODUCT QPR ON QPR.LOGICALREF=STF.QPRODFCREF\r\n\t\tLEFT JOIN L_CAPIWHOUSE CWH ON CWH.NR=STL.SOURCEINDEX AND CWH.FIRMNR=123\r\n\t\t\r\n\r\nWHERE (STF.QPRODFCREF=0  OR STF.QPRODFCREF\u003e0) AND  stl.trcode IN (12,13) --AND --and STF.FICHENO = \u0027URT-00018999-G\u0027--549--6299\r\n---AND QPR.FICHENO=\u0027000268\u0027\r\n--SELECT * FROM LG_123_01_QPRODUCT WHERE\r\n\r\n--SELECT * FROM LG_123_01_STLINE WHERE STFICHEREF=448\r\n--SELECT * FROM LG_123_01_STFICHE WHERE FICHENO=\u0027000027\u0027\r\n",
