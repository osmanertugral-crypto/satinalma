    "full_name":  "dbo.AAA_ORFLINE_ORFICHE_RAPOR",
    "definition":  "CREATE VIEW AAA_ORFLINE_ORFICHE_RAPOR AS\r\nSELECT\r\n\u0027O\u0027 AS DURUM,\r\nORFICHE.LOGICALREF AS ORFICHE_LOGICALREF,\r\nORFLINE.LOGICALREF AS  ORFLINE_LOGICALREF,\r\nORFICHE.PROJECTREF AS ORFICHE_PROJECTREF,\r\nORFLINE.PROJECTREF AS ORFLINE_PROJECTREF,\r\nORFLINE.STOCKREF AS ORFLINE_STOCKREF,\r\nCASE WHEN LINENO_=1 THEN LINENET ELSE 0 END AS B_SATIR_TUTAR\r\n,LINENO_\r\n,AMOUNT\r\n,LINENET\r\n,ORFICHE.FICHENO\r\nFROM LG_001_01_ORFICHE AS ORFICHE \r\nINNER JOIN LG_001_01_ORFLINE AS ORFLINE ON ORFICHE.LOGICALREF=ORFLINE.ORDFICHEREF",
