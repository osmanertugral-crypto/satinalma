    "name":  "LV_001_01_GNTOTCL",
    "full_name":  "dbo.LV_001_01_GNTOTCL",
    "definition":  "CREATE VIEW [dbo].[LV_001_01_GNTOTCL]\nAS\nSELECT 1 AS LOGICALREF\n ,CARDREF AS CARDREF\n ,1 AS TOTTYP\n ,SUM(DEBIT) AS DEBIT\n ,SUM(CREDIT) AS CREDIT\n ,BRANCH AS BRANCH\n ,DEPARTMENT AS DEPARTMENT\nFROM LV_001_01_CLTOTFILV1 WITH(NOEXPAND,NOLOCK)\nGROUP BY CARDREF,BRANCH,DEPARTMENT\nUNION ALL\nSELECT 1 AS LOGICALREF\n ,CARDREF AS CARDREF\n ,2 AS TOTTYP\n ,SUM(DEBIT_RC) AS DEBIT\n ,SUM(CREDIT_RC) AS CREDIT\n ,BRANCH AS BRANCH\n ,DEPARTMENT AS DEPARTMENT\nFROM LV_001_01_CLTOTFILV1 WITH(NOEXPAND,NOLOCK)\nWHERE DEBIT_RC \u003c\u003e0 OR  CREDIT_RC\u003c\u003e0\nGROUP BY CARDREF,BRANCH,DEPARTMENT",
