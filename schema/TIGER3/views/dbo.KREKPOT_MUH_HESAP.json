{
    "type":  "view",
    "schema":  "dbo",
    "name":  "KREKPOT_MUH_HESAP",
    "full_name":  "dbo.KREKPOT_MUH_HESAP",
    "definition":  "\r\n\r\n\r\nCREATE   view [dbo].[KREKPOT_MUH_HESAP] as\r\nSELECT EMUHACC.SPECODE CODE,\r\nSUM(DEBIT) AMOUNT_\r\nFROM LG_123_01_EMFLINE EMFLINE WITH(NOLOCK) \r\nINNER JOIN LG_123_01_EMFICHE EMFICHE WITH(NOLOCK) ON EMFICHE.LOGICALREF = EMFLINE.ACCFICHEREF \r\nLEFT JOIN LG_123_EMUHACC EMUHACC WITH(NOLOCK) ON EMUHACC.LOGICALREF = EMFLINE.ACCOUNTREF \r\nWHERE EMFLINE.CANCELLED = 0 AND  EMUHACC.SPECODE \u003c\u003e \u0027\u0027\r\nAND YEAR(EMFICHE.DATE_) = YEAR_\r\nAND MONTH(EMFICHE.DATE_) IN (MONTH_)\r\nGROUP BY EMUHACC.SPECODE\r\n\r\n\r\n",
    "columns":  [
                    {
                        "COLUMN_NAME":  "CODE",
                        "ORDINAL_POSITION":  1,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "11",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "AMOUNT_",
                        "ORDINAL_POSITION":  2,
                        "DATA_TYPE":  "float",
                        "CHARACTER_MAXIMUM_LENGTH":  "",
                        "IS_NULLABLE":  "YES"
                    }
                ],
