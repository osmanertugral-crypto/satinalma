    "name":  "AA_DETAYLI_ODEME_LISTESI",
    "full_name":  "dbo.AA_DETAYLI_ODEME_LISTESI",
    "definition":  "CREATE VIEW AA_DETAYLI_ODEME_LISTESI AS\n\n\n\nSELECT * FROM \n(\nSELECT *,(SELECT SUM(TL_TUTAR) FROM AA_DETAYLI_ODEME_DATA B WHERE A.CAR_ID=B.CAR_ID AND B.ISLEM_TARIHI\u003c=A.ISLEM_TARIHI) AS BAKIYE, ISNULL((SELECT SUM(AMOUNT) FROM LG_001_01_BNFLINE WHERE \nYEAR(DATE_)\u003e2021 AND  CLIENTREF=CAR_ID AND SIGN=1 AND TRCODE=4) ,0) ODEME\n\n FROM AA_DETAYLI_ODEME_DATA A \n ) AS RAPOR WHERE BAKIYE \u003eISNULL((SELECT SUM(AMOUNT) FROM LG_001_01_BNFLINE WHERE  YEAR(DATE_)\u003e2021 AND  CLIENTREF=CAR_ID AND SIGN=1 AND TRCODE=4) ,0) \n\n",
