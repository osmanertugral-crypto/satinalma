{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_RECETE_FIYAT_RAPORU_123",
    "full_name":  "dbo.AA_RECETE_FIYAT_RAPORU_123",
    "definition":  "\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_RECETE_FIYAT_RAPORU_123] AS \r\n\r\nSELECT KARAVAN_KODU,KARAVAN_ADI,ALT_KOD,ALT_ADI,MIKTAR,BIRIM_FIYATLAR , (MIKTAR*BIRIM_FIYATLAR) AS TUTAR FROM (\r\nSELECT ANAMLZ.LOGICALREF AS MLZ_ID,\r\n\r\nANAMLZ.CODE AS KARAVAN_KODU,\r\nANAMLZ.NAME AS KARAVAN_ADI,\r\nALT_MLZ.CODE AS ALT_KOD,\r\nALT_MLZ.NAME AS ALT_ADI\r\n,BAGTBL.AMNT AS MIKTAR\r\n,(SELECT TOP 1 LINENET/AMOUNT FROM LG_123_01_STLINE WHERE LINETYPE=0 AND PRICE\u003c\u003e0 AND STOCKREF=BAGTBL.STCREF AND TRCODE IN (1,50) ORDER BY DATE_ DESC ) BIRIM_FIYATLAR\r\n--,CASE WHEN (SELECT TOP 1 FIYAT FROM AA_FIYATLANDIRMA_RAPORU WHERE MLZ_ID=BAGTBL.STCREF AND FIYAT IS NOT NULL ORDER BY FIYAT DESC) IS NULL THEN\r\n--(SELECT TOP 1 TANIMLI_FIYAT FROM AA_FIYATLANDIRMA_RAPORU WHERE MLZ_ID=BAGTBL.STCREF AND TANIMLI_FIYAT IS NOT NULL ORDER BY TANIMLI_FIYAT DESC) \r\n--ELSE (SELECT TOP 1 FIYAT FROM AA_FIYATLANDIRMA_RAPORU WHERE MLZ_ID=BAGTBL.STCREF AND FIYAT IS NOT NULL ORDER BY FIYAT DESC)\r\n--END AS BIRIM_FIYATLAR\r\nFROM lg_123_ITEMS ANAMLZ\r\nINNER JOIN LG_123_STCOMPLN BAGTBL ON ANAMLZ.LOGICALREF=BAGTBL.MAINCREF\r\nLEFT OUTER JOIN LG_123_ITEMS ALT_MLZ ON ALT_MLZ.LOGICALREF=BAGTBL.STCREF\r\n WHERE ANAMLZ.SPECODE5=\u0027ANAMLZ\u0027 \r\n\r\n ) AS RAPOR\r\n\r\n",
