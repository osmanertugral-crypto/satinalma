    "full_name":  "dbo.DST_001_01_GİDER_TABLOSUyedek",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[DST_001_01_GİDER_TABLOSUyedek] AS\r\nSELECT     \r\n--EMF.FICHENO AS [Fiş No], \r\n--CASE \r\n--WHEN EMF.TRCODE=1 THEN \u0027Açılış\u0027\r\n--WHEN EMF.TRCODE=2 THEN \u0027Tahsil\u0027\r\n--WHEN EMF.TRCODE=3 THEN \u0027Tediye\u0027\r\n--WHEN EMF.TRCODE=4 THEN \u0027Mahsup\u0027\r\n--WHEN EMF.TRCODE=5 THEN \u0027Özel Fiş\u0027\r\n--WHEN EMF.TRCODE=6 THEN \u0027Kur Farkı Fişi\u0027\r\n--WHEN EMF.TRCODE=7 THEN \u0027Kapanış\u0027\r\n--WHEN EMF.TRCODE=8 THEN \u0027Enflasyon Muhasebesi Fişi\u0027\r\n--WHEN EMF.TRCODE=9 THEN \u0027Konsolidasyon Düzeltme Fişi\u0027\r\n--WHEN EMF.TRCODE=9 THEN \u0027TFRS Düzeltme Fişi\u0027\r\n--ELSE \u0027\u0027 end [Fiş Türü],\r\nEML.KEBIRCODE [Kebir],\r\n--CASE EMF.MODULENR \r\n--WHEN 1 THEN \u0027Malzeme Fişi\u0027 WHEN 2 THEN \u0027Satınalma Ft\u0027 WHEN 3 THEN \u0027Satış Ft\u0027 WHEN 4 THEN \u0027Cari Hesap Fişi\u0027 \r\n--WHEN 5 THEN \u0027Çek-Senet Bordro\u0027 WHEN 6 THEN \u0027Banka Fişi\u0027 WHEN 7 THEN \u0027Kasa İşlemi\u0027 WHEN 20 THEN \u0027Dağıtım Fişi\u0027 \r\n--WHEN 25 THEN \u0027Sabit Kıymet\u0027 WHEN 0 THEN \u0027Kaynak Fiş Yok\u0027 ELSE \u0027\u0027 END AS [Kaynak Fiş Türü], \r\nMONTH(EMF.DATE_) AY ,\r\n--EMF.DATE_ AS [Fiş Tarihi], \r\n--EMF.JOURNALNO AS [Yevmiye No], \r\nEMU.CODE AS [Hesap Kodu],\r\nEMU.DEFINITION_ AS [Hesap Adı],\r\nEMU.EXTNAME AS [Başlık Adı],\r\nSUM(EML.DEBIT)AS Borç,\r\nSUM(EML.CREDIT) AS Alacak,\r\n\r\nSUM(CASE WHEN  EML.DEBIT \u003eEML.CREDIT THEN EML.DEBIT -EML.CREDIT ELSE 0 END )AS Borç_Bakiye,\r\n--(EML.DEBIT -EML.CREDIT) AS \r\nSUM(CASE WHEN  EML.DEBIT \u003cEML.CREDIT THEN EML.CREDIT -EML.DEBIT ELSE 0 END) AS Alacak_Bakiye,\r\n\r\nSUM(CASE WHEN  EML.DEBIT \u003eEML.CREDIT THEN EML.DEBIT -EML.CREDIT ELSE 0 END )-SUM(CASE WHEN  EML.DEBIT \u003cEML.CREDIT THEN EML.CREDIT -EML.DEBIT ELSE 0 END) AS BAKIYE,\r\n--EML.CREDIT-EML.DEBIT as Alacak_Bakiye,\r\n--CASE WHEN EML.TRCURR = 0 THEN \u0027TL\u0027 WHEN EML.TRCURR = 1 THEN \u0027USD\u0027 WHEN EML.TRCURR = 20 THEN \u0027EUR\u0027 ELSE \u0027\u0027 END AS Döviz,\r\nSUM(CASE WHEN EML.SIGN = 0 THEN EML.TRNET ELSE 0 END) AS [Borç İD], SUM(CASE WHEN EML.SIGN = 1 THEN EML.TRNET ELSE 0 END) AS [Alacak İD]\r\n--EML.LINEEXP AS Açıklama\r\n--,EML.CROSSCODE [Karşı Hesap]\r\n--,EMF.CAPIBLOCK_CREADEDDATE [Eklenme Tarihi]\r\n--,CPU.NAME [Ekleyen]\r\n\r\n\r\n\r\nFROM dbo.LG_001_01_EMFLINE AS EML WITH (NOLOCK) \r\n       LEFT OUTER JOIN dbo.LG_001_EMUHACC AS EMU WITH (NOLOCK)  ON EML.ACCOUNTREF = EMU.LOGICALREF \r\n       LEFT OUTER JOIN dbo.LG_001_01_EMFICHE AS EMF WITH (NOLOCK)  ON EMF.LOGICALREF = EML.ACCFICHEREF\r\n       --LEFT OUTER JOIN L_CAPIUSER AS CPU  WITH (NOLOCK) ON CPU.NR=EMF.CAPIBLOCK_CREATEDBY\r\n\r\nWHERE EML.CANCELLED=0 AND EMF.DATE_ BETWEEN \u002720220101\u0027 AND \u002721001231\u0027\r\nand \r\nEML.ACCOUNTCODE IN (\r\n\u0027760.01.02.0003\u0027,\r\n\u0027760.01.02.0004\u0027,\r\n\u0027730.06.0001\u0027,\r\n\u0027760.05.0001\u0027,\r\n\u0027770.03.04.0003.001\u0027,\r\n\u0027770.03.04.0003.002\u0027,\r\n\u0027750.02.003\u0027,\r\n\u0027730.05.0010\u0027,\r\n\u0027730.05.0015\u0027,\r\n\u0027731.05.0010\u0027,\r\n\u0027750.02.002\u0027,\r\n\u0027750.03.001\u0027,\r\n\u0027751.01.001\u0027,\r\n\u0027770.04.02.0025\u0027,\r\n\u0027750.01.001\u0027,\r\n\u0027750.01.002\u0027,\r\n\u0027750.01.003\u0027,\r\n\u0027750.01.004\u0027,\r\n\u0027750.02.001\u0027,\r\n\u0027750.02.005\u0027,\r\n\u0027750.02.004\u0027,\r\n\u0027770.04.02.0037\u0027,\r\n\u0027770.04.02.0038\u0027,\r\n\u0027770.04.02.0039\u0027,\r\n\u0027780.02.01.0006\u0027,\r\n\u0027780.02.01.0007\u0027,\r\n\u0027780.02.01.0008\u0027,\r\n\u0027780.02.01.0010\u0027,\r\n\u0027780.01.01.0001\u0027,\r\n\u0027780.01.01.0002\u0027,\r\n\u0027780.01.01.0003\u0027,\r\n\u0027780.01.01.0004\u0027,\r\n\u0027780.01.01.0005\u0027,\r\n\u0027780.01.01.0007\u0027,\r\n\u0027780.01.01.0008\u0027,\r\n\u0027780.01.01.0011\u0027,\r\n\u0027780.01.01.0014\u0027,\r\n\u0027780.01.01.0015\u0027,\r\n\u002778