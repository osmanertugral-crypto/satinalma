    "full_name":  "dbo.AA_SIPARIS",
    "definition":  "--USE [TIGER3]\r\n--GO\r\n\r\n--/****** Object:  View [dbo].[AA_SIPARIS]    Script Date: 26.12.2022 11:03:16 ******/\r\n--SET ANSI_NULLS ON\r\n--GO\r\n\r\n--SET QUOTED_IDENTIFIER ON\r\n--GO\r\n\r\n\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_SIPARIS] AS\r\n\r\n\r\n\r\nSELECT \r\nyear(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY \r\n,F.DATE_ TARIH\r\n,F.FICHENO FISNO\r\n,C.CODE CARI_KODU\r\n,C.DEFINITION_ CARI_UNVANI\r\n,S.CODE STOK_KODU\r\n,s.NAME STOK_ADI\r\n,L.AMOUNT  MIKTAR\r\n,U.CODE BIRIM\r\n,L.SHIPPEDAMOUNT TESLIM_ALINAN\r\n,AMOUNT-L.SHIPPEDAMOUNT BEKLEYEN\r\n,ISNULL((SELECT sum(AMOUNT) FROM lg_001_01_STLINE WHERE TRCODE=6 AND CLIENTREF=L.CLIENTREF AND STOCKREF=L.STOCKREF),0) AS IADE_MIKTAR\r\n,L.PRICE FIYAT\r\n,L.TOTAL TUTAR\r\n,L.REPORTRATE KUR\r\n,ROUND(NULLIF(L.TOTAL,0)/NULLIF(L.REPORTRATE,0),2) EUR_TUTAR\r\n,(SELECT MAX(REPORTRATE) FROM LG_001_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF) FATURA_KUR\r\n,(SELECT MAX(DATE_) FROM LG_001_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF) FATURA_TARIHI\r\n,(SELECT SUM(LINENET) FROM LG_001_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF) FATURA_TUTAR\r\n\r\n,CAST(ISNULL((SELECT SUM(NULLIF(LINENET,0)/NULLIF(REPORTRATE,0)) FROM LG_001_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF AND LINENET\u003c\u003e0 AND REPORTRATE\u003c\u003e0),0) AS decimal(18,4)) FATURA_EUR\r\n,cast(ISNULL((SELECT SUM((NULLIF(LINENET,0)/NULLIF(REPORTRATE,0))/NULLIF(AMOUNT,0)) FROM LG_001_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF AND LINENET\u003c\u003e0 AND REPORTRATE\u003c\u003e0),0) as decimal(18,4)) EUR_BIRIM_FIYAT\r\n\r\n\r\n\r\n\r\n\r\nFROM LG_001_01_ORFLINE AS L\r\nINNER JOIN LG_001_01_ORFICHE AS F ON F.LOGICALREF=L.ORDFICHEREF\r\nINNER JOIN LG_001_ITEMS AS S ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_001_CLCARD AS C ON C.LOGICALREF=F.CLIENTREF\r\nINNER JOIN LG_001_UNITSETL AS U ON U.LOGICALREF=L.UOMREF\r\n\r\n\r\n\r\nWHERE L.TRCODE=2\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
