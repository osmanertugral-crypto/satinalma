    "name":  "BRK_PROJE_SARF_123",
    "full_name":  "dbo.BRK_PROJE_SARF_123",
    "definition":  "\r\n\r\nCREATE VIEW [dbo].[BRK_PROJE_SARF_123] AS\r\n\r\nSELECT \r\n    STFICHE.FICHENO AS FIS_NO, \r\n    STFICHE.DATE_ AS FIS_TARIHI, \r\n    ITEMS.CODE AS URUN_KODU, \r\n    ITEMS.NAME AS URUN_ADI, \r\n    ITEM_URUN.STGRPCODE AS URUN_TUR, \r\n    PROJECT.CODE AS PROJE_KODU, \r\n    PROJECT.NAME AS PROJE_ADI, \r\n    ITEM_PROJECT.SPECODE2 AS PROJE_TUR, \r\n    STLINE.AMOUNT AS ADET,  \r\n    STLINE.OUTCOST AS BIRIM_FIYAT, \r\n    STLINE.AMOUNT * STLINE.OUTCOST AS TOPLAM\r\n\r\nFROM LG_123_01_STLINE STLINE WITH(NOLOCK)\r\n\r\nINNER JOIN LG_123_01_STFICHE STFICHE WITH(NOLOCK) ON STLINE.STFICHEREF = STFICHE.LOGICALREF\r\nINNER JOIN LG_123_ITEMS ITEMS WITH(NOLOCK) ON STLINE.STOCKREF = ITEMS.LOGICALREF\r\nINNER JOIN LG_123_PROJECT PROJECT WITH(NOLOCK) ON STFICHE.PROJECTREF = PROJECT.LOGICALREF\r\nLEFT JOIN LG_123_ITEMS ITEM_PROJECT WITH(NOLOCK) ON PROJECT.CODE = ITEM_PROJECT.CODE\r\nLEFT JOIN LG_123_ITEMS ITEM_URUN WITH(NOLOCK) ON ITEMS.CODE = ITEM_URUN.CODE\r\n\r\nWHERE STLINE.TRCODE = 12\r\nAND STLINE.CANCELLED = 0\r\n\r\n",
    "columns":  [
