    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n--4706\r\nCREATE     VIEW [dbo].[ONR_TARIHLI_DEPO_RAPORU_123] AS \r\nSELECT \r\n\tLIST.AMBAR_KODU,\r\n\tS.STOK_KODU,\r\n\tS.STOK_ADI, \r\n\tLIST.MIKTAR,\r\n\tSB.BIRIM,\r\n\t--ADRES,\r\n\t--TAKIP_NO,\r\n\t--DURUM_KODU,\r\n\t--PALET,\r\n\t(SELECT AMBAR_ADI FROM EVIRA..AMBAR WHERE AMBAR_KODU=LIST.AMBAR_KODU) AS AMBAR_ADI\r\n\t\r\nFROM \r\n\r\n(\r\n\r\nSELECT  \r\n\tAMBAR_KODU,\r\n\tSTOK_REF,\r\n\tBIRIM_REF,\r\n\tISNULL(CONVERT(FLOAT,SUM(AT.MIKTAR)),0) AS MIKTAR\r\n\t--,ADRES,\r\n\t--TAKIP_NO,\r\n\t--DURUM_KODU,\r\n\t--PALET\r\n\t\r\nFROM \r\n\tEVIRA..AMBARTAKIPDETAY AT \r\nWHERE  \r\n\t\r\n\tAT.HAREKET_TARIHI\u003c=\u00272025-11-20\u0027\r\n\t\r\n\r\nGROUP BY \r\n\tSTOK_REF,\r\n\tBIRIM_REF,\r\n\tAMBAR_KODU\r\n\t--,ADRES,\r\n\t--TAKIP_NO,\r\n\t--DURUM_KODU,\r\n\t--PALET\r\n\t\r\n\t\r\nHAVING \t\r\n\tISNULL(CONVERT(NUMERIC(28,2),SUM(AT.MIKTAR)),0)\u003c\u003e0\t\r\n\t\r\n\r\n) AS LIST \r\n\tLEFT OUTER JOIN EVIRA..STOKKARTI S ON S.STOK_REF=LIST.STOK_REF\r\n\tLEFT OUTER JOIN EVIRA..STOKBIRIM SB ON SB.BIRIM_REF=LIST.BIRIM_REF\r\n",
