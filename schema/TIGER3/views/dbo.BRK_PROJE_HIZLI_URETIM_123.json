    "name":  "BRK_PROJE_HIZLI_URETIM_123",
    "full_name":  "dbo.BRK_PROJE_HIZLI_URETIM_123",
    "definition":  "\r\n\r\n\r\nCREATE VIEW [dbo].[BRK_PROJE_HIZLI_URETIM_123] AS\r\n\r\nSELECT \r\n    STFICHE.FICHENO AS FIS_NO, \r\n    STFICHE.DATE_ AS FIS_TARIHI, \r\n    ITEMS.CODE AS URUN_KODU, \r\n    ITEMS.NAME AS URUN_ADI, \r\n    PROJECT.CODE AS PROJE_KODU, \r\n    PROJECT.NAME AS PROJE_ADI, \r\n    ITEM_PROJECT.SPECODE2 AS PROJE_TUR,\r\n    (SELECT DEFINITION_ \r\n     FROM LG_123_SPECODES WITH (NOLOCK) \r\n     WHERE SPECODETYPE = 1 AND SPECODE = ITEM_PROJECT.SPECODE2) AS PROJE_TUR_AÇIKLAMA,\r\n    STLINE.AMOUNT AS ADET,  \r\n    STLINE.OUTCOST AS BIRIM_FIYAT, \r\n    STLINE.AMOUNT * STLINE.OUTCOST AS TOPLAM\r\nFROM LG_123_01_STLINE STLINE WITH(NOLOCK)\r\nINNER JOIN LG_123_01_STFICHE STFICHE WITH(NOLOCK) ON STLINE.STFICHEREF = STFICHE.LOGICALREF\r\nINNER JOIN LG_123_ITEMS ITEMS WITH(NOLOCK) ON STLINE.STOCKREF = ITEMS.LOGICALREF\r\nINNER JOIN LG_123_PROJECT PROJECT WITH(NOLOCK) ON STFICHE.PROJECTREF = PROJECT.LOGICALREF\r\nLEFT JOIN LG_123_ITEMS ITEM_PROJECT WITH(NOLOCK) ON PROJECT.CODE = ITEM_PROJECT.CODE\r\nWHERE STLINE.TRCODE = 13\r\n  AND STLINE.CANCELLED = 0\r\n  AND ITEMS.CYPHCODE = \u0027KARAVAN\u0027;\r\n\r\n\r\n\r\n",
