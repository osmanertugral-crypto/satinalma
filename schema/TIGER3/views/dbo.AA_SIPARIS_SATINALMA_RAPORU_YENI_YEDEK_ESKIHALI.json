{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_SIPARIS_SATINALMA_RAPORU_YENI_YEDEK_ESKIHALI",
    "full_name":  "dbo.AA_SIPARIS_SATINALMA_RAPORU_YENI_YEDEK_ESKIHALI",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n--6427\r\n\r\n\r\nCREATE VIEW [dbo].[AA_SIPARIS_SATINALMA_RAPORU_YENI_YEDEK_ESKIHALI] AS\r\n\r\n\r\nSELECT\r\n\r\nTA.YIL YIL,\r\nTA.AY AY,\r\nTA.TARIH\r\n,TA.FISNO\r\n,TA.CARI_KODU\r\n,TA.CARI_UNVANI\r\n,TA.STOK_KODU\r\n,TA.STOK_ADI,\r\nTA.MIKTAR,\r\nTA.BIRIM BIRIM,\r\nSUM(TA.TESLIM_ALINAN) TALINAN,\r\nTA.BEKLEYEN,\r\nTA.IADE_MIKTAR,\r\n TA.FIYAT,\r\n\r\nTA.TUTAR,\r\nTA.RD_KUR,\r\nTA.RD_EUR_TUTAR_SIPARIS\r\n,TA.FATURA_RDKUR\r\n,TA.FATURA_TARIHI\r\n,TA.IRSALIYENO\r\n,TA.FATURA_TUTAR FATURA_TUTAR\r\n,TA.FATURA_TUTAR_YENI FATURA_TUTAR_YENI\r\n,SUM(TA.RD_FATURA_EUR) RD_FATURA_EUR\r\n,TA.RD_EUR_BIRIM_FIYAT_FATURA\r\n,TA.[KESILEN_KUR (SİPARİŞ İ.D. KURU)]\r\n,TA.SIPARIS_DOVIZ SIPARIS_DOVIZ_TIPI\r\n,TA.ID_KESILEN_BIRIM_FIYAT\r\n,SUM(TA.KESILEN_TUTAR) FATURA_KESİLEN_TUTAR\r\n----,TA.Row\r\n--,TA.SIRA\r\n\r\n----,ROW_NUMBER()  OVER(partition by TA.Row order by TA.SIRA1) SIRA5\r\n--,TA.SIRA_F\r\n--,TA.SIRA_F2\r\n--,TA.SIRA1\r\nFROM\r\n\r\n(\r\nSELECT \r\nyear(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY \r\n,F.DATE_ TARIH\r\n,F.FICHENO FISNO\r\n,C.CODE CARI_KODU\r\n,C.DEFINITION_ CARI_UNVANI\r\n,S.CODE STOK_KODU\r\n,s.NAME STOK_ADI\r\n,SUM(L.AMOUNT)  MIKTAR\r\n,U.CODE BIRIM\r\n--,L.SHIPPEDAMOUNT TESLIM_ALINAN\r\n,L.AMOUNT AS[SIPARIS_MIKTAR]\r\n,ISNULL(sum(SAT.AMOUNT),0) TESLIM_ALINAN\r\n,L.AMOUNT-L.SHIPPEDAMOUNT BEKLEYEN\r\n---,ISNULL((SELECT sum(AMOUNT) FROM lg_001_01_STLINE WITH (NOLOCK) WHERE TRCODE=6 AND CLIENTREF=L.CLIENTREF AND STOCKREF=L.STOCKREF),0) AS IADE_MIKTAR\r\n\r\n\r\n------------------\r\n--,COUNT(SAT.STFICHEREF) AS IADE_MIKTAR\r\n--,CASE  WHEN COUNT(SAT.STFICHEREF)\u003e1 THEN 7 ELSE 8 END AS IADE_MIKTAR\r\n\r\n--------------\r\n,ISNULL((SELECT sum(RETAMOUNT) FROM lg_001_01_STLINE WITH (NOLOCK) WHERE TRCODE=1 AND CLIENTREF=L.CLIENTREF AND STOCKREF=L.STOCKREF AND ORDFICHEREF=F.LOGICALREF  AND L.LOGICALREF=ORDTRANSREF AND  SAT.STFICHEREF=STFICHEREF AND LOGICALREF IN (SELECT SOURCELINK FROM LG_001_01_STLINE WHERE TRCODE=6  )),0) AS IADE_MIKTAR---AND ORDFICHEREF=F.LOGICALREF\r\n,L.PRICE FIYAT\r\n,SUM(L.TOTAL) TUTAR\r\n\r\n,CASE WHEN L.REPORTRATE=0 THEN (SELECT TOP 1 RATES2 FROM L_DAILYEXCHANGES WHERE CRTYPE=20 AND EDATE\u003e=L.DATE_ ORDER BY EDATE ASC) ELSE L.REPORTRATE END AS RD_KUR\r\n\r\n,CAST((NULLIF(L.LINENET,0)/NULLIF(L.AMOUNT,0))/CASE WHEN L.REPORTRATE=0 THEN (SELECT TOP 1 RATES2 FROM L_DAILYEXCHANGES WHERE \r\nCRTYPE=20 AND EDATE\u003e=L.DATE_ ORDER BY EDATE ASC) ELSE L.REPORTRATE END AS DECIMAL (18,2)) AS RD_EUR_TUTAR_SIPARIS\r\n,SAT.REPORTRATE FATURA_RDKUR\r\n\r\n,SAT.DATE_ FATURA_TARIHI\r\n\r\n,SAT.STFICHEREF IRSALIYENO\r\n,SAT.LINENET FATURA_TUTAR\r\n,SAT5.LINENET FATURA_TUTAR_YENI\r\n,SUM(CAST(ISNULL(( (NULLIF(SAT.LINENET,0)/NULLIF(SAT.REPORTRATE,0)) ),0) AS decimal(18,4)))RD_FATURA_EUR\r\n,cast(ISNULL(( ((NULLIF(SAT.LINENET,0)/NULLIF(SAT.REPORTRATE,0))/NULLIF(SAT.AMOUNT,0)) ),0) as decimal(18,4)) RD_EUR_BIRIM_FIYAT_FATURA\r\n,L.TRRATE [KESILEN_KUR (SİPARİŞ İ.D. KURU)]\r\n,CASE WHEN L.TRCURR =0 THEN \u0027TL\u0027 WHEN L.TRCURR =160 THEN \u0027TL\u0027 WHEN L.TRCURR =20 THEN \u0027EUR\u0027 WHEN L.TRCURR =1 THEN \u0027USD\u0027 ELSE \u0027XXX\u0027 END AS SIPARIS_DOVIZ\r\n,CASE WHEN SAT.TRCURR IN (0,160) THEN (NULLIF(L.LINENET,0)/NULLIF(L.AMOUNT,0)) ELSE\r\ncast(ISNULL(( ((NULLIF(SAT.LINENET,0)/NULLIF(SAT.TRRATE,0))/NULLIF(SAT.AMOUNT,0)) ),0) as decimal(18,4)) END ID_KESILEN_BIRIM_FIYAT\r\n,\r\nSUM(CASE WHEN SAT.TRCURR IN (0,160) THEN SAT.LINENET ELSE\r\nCAST(ISNULL(ROUND(NULLIF(SAT.LINENET,0)/NULLIF(SAT.TRRATE,0),2),0) AS DECIMAL (18,2)) END) KESILEN_TUTAR\r\n--,ROW_NUMBER() OVER(ORDER BY S.LOGICALREF ) AS Row,\r\n\r\n--MIN(SAT.STFICHEREF) OVER(PARTITION BY BRAND) AS MIN_FIYAT,\r\n--ROUND(AVG(SAT.STFICHEREF) OVER(PARTITION BY BRAND),0) ORTALAMA_FIYAT,\r\n--,MAX(L.TOTAL) OVER(partition by L.LOGICALREF order by SAT.STFICHEREF)  SIRA1\r\n\r\n--,ROW_NUMBER() OVER(partition by L.LOGICALREF order by SAT.STFICHEREF) SIRA,\r\n-----ROW_NUMBER()  OVER(partition by SUM(L.TOTAL) order by F.LOGICALREF ) SIRA1,\r\n\r\n--CASE  ROW_NUMBER() OVER(partition by L.LOGICALREF order by SAT.STFICHEREF) WHEN 2 THEN 1 ELSE 999 END AS SIRA_F,\r\n--CASE  ROW_NUMBER() OVER(partition by L.LOGICALREF order by SAT.STFICHEREF) WHEN 2 THEN 888 ELSE 1 END AS SIRA_F2\r\n\r\n\r\nFROM LG_001_01_ORFLINE AS L WITH (NOLOCK)\r\nINNER JOIN LG_001_01_ORFICHE AS F WITH (NOLOCK) ON F.LOGICALREF=L.ORDFICHEREF\r\nINNER JOIN LG_001_ITEMS AS S WITH (NOLOCK) ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_001_CLCARD AS C WITH (NOLOCK) ON C.LOGICALREF=F.CLIENTREF\r\nINNER JOIN LG_001_UNITSETL AS U WITH (NOLOCK) ON U.LOGICALREF=L.UOMREF\r\nLEFT OUTER JOIN  LG_001_01_STLINE AS SAT  WITH (NOLOCK) ON SAT.ORDTRANSREF=L.LOGICALREF AND SAT.TRCODE IN (1) \r\nLEFT OUTER JOIN  LG_001_01_STLINE AS SAT5  WITH (NOLOCK) ON SAT5.ORDTRANSREF=L.LOGICALREF AND SAT5.TRCODE IN (1) AND SAT.LOGICALREF=SAT5.LOGICALREF AND SAT5.BILLED=1\r\n--LEFT OUTER JOIN  LG_001_01_STLINE AS SAT1  WITH (NOLOCK) ON  SAT1.ORDTRANSREF=L.LOGICALREF AND SAT1.TRCODE IN (6)\r\n---and Sat.LOGICALREF= (select max(S1.LOGICALREF) from LG_001_01_STLINE S1 where s1.ordtransref=L.LOGICALREF )\r\n\r\n\r\n\r\nWHERE L.TRCODE=2\r\n---and F.FICHENO IN (\u0027001336\u0027)\r\n--and F.FICHENO IN (\u0027TEF2022000001285\u0027,\u0027001336\u0027,\u0027001441\u0027)\r\n\r\n\r\ngroup by l.date_,F.DATE_,F.FICHENO,C.CODE ,C.DEFINITION_,S.CODE,s.NAME,L.AMOUNT,U.CODE,L.SHIPPEDAMOUNT,L.CLIENTREF,L.STOCKREF,L.PRICE,L.TOTAL,\r\nL.REPORTRATE,L.LINENET,SAT.REPORTRATE,SAT.DATE_,SAT.LINENET,SAT.AMOUNT,L.TRRATE,L.TRCURR,SAT.TRCURR,SAT.TRRATE,F.LOGICALREF,L.LOGICALREF,SAT.STFICHEREF,SAT.LOGICALREF,S.LOGICALREF,L.ORDFICHEREF,SAT5.LINENET)TA\r\n\r\n---6415\r\n--WHERE TA.FISNO=\u0027001825\u0027\r\n---WHERE TA.STOK_KODU=\u00272021X1110\u0027\r\nGROUP BY TA.YIL,TA.MIKTAR,TA.AY,\r\nTA.TARIH\r\n,TA.FISNO\r\n,TA.CARI_KODU\r\n,TA.CARI_UNVANI\r\n,TA.STOK_KODU\r\n,TA.STOK_ADI\r\n,TA.BIRIM \r\n,TA.BEKLEYEN\r\n,TA.FIYAT\r\n,TA.TUTAR\r\n,TA.RD_KUR\r\n,TA.RD_EUR_TUTAR_SIPARIS\r\n,TA.FATURA_RDKUR\r\n,TA.FATURA_TARIHI\r\n,TA.FATURA_TUTAR\r\n,TA.FATURA_TUTAR_YENI\r\n,TA.RD_EUR_BIRIM_FIYAT_FATURA\r\n,TA.[KESILEN_KUR (SİPARİŞ İ.D. KURU)]\r\n,TA.SIPARIS_DOVIZ \r\n,TA.ID_KESILEN_BIRIM_FIYAT\r\n--,TA.KESILEN_TUTAR\r\n,TA.IADE_MIKTAR\r\n,TA.IRSALIYENO \r\n--,TA.SIRA,TA.SIRA_F,TA.SIRA_F2,TA.SIRA1---TA.Row,\r\n",
    "columns":  [
