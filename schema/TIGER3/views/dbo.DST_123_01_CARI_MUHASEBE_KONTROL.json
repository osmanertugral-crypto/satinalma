{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DST_123_01_CARI_MUHASEBE_KONTROL",
    "full_name":  "dbo.DST_123_01_CARI_MUHASEBE_KONTROL",
    "definition":  "\r\nCREATE VIEW [dbo].[DST_123_01_CARI_MUHASEBE_KONTROL]\r\n\r\nAS\r\n\r\nSELECT  CLCARD.CODE \u0027C/H KODU\u0027 ,CLCARD.DEFINITION_ \u0027C/H UNVANI\u0027 \r\n,ISNULL((SELECT SUM(AMOUNT) FROM LG_123_01_CLFLINE WHERE SIGN=0 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027\r\nAND CLIENTREF=CLCARD.LOGICALREF AND PAIDINCASH=0),0) \u0027C/H BORÇ\u0027 ,ISNULL((SELECT SUM(AMOUNT) FROM LG_123_01_CLFLINE WHERE SIGN=1 AND CANCELLED=0 \r\nAND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND CLIENTREF=CLCARD.LOGICALREF AND PAIDINCASH=0),0) \u0027C/H ALACAK\u0027 \r\n,ISNULL((SELECT SUM(AMOUNT) FROM LG_123_01_CLFLINE WHERE SIGN=0 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND CLIENTREF=CLCARD.LOGICALREF AND PAIDINCASH=0),0) - ISNULL((SELECT SUM(AMOUNT) FROM LG_123_01_CLFLINE WHERE SIGN=1 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND CLIENTREF=CLCARD.LOGICALREF AND PAIDINCASH=0),0) \u0027C/H BAKİYE\u0027 \r\n,EMUHACC.CODE \u0027HESAP KODU\u0027 ,EMUHACC.DEFINITION_ \u0027HESAP AÇIKLAMASI\u0027 ,ISNULL((SELECT SUM(DEBIT) FROM LG_123_01_EMFLINE WHERE SPECODE NOT IN  (\u0027D\u0027) AND SIGN=0 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND ACCOUNTREF=EMUHACC.LOGICALREF),0) \u0027MUHASEBE BORÇ\u0027 \r\n,ISNULL((SELECT SUM(CREDIT) FROM LG_123_01_EMFLINE WHERE SPECODE NOT IN (\u0027D\u0027) AND SIGN=1 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND ACCOUNTREF=EMUHACC.LOGICALREF),0) \u0027MUHASEBE ALACAK\u0027\r\n,ISNULL((SELECT SUM(DEBIT) FROM LG_123_01_EMFLINE WHERE  SPECODE NOT IN  (\u0027D\u0027) AND SIGN=0 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND ACCOUNTREF=EMUHACC.LOGICALREF),0) - ISNULL((SELECT SUM(CREDIT) FROM LG_123_01_EMFLINE WHERE SPECODE NOT IN  (\u0027D\u0027) AND SIGN=1 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND ACCOUNTREF=EMUHACC.LOGICALREF),0) \u0027MUHASEBE BAKİYE\u0027 \r\n\r\n---\r\n,(ISNULL((SELECT SUM(AMOUNT) FROM LG_123_01_CLFLINE WHERE SIGN=0 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND CLIENTREF=CLCARD.LOGICALREF AND PAIDINCASH=0),0) - ISNULL((SELECT SUM(AMOUNT) FROM LG_123_01_CLFLINE WHERE SIGN=1 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND CLIENTREF=CLCARD.LOGICALREF AND PAIDINCASH=0),0))-\r\n(ISNULL((SELECT SUM(DEBIT) FROM LG_123_01_EMFLINE WHERE  SPECODE NOT IN  (\u0027D\u0027) AND SIGN=0 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND ACCOUNTREF=EMUHACC.LOGICALREF),0) - ISNULL((SELECT SUM(CREDIT) FROM LG_123_01_EMFLINE WHERE SPECODE NOT IN  (\u0027D\u0027) AND SIGN=1 AND CANCELLED=0 AND DATE_ BETWEEN \u002720230101\u0027 and \u002720291231\u0027 AND ACCOUNTREF=EMUHACC.LOGICALREF),0)) \u0027FARK\u0027 \r\n\r\nFROM LG_123_CRDACREF CRDACREF \r\nLEFT JOIN LG_123_CLCARD CLCARD ON CLCARD.LOGICALREF=CRDACREF.CARDREF \r\nLEFT JOIN LG_123_EMUHACC EMUHACC ON EMUHACC.LOGICALREF=CRDACREF.ACCOUNTREF \r\nWHERE CRDACREF.TRCODE = 5 And TYP = 1\r\n\r\n--AND CLCARD.DEFINITION_ LIKE \u0027YEL%\u0027\r\n",
