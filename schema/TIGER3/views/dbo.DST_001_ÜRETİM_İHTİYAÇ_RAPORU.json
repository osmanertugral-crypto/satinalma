{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DST_001_ÜRETİM_İHTİYAÇ_RAPORU",
    "full_name":  "dbo.DST_001_ÜRETİM_İHTİYAÇ_RAPORU",
    "definition":  "\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n--1788\r\n\r\nCREATE VIEW [dbo].[DST_001_ÜRETİM_İHTİYAÇ_RAPORU] AS \r\n\r\n\r\n\r\nSELECT FIS_NO,FİŞ_TARİHİ,FİŞ_ÖZEL_KODU,PROJE_KODU,URETIM_BITIS_TARIHI,ANAMALZEME_URETIM_TARIHI,MALZEME_ÖZEL_KODU_ANAMALZEME,ANA_ÜRÜN_MİKTAR,KARAVAN_KODU_TÜR,KARAVAN_KODU,KARAVAN_ADI,ALT_KOD_TÜR,MALZEME_ÖZEL_KODU_ALT,ALIM_TARIH,ALIM_TARIH_AY,ALIM_TARIH_HAFTA,ALT_KOD,ALT_ADI,MIKTAR,RAPOR.BIRIM,\r\nPROJELERE_ÇIKIŞLAR,ELDE_KALAN,AÇIK_SATINALMA_SİPARİŞLERİ,\r\n\r\n--(ANA_ÜRÜN_MİKTAR*MIKTAR) AS TOPLAM_İHTİYAÇ,\r\n0 AS TOPLAM_İHTİYAÇ,\r\nBIRIM_FIYATLAR , (MIKTAR*BIRIM_FIYATLAR) AS TUTAR \r\n\r\nFROM (\r\nSELECT ANAMLZ.LOGICALREF AS MLZ_ID,\r\nDEMFICHE.FICHENO FIS_NO,\r\nPRO.CODE PROJE_KODU,\r\nconvert(varchar, DEMFICHE.DATE_, 104)FİŞ_TARİHİ,\r\n--DEMFICHE.DATE_ FİŞ_TARİHİ,\r\nconvert(varchar, XT12.URETIM_BITIS_TARIHI, 104)URETIM_BITIS_TARIHI,\r\n----------------------------\r\nconvert(varchar, DATEADD(day,ANAMLZ.SPECODE4*-1,XT12.URETIM_BITIS_TARIHI), 104)AS ANAMALZEME_URETIM_TARIHI,\r\nconvert(varchar, DATEADD(day,ALT_MLZ.SPECODE4*-1,XT12.URETIM_BITIS_TARIHI), 104)AS ALIM_TARIH_ESKI,\r\nconvert(varchar, DATEADD(day,(convert(int,ALT_MLZ.SPECODE4)+convert(int,ANAMLZ.SPECODE4))*-1,XT12.URETIM_BITIS_TARIHI), 104)AS ALIM_TARIH,\r\n--convert(int,ALT_MLZ.SPECODE4)+convert(int,ANAMLZ.SPECODE4) AS XX,\r\n\r\n\r\nDATEPART(WK,(convert(datetime, DATEADD(day,(convert(int,ALT_MLZ.SPECODE4)+convert(int,ANAMLZ.SPECODE4))*-1,XT12.URETIM_BITIS_TARIHI), 104)))AS ALIM_TARIH_HAFTA,\r\n\r\n\r\n----------------------------------\r\n\r\n--XT12.URETIM_BITIS_TARIHI  URETIM_BITIS_TARIHI,\r\nALT_MLZ.SPECODE4 MALZEME_ÖZEL_KODU_ALT,\r\nDEMFICHE.SPECODE FİŞ_ÖZEL_KODU,\r\n--convert(varchar, DATEADD(day,ALT_MLZ.SPECODE4*-1,XT12.URETIM_BITIS_TARIHI), 104)AS ALIM_TARIH,\r\n\r\n-- DATEADD(day,ALT_MLZ.SPECODE4*-1,XT12.URETIM_BITIS_TARIHI) AS ALIM_TARIH,\r\n MONTH(DATEADD(day,(convert(int,ALT_MLZ.SPECODE4)+convert(int,ANAMLZ.SPECODE4))*-1,XT12.URETIM_BITIS_TARIHI)) ALIM_TARIH_AY,\r\n\r\nDEM.AMOUNT AS [ANA_ÜRÜN_MİKTAR],\r\nANAMLZ.SPECODE4 MALZEME_ÖZEL_KODU_ANAMALZEME,\r\nCASE ANAMLZ.CARDTYPE WHEN 10 THEN \u0027Hammadde\u0027 WHEN 11 THEN \u0027Yarımamül\u0027WHEN 12 THEN \u0027Mamül\u0027WHEN 1 THEN \u0027Ticarimal\u0027ELSE \u0027DIGER\u0027END AS KARAVAN_KODU_TÜR,\r\nANAMLZ.CODE AS KARAVAN_KODU,\r\nANAMLZ.NAME AS KARAVAN_ADI,\r\nALT_MLZ.CODE AS ALT_KOD,\r\nCASE ALT_MLZ.CARDTYPE WHEN 10 THEN \u0027Hammadde\u0027 WHEN 11 THEN \u0027Yarımamül\u0027WHEN 12 THEN \u0027Mamül\u0027WHEN 1 THEN \u0027Ticarimal\u0027ELSE \u0027DIGER\u0027END AS ALT_KOD_TÜR,\r\nALT_MLZ.NAME AS ALT_ADI\r\n,BAGTBL.AMNT AS MIKTAR\r\n,UNT.CODE [BIRIM]\r\n,(SELECT TOP 1 LINENET/AMOUNT FROM LG_001_01_STLINE WHERE LINETYPE=0 AND PRICE\u003c\u003e0 AND STOCKREF=BAGTBL.STCREF AND TRCODE IN (1,50) ORDER BY DATE_ DESC ) BIRIM_FIYATLAR\r\n--,CASE WHEN (SELECT TOP 1 FIYAT FROM AA_FIYATLANDIRMA_RAPORU WHERE MLZ_ID=BAGTBL.STCREF AND FIYAT IS NOT NULL ORDER BY FIYAT DESC) IS NULL THEN\r\n--(SELECT TOP 1 TANIMLI_FIYAT FROM AA_FIYATLANDIRMA_RAPORU WHERE MLZ_ID=BAGTBL.STCREF AND TANIMLI_FIYAT IS NOT NULL ORDER BY TANIMLI_FIYAT DESC) \r\n--ELSE (SELECT TOP 1 FIYAT FROM AA_FIYATLANDIRMA_RAPORU WHERE MLZ_ID=BAGTBL.STCREF AND FIYAT IS NOT NULL ORDER BY FIYAT DESC)\r\n--END AS BIRIM_FIYATLAR\r\n\r\n,ISNULL((SELECT  SUM(MIKTAR) FROM AA_SARF_PROJE WHERE STOK_KODU=ALT_MLZ.CODE AND PROJE_KODU=PRO.CODE),0)AS PROJELERE_ÇIKIŞLAR\r\n,ISNULL(GNT.ONHAND,0) AS ELDE_KALAN\r\n,ISNULL((SELECT SUM(BEKLEYEN)FROM AA_SIPARIS_SATINALMA_RAPORU_YENI WHERE ALT_MLZ.CODE=STOK_KODU AND IADE_MIKTAR=0 AND KAPALI=0 ),0) AS AÇIK_SATINALMA_SİPARİŞLERİ ---AND IADE_MIKTAR=0\r\nFROM lg_001_ITEMS ANAMLZ\r\nINNER JOIN LG_001_STCOMPLN BAGTBL ON ANAMLZ.LOGICALREF=BAGTBL.MAINCREF\r\nLEFT OUTER JOIN LG_001_ITEMS ALT_MLZ ON ALT_MLZ.LOGICALREF=BAGTBL.STCREF\r\nLEFT JOIN LG_001_01_DEMANDLINE DEM ON DEM.ITEMREF=BAGTBL.MAINCREF\r\nLEFT JOIN LG_001_01_DEMANDFICHE DEMFICHE ON DEMFICHE.LOGICALREF=DEM.DEMANDFICHEREF\r\nLEFT JOIN LG_XT1226001_001 XT12 ON XT12.PARLOGREF=DEMFICHE.LOGICALREF\r\nLEFT JOIN LG_001_PROJECT PRO ON PRO.LOGICALREF=DEMFICHE.PROJECTREF\r\nLEFT JOIN LV_001_01_GNTOTST GNT ON GNT.STOCKREF=ALT_MLZ.LOGICALREF AND GNT.INVENNO=2\r\nLEFT JOIN LG_001_UNITSETF UNT ON UNT.LOGICALREF=ALT_MLZ.UNITSETREF\r\n WHERE ANAMLZ.SPECODE5=\u0027ANAMLZ\u0027 AND DEMFICHE.STATUS=0 \r\n\r\n --AND PRO.CODE=\u0027G0255\u0027\r\n --and ALT_MLZ.code=\u0027KRXX0099H027\u0027\r\n --AND ANAMLZ.CODE=\u0027G0.TÜRKİYE.01 BANYOLU\u0027\r\n\r\n ) AS RAPOR \r\n-- ORDER BY FIS_NO\r\n",
