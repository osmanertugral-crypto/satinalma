    "name":  "AA_FIYATLANDIRMA_RAPORU",
    "full_name":  "dbo.AA_FIYATLANDIRMA_RAPORU",
    "definition":  "\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_FIYATLANDIRMA_RAPORU] AS \r\n\r\nSELECT \r\nS.LOGICALREF MLZ_ID,\r\nyear(F.DATE_) YIL\r\n,MONTH(F.DATE_) AY \r\n,F.DATE_ TARIH\r\n,F.FICHENO FISNO\r\n,C.CODE CARI_KODU\r\n,C.DEFINITION_ CARI_UNVANI\r\n,S.STGRPCODE STOK_GRUP\r\n,S.CODE STOK_KODU\r\n,s.NAME STOK_ADI\r\n,L.AMOUNT  MIKTAR\r\n,U.CODE BIRIM\r\n,L.SHIPPEDAMOUNT TESLIM_ALINAN\r\n,AMOUNT-L.SHIPPEDAMOUNT BEKLEYEN\r\n,L.PRICE FIYAT\r\n,L.TOTAL TUTAR\r\n,L.REPORTRATE KUR\r\n,ROUND(NULLIF(L.TOTAL,0)/NULLIF(L.REPORTRATE,0),2) EUR_TUTAR\r\n,(SELECT MAX(REPORTRATE) FROM LG_123_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF) FATURA_KUR\r\n,(SELECT MAX(DATE_) FROM LG_123_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF) FATURA_TARIHI\r\n,(SELECT SUM(LINENET) FROM LG_123_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF) FATURA_TUTAR\r\n\r\n,CAST(ISNULL((SELECT SUM(NULLIF(LINENET,0)/NULLIF(REPORTRATE,0)) FROM LG_123_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF AND LINENET\u003c\u003e0 AND REPORTRATE\u003c\u003e0),0) AS decimal(18,4)) FATURA_EUR\r\n,cast(ISNULL((SELECT SUM((NULLIF(LINENET,0)/NULLIF(REPORTRATE,0))/AMOUNT) FROM LG_123_01_STLINE WHERE ORDTRANSREF=L.LOGICALREF AND LINENET\u003c\u003e0 AND REPORTRATE\u003c\u003e0),0) as decimal(18,4)) EUR_BIRIM_FIYAT\r\n\r\n\r\n\r\n,PARASI.PRICE AS TANIMLI_FIYAT\r\n\r\nFROM \r\nLG_123_ITEMS AS S \r\n\r\nLEFT OUTER JOIN LG_123_PRCLIST PARASI ON PARASI.CARDREF=S.LOGICALREF\r\n\r\n\r\nLEFT OUTER  JOIN LG_123_01_ORFLINE AS L ON S.LOGICALREF=L.STOCKREF AND L.TRCODE=2\r\nLEFT OUTER JOIN LG_123_01_ORFICHE AS F ON F.LOGICALREF=L.ORDFICHEREF\r\nLEFT  OUTER JOIN LG_123_CLCARD AS C ON C.LOGICALREF=F.CLIENTREF\r\nLEFT  OUTER JOIN LG_123_UNITSETL AS U ON U.LOGICALREF=L.UOMREF\r\n\r\n\r\n",
