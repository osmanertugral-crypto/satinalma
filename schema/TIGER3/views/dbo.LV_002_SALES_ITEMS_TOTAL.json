{
    "type":  "view",
    "schema":  "dbo",
    "name":  "LV_002_SALES_ITEMS_TOTAL",
    "full_name":  "dbo.LV_002_SALES_ITEMS_TOTAL",
    "definition":  "CREATE VIEW [dbo].[LV_002_SALES_ITEMS_TOTAL] AS\n              \nSELECT\n        01 AS PERIOD,\n        ISNULL(CLASS.CODE,0) AS CLASS_CODE,\n        ITEMS.STGRPCODE AS ITEMS_STGRPCODE,\n        ISNULL(INVOICE.GRPCODE,3) AS INVOICE_GRPCODE,\n        (CASE INVOICE.GRPCODE\n        WHEN 1 THEN \u0027(*%:1012,3000)Satınalma..........\u0027\n        WHEN 2 THEN \u0027(*%:1012,6000)Satış..........\u0027 ELSE \u0027(*%:1012,1000)Malzeme Yönetimi..........\u0027 END) AS INVOICE_GRPCODE_TIPI,\n        STLINE.CANCELLED AS STLINE_CANCELLED,\n        (CASE STLINE.CANCELLED\n        WHEN 0 THEN \u0027(*%:9504,0)İptal Edilmemiş Fişler..........\u0027\n        WHEN 1 THEN \u0027(*%:9504,1)İptal Edilmiş Fişler..........\u0027 ELSE \u0027\u0027 END) AS STLINE_CANCELLED_AÇIKLAMA,\n        STLINE.BILLED AS STLINE_BILLED,\n        (CASE STLINE.BILLED\n        WHEN 0 THEN \u0027(*%:23205,27)Faturalanmamış irsaliyeler..........\u0027\n        WHEN 1 THEN \u0027(*%:23205,27)Faturalanmış irsaliyeler..........\u0027  ELSE \u0027\u0027 END) AS STLINE_BILLED_TIPI,\n        DATEPART(YYYY,STLINE.DATE_) AS  STLINE_YEAR,\n        DATEPART(qq,STLINE.DATE_) AS STLINE_QUARTER,\n        CASE WHEN DATEPART(qq,STLINE.DATE_) IN (1,2) THEN 1 ELSE 2 END AS STLINE_HALF,\n        DATEPART(MM,STLINE.DATE_) AS  STLINE_MONTH,\n        DATEPART(wk,STLINE.DATE_) AS STLINE_WEEK,\n        DATEPART(dd,STLINE.DATE_) AS STLINE_DAY,\n        CAPIDIV.NR AS CAPIDIV_NR,\n        CAPIDEPT.NR AS CAPIDEPT_NR,\n        CAPIWHOUSE.NR AS CAPIWHOUSE_NR,\n        SLSMAN.CODE AS SLSMAN_CODE,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN (STLINE.AMOUNT*(CASE STLINE.UINFO2 WHEN 0 THEN 1 ELSE STLINE.UINFO2/STLINE.UINFO1 END)) ELSE 0 END))) AS STLINE_INPUT_AMOUNT,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0 ELSE (STLINE.AMOUNT*(CASE STLINE.UINFO2 WHEN 0 THEN 1 ELSE STLINE.UINFO2/STLINE.UINFO1 END)) END))) AS STLINE_OUTPUT_AMOUNT,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.PRICE  ELSE 0 END))) AS STLINE_INPUT_PRICE,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.PRICE END))) AS STLINE_OUTPUT_PRICE,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.TOTAL  ELSE 0 END))) AS STLINE_INPUT_TOTAL,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.TOTAL END))) AS STLINE_OUTPUT_TOTAL,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.DISTCOST  ELSE 0 END))) AS STLINE_INPUT_DISTCOST,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.DISTCOST END))) AS STLINE_OUTPUT_DISTCOST,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.DISTDISC  ELSE 0 END))) AS STLINE_INPUT_DISTDISC,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.DISTDISC END))) AS STLINE_OUTPUT_DISTDISC,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.DISTEXP  ELSE 0 END))) AS STLINE_INPUT_DISTEXP,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.DISTEXP END))) AS STLINE_OUTPUT_DISTEXP,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.DISTPROM  ELSE 0 END))) AS STLINE_INPUT_DISTPROM,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.DISTPROM END))) AS STLINE_OUTPUT_DISTPROM,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.VATAMNT  ELSE 0 END))) AS STLINE_INPUT_VATAMNT,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.VATAMNT END))) AS STLINE_OUTPUT_VATAMNT,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.VATMATRAH  ELSE 0 END))) AS STLINE_INPUT_VATMATRAH,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.VATMATRAH END))) AS STLINE_OUTPUT_VATMATRAH,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.OUTCOST  ELSE 0 END))) AS STLINE_INPUT_OUTCOST,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.OUTCOST END))) AS STLINE_OUTPUT_OUTCOST,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.LINENET  ELSE 0 END))) AS STLINE_INPUT_LINENET,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.LINENET END))) AS STLINE_OUTPUT_LINENET,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.DIFFPRCOST  ELSE 0 END))) AS STLINE_INPUT_DIFFPRCOST,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.DIFFPRCOST END))) AS STLINE_OUTPUT_DIFFPRCOST,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.DIFFREPPRICE  ELSE 0 END))) AS STLINE_INPUT_DIFFREPPRICE,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.DIFFREPPRICE END))) AS STLINE_OUTPUT_DIFFREPPRICE,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN STLINE.DIFFPRCRCOST  ELSE 0 END))) AS STLINE_INPUT_DIFFPRCRCOST,\n        SUM(((CASE WHEN STLINE.IOCODE IN (1,2) THEN 0  ELSE STLINE.DIFFPRCRCOST END))) AS STLINE_OUTPUT_DIFFPRCRCOST\nFROM\n LG_002_ITEMS ITEMS (NOLOCK)\n LEFT OUTER JOIN LG_002_ITMCLSAS ITC (NOLOCK) ON ITEMS.LOGICALREF=ITC.CHILDREF AND ITC.UPLEVEL=0\n LEFT OUTER JOIN LG_002_ITEMS CLASS (NOLOCK) ON ITC.PARENTREF=CLASS.LOGICALREF\n LEFT OUTER JOIN LG_002_01_STLINE STLINE (NOLOCK) ON ITEMS.LOGICALREF=STLINE.STOCKREF AND STLINE.LINETYPE NOT IN (2,3,4)\n LEFT OUTER JOIN LG_002_01_INVOICE INVOICE (NOLOCK) ON STLINE.INVOICEREF=INVOICE.LOGICALREF\n LEFT OUTER JOIN \"TIGER3\"..LG_SLSMAN SLSMAN (NOLOCK) ON INVOICE.SALESMANREF=SLSMAN.LOGICALREF AND SLSMAN.FIRMNR=002\n LEFT OUTER JOIN \"TIGER3\"..L_CAPIWHOUSE CAPIWHOUSE WITH(NOLOCK) ON INVOICE.SOURCEINDEX=CAPIWHOUSE.NR AND CAPIWHOUSE.FIRMNR=002\n LEFT OUTER JOIN \"TIGER3\"..L_CAPIDIV CAPIDIV (NOLOCK) ON INVOICE.BRANCH=CAPIDIV.NR AND CAPIDIV.FIRMNR=002\n LEFT OUTER JOIN \"TIGER3\"..L_CAPIDEPT CAPIDEPT (NOLOCK) ON INVOICE.DEPARTMENT=CAPIDEPT.NR AND CAPIDEPT.FIRMNR=002\nWHERE\n        STLINE.LINETYPE NOT IN (2,3)\nGROUP BY\n        ISNULL(CLASS.CODE,0),\n        ITEMS.STGRPCODE,\n        INVOICE.GRPCODE,\n        DATEPART(YYYY,STLINE.DATE_),\n        DATEPART(qq,STLINE.DATE_) ,\n        CASE WHEN DATEPART(qq,STLINE.DATE_) IN (1,2) THEN 1 ELSE 2 END ,\n        DATEPART(MM,STLINE.DATE_),\n        DATEPART(wk,STLINE.DATE_),\n        DATEPART(dd,STLINE.DATE_),\n        STLINE.CANCELLED,\n        STLINE.BILLED,\n        CAPIDIV.NR,\n        CAPIDEPT.NR,\n        CAPIWHOUSE.NR,\n        SLSMAN.CODE",
    "columns":  [
