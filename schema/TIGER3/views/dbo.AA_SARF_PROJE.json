    "name":  "AA_SARF_PROJE",
    "full_name":  "dbo.AA_SARF_PROJE",
    "definition":  "\r\n\r\n\r\n\r\n\r\n--SELECT * FROM AA_SARF_PROJE WHERE IS_EMRI_N0=\u0027RXL011\u0027\r\n\r\nCREATE VIEW [dbo].[AA_SARF_PROJE] AS\r\n\r\n\r\nselect \r\n--L.SOURCEINDEX AS AMBAR,\r\nYEAR(F.DATE_) YEAR_\r\n,MONTH(F.DATE_) MONTH_\r\n,F.DATE_ DATE_\r\n,F.FICHENO FISNO\r\n,P.CODE IS_EMRI_N0\r\n,P.NAME IS_EMRI_ADI\r\n,P.ENDDATE ENDDATE\r\n,S.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,AMOUNT MIKTAR\r\n,U.CODE BRIM\r\n,CASE WHEN L.PRICE\u003c\u003e0 THEN L.PRICE ELSE (SELECT TOP 1 PRICE FROM LG_001_01_STLINE WHERE LINETYPE=0 AND STOCKREF=L.STOCKREF AND PRICE\u003c\u003e0 AND  TRCODE IN (50,1) AND DATE_\u003c=L.DATE_  ORDER BY DATE_ DESC) END BRIM_FIYAT\r\n,CASE WHEN L.PRICE\u003c\u003e0 THEN L.PRICE ELSE (SELECT TOP 1 PRICE FROM LG_001_01_STLINE WHERE LINETYPE=0 AND STOCKREF=L.STOCKREF AND PRICE\u003c\u003e0 AND  TRCODE IN (50,1) AND DATE_\u003c=L.DATE_  ORDER BY DATE_ DESC)  END*L.AMOUNT  TUTAR\r\n\r\n,CASE SUBSTRING((SELECT CODE FROM LG_001_PROJECT WHERE LOGICALREF=L.PROJECTREF),1,2) \r\nWHEN \u0027G0\u0027 THEN \u0027GLADIATOR KABIN\u0027 \r\nWHEN \u0027G1\u0027 THEN \u0027GLADIATOR KABIN\u0027 \r\nWHEN \u0027R0\u0027 THEN \u0027RONIN KABIN\u0027\r\nWHEN \u0027RX\u0027 THEN \u0027RONIN XL\u0027\r\nWHEN \u0027FO\u0027 THEN \u0027RONIN KABINR\u0027\r\nWHEN \u0027F0\u0027 THEN \u0027FREDOOM\u0027\r\nWHEN \u0027T0\u0027 THEN \u0027TROY\u0027\r\nWHEN \u0027MC\u0027 THEN \u0027MOHICAN\u0027\r\nWHEN \u0027RV\u0027 THEN \u0027REVIVA\u0027\r\nWHEN \u0027GL\u0027 THEN \u0027GLADIATOR XL\u0027\r\nWHEN \u0027GL\u0027 THEN \u0027GLADIATOR XL\u0027\r\nWHEN \u0027PA\u0027 THEN \u0027PAN ANATOLIA\u0027 \r\nWHEN \u002720\u0027 THEN \u0027AKSESUAR\u0027 \r\nEND TUR\r\n,(SELECT MAX(MONTH(DATE_)) FROM LG_001_01_STLINE WHERE PROJECTREF=L.PROJECTREF AND TRCODE IN (7,8) ) SATIS_AY\r\n,(SELECT MAX(YEAR(DATE_)) FROM LG_001_01_STLINE WHERE PROJECTREF=L.PROJECTREF AND TRCODE IN (7,8) ) SATIS_YIL\r\n,CASE S.STGRPCODE WHEN \u0027ARABA\u0027 THEN \u0027ARABA\u0027 WHEN \u0027OTV\u0027 THEN \u0027OTV\u0027 ELSE\r\n--CASE WHEN L.STOCKREF IN (SELECT STOCKREF FROM LG_001_01_ORFLINE WHERE PROJECTREF=P.LOGICALREF AND TRCODE=1)\r\n--THEN \u0027OPSIYONEL\u0027 ELSE \u0027STANDART\u0027 END END RECETE_TURU\r\nCASE WHEN L.STOCKREF IN (SELECT STCREF FROM LG_001_STCOMPLN WHERE MAINCREF IN \r\n(SELECT STOCKREF FROM LG_001_01_ORFLINE WHERE PROJECTREF=P.LOGICALREF AND TRCODE=1)) OR\r\n L.STOCKREF IN (SELECT STOCKREF FROM LG_001_01_ORFLINE WHERE PROJECTREF=P.LOGICALREF AND TRCODE=1 AND LINENO_\u003c\u003e1)\r\n THEN \u0027OPSIYONEL\u0027 WHEN L.STOCKREF IN (SELECT STOCKREF FROM LG_001_01_ORFLINE WHERE PROJECTREF=P.LOGICALREF AND TRCODE=1 AND LINENO_=1) THEN \u0027STANDART\u0027 ELSE  \u0027STANDART\u0027 END END RECETE_TURU,\r\n P.CODE AS PROJE_KODU\r\nFROM LG_001_01_STLINE AS L\r\nINNER JOIN LG_001_01_STFICHE AS F ON F.LOGICALREF=L.STFICHEREF\r\nINNER JOIN LG_001_ITEMS AS S ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_001_UNITSETL AS U ON U.LOGICALREF=L.UOMREF\r\nINNER JOIN LG_001_PROJECT AS P ON P.LOGICALREF=L.PROJECTREF\r\n\r\nWHERE F.TRCODE IN(25) AND L.SOURCEINDEX=2\r\n---AND P.CODE=\u0027G0255\u0027\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
