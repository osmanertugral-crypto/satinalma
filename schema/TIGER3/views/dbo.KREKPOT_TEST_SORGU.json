{
    "type":  "view",
    "schema":  "dbo",
    "name":  "KREKPOT_TEST_SORGU",
    "full_name":  "dbo.KREKPOT_TEST_SORGU",
    "definition":  "\r\n\r\n\r\n\r\n\r\nCREATE     view [dbo].[KREKPOT_TEST_SORGU] as\r\nSELECT EMUHACC.CODE, EMUHACC.SPECODE, EMUHACC.DEFINITION_, SUM(DEBIT - CREDIT) AMOUNT_\r\nFROM LG_123_01_EMFLINE EMFLINE WITH(NOLOCK) \r\nINNER JOIN LG_123_01_EMFICHE EMFICHE WITH(NOLOCK) ON EMFICHE.LOGICALREF = EMFLINE.ACCFICHEREF \r\nLEFT JOIN LG_123_EMUHACC EMUHACC WITH(NOLOCK) ON EMUHACC.LOGICALREF = EMFLINE.ACCOUNTREF \r\nWHERE EMFLINE.CANCELLED = 0 --AND  EMUHACC.SPECODE \u003c\u003e \u0027\u0027\r\nAND YEAR(EMFICHE.DATE_) = 2025\r\nAND MONTH(EMFICHE.DATE_) IN (11)\r\nGROUP BY EMUHACC.CODE, EMUHACC.SPECODE, EMUHACC.DEFINITION_\r\n\r\n",
    "columns":  [
                    {
                        "COLUMN_NAME":  "CODE",
                        "ORDINAL_POSITION":  1,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "101",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "SPECODE",
                        "ORDINAL_POSITION":  2,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "11",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "DEFINITION_",
                        "ORDINAL_POSITION":  3,
                        "DATA_TYPE":  "varchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "101",
                        "IS_NULLABLE":  "YES"
                    },
                    {
                        "COLUMN_NAME":  "AMOUNT_",
                        "ORDINAL_POSITION":  4,
                        "DATA_TYPE":  "float",
                        "CHARACTER_MAXIMUM_LENGTH":  "",
                        "IS_NULLABLE":  "YES"
                    }
                ],
