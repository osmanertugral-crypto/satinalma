    "name":  "AA_SATIN_ALMA",
    "full_name":  "dbo.AA_SATIN_ALMA",
    "definition":  "\r\n\r\n\r\nCREATE VIEW [dbo].[AA_SATIN_ALMA] AS\r\n\r\nselect \r\nS.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,YEAR(L.DATE_) YIL\r\n,MONTH(L.DATE_) AY\r\n,L.DATE_ TARIH\r\n,(SELECT CODE FROM LG_123_CLCARD WHERE LOGICALREF=L.CLIENTREF) CARI_KODU\r\n,(SELECT DEFINITION_ FROM LG_123_CLCARD WHERE LOGICALREF=L.CLIENTREF) CARI_UNVANI\r\n,L.AMOUNT MIKTAR\r\n,(SELECT CODE FROM LG_123_UNITSETL WHERE LOGICALREF=L.UOMREF) BIRIM\r\n,L.LINENET/L.AMOUNT BRIM_FİYAT\r\n,L.LINENET TUTAR\r\n,CASE WHEN REPORTRATE=0 THEN (SELECT TOP 1 RATES2 FROM L_DAILYEXCHANGES WHERE CRTYPE=20 AND EDATE\u003e=L.DATE_ ORDER BY EDATE ASC) ELSE REPORTRATE END AS EUR_KUR\r\n,(L.LINENET/L.AMOUNT)/CASE WHEN REPORTRATE=0 THEN (SELECT TOP 1 RATES2 FROM L_DAILYEXCHANGES WHERE CRTYPE=20 AND EDATE\u003e=L.DATE_ ORDER BY EDATE ASC) ELSE REPORTRATE END EUR_FIYAT\r\n\r\nfrom lg_123_ITEMS AS S\r\nINNER JOIN LG_123_01_STLINE AS L ON L.STOCKREF = S.LOGICALREF\r\n\r\nWHERE L.LINETYPE=0\r\nAND L.CANCELLED=0\r\nAND L.TRCODE IN (1)\r\n--order by S.CODE,L.DATE_) \r\n\r\n",
