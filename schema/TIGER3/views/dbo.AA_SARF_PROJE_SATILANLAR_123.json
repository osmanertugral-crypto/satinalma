    "name":  "AA_SARF_PROJE_SATILANLAR_123",
    "full_name":  "dbo.AA_SARF_PROJE_SATILANLAR_123",
    "definition":  "\r\n\r\n\r\n\r\n\r\nCREATE VIEW [dbo].[AA_SARF_PROJE_SATILANLAR_123] AS\r\n\r\n\r\nselect \r\nYEAR(F.DATE_) YEAR_\r\n,MONTH(F.DATE_) MONTH_\r\n,F.DATE_ DATE_\r\n,F.FICHENO FISNO\r\n,(SELECT CODE FROM LG_123_PROJECT WHERE LOGICALREF=L.PROJECTREF) IS_EMRI_N0\r\n,(SELECT NAME FROM LG_123_PROJECT WHERE LOGICALREF=L.PROJECTREF) IS_EMRI_ADI\r\n,S.CODE STOK_KODU\r\n,S.NAME STOK_ADI\r\n,AMOUNT MIKTAR\r\n,U.CODE BRIM\r\n,(SELECT TOP 1 PRICE FROM LG_123_01_STLINE WHERE LINETYPE=0 AND STOCKREF=L.STOCKREF AND  TRCODE IN (50,1) AND DATE_\u003c= L.DATE_ ORDER BY DATE_ DESC) BRIM_FIYAT\r\n,(SELECT TOP 1 PRICE FROM LG_123_01_STLINE WHERE LINETYPE=0 AND STOCKREF=L.STOCKREF AND   TRCODE IN (50,1)  AND DATE_\u003c= L.DATE_ ORDER BY DATE_ DESC)*L.AMOUNT  TUTAR\r\n,CASE SUBSTRING((SELECT CODE FROM LG_123_PROJECT WHERE LOGICALREF=L.PROJECTREF),1,2) \r\nWHEN \u0027G0\u0027 THEN \u0027GLADIATOR KABIN\u0027 \r\nWHEN \u0027G1\u0027 THEN \u0027GLADIATOR KABIN\u0027 \r\nWHEN \u0027R0\u0027 THEN \u0027RONIN KABIN\u0027\r\nWHEN \u0027RX\u0027 THEN \u0027RONIN XL\u0027\r\nWHEN \u0027FO\u0027 THEN \u0027RONIN KABINR\u0027\r\nWHEN \u0027F0\u0027 THEN \u0027FREDOOM\u0027\r\nWHEN \u0027T0\u0027 THEN \u0027TROY\u0027\r\nWHEN \u0027MC\u0027 THEN \u0027MOHICAN\u0027\r\nWHEN \u0027RV\u0027 THEN \u0027REVIVA\u0027\r\nWHEN \u0027GL\u0027 THEN \u0027GLADIATOR XL\u0027\r\nWHEN \u0027GL\u0027 THEN \u0027GLADIATOR XL\u0027\r\nWHEN \u0027PA\u0027 THEN \u0027PAN ANATOLIA\u0027 \r\nWHEN \u002720\u0027 THEN \u0027AKSESUAR\u0027 \r\nEND TUR\r\n,(SELECT MAX(MONTH(DATE_)) FROM LG_123_01_STLINE WHERE PROJECTREF=L.PROJECTREF AND TRCODE IN (7,8) ) SATIS_AY\r\n,(SELECT MAX(YEAR(DATE_)) FROM LG_123_01_STLINE WHERE PROJECTREF=L.PROJECTREF AND TRCODE IN (7,8) ) SATIS_YIL\r\n\r\n\r\n\r\n\r\n\r\nFROM LG_123_01_STLINE AS L\r\nINNER JOIN LG_123_01_STFICHE AS F ON F.LOGICALREF=L.STFICHEREF\r\nINNER JOIN LG_123_ITEMS AS S ON S.LOGICALREF=L.STOCKREF\r\nINNER JOIN LG_123_UNITSETL AS U ON U.LOGICALREF=L.UOMREF\r\n\r\nWHERE F.TRCODE=12 \r\n--AND S.CODE=\u00272021X201\u0027\r\nAND (SELECT MAX(MONTH(DATE_)) FROM LG_123_01_STLINE WHERE PROJECTREF=L.PROJECTREF AND TRCODE IN (7,8) and YEAR(DATE_)\u003e2021 ) IS NOT NULL\r\nand YEAR(F.DATE_)\u003e2021\r\n\r\n\r\n",
