{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AA_GIDER_RAPORU_YENI",
    "full_name":  "dbo.AA_GIDER_RAPORU_YENI",
    "definition":  "\r\nCREATE VIEW [dbo].[AA_GIDER_RAPORU_YENI] AS \r\nselect \r\nLEFT(H.CODE,3) AS ANA_KOD,\r\nH.CODE\r\n,H.DEFINITION_\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =1),0) \u002701_OCAK\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =2),0) \u002702_SUBAT\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =3),0) \u002703_MART\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =4),0) \u002704_NISAN\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =5),0) \u002705_MAYIS\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =6),0) \u002706_HAZIRAN\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =7),0) \u002707_TEMMUZ\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =8),0) \u002708_AGUSTOS\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =9),0) \u002709_EYLUL\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =10),0) \u002710_EKIM\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =11),0) \u002711_KASIM\u0027\r\n,ISNULL((SELECT SUM(DEBIT+CREDIT*-1) FROM LG_001_01_EMFLINE WHERE ACCOUNTCODE=H.CODE AND CANCELLED=0 AND YEAR(DATE_)=2022 AND MONTH(DATE_) =12),0) \u002712_ARALIK\u0027\r\n\r\nfrom LG_001_EMUHACC  AS H\r\n\r\n\r\nWHERE (H.CODE LIKE\u00277%\u0027 OR  H.CODE LIKE\u0027610%\u0027 OR   H.CODE LIKE\u0027689%\u0027 OR  H.CODE LIKE\u0027656%\u0027 OR H.CODE LIKE\u0027264%\u0027 OR H.CODE LIKE\u0027150%\u0027 \r\nOR H.CODE LIKE\u0027253%\u0027 OR H.CODE LIKE\u0027254%\u0027 OR H.CODE LIKE\u0027255%\u0027 ) AND H.CODE NOT LIKE\u0027710%\u0027 AND H.CODE NOT LIKE\u0027711%\u0027\r\n--AND LEN(H.CODE)=3\r\nAND H.CODE IN (SELECT ACCOUNTCODE FROM LG_001_01_EMFLINE)\r\n",
