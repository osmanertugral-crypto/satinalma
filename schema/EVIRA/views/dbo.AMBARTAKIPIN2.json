    "name":  "AMBARTAKIPIN2",
    "full_name":  "dbo.AMBARTAKIPIN2",
    "definition":  "CREATE VIEW [dbo].[AMBARTAKIPIN2] WITH SCHEMABINDING \r\nAS\r\nSELECT       HEDEF_AMBAR AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, HEDEF_ADRES ADRES,CASE WHEN IZLEME_TURU IN(0,3,4) THEN \u0027\u0027 ELSE  TAKIP_NO END TAKIP_NO, HEDEF_DURUM DURUM_KODU, HEDEF_PALET PALET,HEDEF_PAKET PAKET, SUM(MIKTAR*(CARPAN2/CARPAN1)) AS MIKTAR, COUNT_BIG(*) AS C\r\nFROM            dbo.STOKHAREKETLERI WITH(NOLOCK)\r\nWHERE        (FIS_GCD=2)\r\nGROUP BY HEDEF_AMBAR, STOK_REF,VARYANT_REF, ANABIRIM_REF, HEDEF_ADRES, TAKIP_NO, HEDEF_DURUM, HEDEF_PALET,HEDEF_PAKET,IZLEME_TURU",
