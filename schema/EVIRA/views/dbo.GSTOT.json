{
    "type":  "view",
    "schema":  "dbo",
    "name":  "GSTOT",
    "full_name":  "dbo.GSTOT",
    "definition":  "CREATE VIEW [dbo].[GSTOT] AS\r\nSELECT \r\n      AMBAR_KODU,\r\n      STOK_REF,\r\n      STOK_KODU,\r\n      STOK_ADI,\r\n\t  STOK_ADI2,\r\n\t  STOK_ADI3,\r\n\t  STOK_ADI4,\r\n\t  ISNULL(VARYANT_REF,0) VARYANT_REF,\r\n\t  VARYANT_KODU,\r\n\t  VARYANT_ADI,\r\n\t  VARYANT_ADI2,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,\r\n      SUM(SAYIM1) AS SAYIM1,\r\n      SUM(SAYIM2) AS SAYIM2,\r\n      SUM(SAYIM3) AS SAYIM3,\r\n      SUM(KONTROL_SAYIM) AS KONTROL_SAYIM,\r\n      ISNULL(SUM(KONTROL_SAYIM),SUM(SAYIM1)) AS EVIRA_SAYIM1,\r\n      ISNULL(SUM(KONTROL_SAYIM),SUM(SAYIM2)) AS EVIRA_SAYIM2,\r\n      ISNULL(SUM(KONTROL_SAYIM),SUM(SAYIM3)) AS EVIRA_SAYIM3\r\n      \r\nFROM (\r\n\r\nSELECT \r\n      SF.AMBAR_KODU,\r\n      S.STOK_REF,\r\n      S.STOK_KODU,\r\n      S.STOK_ADI,\r\n\t  S.STOK_ADI2,\r\n\t  S.STOK_ADI3,\r\n\t  S.STOK_ADI4,\r\n\t  VR.VARYANT_REF,\r\n\t  VR.VARYANT_KODU,\r\n\t  VR.VARYANT_ADI,\r\n\t  VR.VARYANT_ADI2,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,\r\n      SUM(MIKTAR*(CARPAN2/CARPAN1)) AS SAYIM1,\r\n      SAYIM2=0,\r\n      SAYIM3=0,\r\n      KONTROL_SAYIM= NULL\r\nFROM \r\n      STOKFISLERI SF WITH(NOLOCK)\r\n      LEFT OUTER JOIN STOKHAREKETLERI SH WITH(NOLOCK) ON SH.FB_REF=SF.FB_REF\r\n      LEFT OUTER JOIN STOKKARTI S WITH(NOLOCK) ON S.STOK_REF=SH.STOK_REF\r\n\t  LEFT OUTER JOIN VARYANT VR WITH(NOLOCK) ON VR.STOK_REF=SH.STOK_REF AND VR.VARYANT_REF=SH.VARYANT_REF \r\nWHERE \r\n      SF.FIS_TURU=100\r\n      AND SF.SAYIM_STATUS=0\r\n      AND SF.SAYIM_TURU=1\r\n      AND S.STOK_KODU IS NOT NULL\r\n      \r\nGROUP BY \r\n      SF.AMBAR_KODU,\r\n      S.STOK_KODU,\r\n      S.STOK_ADI,\r\n\t  S.STOK_ADI2,\r\n\t  S.STOK_ADI3,\r\n\t  S.STOK_ADI4,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,\r\n      S.STOK_REF,\r\n\t  VR.VARYANT_REF,\r\n\t  VR.VARYANT_KODU,\r\n\t  VR.VARYANT_ADI,\r\n\t  VR.VARYANT_ADI2\r\nUNION ALL\r\n      \r\n      SELECT \r\n      SF.AMBAR_KODU,\r\n      S.STOK_REF,\r\n      S.STOK_KODU,\r\n      S.STOK_ADI,\r\n\t  S.STOK_ADI2,\r\n\t  S.STOK_ADI3,\r\n\t  S.STOK_ADI4,\r\n\t  VR.VARYANT_REF,\r\n\t  VR.VARYANT_KODU,\r\n\t  VR.VARYANT_ADI,\r\n\t  VR.VARYANT_ADI2,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,\r\n      SAYIM1=0,\r\n      SUM(MIKTAR*(CARPAN2/CARPAN1)) AS SAYIM2,\r\n      SAYIM3=0,\r\n      KONTROL_SAYIM= NULL\r\nFROM \r\n      STOKFISLERI SF WITH(NOLOCK)\r\n      LEFT OUTER JOIN STOKHAREKETLERI SH WITH(NOLOCK) ON SH.FB_REF=SF.FB_REF\r\n      LEFT OUTER JOIN STOKKARTI S WITH(NOLOCK) ON S.STOK_REF=SH.STOK_REF\r\n\t  LEFT OUTER JOIN VARYANT VR WITH(NOLOCK) ON VR.STOK_REF=SH.STOK_REF AND VR.VARYANT_REF=SH.VARYANT_REF \r\nWHERE \r\n      SF.FIS_TURU=100\r\n      AND SF.SAYIM_STATUS=0\r\n      AND SF.SAYIM_TURU=2\r\n      AND S.STOK_KODU IS NOT NULL\r\n      \r\nGROUP BY \r\n      SF.AMBAR_KODU,\r\n      S.STOK_KODU,\r\n      S.STOK_ADI,\r\n\t  S.STOK_ADI2,\r\n\t  S.STOK_ADI3,\r\n\t  S.STOK_ADI4,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,S.STOK_REF,\r\n\t  VR.VARYANT_REF,\r\n\t  VR.VARYANT_KODU,\r\n\t  VR.VARYANT_ADI,\r\n\t  VR.VARYANT_ADI2\r\nUNION ALL\r\n\r\nSELECT \r\n      SF.AMBAR_KODU,\r\n      S.STOK_REF,\r\n      S.STOK_KODU,\r\n      S.STOK_ADI,\r\n\t  S.STOK_ADI2,\r\n\t  S.STOK_ADI3,\r\n\t  S.STOK_ADI4,\r\n\t  VR.VARYANT_REF,\r\n\t  VR.VARYANT_KODU,\r\n\t  VR.VARYANT_ADI,\r\n\t  VR.VARYANT_ADI2,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,\r\n      SAYIM1=0,\r\n      SAYIM2=0,\r\n      SUM(MIKTAR*(CARPAN2/CARPAN1)) AS SAYIM3,\r\n      KONTROL_SAYIM= NULL\r\nFROM \r\n      STOKFISLERI SF WITH(NOLOCK)\r\n      LEFT OUTER JOIN STOKHAREKETLERI SH WITH(NOLOCK) ON SH.FB_REF=SF.FB_REF\r\n      LEFT OUTER JOIN STOKKARTI S WITH(NOLOCK) ON S.STOK_REF=SH.STOK_REF\r\n\t  LEFT OUTER JOIN VARYANT VR  WITH(NOLOCK) ON VR.STOK_REF=SH.STOK_REF AND VR.VARYANT_REF=SH.VARYANT_REF \r\nWHERE \r\n      SF.FIS_TURU=100\r\n      AND SF.SAYIM_STATUS=0\r\n      AND SF.SAYIM_TURU=3\r\n      AND S.STOK_KODU IS NOT NULL\r\n      \r\nGROUP BY \r\n      SF.AMBAR_KODU,\r\n      S.STOK_KODU,\r\n      S.STOK_ADI,\r\n\t  S.STOK_ADI2,\r\n\t  S.STOK_ADI3,\r\n\t  S.STOK_ADI4,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,S.STOK_REF,\r\n\t  VR.VARYANT_REF,\r\n\t  VR.VARYANT_KODU,\r\n\t  VR.VARYANT_ADI,\r\n\t  VR.VARYANT_ADI2\r\n\r\nUNION ALL\r\n\r\n      \r\nSELECT \r\n      SF.AMBAR_KODU,\r\n      S.STOK_REF,\r\n      S.STOK_KODU,\r\n      S.STOK_ADI,\r\n\t  S.STOK_ADI2,\r\n\t  S.STOK_ADI3,\r\n\t  S.STOK_ADI4,\r\n\t  VR.VARYANT_REF,\r\n\t  VR.VARYANT_KODU,\r\n\t  VR.VARYANT_ADI,\r\n\t  VR.VARYANT_ADI2,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,\r\n      SAYIM1=0,\r\n      SAYIM2=0,\r\n      SAYIM3=0,\r\n      SUM(MIKTAR*(CARPAN2/CARPAN1)) AS KONTROL_SAYIM\r\nFROM \r\n      STOKFISLERI SF WITH(NOLOCK)\r\n      LEFT OUTER JOIN STOKHAREKETLERI SH WITH(NOLOCK) ON SH.FB_REF=SF.FB_REF\r\n      LEFT OUTER JOIN STOKKARTI S WITH(NOLOCK) ON S.STOK_REF=SH.STOK_REF\r\n\t  LEFT OUTER JOIN VARYANT VR WITH(NOLOCK) ON VR.STOK_REF=SH.STOK_REF AND VR.VARYANT_REF=SH.VARYANT_REF \r\nWHERE \r\n      SF.FIS_TURU=100\r\n      AND SF.SAYIM_STATUS=0\r\n      AND SF.SAYIM_TURU=4\r\n      AND S.STOK_KODU IS NOT NULL\r\n      \r\nGROUP BY \r\n      SF.AMBAR_KODU,\r\n      S.STOK_KODU,\r\n      S.STOK_ADI,\r\n\t  S.STOK_ADI2,\r\n\t  S.STOK_ADI3,\r\n\t  S.STOK_ADI4,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,S.STOK_REF,\r\n\t  VR.VARYANT_REF,\r\n\t  VR.VARYANT_KODU,\r\n\t  VR.VARYANT_ADI,\r\n\t  VR.VARYANT_ADI2\r\n      \r\n      ) AS LIST\r\n      \r\n      \r\n            \r\n      GROUP BY \r\n      AMBAR_KODU,\r\n      STOK_KODU,\r\n      STOK_ADI,\r\n\t  STOK_ADI2,\r\n\t  STOK_ADI3,\r\n\t  STOK_ADI4,\r\n      ADRES,\r\n      TAKIP_NO,\r\n      DURUM_KODU,\r\n      PALET,\r\n      STOK_REF,\r\n\t  VARYANT_REF,\r\n\t  VARYANT_KODU,\r\n\t  VARYANT_ADI,\r\n\t  VARYANT_ADI2",
