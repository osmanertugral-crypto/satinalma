{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DEPO_STOK_RAPORU_TUM_DEPOLAR",
    "full_name":  "dbo.DEPO_STOK_RAPORU_TUM_DEPOLAR",
    "definition":  "\r\nCREATE VIEW [dbo].[DEPO_STOK_RAPORU_TUM_DEPOLAR] AS\r\n\r\n\r\nSELECT  \r\n\t\r\n\tAT.AMBAR_KODU,\r\n\tS.STOK_KODU,\r\n\tS.STOK_ADI, \r\n\tSB.BIRIM,\r\n\tISNULL(CONVERT(FLOAT,SUM(AT.MIKTAR)),0) AS MIKTAR\r\n\t,(SELECT AMBAR_ADI FROM AMBAR WHERE AMBAR_KODU=AT.AMBAR_KODU) AS AMBAR_ADI\r\n\t--,ADRES,\r\n\t--TAKIP_NO,\r\n\t--DURUM_KODU,\r\n\t--PALET\r\n\t\r\nFROM \r\n\tAMBARTAKIPDETAY AT LEFT OUTER JOIN STOKKARTI S ON S.STOK_REF=AT.STOK_REF\r\n\tLEFT OUTER JOIN STOKBIRIM SB ON SB.BIRIM_REF=AT.BIRIM_REF\r\n\r\n\t\r\n\r\nGROUP BY \r\n\tAT.AMBAR_KODU,\r\n\tS.STOK_KODU,\r\n\tS.STOK_ADI, \r\n\tSB.BIRIM\r\n\t--,ADRES,\r\n\t--TAKIP_NO,\r\n\t--DURUM_KODU,\r\n\t--PALET\r\n\t\r\n\t\r\nHAVING \t\r\n\tISNULL(CONVERT(NUMERIC(28,2),SUM(AT.MIKTAR)),0)\u003c\u003e0\t\r\n\t\r\n",
    "columns":  [
                    {
                        "COLUMN_NAME":  "AMBAR_KODU",
                        "ORDINAL_POSITION":  1,
                        "DATA_TYPE":  "nvarchar",
                        "CHARACTER_MAXIMUM_LENGTH":  "50",
                        "IS_NULLABLE":  "YES"
                    },
