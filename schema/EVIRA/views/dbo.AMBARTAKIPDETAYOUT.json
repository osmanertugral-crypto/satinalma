{
    "type":  "view",
    "schema":  "dbo",
    "name":  "AMBARTAKIPDETAYOUT",
    "full_name":  "dbo.AMBARTAKIPDETAYOUT",
    "definition":  "CREATE VIEW [dbo].[AMBARTAKIPDETAYOUT] WITH SCHEMABINDING \r\nAS\r\nSELECT       HAREKET_TARIHI, AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES,CASE WHEN IZLEME_TURU IN(0,3,4) THEN \u0027\u0027 ELSE  TAKIP_NO END TAKIP_NO, DURUM_KODU, PALET,PAKET, SUM((MIKTAR*(CARPAN2/CARPAN1))*-1) AS MIKTAR, COUNT_BIG(*) AS C\r\nFROM            dbo.STOKHAREKETLERI WITH(NOLOCK)\r\nWHERE        (FIS_GCD IN (1,2))\r\nGROUP BY HAREKET_TARIHI, AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET,IZLEME_TURU",
