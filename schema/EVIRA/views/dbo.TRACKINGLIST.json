    "name":  "TRACKINGLIST",
    "full_name":  "dbo.TRACKINGLIST",
    "definition":  "CREATE VIEW [dbo].[TRACKINGLIST] AS\r\nSELECT        TAKIPDTY_REF, STOK_KODU, STOK_ADI,STOK_ADI2,STOK_ADI3,STOK_ADI4, URETICI_KODU, STOK_REF, TAKIP_NO, GBS_TARIHI, GBT_TARIHI, URT_TARIHI, RETEST_TARIHI, SKT_TARIHI, ALAN1, ALAN2, ALAN3, ALAN4, GIRIS_TARIHI, KAYIT_TARIHI, \r\n                         GUNCELLEME_TARIHI, GKULLANICI_REF, BLOKE, BLOKE_NEDENI, BLOKE_TARIHI, BKULLANICI_REF, E1, E2, E3, E4, E5, E6, E7, E8, E9, E10, E11, E12, E13, E14, E15, E16, E17, E18, E19, E20, IZLEME_TURU, BKULLANICI, \r\n                         VARYANT_REF, VARYANT_KODU, VARYANT_ADI, VARYANT_ADI2, BIRIM, CHK, SMIK, INSTOCK\r\nFROM            (SELECT        STOK_KODU, STOK_ADI,STOK_ADI2,STOK_ADI3,STOK_ADI4, URETICI_KODU, STOK_REF, TAKIP_NO, GBS_TARIHI, GBT_TARIHI, URT_TARIHI, RETEST_TARIHI, SKT_TARIHI, ALAN1, ALAN2, ALAN3, ALAN4, GIRIS_TARIHI, KAYIT_TARIHI, \r\n                                                    GUNCELLEME_TARIHI, GKULLANICI_REF, BLOKE, BLOKE_NEDENI, BLOKE_TARIHI, BKULLANICI_REF, E1, E2, E3, E4, E5, E6, E7, E8, E9, E10, E11, E12, E13, E14, E15, E16, E17, E18, E19, E20, TAKIPDTY_REF, \r\n                                                    IZLEME_TURU, BKULLANICI, VARYANT_REF, VARYANT_KODU, VARYANT_ADI, VARYANT_ADI2, BIRIM, CHK, SMIK, CASE WHEN SMIK\u003c\u003e0 THEN 1 ELSE 0 END AS INSTOCK\r\n                          FROM            (SELECT        dbo.STOKKARTI.STOK_KODU, dbo.STOKKARTI.STOK_ADI, dbo.STOKKARTI.STOK_ADI2, dbo.STOKKARTI.STOK_ADI3, dbo.STOKKARTI.STOK_ADI4, dbo.STOKKARTI.URETICI_KODU, dbo.TAKIPDTY.STOK_REF, dbo.TAKIPDTY.TAKIP_NO, dbo.TAKIPDTY.GBS_TARIHI, dbo.TAKIPDTY.GBT_TARIHI,\r\n                                                                               dbo.TAKIPDTY.URT_TARIHI, dbo.TAKIPDTY.RETEST_TARIHI, dbo.TAKIPDTY.SKT_TARIHI, dbo.TAKIPDTY.ALAN1, dbo.TAKIPDTY.ALAN2, dbo.TAKIPDTY.ALAN3, dbo.TAKIPDTY.ALAN4, \r\n                                                                              dbo.TAKIPDTY.GIRIS_TARIHI, dbo.TAKIPDTY.KAYIT_TARIHI, dbo.TAKIPDTY.GUNCELLEME_TARIHI, dbo.TAKIPDTY.GKULLANICI_REF, dbo.TAKIPDTY.BLOKE, dbo.TAKIPDTY.BLOKE_NEDENI, \r\n                                                                              dbo.TAKIPDTY.BLOKE_TARIHI, dbo.TAKIPDTY.BKULLANICI_REF, dbo.TAKIPDTY.E1, dbo.TAKIPDTY.E2, dbo.TAKIPDTY.E3, dbo.TAKIPDTY.E4, dbo.TAKIPDTY.E5, dbo.TAKIPDTY.E6, dbo.TAKIPDTY.E7, \r\n                                                                              dbo.TAKIPDTY.E8, dbo.TAKIPDTY.E9, dbo.TAKIPDTY.E10, dbo.TAKIPDTY.E11, dbo.TAKIPDTY.E12, dbo.TAKIPDTY.E13, dbo.TAKIPDTY.E14, dbo.TAKIPDTY.E15, dbo.TAKIPDTY.E16, dbo.TAKIPDTY.E17, \r\n                                                                              dbo.TAKIPDTY.E18, dbo.TAKIPDTY.E19, dbo.TAKIPDTY.E20, dbo.TAKIPDTY.TAKIPDTY_REF, dbo.STOKKARTI.IZLEME_TURU, \r\n                                                                              dbo.KULLANICI.KULLANICI_ADI + \u0027 \u0027 + dbo.KULLANICI.ADI_SOYADI AS BKULLANICI, dbo.TAKIPDTY.VARYANT_REF, dbo.VARYANT.VARYANT_KODU, dbo.VARYANT.VARYANT_ADI, dbo.VARYANT.VARYANT_ADI2, dbo.STOKBIRIM.BIRIM, \r\n                                                                              0 AS CHK, ISNULL\r\n                                                                                  ((SELECT        CONVERT(FLOAT, CONVERT(NUMERIC(24, 8), SUM(MIKTAR))) AS Expr1\r\n                                                                                      FROM            dbo.AMBARTAKIP\r\n                                                                                      WHERE        (STOK_REF = dbo.TAKIPDTY.STOK_REF) AND (VARYANT_REF = dbo.TAKIPDTY.VARYANT_REF) AND \r\n                                                                                                               (TAKIP_NO COLLATE DATABASE_DEFAULT = dbo.TAKIPDTY.TAKIP_NO COLLATE DATABASE_DEFAULT)), 0) AS SMIK\r\n                                                    FROM            dbo.TAKIPDTY WITH (NOLOCK) INNER JOIN\r\n                                                                              dbo.STOKKARTI WITH (NOLOCK) ON dbo.TAKIPDTY.STOK_REF = dbo.STOKKARTI.STOK_REF LEFT OUTER JOIN\r\n                                                                              dbo.STOKBIRIM WITH (NOLOCK) ON dbo.STOKBIRIM.STOK_REF = dbo.TAKIPDTY.STOK_REF AND dbo.STOKBIRIM.SIRA_NO = 1 LEFT OUTER JOIN\r\n                                                                              dbo.VARYANT WITH (NOLOCK) ON dbo.VARYANT.STOK_REF = dbo.TAKIPDTY.STOK_REF AND dbo.VARYANT.VARYANT_REF = dbo.TAKIPDTY.VARYANT_REF LEFT OUTER JOIN\r\n                                                                              dbo.KULLANICI WITH (NOLOCK) ON dbo.KULLANICI.KULLANICI_REF = dbo.TAKIPDTY.BKULLANICI_REF) AS T\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t  \r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t  ) AS TBL",
