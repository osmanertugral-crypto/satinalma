    "name":  "PRODUCTIONLIST",
    "full_name":  "dbo.PRODUCTIONLIST",
    "definition":  "CREATE VIEW [dbo].[PRODUCTIONLIST] WITH SCHEMABINDING \r\nAS\r\nSELECT        dbo.URETIMBASLIK.UB_REF, dbo.URETIMBASLIK.STATUS, dbo.URETIMBASLIK.YAZDIRMA_TARIHI, dbo.URETIMBASLIK.TARIH, dbo.URETIMBASLIK.SAAT, dbo.URETIMBASLIK.FIS_NO, \r\n                         dbo.URETIMBASLIK.BELGE_NO, dbo.URETIMBASLIK.AMBAR_KODU, dbo.URETIMBASLIK.ACIKLAMA1, dbo.URETIMBASLIK.ACIKLAMA2, dbo.URETIMBASLIK.ACIKLAMA3, dbo.URETIMBASLIK.DURUM_KODU, \r\n                         dbo.URETIMBASLIK.GRUP_KODU, dbo.URETIMBASLIK.YETKI_KODU, dbo.URETIMBASLIK.KULLANICI_REF, dbo.FIRMAKARTI.FIRMA_KODU, dbo.FIRMAKARTI.FIRMA_UNVANI, dbo.URETIMBASLIK.MIKTAR, \r\n                         dbo.URETIMBASLIK.GMIKTAR, dbo.URETIMBASLIK.BASLANGIC_TARIHI, dbo.URETIMBASLIK.BITIS_TARIHI, dbo.URETIMBASLIK.ISTASYON_KODU, dbo.URETIMBASLIK.OZELKOD, \r\n                         dbo.URETIMBASLIK.RECETE_KODU, dbo.URETIMBASLIK.ROTA_KODU, dbo.URETIMBASLIK.AKTIF, dbo.URETIMBASLIK.ONCELIK, dbo.URETIMBASLIK.STOK_REF, dbo.URETIMBASLIK.BIRIM_REF, \r\n                         dbo.URETIMBASLIK.SB_REF, dbo.SIPARISFISLERI.SIPARIS_NO, dbo.STOKKARTI.STOK_KODU, dbo.STOKKARTI.STOK_ADI,dbo.URETIMBASLIK.PROJE_REF ,PR.PROJE_KODU\r\nFROM            dbo.URETIMBASLIK WITH(NOLOCK) LEFT OUTER JOIN\r\n                         dbo.STOKKARTI WITH(NOLOCK) ON dbo.STOKKARTI.STOK_REF = dbo.URETIMBASLIK.STOK_REF LEFT OUTER JOIN\r\n                         dbo.SIPARISFISLERI WITH(NOLOCK) ON dbo.SIPARISFISLERI.SB_REF = dbo.URETIMBASLIK.SB_REF LEFT OUTER JOIN\r\n\t\t\t\t\t\t dbo.PROJE AS PR WITH(NOLOCK) ON PR.PROJE_REF = dbo.URETIMBASLIK.PROJE_REF LEFT OUTER JOIN\r\n                         dbo.FIRMAKARTI WITH(NOLOCK) ON dbo.FIRMAKARTI.FIRMA_REF = dbo.SIPARISFISLERI.FIRMA_REF",
