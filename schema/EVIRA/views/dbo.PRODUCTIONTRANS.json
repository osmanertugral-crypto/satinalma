    "name":  "PRODUCTIONTRANS",
    "full_name":  "dbo.PRODUCTIONTRANS",
    "definition":  "CREATE VIEW [dbo].[PRODUCTIONTRANS] AS\r\nSELECT        UH.UH_REF, UB.FIS_NO, UH.TARIH, UH.SAAT, UH.AKOD, UA.ADI AS AADI, UB.RECETE_KODU, UH.DURUM1, UD1.ACIKLAMASI AS ADURUM1, UH.DURUM2, UD2.ACIKLAMASI AS ADURUM2, K.KULLANICI_ADI, K.ADI_SOYADI, \r\n                         SK.STOK_KODU, SK.STOK_ADI, SK.STOK_ADI2, SK.STOK_ADI3, SK.STOK_ADI4, SP.SIPARIS_NO, FK.FIRMA_KODU, FK.FIRMA_UNVANI, UH.ALAN1, UH.ALAN2, UH.ALAN3, UH.ALAN4\r\nFROM            dbo.URETIMHAREKET AS UH WITH(NOLOCK) LEFT OUTER JOIN\r\n                         dbo.URETIMBASLIK AS UB WITH(NOLOCK) ON UB.UB_REF = UH.UB_REF LEFT OUTER JOIN\r\n                         dbo.KULLANICI AS K WITH(NOLOCK) ON K.KULLANICI_REF = UH.KULLANICI_REF LEFT OUTER JOIN\r\n                         dbo.URETIMAKOD AS UA WITH(NOLOCK) ON UA.KODU = UH.AKOD LEFT OUTER JOIN\r\n                         dbo.URETIMDURUM AS UD1 WITH(NOLOCK) ON UD1.DURUM_KODU = UH.DURUM1 LEFT OUTER JOIN\r\n                         dbo.URETIMDURUM AS UD2 WITH(NOLOCK) ON UD2.DURUM_KODU = UH.DURUM2 LEFT OUTER JOIN\r\n                         dbo.STOKKARTI AS SK WITH(NOLOCK) ON SK.STOK_REF = UB.STOK_REF LEFT OUTER JOIN\r\n                         dbo.SIPARISFISLERI AS SP WITH(NOLOCK) ON SP.SIPARIS_TURU = 1 AND SP.SB_REF = UB.SB_REF LEFT OUTER JOIN\r\n                         dbo.FIRMAKARTI AS FK WITH(NOLOCK) ON FK.FIRMA_REF = SP.FIRMA_REF",
