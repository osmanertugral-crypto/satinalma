    "name":  "URUNADRESW",
    "full_name":  "dbo.URUNADRESW",
    "definition":  "CREATE VIEW [dbo].[URUNADRESW] AS\r\nSELECT        UA.URUNADRES_REF, UA.STOK_REF, UA.ADRES, UA.MINMIKTAR, UA.MAXMIKTAR, UA.KRTMIKTAR, SK.STOK_KODU, SK.STOK_ADI,SK.STOK_ADI2,SK.STOK_ADI3,SK.STOK_ADI4, SA.ADRES_ACIKLAMASI, UA.AMBAR_KODU\r\nFROM            dbo.URUNADRES AS UA WITH(NOLOCK) LEFT OUTER JOIN\r\n                         dbo.STOKKARTI AS SK WITH(NOLOCK) ON SK.STOK_REF = UA.STOK_REF LEFT OUTER JOIN\r\n                         dbo.STOKADRES AS SA WITH(NOLOCK) ON SA.ADRES = UA.ADRES AND SA.AMBAR_KODU = UA.AMBAR_KODU",
