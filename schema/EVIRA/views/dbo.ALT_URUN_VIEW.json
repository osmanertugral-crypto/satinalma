    "full_name":  "dbo.ALT_URUN_VIEW",
    "definition":  "\r\nCREATE VIEW [dbo].[ALT_URUN_VIEW]\r\nAS\r\nSELECT \r\nSK.STOK_REF,\r\nSK.STOK_KODU ANA_URUN_KODU,\r\nSK.STOK_ADI ANA_URUN_ADI,\r\nSA.MIKTAR,\r\nSK2.STOK_REF STOK_ALT_REF , \r\nSK2.STOK_KODU AS STOK_ALT_KOD,\r\nSK2.STOK_ADI AS STOK_ALT_ADI\r\n\r\nFROM \r\nSTOKALT SA LEFT OUTER JOIN STOKKARTI SK ON SA.STOK_REF=SK.STOK_REF\r\nLEFT OUTER JOIN STOKKARTI SK2 ON SK2.STOK_REF=SA.STOKSUB_REF\r\n",
