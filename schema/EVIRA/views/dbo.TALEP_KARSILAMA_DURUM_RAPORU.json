{
    "type":  "view",
    "schema":  "dbo",
    "name":  "TALEP_KARSILAMA_DURUM_RAPORU",
    "full_name":  "dbo.TALEP_KARSILAMA_DURUM_RAPORU",
    "definition":  "\r\nCREATE VIEW [dbo].[TALEP_KARSILAMA_DURUM_RAPORU]\r\nAS\r\nSELECT\r\n    TARIH,\r\n    GRUP,\r\n    FIS_NO,\r\n    PROJE,\r\n    STOK_KODU,\r\n    STOK_ADI,\r\n    TALEP_MIKTAR,\r\n    TALEP_KARSILAMA_MIKTAR,\r\n    GEBZE_STOK,\r\n    MONTAJ_STOK,\r\n    URETIM_STOK,\r\n    ISNULL((\r\n        SELECT SUM(MIKTAR) - SUM(SEVKEDILEN_MIKTAR) \r\n        FROM SIPARISFISLERI SF \r\n        INNER JOIN SIPARISHAREKETLERI SH ON SF.SB_REF = SH.SB_REF \r\n        WHERE SF.KAPALI = 0 \r\n        AND SH.STOK_REF = LIST.ANA_STOK_REF \r\n        AND SF.SIPARIS_TURU = 2\r\n    ), 0) AS SIPARIS_MIKTAR\r\nFROM (\r\n    -- First subquery for main products\r\n    SELECT \r\n        PF.TARIH,\r\n        \u00271\u0027 AS GRUP,\r\n        PF.FIS_NO,\r\n        P.PROJE_KODU + \u0027-\u0027 + P.PROJE_ADI AS PROJE,\r\n        PF.TB_REF,\r\n        SK.STOK_REF AS ANA_STOK_REF,\r\n        \u00270\u0027 AS STOK_ALT_REF,\r\n        SK.STOK_KODU,\r\n        SK.STOK_ADI,\r\n        SUM(PH.MIKTAR) AS TALEP_MIKTAR,\r\n        ISNULL((\r\n            SELECT SUM(MIKTAR) \r\n            FROM STOKHAREKETLERI SH \r\n            WHERE SH.TB_REF = PF.TB_REF \r\n            AND SH.STOK_REF = PH.STOK_REF \r\n            AND SH.FIS_TURU IN (25, 303)\r\n        ), 0) AS TALEP_KARSILAMA_MIKTAR,\r\n        ISNULL((\r\n            SELECT CONVERT(NUMERIC(18,2), SUM(MIKTAR)) \r\n            FROM AMBARTAKIP AT \r\n            WHERE AT.STOK_REF = PH.STOK_REF \r\n            AND AT.AMBAR_KODU = 2\r\n        ), 0) AS GEBZE_STOK,\r\n        ISNULL((\r\n            SELECT CONVERT(NUMERIC(18,2), SUM(MIKTAR)) \r\n            FROM AMBARTAKIP AT \r\n            WHERE AT.STOK_REF = PH.STOK_REF \r\n            AND AT.AMBAR_KODU = 5\r\n        ), 0) AS MONTAJ_STOK,\r\n        ISNULL((\r\n            SELECT CONVERT(NUMERIC(18,2), SUM(MIKTAR)) \r\n            FROM AMBARTAKIP AT \r\n            WHERE AT.STOK_REF = PH.STOK_REF \r\n            AND AT.AMBAR_KODU = 11\r\n        ), 0) AS URETIM_STOK\r\n    FROM TALEPFISLERI PF \r\n    LEFT OUTER JOIN TALEPHAREKETLERI PH ON PF.TB_REF = PH.TB_REF\r\n    LEFT OUTER JOIN STOKKARTI SK ON SK.STOK_REF = PH.STOK_REF \r\n    LEFT OUTER JOIN PROJE P ON P.PROJE_REF = PF.PROJE_REF\r\n    WHERE PF.TB_TURU = 1\r\n    GROUP BY \r\n        SK.STOK_KODU, SK.STOK_ADI, PF.TB_REF, PH.STOK_REF,\r\n        SK.STOK_TIPI, SK.STOK_REF, PF.FIS_NO, P.PROJE_KODU,\r\n        P.PROJE_ADI, PF.TARIH\r\n\r\n    UNION ALL\r\n\r\n    -- Second subquery for sub-products\r\n    SELECT \r\n        PF.TARIH,\r\n        \u00272\u0027 AS GRUP,\r\n        PF.FIS_NO,\r\n        P.PROJE_KODU + \u0027-\u0027 + P.PROJE_ADI AS PROJE,\r\n        PF.TB_REF,\r\n        SK.STOK_REF AS ANA_STOK_REF,\r\n        SK.STOK_ALT_REF,\r\n        SK.STOK_ALT_KOD,\r\n        SK.STOK_ALT_ADI,\r\n        SUM(SK.MIKTAR) * SUM(PH.MIKTAR) AS TALEP_MIKTAR,\r\n        ISNULL((\r\n            SELECT SUM(SK.MIKTAR) * SUM(SH.MIKTAR) \r\n            FROM STOKHAREKETLERI SH \r\n            WHERE SH.TB_REF = PF.TB_REF \r\n            AND SH.STOK_REF = PH.STOK_REF \r\n            AND SH.FIS_TURU IN (25, 303)\r\n        ), 0) AS TALEP_KARSILAMA_MIKTAR,\r\n        ISNULL((\r\n            SELECT CONVERT(NUMERIC(18,2), SUM(MIKTAR)) \r\n            FROM AMBARTAKIP AT \r\n            WHERE AT.STOK_REF = SK.STOK_ALT_REF \r\n            AND AT.AMBAR_KODU = 2\r\n        ), 0) AS GEBZE_STOK,\r\n        ISNULL((\r\n            SELECT CONVERT(NUMERIC(18,2), SUM(MIKTAR)) \r\n            FROM AMBARTAKIP AT \r\n            WHERE AT.STOK_REF = SK.STOK_ALT_REF \r\n            AND AT.AMBAR_KODU = 5\r\n        ), 0) AS MONTAJ_STOK,\r\n        ISNULL((\r\n            SELECT CONVERT(NUMERIC(18,2), SUM(MIKTAR)) \r\n            FROM AMBARTAKIP AT \r\n            WHERE AT.STOK_REF = SK.STOK_ALT_REF \r\n            AND AT.AMBAR_KODU = 11\r\n        ), 0) AS URETIM_STOK\r\n    FROM TALEPFISLERI PF \r\n    LEFT OUTER JOIN TALEPHAREKETLERI PH ON PF.TB_REF = PH.TB_REF\r\n    LEFT OUTER JOIN ALT_URUN_VIEW SK ON SK.STOK_REF = PH.STOK_REF \r\n    LEFT OUTER JOIN PROJE P ON P.PROJE_REF = PF.PROJE_REF\r\n    WHERE PF.TB_TURU = 1\r\n    GROUP BY \r\n        SK.STOK_ALT_KOD, SK.STOK_ALT_ADI, PF.TB_REF, PH.STOK_REF,\r\n        SK.STOK_REF, SK.STOK_ALT_REF, PF.FIS_NO, P.PROJE_KODU,\r\n        P.PROJE_ADI, PF.TARIH\r\n) LIST \r\nWHERE \r\n    ANA_STOK_REF IS NOT NULL \r\n    AND LIST.TARIH \u003e= \u00272024-01-01\u0027\r\n    AND LIST.TARIH \u003c= \u00272024-12-31\u0027\r\n",
