    "name":  "STOKDURUMRAPORU1",
    "full_name":  "dbo.STOKDURUMRAPORU1",
    "definition":  "\r\n\r\n\r\nCREATE VIEW [dbo].[STOKDURUMRAPORU1]\r\nAS\r\nSELECT \r\n\r\n(CASE WHEN SK.KULLANIM=1 THEN \u0027KULLANIM DIŞI\u0027 ELSE \u0027KULLANIM ICI\u0027 END) KULLANIM,\r\nSK.STOK_REF,\r\nSK.STOK_KODU ,\r\nSK.STOK_ADI,\r\nSK.GRUP_KODU,\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE SH.FIS_TURU IN (\u002701\u0027) AND AMBAR_KODU=\u00272\u0027 AND SH.STOK_REF=SK.STOK_REF AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027   ),\u00270\u0027) SATINALMA_MIKTAR,\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE SH.FIS_TURU IN (\u002706\u0027) AND AMBAR_KODU=\u00272\u0027 AND SH.STOK_REF=SK.STOK_REF AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027    ),\u00270\u0027) ALIM_IADE_MIKTAR,\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE SH.FIS_TURU IN (\u002701\u0027) AND AMBAR_KODU=\u00272\u0027 AND SH.STOK_REF=SK.STOK_REF  AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027   ),\u00270\u0027)-\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE SH.FIS_TURU IN (\u002706\u0027) AND AMBAR_KODU=\u00272\u0027 AND SH.STOK_REF=SK.STOK_REF AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027   ),\u00270\u0027) NET_MIKTAR,\r\n\r\n\r\n\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE AMBAR_KODU=2 AND HEDEF_AMBAR\u003c\u003e2 AND FIS_GCD=2  AND SH.STOK_REF=SK.STOK_REF  AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027  ),\u00270\u0027) \u00272 nolu ambardan verılenler\u0027,\r\n\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE AMBAR_KODU\u003c\u003e2 AND HEDEF_AMBAR=2 AND FIS_GCD=2  AND SH.STOK_REF=SK.STOK_REF AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027   ),\u00270\u0027) \u00272 nolu ambara gerı gelenler\u0027,\r\n\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(AT.MIKTAR)) FROM AMBARTAKIPDETAY AT WITH(NOLOCK) WHERE AT.STOK_REF=SK.STOK_REF   AND AT.AMBAR_KODU=2),\u00270\u0027) \u0027DÖNEM SONU STOK\u0027,\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(AT.MIKTAR)) FROM AMBARTAKIPDETAY AT WITH(NOLOCK) WHERE AT.STOK_REF=SK.STOK_REF   AND AT.AMBAR_KODU=2 AND AT.HAREKET_TARIHI\u003c=\u00272024-12-31\u0027 ),\u00270\u0027) \u0027DÖNEM BAŞI STOK\u0027,\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(AT.MIKTAR)) FROM AMBARTAKIPDETAY AT WITH(NOLOCK) WHERE AT.STOK_REF=SK.STOK_REF   AND AT.AMBAR_KODU IN (14,15)),\u00270\u0027) \u0027DIGER DÖNEM SONU STOK\u0027,\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(AT.MIKTAR)) FROM AMBARTAKIPDETAY AT WITH(NOLOCK) WHERE AT.STOK_REF=SK.STOK_REF  AND AT.AMBAR_KODU IN (14,15) AND AT.HAREKET_TARIHI\u003c=\u00272024-12-31\u0027 ),\u00270\u0027) \u0027DIGER AMB DÖNEM SONU STOK\u0027,\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE SH.FIS_TURU IN (\u002701\u0027) AND AMBAR_KODU\u003c\u003e\u00272\u0027 AND SH.STOK_REF=SK.STOK_REF  ),\u00270\u0027) \u0027HARICI SATIN ALMA\u0027,\r\n\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE SH.FIS_TURU IN (\u0027-10\u0027)  AND SH.STOK_REF=SK.STOK_REF   AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027  ),\u00270\u0027) \u0027VIRMAN GIRIS\u0027,\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE SH.FIS_TURU IN (\u0027-11\u0027)  AND SH.STOK_REF=SK.STOK_REF   AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027  ),\u00270\u0027) \u0027VIRMAN CIKIS\u0027,\r\n\r\n\r\nISNULL((SELECT CONVERT(NUMERIC(18,2),SUM(MIKTAR)) FROM STOKHAREKETLERI SH WITH(NOLOCK) WHERE SH.FIS_TURU IN (\u002708\u0027) AND SH.HAREKET_TARIHI\u003e=\u00272024-01-01\u0027    AND SH.STOK_REF=(SELECT TOP 1  SK2.STOK_REF FROM STOKKARTI SK2 WHERE  SK2.STOK_KODU LIKE  +\u0027%\u0027+SK.STOK_KODU+\u0027%\u0027  AND SK2.STOK_KODU LIKE \u0027%153%\u0027)  ),\u00270\u0027) SATIS\r\n\r\nFROM \r\n\r\n STOKKARTI SK   WITH(NOLOCK)\r\n",
