    "name":  "AMBARTAKIP",
    "full_name":  "dbo.AMBARTAKIP",
    "definition":  "CREATE VIEW [dbo].[AMBARTAKIP] AS\r\nSELECT        AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF AS BIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET, CONVERT(NUMERIC(24,8),SUM(MIKTAR)) AS MIKTAR\r\nFROM            (SELECT        AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET, MIKTAR\r\n                          FROM            dbo.AMBARTAKIPIN0 WITH(NOLOCK)\r\n                          UNION ALL\r\n                          SELECT        AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET, MIKTAR\r\n                          FROM            dbo.AMBARTAKIPIN2 WITH(NOLOCK)\r\n                          UNION ALL\r\n                          SELECT        AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET, MIKTAR\r\n                          FROM            dbo.AMBARTAKIPOUT WITH(NOLOCK)\r\n                           ) AS T\r\nGROUP BY AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET\r\nHAVING CONVERT(NUMERIC(24,8),SUM(MIKTAR))\u003c\u003e0",
