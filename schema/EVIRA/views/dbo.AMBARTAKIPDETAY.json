    "name":  "AMBARTAKIPDETAY",
    "full_name":  "dbo.AMBARTAKIPDETAY",
    "definition":  "CREATE VIEW [dbo].[AMBARTAKIPDETAY] AS\r\nSELECT        HAREKET_TARIHI, AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF AS BIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET, CONVERT(NUMERIC(24,8),SUM(MIKTAR)) AS MIKTAR\r\nFROM            (SELECT        HAREKET_TARIHI, AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET, MIKTAR\r\n                          FROM            dbo.AMBARTAKIPDETAYIN0 WITH(NOLOCK)\r\n                          UNION ALL\r\n                          SELECT        HAREKET_TARIHI, AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET, MIKTAR\r\n                          FROM            dbo.AMBARTAKIPDETAYIN2 WITH(NOLOCK)\r\n                          UNION ALL\r\n                          SELECT        HAREKET_TARIHI, AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET, MIKTAR\r\n                          FROM            dbo.AMBARTAKIPDETAYOUT WITH(NOLOCK)\r\n                           ) AS T\r\nGROUP BY HAREKET_TARIHI, AMBAR_KODU, STOK_REF,VARYANT_REF, ANABIRIM_REF, ADRES, TAKIP_NO, DURUM_KODU, PALET,PAKET",
