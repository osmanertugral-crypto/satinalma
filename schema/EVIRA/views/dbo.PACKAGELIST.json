{
    "type":  "view",
    "schema":  "dbo",
    "name":  "PACKAGELIST",
    "full_name":  "dbo.PACKAGELIST",
    "definition":  "CREATE VIEW [dbo].[PACKAGELIST] AS \r\nSELECT \r\n\tPL.PAKET_REF,AT.PAKET,PL.AKTIF,PL.FIRMA_REF,PL.SB_REF,PL.TB_REF,PL.PB_REF,PL.OLUSTURMA_TARIHI,PL.PAKET_DURUMU,\r\n\tPLE.PAKETEK_REF,PLE.AGIRLIK,PLE.BURUTAGIRLIK,PLE.UZUNLUK,PLE.YUKSEKLIK,PLE.GENISLIK,PLE.E1,PLE.E2,PLE.E3,PLE.E4,PLE.E5, PLE.E6,PLE.E7,PLE.E8,PLE.E9,PLE.E10, \r\n\t(SELECT SIPARIS_NO FROM SIPARISFISLERI   WITH (NOLOCK) WHERE SB_REF=PL.SB_REF) AS SIPARIS_NO,\r\n\t(SELECT FIS_NO     FROM TALEPFISLERI     WITH (NOLOCK) WHERE TB_REF=PL.TB_REF) AS TALEP_NO,\r\n    (SELECT FIS_NO     FROM PLANLAMAFISLERI  WITH (NOLOCK) WHERE PB_REF=PL.PB_REF) AS PLANLAMA_NO,\r\n\tFK.FIRMA_KODU,\r\n\tFK.FIRMA_UNVANI,\r\n\tAT.AMBAR_KODU,PS.ADRES\r\nFROM AMBARTAKIP AT WITH(NOLOCK) \r\n\tINNER JOIN PAKET PL WITH(NOLOCK) ON PL.PAKET=AT.PAKET\r\n    LEFT OUTER JOIN PACKAGESHELF PS ON PS.PAKET=AT.PAKET AND PS.AMBAR_KODU=AT.AMBAR_KODU\r\n\tLEFT OUTER JOIN PAKETEK PLE WITH (NOLOCK) ON PLE.PAKET=PL.PAKET \t\r\n\tLEFT OUTER JOIN FIRMAKARTI FK WITH (NOLOCK) ON FK.FIRMA_REF=PL.FIRMA_REF \t\r\nWHERE AT.PAKET\u003c\u003e\u0027\u0027 \r\nGROUP BY AT.AMBAR_KODU,AT.PAKET,PS.ADRES,FK.FIRMA_KODU,FK.FIRMA_UNVANI\r\n\t,PL.PAKET_REF,PL.PAKET,PL.AKTIF,PL.FIRMA_REF,PL.SB_REF,PL.TB_REF,PL.PB_REF,PL.OLUSTURMA_TARIHI,PL.PAKET_DURUMU,\r\n\tPLE.PAKETEK_REF,PLE.AGIRLIK,PLE.BURUTAGIRLIK,PLE.UZUNLUK,PLE.YUKSEKLIK,PLE.GENISLIK,PLE.E1,PLE.E2,PLE.E3,PLE.E4,PLE.E5, PLE.E6,PLE.E7,PLE.E8,PLE.E9,PLE.E10\r\nHAVING SUM(AT.MIKTAR)\u003c\u003e0",
