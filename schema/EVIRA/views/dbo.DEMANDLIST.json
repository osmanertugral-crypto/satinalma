{
    "type":  "view",
    "schema":  "dbo",
    "name":  "DEMANDLIST",
    "full_name":  "dbo.DEMANDLIST",
    "definition":  "CREATE VIEW [dbo].[DEMANDLIST] WITH SCHEMABINDING \r\nAS\r\nSELECT        dbo.TALEPFISLERI.TB_REF, dbo.TALEPFISLERI.STATUS, dbo.TALEPFISLERI.YAZDIRMA_TARIHI, dbo.TALEPFISLERI.TARIH, dbo.TALEPFISLERI.SAAT, dbo.TALEPFISLERI.FIS_NO, \r\n                         dbo.TALEPFISLERI.BELGE_NO, dbo.TALEPFISLERI.AMBAR_KODU, dbo.TALEPFISLERI.HEDEF_AMBAR, dbo.TALEPFISLERI.ACIKLAMA, dbo.TALEPFISLERI.DURUM_KODU, \r\n                         dbo.TALEPFISLERI.GRUP_KODU, dbo.TALEPFISLERI.YETKI_KODU, dbo.TALEPFISLERI.KULLANICI_REF, dbo.TALEPFISLERI.PERSONEL_KODU, dbo.FIRMAKARTI.FIRMA_KODU, \r\n                         dbo.FIRMAKARTI.FIRMA_UNVANI, dbo.SEVKIYATADRES.KODU AS ADRES_FIRMA_KODU, \r\n                         dbo.SEVKIYATADRES.ACIKLAMASI AS ADRES_FIRMA_UNVANI, dbo.TALEPFISLERI.AKTIF, dbo.TALEPFISLERI.TB_TURU, dbo.TALEPFISLERI.TESLIM_TARIHI, dbo.TALEPFISLERI.ONCELIK_ACIKLAMASI, \r\n                         dbo.TALEPFISLERI.ONCELIK, dbo.TALEPFISLERI.OZELKOD, dbo.TALEPFISLERI.PROJE_REF, PR.PROJE_KODU, \r\n                         dbo.TALEPFISLERI.DEPO_BOLGE, EKA.EKA1, EKA.EKA2, EKA.EKA3, EKA.EKA4, EKA.EKA5, EKA.EKA6, EKA.EKA7, EKA.EKA8, EKA.EKA9, EKA.EKA10, EKA.EKA11, EKA.EKA12, EKA.EKA13, EKA.EKA14, EKA.EKA15, EKA.EKA16, \r\n                         EKA.EKA17, EKA.EKA18, EKA.EKA19, EKA.EKA20, dbo.TALEPFISLERI.BOLUM, dbo.TALEPFISLERI.HEDEF_BOLUM, dbo.FIRMAKARTI.YETKI_KODU AS FIRMA_YETKI_KODU, dbo.TALEPFISLERI.KAPATILMA_TARIHI, \r\n                         dbo.TALEPFISLERI.KKULLANICI_REF, dbo.TALEPFISLERI.TASIYICI_KODU, PF.FIS_NO AS PLANLAMA_NO, PF.PB_REF,CONVERT(BIT,ISNULL(dbo.TALEPFISLERI.YM,0)) YMTF,\r\n\t\t\t\t\t\t dbo.TALEPFISLERI.BOLGE_KODU\r\nFROM            dbo.TALEPFISLERI WITH (NOLOCK) LEFT OUTER JOIN\r\n                         dbo.FIRMAKARTI WITH (NOLOCK) ON dbo.FIRMAKARTI.FIRMA_REF = dbo.TALEPFISLERI.FIRMA_REF LEFT OUTER JOIN\r\n                         dbo.PROJE AS PR WITH (NOLOCK) ON PR.PROJE_REF = dbo.TALEPFISLERI.PROJE_REF LEFT OUTER JOIN\r\n                         dbo.SEVKIYATADRES WITH (NOLOCK) ON dbo.SEVKIYATADRES.SEVKIYATADRES_REF = dbo.TALEPFISLERI.SEVK_ADRES_REF LEFT OUTER JOIN\r\n                         dbo.PLANLAMAFISLERI AS PF WITH (NOLOCK) ON PF.PB_TURU = 6 AND PF.PB_REF = dbo.TALEPFISLERI.PB_REF LEFT OUTER JOIN\r\n                         dbo.TBEKACIKLAMA AS EKA WITH (NOLOCK) ON EKA.TB_REF = dbo.TALEPFISLERI.TB_REF",
